// UDP socket for datagram-based communication.
import tt::util::Pair;

public class UdpSocket {
    private int handle;
    private bool closed;

    public fn init() {
        this.handle = -1;
        this.closed = false;
    }

    public fn bind(host: string, port: int): void {
        this.handle = UdpSocket_new();
        UdpSocket_bind(this.handle, host, port);
    }

    public fn sendTo(data: string, host: string, port: int): int {
        return UdpSocket_sendTo(this.handle, data, host, port);
    }

    public fn receiveFrom(bufferSize: int): Pair<string, Pair<string, int>> {
        // Returns (data, (host, port))
        let result: string = UdpSocket_recvFrom(this.handle, bufferSize);
        let addr: string = UdpSocket_lastSenderHost(this.handle);
        let port: int = UdpSocket_lastSenderPort(this.handle);
        let addrPair: Pair<string, int> = new Pair<string, int>(addr, port);
        return new Pair<string, Pair<string, int>>(result, addrPair);
    }

    public fn close(): void {
        if (!this.closed) {
            UdpSocket_close(this.handle);
            this.closed = true;
        }
    }

    public fn setTimeout(ms: int): void {
        UdpSocket_setTimeout(this.handle, ms);
    }

    public fn isClosed(): bool {
        return this.closed;
    }
}
