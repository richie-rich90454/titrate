// AudioBuffer.tr — Audio buffer with sample operations
import tt::util::ArrayList;
import tt::math::Math;
import tt::math::MathAdvanced;

public class AudioBuffer {
    public int sampleRate;
    public int channels;
    public ArrayList<ArrayList<double>> samples;

    public fn init(rate: int, ch: int) {
        this.sampleRate = rate;
        this.channels = ch;
        this.samples = new ArrayList<ArrayList<double>>();
        var i: int = 0;
        while (i < ch) {
            this.samples.add(new ArrayList<double>());
            i = i + 1;
        }
    }

    public fn numFrames(): int {
        if (this.channels == 0) { return 0; }
        return this.samples.get(0).size();
    }

    public fn duration(): double {
        if (this.sampleRate == 0) { return 0.0; }
        return this.numFrames() as double / this.sampleRate as double;
    }

    public fn getSample(channel: int, frame: int): double {
        if (channel < 0 || channel >= this.channels) { return 0.0; }
        if (frame < 0 || frame >= this.numFrames()) { return 0.0; }
        return this.samples.get(channel).get(frame);
    }

    public fn setSample(channel: int, frame: int, value: double): void {
        if (channel < 0 || channel >= this.channels) { return; }
        if (frame < 0 || frame >= this.numFrames()) { return; }
        this.samples.get(channel).set(frame, value);
    }

    public fn addFrame(values: ArrayList<double>): void {
        var i: int = 0;
        while (i < this.channels && i < values.size()) {
            this.samples.get(i).add(values.get(i));
            i = i + 1;
        }
    }

    public fn normalize(): void {
        var maxVal: double = 0.0;
        var c: int = 0;
        while (c < this.channels) {
            var i: int = 0;
            while (i < this.samples.get(c).size()) {
                let absVal: double = Math.abs(this.samples.get(c).get(i));
                if (absVal > maxVal) { maxVal = absVal; }
                i = i + 1;
            }
            c = c + 1;
        }
        if (maxVal < 1e-10) { return; }
        let factor: double = 1.0 / maxVal;
        c = 0;
        while (c < this.channels) {
            var i: int = 0;
            while (i < this.samples.get(c).size()) {
                this.samples.get(c).set(i, this.samples.get(c).get(i) * factor);
                i = i + 1;
            }
            c = c + 1;
        }
    }

    public fn fadeIn(durationSec: double): void {
        let numFrames: int = Math.min(Math.round(durationSec * this.sampleRate as double) as int, this.numFrames());
        var c: int = 0;
        while (c < this.channels) {
            var i: int = 0;
            while (i < numFrames) {
                let factor: double = i as double / numFrames as double;
                this.samples.get(c).set(i, this.samples.get(c).get(i) * factor);
                i = i + 1;
            }
            c = c + 1;
        }
    }

    public fn fadeOut(durationSec: double): void {
        let total: int = this.numFrames();
        let numFrames: int = Math.min(Math.round(durationSec * this.sampleRate as double) as int, total);
        var c: int = 0;
        while (c < this.channels) {
            var i: int = 0;
            while (i < numFrames) {
                let factor: double = (numFrames - i) as double / numFrames as double;
                this.samples.get(c).set(total - numFrames + i, this.samples.get(c).get(total - numFrames + i) * factor);
                i = i + 1;
            }
            c = c + 1;
        }
    }

    public fn mix(other: AudioBuffer): AudioBuffer {
        let result: AudioBuffer = new AudioBuffer(this.sampleRate, this.channels);
        let len: int = Math.max(this.numFrames(), other.numFrames());
        var i: int = 0;
        while (i < len) {
            var c: int = 0;
            let frame: ArrayList<double> = new ArrayList<double>();
            while (c < this.channels) {
                let a: double = this.getSample(c, i);
                let b: double = other.getSample(c, i);
                frame.add((a + b) * 0.5);
                c = c + 1;
            }
            result.addFrame(frame);
            i = i + 1;
        }
        return result;
    }

    public fn splice(startFrame: int, endFrame: int): AudioBuffer {
        let result: AudioBuffer = new AudioBuffer(this.sampleRate, this.channels);
        var i: int = startFrame;
        while (i < endFrame && i < this.numFrames()) {
            let frame: ArrayList<double> = new ArrayList<double>();
            var c: int = 0;
            while (c < this.channels) {
                frame.add(this.samples.get(c).get(i));
                c = c + 1;
            }
            result.addFrame(frame);
            i = i + 1;
        }
        return result;
    }

    public fn reversed(): AudioBuffer {
        let result: AudioBuffer = new AudioBuffer(this.sampleRate, this.channels);
        let n: int = this.numFrames();
        var i: int = n - 1;
        while (i >= 0) {
            let frame: ArrayList<double> = new ArrayList<double>();
            var c: int = 0;
            while (c < this.channels) {
                frame.add(this.samples.get(c).get(i));
                c = c + 1;
            }
            result.addFrame(frame);
            i = i - 1;
        }
        return result;
    }
}
