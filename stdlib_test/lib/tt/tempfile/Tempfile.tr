// Tempfile provides temporary file and directory creation, mirroring Python's tempfile module.
import tt::lang::String;

// Create a temporary file and return its path.
public fn createTempFile(): string {
    return Tempfile_create();
}

// Create a temporary directory and return its path.
public fn createTempDir(): string {
    let basePath: string = getTempDir();
    let randomHex: string = Os_urandom(4);
    let dirName: string = "tmpdir_" + randomHex;
    let dirPath: string = Path_join(basePath, dirName);
    Dir_create(dirPath);
    return dirPath;
}

// Get the system's temporary directory path.
public fn getTempDir(): string {
    var tmp: string = Sys_env("TEMP");
    if (tmp != null && String.length(tmp) > 0) {
        return tmp;
    }
    tmp = Sys_env("TMP");
    if (tmp != null && String.length(tmp) > 0) {
        return tmp;
    }
    tmp = Sys_env("TMPDIR");
    if (tmp != null && String.length(tmp) > 0) {
        return tmp;
    }
    return "/tmp";
}

// NamedTempFile provides a temporary file with a visible name.
public class NamedTempFile {
    public string name;
    public string path;
    private bool _closed;

    public fn init(prefix: string, suffix: string, dir: string) {
        let baseDir: string = dir;
        if (String.length(baseDir) == 0) {
            baseDir = getTempDir();
        }
        let randomHex: string = Os_urandom(8);
        this.name = prefix + randomHex + suffix;
        this.path = Path_join(baseDir, this.name);
        File_writeFile(this.path, "");
        this._closed = false;
    }

    public fn write(data: string): void {
        if (this._closed) {
            return;
        }
        File_writeFile(this.path, data);
    }

    public fn read(): string {
        if (this._closed) {
            return "";
        }
        return File_readFile(this.path);
    }

    public fn close(): void {
        this._closed = true;
    }

    public fn isClosed(): bool {
        return this._closed;
    }

    public fn delete(): void {
        if (!this._closed) {
            this.close();
        }
        Dir_remove(this.path);
    }

    public fn toString(): string {
        return "NamedTempFile(" + this.path + ")";
    }
}

// TempDirectory provides a temporary directory that can be cleaned up.
public class TempDirectory {
    public string path;

    public fn init(prefix: string) {
        let baseDir: string = getTempDir();
        let randomHex: string = Os_urandom(8);
        let dirName: string = prefix + randomHex;
        this.path = Path_join(baseDir, dirName);
        Dir_create(this.path);
    }

    public fn cleanup(): void {
        Dir_removeTree(this.path);
    }
}

// Create a named temporary file and return its path.
public fn mkstemp(prefix: string, suffix: string, dir: string): string {
    let f: NamedTempFile = new NamedTempFile(prefix, suffix, dir);
    return f.path;
}

// Create a temporary directory and return its path.
public fn mkdtemp(prefix: string): string {
    let d: TempDirectory = new TempDirectory(prefix);
    return d.path;
}

// Get the system's temporary directory path (alternate name).
public fn getTempDirB(): string {
    return getTempDir();
}
