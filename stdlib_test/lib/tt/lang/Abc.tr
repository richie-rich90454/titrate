// Abstract base class support.
import tt::util::ArrayList;

public class Abc {
    public string className;
    private ArrayList<string> abstractMethods;

    public fn init(className: string) {
        this.className = className;
        this.abstractMethods = new ArrayList<string>();
    }

    public fn abstractMethod(name: string): void {
        this.abstractMethods.add(name);
    }

    public fn isAbstractMethod(name: string): bool {
        var i: int = 0;
        while (i < this.abstractMethods.size()) {
            if (this.abstractMethods.get(i) == name) { return true; }
            i = i + 1;
        }
        return false;
    }

    public fn getAbstractMethods(): ArrayList<string> {
        return this.abstractMethods;
    }

    public fn isAbstract(): bool {
        return this.abstractMethods.size() > 0;
    }

    public fn toString(): string {
        return "AbstractClass(" + this.className + ")";
    }
}

// Mark a method as abstract (convention-based).
public fn abstractMethod(name: string): string {
    return "__abstract__" + name;
}

// Check if a method name is abstract.
public fn isAbstract(methodName: string): bool {
    return String.length(methodName) > 11 && String.substring(methodName, 0, 11) == "__abstract__";
}
