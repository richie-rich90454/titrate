// Extended utility methods for Character type (Task 210).
import tt::lang::String;

// Check if a character is a letter.
public fn isLetter(ch: string): bool {
    if (String_length(ch) == 0) { return false; }
    let c: string = String_charAt(ch, 0);
    return (c >= "A" && c <= "Z") || (c >= "a" && c <= "z");
}

// Check if a character is a digit.
public fn isDigitChar(ch: string): bool {
    if (String_length(ch) == 0) { return false; }
    let c: string = String_charAt(ch, 0);
    return c >= "0" && c <= "9";
}

// Check if a character is whitespace.
public fn isWhitespace(ch: string): bool {
    if (String_length(ch) == 0) { return false; }
    let c: string = String_charAt(ch, 0);
    return c == " " || c == "\t" || c == "\n" || c == "\r" || c == "\f" || c == "\v";
}

// Check if a character is uppercase.
public fn isUpperCase(ch: string): bool {
    if (String_length(ch) == 0) { return false; }
    let c: string = String_charAt(ch, 0);
    return c >= "A" && c <= "Z";
}

// Check if a character is lowercase.
public fn isLowerCase(ch: string): bool {
    if (String_length(ch) == 0) { return false; }
    let c: string = String_charAt(ch, 0);
    return c >= "a" && c <= "z";
}

// Convert a character to uppercase.
public fn toUpperCase(ch: string): string {
    if (String_length(ch) == 0) { return ch; }
    let c: string = String_charAt(ch, 0);
    if (c >= "a" && c <= "z") {
        let code: int = c as int - 32;
        return code as string;
    }
    return c;
}

// Convert a character to lowercase.
public fn toLowerCase(ch: string): string {
    if (String_length(ch) == 0) { return ch; }
    let c: string = String_charAt(ch, 0);
    if (c >= "A" && c <= "Z") {
        let code: int = c as int + 32;
        return code as string;
    }
    return c;
}

// Get the numeric value of a character (0-9 for digits, 10-35 for A-Z/a-z, -1 otherwise).
public fn getNumericValue(ch: string): int {
    if (String_length(ch) == 0) { return -1; }
    let c: string = String_charAt(ch, 0);
    if (c >= "0" && c <= "9") { return c as int - "0" as int; }
    if (c >= "A" && c <= "Z") { return c as int - "A" as int + 10; }
    if (c >= "a" && c <= "z") { return c as int - "a" as int + 10; }
    return -1;
}

// Check if a character is alphabetic.
public fn isAlphabetic(ch: string): bool {
    if (String_length(ch) == 0) { return false; }
    let c: string = String_charAt(ch, 0);
    return (c >= "A" && c <= "Z") || (c >= "a" && c <= "z");
}

// Check if a character is a defined Unicode code point.
public fn isDefined(ch: string): bool {
    if (String_length(ch) == 0) { return false; }
    let code: int = String_charAt(ch, 0) as int;
    // Basic check: code points 0-0x10FFFF are defined (surrogates excluded)
    if (code >= 0xD800 && code <= 0xDFFF) { return false; }
    return code >= 0 && code <= 0x10FFFF;
}
