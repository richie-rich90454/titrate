// Extended utility methods for the Long type (Task 203).
import tt::lang::Long;
import tt::lang::Integer;

// Parse a string as a long.
public fn parseLong(s: string): long {
    return Long.parseLong(s);
}

// Divide two longs treating them as unsigned.
public fn divideUnsigned(dividend: long, divisor: long): long {
    if (divisor == 0) {
        throw "ArithmeticException: division by zero";
    }
    // For unsigned division, if dividend is non-negative, standard division works
    // when divisor is also non-negative. For the general case we use a shift-subtract algorithm.
    if (dividend >= 0 && divisor >= 0) {
        return dividend / divisor;
    }
    if (dividend >= 0) {
        // dividend >= 0, divisor < 0 (as unsigned, divisor is very large)
        // result is 0 if dividend < unsigned divisor, else 1
        if (dividend < divisor) {
            return 0;
        }
        return 1;
    }
    if (divisor >= 0) {
        // dividend < 0 (unsigned large), divisor >= 0
        // Use shift-subtract division on the upper and lower halves
        // Simplified: use the fact that unsigned dividend = dividend + 2^63
        // This is complex; use iterative approach
        var q: long = 0;
        var rem: long = dividend;
        // Shift divisor left to align with dividend
        var shift: int = 0;
        var d: long = divisor;
        while (d >= 0 && shift < 64) {
            d = d << 1;
            shift = shift + 1;
        }
        d = d >>> 1;
        shift = shift - 1;
        while (shift >= 0) {
            q = q << 1;
            // Compare rem >= d as unsigned
            if (rem >= 0 && d >= 0) {
                if (rem >= d) {
                    rem = rem - d;
                    q = q + 1;
                }
            } else if (rem < 0) {
                // rem is unsigned-large
                rem = rem - d;
                q = q + 1;
            }
            d = d >>> 1;
            shift = shift - 1;
        }
        return q;
    }
    // Both negative (both unsigned large)
    // Compare as unsigned: if dividend >= divisor, return 1, else 0
    if (dividend >= divisor) {
        return 1;
    }
    return 0;
}

// Compute the unsigned remainder of dividend / divisor.
public fn remainderUnsigned(dividend: long, divisor: long): long {
    if (divisor == 0) {
        throw "ArithmeticException: division by zero";
    }
    if (dividend >= 0 && divisor >= 0) {
        return dividend % divisor;
    }
    if (dividend >= 0) {
        // dividend < unsigned divisor
        return dividend;
    }
    if (divisor >= 0) {
        // Use shift-subtract
        var rem: long = dividend;
        var shift: int = 0;
        var d: long = divisor;
        while (d >= 0 && shift < 64) {
            d = d << 1;
            shift = shift + 1;
        }
        d = d >>> 1;
        shift = shift - 1;
        while (shift >= 0) {
            if (rem >= 0 && d >= 0) {
                if (rem >= d) {
                    rem = rem - d;
                }
            } else if (rem < 0) {
                rem = rem - d;
            }
            d = d >>> 1;
            shift = shift - 1;
        }
        return rem;
    }
    // Both negative
    if (dividend >= divisor) {
        return dividend - divisor;
    }
    return dividend;
}

// Count the number of leading zero bits in a long.
public fn numberOfLeadingZeros(n: long): int {
    if (n == 0) { return 64; }
    var count: int = 0;
    var val: long = n;
    while (val >= 0) {
        count = count + 1;
        val = val << 1;
    }
    return count;
}

// Count the number of trailing zero bits in a long.
public fn numberOfTrailingZeros(n: long): int {
    if (n == 0) { return 64; }
    var count: int = 0;
    var val: long = n;
    while ((val & 1) == 0) {
        count = count + 1;
        val = val >>> 1;
    }
    return count;
}

// Reverse the bits of a long.
public fn reverse(n: long): long {
    var val: long = n;
    var result: long = 0;
    var i: int = 0;
    while (i < 64) {
        result = result << 1;
        result = result | (val & 1);
        val = val >>> 1;
        i = i + 1;
    }
    return result;
}

// Reverse the bytes of a long.
public fn reverseBytes(n: long): long {
    var result: long = 0;
    var val: long = n;
    var i: int = 0;
    while (i < 8) {
        result = result << 8;
        result = result | (val & 0xFF);
        val = val >>> 8;
        i = i + 1;
    }
    return result;
}

// Count the number of one-bits in a long.
public fn bitCountLong(n: long): int {
    var count: int = 0;
    var val: long = n;
    var bits: int = 0;
    while (val != 0 && bits < 64) {
        count = count + (val & 1) as int;
        val = val >>> 1;
        bits = bits + 1;
    }
    return count;
}
