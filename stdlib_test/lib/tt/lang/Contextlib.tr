// Contextlib — extended context manager utilities: ContextManager, closing, suppress, ExitStack.
import tt::util::ArrayList;
import tt::lang::Variant;

// ContextManager wraps enter and exit functions for use with the with-statement.
public class ContextManager {
    public fn(): Variant enterFn;
    public fn(): void exitFn;

    public fn init(enterFn: fn(): Variant, exitFn: fn(): void) {
        this.enterFn = enterFn;
        this.exitFn = exitFn;
    }

    // Enter the context, returning the resource.
    public fn enter(): Variant {
        return this.enterFn();
    }

    // Exit the context, performing cleanup.
    public fn exit(): void {
        this.exitFn();
    }
}

// Create a context manager that calls a close function on exit.
public fn closing(resource: Variant, closeFn: fn(): void): ContextManager {
    let capturedResource: Variant = resource;
    let capturedClose: fn(): void = closeFn;
    let cm: ContextManager = new ContextManager(
        fn(): Variant {
            return capturedResource;
        },
        fn(): void {
            capturedClose();
        }
    );
    return cm;
}

// Create a context manager that suppresses specified exception types.
// If an exception matching one of the types is thrown inside the block, it is caught silently.
public fn suppress(exceptionTypes: ArrayList<string>): ContextManager {
    let capturedTypes: ArrayList<string> = exceptionTypes;
    let cm: ContextManager = new ContextManager(
        fn(): Variant {
            return null;
        },
        fn(): void {
            // Suppression is handled at the call site by wrapping the block in try/catch.
        }
    );
    return cm;
}

// ExitStack manages a dynamic stack of cleanup callbacks.
public class ExitStack {
    public ArrayList<fn(): void> callbacks;

    public fn init() {
        this.callbacks = new ArrayList<fn(): void>();
    }

    // Push a cleanup callback onto the stack.
    public fn push(callback: fn(): void): void {
        this.callbacks.add(callback);
    }

    // Call all registered callbacks in LIFO order and clear the stack.
    public fn popAll(): void {
        var i: int = this.callbacks.size() - 1;
        while (i >= 0) {
            this.callbacks.get(i)();
            i = i - 1;
        }
        this.callbacks = new ArrayList<fn(): void>();
    }

    // Enter a context manager, register its exit for cleanup, and return the enter result.
    public fn enterContext(cm: ContextManager): Variant {
        let result: Variant = cm.enter();
        let capturedExit: fn(): void = cm.exitFn;
        this.callbacks.add(capturedExit);
        return result;
    }
}
