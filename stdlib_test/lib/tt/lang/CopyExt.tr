// CopyExt — extended copy utilities with memoization and type-dispatched copying.
import tt::util::ArrayList;
import tt::util::HashMap;
import tt::lang::Variant;
import tt::lang::String;

// Deep copy an object with a memo dictionary to handle shared references and cycles.
// The memo maps already-copied objects to their copies to preserve identity.
public fn deepCopy(obj: Variant, memo: HashMap): Variant {
    if (obj == null) { return null; }
    // Check memo for already-copied object
    let key: string = obj.toString();
    if (memo.containsKey(key)) {
        return memo.get(key);
    }
    if (obj is ArrayList) {
        let list: ArrayList<Variant> = obj as ArrayList<Variant>;
        let result: ArrayList<Variant> = new ArrayList<Variant>();
        memo.put(key, result);
        var i: int = 0;
        while (i < list.size()) {
            result.add(deepCopy(list.get(i), memo));
            i = i + 1;
        }
        return result;
    }
    if (obj is HashMap) {
        let map: HashMap<string, Variant> = obj as HashMap<string, Variant>;
        let result: HashMap<string, Variant> = new HashMap<string, Variant>();
        memo.put(key, result);
        let keys: ArrayList<string> = map.keys();
        var i: int = 0;
        while (i < keys.size()) {
            let k: string = keys.get(i);
            result.put(k, deepCopy(map.get(k), memo));
            i = i + 1;
        }
        return result;
    }
    // Primitive or non-container: return as-is
    return obj;
}

// Shallow copy an object. For containers, copies the container but not the elements.
public fn shallowCopy(obj: Variant): Variant {
    if (obj == null) { return null; }
    if (obj is ArrayList) {
        let list: ArrayList<Variant> = obj as ArrayList<Variant>;
        let result: ArrayList<Variant> = new ArrayList<Variant>();
        var i: int = 0;
        while (i < list.size()) {
            result.add(list.get(i));
            i = i + 1;
        }
        return result;
    }
    if (obj is HashMap) {
        let map: HashMap<string, Variant> = obj as HashMap<string, Variant>;
        let result: HashMap<string, Variant> = new HashMap<string, Variant>();
        let keys: ArrayList<string> = map.keys();
        var i: int = 0;
        while (i < keys.size()) {
            let k: string = keys.get(i);
            result.put(k, map.get(k));
            i = i + 1;
        }
        return result;
    }
    return obj;
}

// CopyDispatcher allows registering custom copy functions per type name.
public class CopyDispatcher {
    public HashMap<string, fn(Variant, HashMap): Variant> dispatchers;

    public fn init() {
        this.dispatchers = new HashMap<string, fn(Variant, HashMap): Variant>();
    }

    // Register a custom copier function for a given type name.
    public fn register(typeName: string, copier: fn(Variant, HashMap): Variant): void {
        this.dispatchers.put(typeName, copier);
    }

    // Copy an object using the registered copier for its type, or fall back to deepCopy.
    public fn copy(obj: Variant, memo: HashMap): Variant {
        if (obj == null) { return null; }
        let typeName: string = TypeName_of(obj);
        if (this.dispatchers.containsKey(typeName)) {
            let copier: fn(Variant, HashMap): Variant = this.dispatchers.get(typeName);
            return copier(obj, memo);
        }
        return deepCopy(obj, memo);
    }
}

// Create a modified copy of an object by applying changes from a HashMap.
// For HashMaps, returns a shallow copy with the changes merged in.
// For ArrayLists, returns a shallow copy with elements replaced at indices
// given by string keys (e.g. "0", "1") in changes.
// For other objects, returns the object unchanged.
public fn replace(obj: Variant, changes: HashMap): Variant {
    if (obj == null) { return null; }
    if (obj is HashMap) {
        let map: HashMap<string, Variant> = obj as HashMap<string, Variant>;
        let result: HashMap<string, Variant> = new HashMap<string, Variant>();
        let keys: ArrayList<string> = map.keys();
        var i: int = 0;
        while (i < keys.size()) {
            let k: string = keys.get(i);
            result.put(k, map.get(k));
            i = i + 1;
        }
        let changeKeys: ArrayList<string> = changes.keys();
        i = 0;
        while (i < changeKeys.size()) {
            let k: string = changeKeys.get(i);
            result.put(k, changes.get(k));
            i = i + 1;
        }
        return result;
    }
    if (obj is ArrayList) {
        let list: ArrayList<Variant> = obj as ArrayList<Variant>;
        let result: ArrayList<Variant> = new ArrayList<Variant>();
        var i: int = 0;
        while (i < list.size()) {
            result.add(list.get(i));
            i = i + 1;
        }
        let changeKeys: ArrayList<string> = changes.keys();
        i = 0;
        while (i < changeKeys.size()) {
            let k: string = changeKeys.get(i);
            let idx: int = _parseIntSimple(k);
            if (idx >= 0 && idx < result.size()) {
                result.set(idx, changes.get(k));
            }
            i = i + 1;
        }
        return result;
    }
    return obj;
}

// Parse a non-negative integer from a decimal string.
// Returns -1 if the string is not a valid non-negative integer.
fn _parseIntSimple(s: string): int {
    var result: int = 0;
    var i: int = 0;
    while (i < String.length(s)) {
        let c: string = String.charAt(s, i);
        let code: int = String.charAt(c, 0) as int;
        if (code < 48 || code > 57) {
            return -1;
        }
        result = result * 10 + (code - 48);
        i = i + 1;
    }
    if (i == 0) {
        return -1;
    }
    return result;
}
