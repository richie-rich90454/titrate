// Extended tuple classes for grouping fixed numbers of values (Task 209).
import tt::util::ArrayList;

// Tuple3 holds three Variant values.
public class Tuple3 {
    public Variant first;
    public Variant second;
    public Variant third;

    public fn init(first: Variant, second: Variant, third: Variant) {
        this.first = first;
        this.second = second;
        this.third = third;
    }

    public fn getFirst(): Variant {
        return this.first;
    }

    public fn getSecond(): Variant {
        return this.second;
    }

    public fn getThird(): Variant {
        return this.third;
    }

    public fn toString(): string {
        return "(" + this.first + ", " + this.second + ", " + this.third + ")";
    }
}

// Tuple4 holds four Variant values.
public class Tuple4 {
    public Variant first;
    public Variant second;
    public Variant third;
    public Variant fourth;

    public fn init(first: Variant, second: Variant, third: Variant, fourth: Variant) {
        this.first = first;
        this.second = second;
        this.third = third;
        this.fourth = fourth;
    }

    public fn getFirst(): Variant {
        return this.first;
    }

    public fn getSecond(): Variant {
        return this.second;
    }

    public fn getThird(): Variant {
        return this.third;
    }

    public fn getFourth(): Variant {
        return this.fourth;
    }

    public fn toString(): string {
        return "(" + this.first + ", " + this.second + ", " + this.third + ", " + this.fourth + ")";
    }
}

// Tuple5 holds five Variant values.
public class Tuple5 {
    public Variant first;
    public Variant second;
    public Variant third;
    public Variant fourth;
    public Variant fifth;

    public fn init(first: Variant, second: Variant, third: Variant, fourth: Variant, fifth: Variant) {
        this.first = first;
        this.second = second;
        this.third = third;
        this.fourth = fourth;
        this.fifth = fifth;
    }

    public fn getFirst(): Variant {
        return this.first;
    }

    public fn getSecond(): Variant {
        return this.second;
    }

    public fn getThird(): Variant {
        return this.third;
    }

    public fn getFourth(): Variant {
        return this.fourth;
    }

    public fn getFifth(): Variant {
        return this.fifth;
    }

    public fn toString(): string {
        return "(" + this.first + ", " + this.second + ", " + this.third + ", " + this.fourth + ", " + this.fifth + ")";
    }
}
