// Delaunay.tr — Delaunay triangulation (Bowyer-Watson) and Voronoi diagram
import tt::util::ArrayList;
import tt::math::MathAdvanced;

public class Point2D {
    public double x;
    public double y;

    public fn init(x: double, y: double) {
        this.x = x;
        this.y = y;
    }
}

public class Triangle {
    public int a;
    public int b;
    public int c;

    public fn init(a: int, b: int, c: int) {
        this.a = a;
        this.b = b;
        this.c = c;
    }
}

public class Edge {
    public int a;
    public int b;

    public fn init(a: int, b: int) {
        this.a = a;
        this.b = b;
    }
}

// Circumcircle test
fn _inCircumcircle(points: ArrayList<Point2D>, tri: Triangle, p: Point2D): bool {
    let ax: double = points.get(tri.a).x;
    let ay: double = points.get(tri.a).y;
    let bx: double = points.get(tri.b).x;
    let by: double = points.get(tri.b).y;
    let cx: double = points.get(tri.c).x;
    let cy: double = points.get(tri.c).y;
    let d: double = 2.0 * (ax * (by - cy) + bx * (cy - ay) + cx * (ay - by));
    if (Math.abs(d) < 1e-10) { return false; }
    let ux: double = ((ax * ax + ay * ay) * (by - cy) + (bx * bx + by * by) * (cy - ay) + (cx * cx + cy * cy) * (ay - by)) / d;
    let uy: double = ((ax * ax + ay * ay) * (cx - bx) + (bx * bx + by * by) * (ax - cx) + (cx * cx + cy * cy) * (bx - ax)) / d;
    let r2: double = (ax - ux) * (ax - ux) + (ay - uy) * (ay - uy);
    let dist2: double = (p.x - ux) * (p.x - ux) + (p.y - uy) * (p.y - uy);
    return dist2 < r2;
}

// Bowyer-Watson Delaunay triangulation
public fn delaunay(points: ArrayList<Point2D>): ArrayList<Triangle> {
    let n: int = points.size();
    if (n < 3) { return new ArrayList<Triangle>(); }
    // Create super triangle
    let allPoints: ArrayList<Point2D> = new ArrayList<Point2D>();
    var i: int = 0;
    while (i < n) {
        allPoints.add(points.get(i));
        i = i + 1;
    }
    allPoints.add(new Point2D(-1e6, -1e6));
    allPoints.add(new Point2D(1e6, -1e6));
    allPoints.add(new Point2D(0.0, 1e6));
    let superA: int = n;
    let superB: int = n + 1;
    let superC: int = n + 2;
    let triangles: ArrayList<Triangle> = new ArrayList<Triangle>();
    triangles.add(new Triangle(superA, superB, superC));
    // Add points one at a time
    i = 0;
    while (i < n) {
        let p: Point2D = allPoints.get(i);
        let badTriangles: ArrayList<int> = new ArrayList<int>();
        var j: int = 0;
        while (j < triangles.size()) {
            if (_inCircumcircle(allPoints, triangles.get(j), p)) {
                badTriangles.add(j);
            }
            j = j + 1;
        }
        // Find boundary edges
        let edges: ArrayList<Edge> = new ArrayList<Edge>();
        j = 0;
        while (j < badTriangles.size()) {
            let tri: Triangle = triangles.get(badTriangles.get(j));
            edges.add(new Edge(tri.a, tri.b));
            edges.add(new Edge(tri.b, tri.c));
            edges.add(new Edge(tri.c, tri.a));
            j = j + 1;
        }
        // Remove bad triangles (in reverse order)
        j = badTriangles.size() - 1;
        while (j >= 0) {
            triangles.removeAt(badTriangles.get(j));
            // Rebuild bad indices
            var k: int = j + 1;
            while (k < badTriangles.size()) {
                if (badTriangles.get(k) > badTriangles.get(j)) {
                    badTriangles.set(k, badTriangles.get(k) - 1);
                }
                k = k + 1;
            }
            j = j - 1;
        }
        // Create new triangles
        j = 0;
        while (j < edges.size()) {
            triangles.add(new Triangle(edges.get(j).a, edges.get(j).b, i));
            j = j + 1;
        }
        i = i + 1;
    }
    // Remove triangles with super triangle vertices
    let result: ArrayList<Triangle> = new ArrayList<Triangle>();
    i = 0;
    while (i < triangles.size()) {
        let tri: Triangle = triangles.get(i);
        if (tri.a < n && tri.b < n && tri.c < n) {
            result.add(tri);
        }
        i = i + 1;
    }
    return result;
}

// Voronoi diagram extraction from Delaunay triangulation
// Returns list of Voronoi cells, each cell is a list of circumcenter coordinates [x, y]
public fn voronoi(points: ArrayList<Point2D>, triangles: ArrayList<Triangle>): ArrayList<ArrayList<double>> {
    let cells: ArrayList<ArrayList<double>> = new ArrayList<ArrayList<double>>();
    var i: int = 0;
    while (i < points.size()) {
        let cell: ArrayList<double> = new ArrayList<double>();
        // Find all triangles containing point i and compute circumcenters
        var j: int = 0;
        while (j < triangles.size()) {
            let tri: Triangle = triangles.get(j);
            if (tri.a == i || tri.b == i || tri.c == i) {
                // Compute circumcenter
                let ax: double = points.get(tri.a).x;
                let ay: double = points.get(tri.a).y;
                let bx: double = points.get(tri.b).x;
                let by: double = points.get(tri.b).y;
                let cx: double = points.get(tri.c).x;
                let cy: double = points.get(tri.c).y;
                let d: double = 2.0 * (ax * (by - cy) + bx * (cy - ay) + cx * (ay - by));
                if (Math.abs(d) > 1e-10) {
                    let ux: double = ((ax * ax + ay * ay) * (by - cy) + (bx * bx + by * by) * (cy - ay) + (cx * cx + cy * cy) * (ay - by)) / d;
                    let uy: double = ((ax * ax + ay * ay) * (cx - bx) + (bx * bx + by * by) * (ax - cx) + (cx * cx + cy * cy) * (bx - ax)) / d;
                    cell.add(ux);
                    cell.add(uy);
                }
            }
            j = j + 1;
        }
        cells.add(cell);
        i = i + 1;
    }
    return cells;
}
