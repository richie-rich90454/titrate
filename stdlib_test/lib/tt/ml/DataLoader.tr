// DataLoader.tr — Dataset abstraction, batch generation, shuffling, splitting
import tt::util::ArrayList;
import tt::math::Math;
import tt::math::MathAdvanced;

public class Dataset {
    public ArrayList<ArrayList<double>> features;
    public ArrayList<ArrayList<double>> labels;

    public fn init() {
        this.features = new ArrayList<ArrayList<double>>();
        this.labels = new ArrayList<ArrayList<double>>();
    }

    public fn add(feature: ArrayList<double>, label: ArrayList<double>): void {
        this.features.add(feature);
        this.labels.add(label);
    }

    public fn size(): int {
        return this.features.size();
    }

    public fn get(i: int): ArrayList<ArrayList<double>> {
        let result: ArrayList<ArrayList<double>> = new ArrayList<ArrayList<double>>();
        result.add(this.features.get(i));
        result.add(this.labels.get(i));
        return result;
    }
}

public class DataLoader {
    public Dataset dataset;
    public int batchSize;
    public bool shuffle;
    public ArrayList<int> indices;

    public fn init(data: Dataset, batch: int, shuf: bool) {
        this.dataset = data;
        this.batchSize = batch;
        this.shuffle = shuf;
        this.indices = new ArrayList<int>();
        var i: int = 0;
        while (i < data.size()) {
            this.indices.add(i);
            i = i + 1;
        }
        if (this.shuffle) {
            _shuffleIndices(this.indices);
        }
    }

    public fn numBatches(): int {
        return (this.dataset.size() + this.batchSize - 1) / this.batchSize;
    }

    public fn getBatch(batchIdx: int): ArrayList<ArrayList<ArrayList<double>>> {
        let start: int = batchIdx * this.batchSize;
        let end: int = Math.min(start + this.batchSize, this.dataset.size());
        let batchFeatures: ArrayList<ArrayList<double>> = new ArrayList<ArrayList<double>>();
        let batchLabels: ArrayList<ArrayList<double>> = new ArrayList<ArrayList<double>>();
        var i: int = start;
        while (i < end) {
            let idx: int = this.indices.get(i);
            batchFeatures.add(this.dataset.features.get(idx));
            batchLabels.add(this.dataset.labels.get(idx));
            i = i + 1;
        }
        let result: ArrayList<ArrayList<ArrayList<double>>> = new ArrayList<ArrayList<ArrayList<double>>>();
        result.add(batchFeatures);
        result.add(batchLabels);
        return result;
    }

    public fn shuffle(): void {
        _shuffleIndices(this.indices);
    }

    public fn reset(): void {
        this.indices = new ArrayList<int>();
        var i: int = 0;
        while (i < this.dataset.size()) {
            this.indices.add(i);
            i = i + 1;
        }
        if (this.shuffle) {
            _shuffleIndices(this.indices);
        }
    }
}

// Fisher-Yates shuffle
fn _shuffleIndices(indices: ArrayList<int>): void {
    let n: int = indices.size();
    var i: int = n - 1;
    while (i > 0) {
        let j: int = Math.abs(Random_nextInt()) % (i + 1);
        let tmp: int = indices.get(i);
        indices.set(i, indices.get(j));
        indices.set(j, tmp);
        i = i - 1;
    }
}

// Train/validation/test split
public fn trainValTestSplit(dataset: Dataset, trainRatio: double, valRatio: double): ArrayList<Dataset> {
    let result: ArrayList<Dataset> = new ArrayList<Dataset>();
    let trainData: Dataset = new Dataset();
    let valData: Dataset = new Dataset();
    let testData: Dataset = new Dataset();
    let n: int = dataset.size();
    let trainEnd: int = Math.floor(n as double * trainRatio) as int;
    let valEnd: int = Math.floor(n as double * (trainRatio + valRatio)) as int;
    var i: int = 0;
    while (i < n) {
        if (i < trainEnd) {
            trainData.add(dataset.features.get(i), dataset.labels.get(i));
        } else {
            if (i < valEnd) {
                valData.add(dataset.features.get(i), dataset.labels.get(i));
            } else {
                testData.add(dataset.features.get(i), dataset.labels.get(i));
            }
        }
        i = i + 1;
    }
    result.add(trainData);
    result.add(valData);
    result.add(testData);
    return result;
}
