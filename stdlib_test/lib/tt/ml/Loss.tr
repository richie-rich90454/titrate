// Loss.tr — Loss functions for neural network training
import tt::util::ArrayList;
import tt::math::Math;
import tt::math::MathAdvanced;

public fn mseLoss(predicted: ArrayList<double>, actual: ArrayList<double>): double {
    var sum: double = 0.0;
    let n: int = Math.min(predicted.size(), actual.size());
    var i: int = 0;
    while (i < n) {
        let diff: double = predicted.get(i) - actual.get(i);
        sum = sum + diff * diff;
        i = i + 1;
    }
    return sum / n as double;
}

public fn maeLoss(predicted: ArrayList<double>, actual: ArrayList<double>): double {
    var sum: double = 0.0;
    let n: int = Math.min(predicted.size(), actual.size());
    var i: int = 0;
    while (i < n) {
        sum = sum + Math.abs(predicted.get(i) - actual.get(i));
        i = i + 1;
    }
    return sum / n as double;
}

public fn crossEntropyLoss(predicted: ArrayList<double>, actual: ArrayList<double>): double {
    var sum: double = 0.0;
    let n: int = Math.min(predicted.size(), actual.size());
    var i: int = 0;
    while (i < n) {
        let p: double = predicted.get(i);
        if (p > 1e-15) {
            sum = sum - actual.get(i) * MathAdvanced.ln(p);
        }
        i = i + 1;
    }
    return sum;
}

public fn binaryCrossEntropyLoss(predicted: double, actual: double): double {
    let p: double = Math.max(1e-15, Math.min(predicted, 1.0 - 1e-15));
    return -(actual * MathAdvanced.ln(p) + (1.0 - actual) * MathAdvanced.ln(1.0 - p));
}

public fn hingeLoss(predicted: double, actual: double): double {
    return Math.max(0.0, 1.0 - actual * predicted);
}

public fn huberLoss(predicted: double, actual: double, delta: double): double {
    let diff: double = predicted - actual;
    if (Math.abs(diff) <= delta) {
        return 0.5 * diff * diff;
    }
    return delta * (Math.abs(diff) - 0.5 * delta);
}

// Vectorized Huber loss
public fn huberLossVec(predicted: ArrayList<double>, actual: ArrayList<double>, delta: double): double {
    var sum: double = 0.0;
    let n: int = Math.min(predicted.size(), actual.size());
    var i: int = 0;
    while (i < n) {
        let diff: double = predicted.get(i) - actual.get(i);
        if (Math.abs(diff) <= delta) {
            sum = sum + 0.5 * diff * diff;
        } else {
            sum = sum + delta * (Math.abs(diff) - 0.5 * delta);
        }
        i = i + 1;
    }
    return sum / n as double;
}

public fn klDivergence(p: ArrayList<double>, q: ArrayList<double>): double {
    var sum: double = 0.0;
    let n: int = Math.min(p.size(), q.size());
    var i: int = 0;
    while (i < n) {
        let pi: double = p.get(i);
        let qi: double = q.get(i);
        if (pi > 1e-15 && qi > 1e-15) {
            sum = sum + pi * MathAdvanced.ln(pi / qi);
        }
        i = i + 1;
    }
    return sum;
}

// Loss gradients
public fn mseGradient(predicted: ArrayList<double>, actual: ArrayList<double>): ArrayList<double> {
    let result: ArrayList<double> = new ArrayList<double>();
    let n: int = Math.min(predicted.size(), actual.size());
    var i: int = 0;
    while (i < n) {
        result.add(2.0 * (predicted.get(i) - actual.get(i)) / n as double);
        i = i + 1;
    }
    return result;
}

public fn crossEntropyGradient(predicted: ArrayList<double>, actual: ArrayList<double>): ArrayList<double> {
    let result: ArrayList<double> = new ArrayList<double>();
    let n: int = Math.min(predicted.size(), actual.size());
    var i: int = 0;
    while (i < n) {
        let p: double = Math.max(predicted.get(i), 1e-15);
        result.add((p - actual.get(i)) / n as double);
        i = i + 1;
    }
    return result;
}
