import tt::util::ArrayList;
import tt::util::HashMap;
import tt::util::Pair;
import tt::math::Math;
import tt::math::MathAdvanced;
import tt::linalg::Qr;

// Eigenvalue algorithms module
// Matrices are stored as flat ArrayList<double> in row-major order.
// Element (i, j) of an n x n matrix is at index i * n + j.

// All eigenvalues via QR algorithm with shifts
public fn eigenvalues(a: ArrayList<double>, n: int): ArrayList<double> {
    // Copy matrix
    let work: ArrayList<double> = new ArrayList<double>();
    var i: int = 0;
    while (i < n * n) {
        work.add(a.get(i));
        i = i + 1;
    }

    // QR iteration with Wilkinson shift
    var iter: int = 0;
    let maxIter: int = 300;
    while (iter < maxIter) {
        // Check convergence: off-diagonal norm
        var offDiag: double = 0.0;
        var ii: int = 0;
        while (ii < n) {
            var jj: int = 0;
            while (jj < n) {
                if (ii != jj) {
                    let v: double = Math.abs(work.get(ii * n + jj));
                    if (v > offDiag) { offDiag = v; }
                }
                jj = jj + 1;
            }
            ii = ii + 1;
        }
        if (offDiag < 1e-12) { break; }

        // Wilkinson shift
        let d: double = (work.get((n - 2) * n + (n - 2)) - work.get((n - 1) * n + (n - 1))) / 2.0;
        let sign: double = d >= 0.0 ? 1.0 : -1.0;
        let off: double = work.get((n - 1) * n + (n - 2));
        let mu: double = work.get((n - 1) * n + (n - 1))
            - off * off / (d + sign * MathAdvanced.sqrt(d * d + off * off));

        // Shift
        ii = 0;
        while (ii < n) {
            work.set(ii * n + ii, work.get(ii * n + ii) - mu);
            ii = ii + 1;
        }

        // QR step
        let qrResult: HashMap<string, ArrayList<double>> = Qr.qrHouseholder(work, n, n);
        let qMat: ArrayList<double> = qrResult.get("Q");
        let rMat: ArrayList<double> = qrResult.get("R");

        // Form R * Q + mu * I
        ii = 0;
        while (ii < n) {
            var jj: int = 0;
            while (jj < n) {
                var sum: double = 0.0;
                var kk: int = 0;
                while (kk < n) {
                    sum = sum + rMat.get(ii * n + kk) * qMat.get(kk * n + jj);
                    kk = kk + 1;
                }
                if (ii == jj) { sum = sum + mu; }
                work.set(ii * n + jj, sum);
                jj = jj + 1;
            }
            ii = ii + 1;
        }

        iter = iter + 1;
    }

    // Extract diagonal as eigenvalues
    let result: ArrayList<double> = new ArrayList<double>();
    i = 0;
    while (i < n) {
        result.add(work.get(i * n + i));
        i = i + 1;
    }
    return result;
}

// Eigenvalues and eigenvectors via QR algorithm
// Returns Pair where first = eigenvalues (ArrayList<double>), second = eigenvectors (ArrayList<double>, n x n column-major)
public fn eigenvectors(a: ArrayList<double>, n: int): Pair<ArrayList<double>, ArrayList<double>> {
    // Copy matrix
    let work: ArrayList<double> = new ArrayList<double>();
    var i: int = 0;
    while (i < n * n) {
        work.add(a.get(i));
        i = i + 1;
    }

    // Accumulate eigenvectors: start with identity
    let qAccum: ArrayList<double> = new ArrayList<double>();
    i = 0;
    while (i < n * n) {
        if (i % (n + 1) == 0) {
            qAccum.add(1.0);
        } else {
            qAccum.add(0.0);
        }
        i = i + 1;
    }

    // QR iteration with Wilkinson shift
    var iter: int = 0;
    let maxIter: int = 300;
    while (iter < maxIter) {
        // Check convergence
        var offDiag: double = 0.0;
        var ii: int = 0;
        while (ii < n) {
            var jj: int = 0;
            while (jj < n) {
                if (ii != jj) {
                    let v: double = Math.abs(work.get(ii * n + jj));
                    if (v > offDiag) { offDiag = v; }
                }
                jj = jj + 1;
            }
            ii = ii + 1;
        }
        if (offDiag < 1e-12) { break; }

        // Wilkinson shift
        let d: double = (work.get((n - 2) * n + (n - 2)) - work.get((n - 1) * n + (n - 1))) / 2.0;
        let sign: double = d >= 0.0 ? 1.0 : -1.0;
        let off: double = work.get((n - 1) * n + (n - 2));
        let mu: double = work.get((n - 1) * n + (n - 1))
            - off * off / (d + sign * MathAdvanced.sqrt(d * d + off * off));

        // Shift
        ii = 0;
        while (ii < n) {
            work.set(ii * n + ii, work.get(ii * n + ii) - mu);
            ii = ii + 1;
        }

        // QR step
        let qrResult: HashMap<string, ArrayList<double>> = Qr.qrHouseholder(work, n, n);
        let qMat: ArrayList<double> = qrResult.get("Q");
        let rMat: ArrayList<double> = qrResult.get("R");

        // Form R * Q + mu * I
        ii = 0;
        while (ii < n) {
            var jj: int = 0;
            while (jj < n) {
                var sum: double = 0.0;
                var kk: int = 0;
                while (kk < n) {
                    sum = sum + rMat.get(ii * n + kk) * qMat.get(kk * n + jj);
                    kk = kk + 1;
                }
                if (ii == jj) { sum = sum + mu; }
                work.set(ii * n + jj, sum);
                jj = jj + 1;
            }
            ii = ii + 1;
        }

        // Accumulate Q
        let newAccum: ArrayList<double> = new ArrayList<double>();
        ii = 0;
        while (ii < n * n) {
            newAccum.add(0.0);
            ii = ii + 1;
        }
        ii = 0;
        while (ii < n) {
            var jj: int = 0;
            while (jj < n) {
                var sum: double = 0.0;
                var kk: int = 0;
                while (kk < n) {
                    sum = sum + qAccum.get(ii * n + kk) * qMat.get(kk * n + jj);
                    kk = kk + 1;
                }
                newAccum.set(ii * n + jj, sum);
                jj = jj + 1;
            }
            ii = ii + 1;
        }
        qAccum.clear();
        ii = 0;
        while (ii < n * n) {
            qAccum.add(newAccum.get(ii));
            ii = ii + 1;
        }

        iter = iter + 1;
    }

    // Extract eigenvalues
    let evals: ArrayList<double> = new ArrayList<double>();
    i = 0;
    while (i < n) {
        evals.add(work.get(i * n + i));
        i = i + 1;
    }

    return new Pair<ArrayList<double>, ArrayList<double>>(evals, qAccum);
}

// Power iteration: finds the dominant eigenvalue and eigenvector
// Returns Pair where first = eigenvalue (double), second = eigenvector (ArrayList<double>)
public fn powerIteration(a: ArrayList<double>, n: int, maxIter: int): Pair<double, ArrayList<double>> {
    // Start with vector of ones
    let v: ArrayList<double> = new ArrayList<double>();
    var i: int = 0;
    while (i < n) {
        v.add(1.0);
        i = i + 1;
    }

    var iter: int = 0;
    while (iter < maxIter) {
        // v = A * v
        let vNew: ArrayList<double> = new ArrayList<double>();
        i = 0;
        while (i < n) {
            var sum: double = 0.0;
            var k: int = 0;
            while (k < n) {
                sum = sum + a.get(i * n + k) * v.get(k);
                k = k + 1;
            }
            vNew.add(sum);
            i = i + 1;
        }

        // Compute norm
        var norm: double = 0.0;
        i = 0;
        while (i < n) {
            norm = norm + vNew.get(i) * vNew.get(i);
            i = i + 1;
        }
        norm = MathAdvanced.sqrt(norm);
        if (norm < 1e-15) { break; }

        // Normalize
        i = 0;
        while (i < n) {
            v.set(i, vNew.get(i) / norm);
            i = i + 1;
        }
        iter = iter + 1;
    }

    // Compute eigenvalue: lambda = v^T * A * v
    let av: ArrayList<double> = new ArrayList<double>();
    i = 0;
    while (i < n) {
        var sum: double = 0.0;
        var k: int = 0;
        while (k < n) {
            sum = sum + a.get(i * n + k) * v.get(k);
            k = k + 1;
        }
        av.add(sum);
        i = i + 1;
    }

    var eigenvalue: double = 0.0;
    i = 0;
    while (i < n) {
        eigenvalue = eigenvalue + v.get(i) * av.get(i);
        i = i + 1;
    }

    return new Pair<double, ArrayList<double>>(eigenvalue, v);
}

// Inverse iteration with shift: finds eigenvalue closest to shift and its eigenvector
// Returns Pair where first = eigenvalue (double), second = eigenvector (ArrayList<double>)
public fn inverseIteration(a: ArrayList<double>, n: int, shift: double, maxIter: int): Pair<double, ArrayList<double>> {
    // Form (A - shift * I)
    let shifted: ArrayList<double> = new ArrayList<double>();
    var i: int = 0;
    while (i < n * n) {
        if (i % (n + 1) == 0) {
            shifted.add(a.get(i) - shift);
        } else {
            shifted.add(a.get(i));
        }
        i = i + 1;
    }

    // Small perturbation to avoid exact singularity
    shifted.set(0, shifted.get(0) + 1e-10);

    // Start with vector of ones
    let v: ArrayList<double> = new ArrayList<double>();
    i = 0;
    while (i < n) {
        v.add(1.0);
        i = i + 1;
    }

    // LU decomposition of shifted matrix for solving
    let luResult: HashMap<string, ArrayList<double>> = luDecompose(shifted, n);
    let lu: ArrayList<double> = luResult.get("LU");
    let perm: ArrayList<int> = luResult.get("perm");

    var iter: int = 0;
    while (iter < maxIter) {
        // Solve (A - shift*I) * w = v using LU
        let w: ArrayList<double> = luSolve(lu, perm, n, v);

        // Compute norm
        var norm: double = 0.0;
        i = 0;
        while (i < n) {
            norm = norm + w.get(i) * w.get(i);
            i = i + 1;
        }
        norm = MathAdvanced.sqrt(norm);
        if (norm < 1e-15) { break; }

        // Normalize
        i = 0;
        while (i < n) {
            v.set(i, w.get(i) / norm);
            i = i + 1;
        }
        iter = iter + 1;
    }

    // Compute eigenvalue via Rayleigh quotient
    let eigenvalue: double = rayleighQuotient(a, n, v);

    return new Pair<double, ArrayList<double>>(eigenvalue, v);
}

// Rayleigh quotient: v^T * A * v / (v^T * v)
public fn rayleighQuotient(a: ArrayList<double>, n: int, v: ArrayList<double>): double {
    // Compute A * v
    let av: ArrayList<double> = new ArrayList<double>();
    var i: int = 0;
    while (i < n) {
        var sum: double = 0.0;
        var k: int = 0;
        while (k < n) {
            sum = sum + a.get(i * n + k) * v.get(k);
            k = k + 1;
        }
        av.add(sum);
        i = i + 1;
    }

    // v^T * A * v
    var numerator: double = 0.0;
    i = 0;
    while (i < n) {
        numerator = numerator + v.get(i) * av.get(i);
        i = i + 1;
    }

    // v^T * v
    var denominator: double = 0.0;
    i = 0;
    while (i < n) {
        denominator = denominator + v.get(i) * v.get(i);
        i = i + 1;
    }

    if (denominator < 1e-15) { return 0.0; }
    return numerator / denominator;
}

// ---- Internal helpers ----

// LU decomposition with partial pivoting
// Returns HashMap with "LU" (combined L and U) and "perm" (row permutation)
fn luDecompose(a: ArrayList<double>, n: int): HashMap<string, ArrayList<double>> {
    let result: HashMap<string, ArrayList<double>> = new HashMap<string, ArrayList<double>>();

    let lu: ArrayList<double> = new ArrayList<double>();
    var i: int = 0;
    while (i < n * n) {
        lu.add(a.get(i));
        i = i + 1;
    }

    // Permutation as doubles (will be cast to int when used)
    let permArr: ArrayList<double> = new ArrayList<double>();
    i = 0;
    while (i < n) {
        permArr.add(i as double);
        i = i + 1;
    }

    var col: int = 0;
    while (col < n) {
        // Find pivot
        var maxVal: double = Math.abs(lu.get(col * n + col));
        var maxRow: int = col;
        var row: int = col + 1;
        while (row < n) {
            let val: double = Math.abs(lu.get(row * n + col));
            if (val > maxVal) {
                maxVal = val;
                maxRow = row;
            }
            row = row + 1;
        }

        // Swap rows
        if (maxRow != col) {
            var j: int = 0;
            while (j < n) {
                let tmp: double = lu.get(col * n + j);
                lu.set(col * n + j, lu.get(maxRow * n + j));
                lu.set(maxRow * n + j, tmp);
                j = j + 1;
            }
            let tmpP: double = permArr.get(col);
            permArr.set(col, permArr.get(maxRow));
            permArr.set(maxRow, tmpP);
        }

        // Eliminate below
        if (Math.abs(lu.get(col * n + col)) > 1e-15) {
            row = col + 1;
            while (row < n) {
                let factor: double = lu.get(row * n + col) / lu.get(col * n + col);
                lu.set(row * n + col, factor);
                var j: int = col + 1;
                while (j < n) {
                    lu.set(row * n + j, lu.get(row * n + j) - factor * lu.get(col * n + j));
                    j = j + 1;
                }
                row = row + 1;
            }
        }
        col = col + 1;
    }

    result.put("LU", lu);
    result.put("perm", permArr);
    return result;
}

// Solve using LU decomposition
fn luSolve(lu: ArrayList<double>, perm: ArrayList<double>, n: int, b: ArrayList<double>): ArrayList<double> {
    // Apply permutation to b
    let y: ArrayList<double> = new ArrayList<double>();
    var i: int = 0;
    while (i < n) {
        let pIdx: int = perm.get(i) as int;
        y.add(b.get(pIdx));
        i = i + 1;
    }

    // Forward substitution (L has unit diagonal, stored below diagonal of LU)
    i = 0;
    while (i < n) {
        var sum: double = y.get(i);
        var k: int = 0;
        while (k < i) {
            sum = sum - lu.get(i * n + k) * y.get(k);
            k = k + 1;
        }
        y.set(i, sum);
        i = i + 1;
    }

    // Back substitution (U stored on and above diagonal of LU)
    let x: ArrayList<double> = new ArrayList<double>();
    i = 0;
    while (i < n) {
        x.add(0.0);
        i = i + 1;
    }

    i = n - 1;
    while (i >= 0) {
        var sum: double = y.get(i);
        var k: int = i + 1;
        while (k < n) {
            sum = sum - lu.get(i * n + k) * x.get(k);
            k = k + 1;
        }
        let diag: double = lu.get(i * n + i);
        if (Math.abs(diag) < 1e-15) {
            x.set(i, 0.0);
        } else {
            x.set(i, sum / diag);
        }
        i = i - 1;
    }

    return x;
}
