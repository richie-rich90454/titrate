// Kde module providing kernel density estimation algorithms.
import tt::util::ArrayList;
import tt::math::Math;
import tt::math::MathAdvanced;
import tt::statistics::Statistics;

// Gaussian KDE evaluated at evenly spaced points.
// data: the observed data points.
// bandwidth: the smoothing bandwidth (h).
// points: number of evaluation points.
// Returns density values at evenly spaced points spanning the data range.
public fn kdeGaussian(data: ArrayList<double>, bandwidth: double, points: int): ArrayList<double> {
    let result: ArrayList<double> = new ArrayList<double>();
    if (data.size() == 0 || points <= 0) { return result; }
    let lo: double = dataMin(data) - 3.0 * bandwidth;
    let hi: double = dataMax(data) + 3.0 * bandwidth;
    let step: double = (hi - lo) / (points - 1) as double;
    var i: int = 0;
    while (i < points) {
        let x: double = lo + i as double * step;
        result.add(kdeEvaluate(data, bandwidth, x));
        i = i + 1;
    }
    return result;
}

// Silverman's rule of thumb for bandwidth selection.
// h = 0.9 * min(stdev, IQR/1.34) * n^(-1/5)
public fn silvermanBandwidth(data: ArrayList<double>): double {
    let n: int = data.size();
    if (n < 2) { return 1.0; }
    let s: double = Statistics.stdev(data);
    let qs: ArrayList<double> = Statistics.quantiles(data, 4);
    // quantiles(data, 4) returns [Q1, Q2, Q3]
    let iqr: double = 0.0;
    if (qs.size() >= 3) {
        iqr = qs.get(2) - qs.get(0);
    }
    let spread: double = Math.min(s, iqr / 1.34);
    if (spread == 0.0) { return 1.0; }
    return 0.9 * spread * MathAdvanced.pow(n as double, -0.2);
}

// Scott's rule for bandwidth selection.
// h = 1.06 * stdev * n^(-1/5)
public fn scottBandwidth(data: ArrayList<double>): double {
    let n: int = data.size();
    if (n < 2) { return 1.0; }
    let s: double = Statistics.stdev(data);
    if (s == 0.0) { return 1.0; }
    return 1.06 * s * MathAdvanced.pow(n as double, -0.2);
}

// Evaluate Gaussian KDE at a single point x.
// f(x) = (1/(n*h)) * sum( K((x - xi)/h) )
// where K is the Gaussian kernel: (1/sqrt(2*pi)) * exp(-0.5 * u^2)
public fn kdeEvaluate(data: ArrayList<double>, bandwidth: double, x: double): double {
    let n: int = data.size();
    if (n == 0 || bandwidth <= 0.0) { return 0.0; }
    let invH: double = 1.0 / bandwidth;
    let coeff: double = 1.0 / (n as double * bandwidth * MathAdvanced.sqrt(2.0 * Math.PI()));
    var sum: double = 0.0;
    var i: int = 0;
    while (i < n) {
        let u: double = (x - data.get(i)) * invH;
        sum = sum + MathAdvanced.exp(-0.5 * u * u);
        i = i + 1;
    }
    return coeff * sum;
}

// Compute KDE on a grid and return [xs, ys] for plotting.
// data: the observed data points.
// bandwidth: the smoothing bandwidth (h).
// lo: lower bound of evaluation range.
// hi: upper bound of evaluation range.
// n: number of grid points.
// Returns ArrayList<ArrayList<double>> where index 0 is xs and index 1 is ys.
public fn kdeGrid(data: ArrayList<double>, bandwidth: double, lo: double, hi: double, n: int): ArrayList<ArrayList<double>> {
    let result: ArrayList<ArrayList<double>> = new ArrayList<ArrayList<double>>();
    let xs: ArrayList<double> = new ArrayList<double>();
    let ys: ArrayList<double> = new ArrayList<double>();
    if (data.size() == 0 || n <= 0) {
        result.add(xs);
        result.add(ys);
        return result;
    }
    let step: double = (hi - lo) / (n - 1) as double;
    var i: int = 0;
    while (i < n) {
        let x: double = lo + i as double * step;
        xs.add(x);
        ys.add(kdeEvaluate(data, bandwidth, x));
        i = i + 1;
    }
    result.add(xs);
    result.add(ys);
    return result;
}

// Helper: minimum value in data.
fn dataMin(data: ArrayList<double>): double {
    if (data.size() == 0) { return 0.0; }
    var m: double = data.get(0);
    var i: int = 1;
    while (i < data.size()) {
        if (data.get(i) < m) { m = data.get(i); }
        i = i + 1;
    }
    return m;
}

// Helper: maximum value in data.
fn dataMax(data: ArrayList<double>): double {
    if (data.size() == 0) { return 0.0; }
    var m: double = data.get(0);
    var i: int = 1;
    while (i < data.size()) {
        if (data.get(i) > m) { m = data.get(i); }
        i = i + 1;
    }
    return m;
}
