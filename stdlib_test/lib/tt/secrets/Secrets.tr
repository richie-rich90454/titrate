// Secrets provides cryptographically secure random generation, mirroring Python's secrets module.
// Uses Os_urandom() for cryptographic randomness from the OS CSPRNG.
import tt::util::ArrayList;
import tt::encoding::Hex;
import tt::encoding::Base64;

// Generate a random hex token of nBytes bytes.
public fn tokenHex(nBytes: int): string {
    return Os_urandom(nBytes);
}

// Generate a random byte token as a string of nBytes bytes.
public fn tokenBytes(nBytes: int): string {
    let hex: string = Os_urandom(nBytes);
    return Hex.decode(hex);
}

// Generate a URL-safe random token of nBytes bytes.
public fn tokenUrlSafe(nBytes: int): string {
    let raw: string = tokenBytes(nBytes);
    return Base64.encodeUrlSafe(raw);
}

// Choose a random element from the list.
public fn choice<T>(list: ArrayList<T>): T {
    if (list.size() == 0) { return null; }
    let idx: int = randBelow(list.size());
    return list.get(idx);
}

// Generate a random integer in [0, n).
public fn randBelow(n: int): int {
    if (n <= 0) { return 0; }
    let hex: string = Os_urandom(3);
    let bytes: ArrayList<int> = Hex.decodeToBytes(hex);
    let val: int = bytes.get(0) * 65536 + bytes.get(1) * 256 + bytes.get(2);
    return val % n;
}

// SystemRandom: cryptographically secure random number generator.
public class SystemRandom {
    public fn init() {
        // No state needed - uses system CSPRNG
    }

    // Return a random integer in [0, bound).
    public fn randBelow(bound: int): int {
        if (bound <= 0) { return 0; }
        let hex: string = Os_urandom(3);
        let bytes: ArrayList<int> = Hex.decodeToBytes(hex);
        let val: int = bytes.get(0) * 65536 + bytes.get(1) * 256 + bytes.get(2);
        return val % bound;
    }

    // Return a random integer in [min, max].
    public fn randint(min: int, max: int): int {
        if (min > max) { return min; }
        return min + this.randBelow(max - min + 1);
    }

    // Return a random double in [0.0, 1.0).
    public fn random(): double {
        let hex: string = Os_urandom(4);
        let bytes: ArrayList<int> = Hex.decodeToBytes(hex);
        let val: int = bytes.get(0) * 16777216 + bytes.get(1) * 65536 + bytes.get(2) * 256 + bytes.get(3);
        return (val as double) / 4294967296.0;
    }

    // Return n random bytes as a string.
    public fn randbytes(n: int): string {
        return tokenBytes(n);
    }

    // Shuffle an ArrayList in place using Fisher-Yates.
    public fn shuffle<T>(list: ArrayList<T>): void {
        var i: int = list.size() - 1;
        while (i > 0) {
            let j: int = this.randBelow(i + 1);
            let temp: T = list.get(i);
            list.set(i, list.get(j));
            list.set(j, temp);
            i = i - 1;
        }
    }

    // Return a random element from a non-empty ArrayList.
    public fn choice<T>(list: ArrayList<T>): T {
        let idx: int = this.randBelow(list.size());
        return list.get(idx);
    }
}
