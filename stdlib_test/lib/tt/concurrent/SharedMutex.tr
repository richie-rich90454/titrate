// Reader-writer lock.
public class SharedMutex {
    private int handle;

    public fn init() {
        this.handle = SharedMutex_new();
    }

    public fn sharedLock(): void {
        SharedMutex_sharedLock(this.handle);
    }

    public fn sharedUnlock(): void {
        SharedMutex_sharedUnlock(this.handle);
    }

    public fn uniqueLock(): void {
        SharedMutex_uniqueLock(this.handle);
    }

    public fn uniqueUnlock(): void {
        SharedMutex_uniqueUnlock(this.handle);
    }

    public fn trySharedLock(): bool {
        return SharedMutex_trySharedLock(this.handle);
    }

    public fn tryUniqueLock(): bool {
        return SharedMutex_tryUniqueLock(this.handle);
    }
}
