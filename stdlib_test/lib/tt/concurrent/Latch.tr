// Latch synchronization primitive (one-shot countdown).
import tt::concurrent::AtomicInt;
import tt::concurrent::Mutex;
import tt::concurrent::ConditionVariable;

public class Latch {
    private AtomicInt count;
    private Mutex mutex;
    private ConditionVariable cv;

    public fn init(count: int) {
        this.count = new AtomicInt(count);
        this.mutex = new Mutex();
        this.cv = new ConditionVariable();
    }

    public fn countDown(): void {
        let current: int = this.count.get();
        if (current > 0) {
            this.count.fetchSub(1);
            if (this.count.get() == 0) {
                this.mutex.lock();
                this.cv.notifyAll();
                this.mutex.unlock();
            }
        }
    }

    public fn wait(): void {
        while (this.count.get() > 0) {
            this.mutex.lock();
            if (this.count.get() > 0) {
                this.cv.wait(this.mutex);
            }
            this.mutex.unlock();
        }
    }

    public fn tryWait(): bool {
        return this.count.get() == 0;
    }

    public fn count(): int {
        return this.count.get();
    }
}
