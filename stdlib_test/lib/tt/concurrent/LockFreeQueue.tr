// Lock-free data structures for low-latency concurrent access.
// Since Titrate doesn't have true atomic operations yet, these are implemented
// as logical structures that describe lock-free algorithms using a simple
// array-based ring buffer approach.
import tt::util::ArrayList;
import tt::lang::Integer;
import tt::lang::Double;
import tt::lang::Variant;

// Single-Producer Single-Consumer ring buffer.
// Optimal for pipelines where exactly one thread produces and one consumes.
public class SPSCRingBuffer {
    public int capacity;
    public ArrayList<Variant> buffer;
    public int head;
    public int tail;

    public fn init(capacity: int) {
        // Round up to next power of 2 for efficient modulo via bitmask
        var cap: int = 1;
        while (cap < capacity) {
            cap = cap * 2;
        }
        if (cap < 2) {
            cap = 2;
        }
        this.capacity = cap;
        this.buffer = new ArrayList<Variant>();
        var i: int = 0;
        while (i < cap) {
            this.buffer.add(null);
            i = i + 1;
        }
        this.head = 0;
        this.tail = 0;
    }

    // Try to push a value. Returns false if the buffer is full.
    public fn push(value: Variant): bool {
        if (this.isFull()) {
            return false;
        }
        this.buffer.set(this.tail, value);
        this.tail = (this.tail + 1) % this.capacity;
        return true;
    }

    // Try to pop a value. Returns null if the buffer is empty.
    public fn pop(): Variant {
        if (this.isEmpty()) {
            return null;
        }
        let value: Variant = this.buffer.get(this.head);
        this.buffer.set(this.head, null);
        this.head = (this.head + 1) % this.capacity;
        return value;
    }

    public fn isEmpty(): bool {
        return this.head == this.tail;
    }

    public fn isFull(): bool {
        return (this.tail + 1) % this.capacity == this.head;
    }

    public fn size(): int {
        let diff: int = this.tail - this.head;
        if (diff < 0) {
            return diff + this.capacity;
        }
        return diff;
    }

    public fn toString(): string {
        return "SPSCRingBuffer(capacity=" + Integer.toString(this.capacity) + ", size=" + Integer.toString(this.size()) + ")";
    }
}

// Multi-Producer Single-Consumer ring buffer.
// Multiple producers can push, but only one consumer pops.
// Uses simple CAS-like logic (sequential in Titrate).
public class MPSCRingBuffer {
    public int capacity;
    public ArrayList<Variant> buffer;
    public int head;
    public int tail;

    public fn init(capacity: int) {
        var cap: int = 1;
        while (cap < capacity) {
            cap = cap * 2;
        }
        if (cap < 2) {
            cap = 2;
        }
        this.capacity = cap;
        this.buffer = new ArrayList<Variant>();
        var i: int = 0;
        while (i < cap) {
            this.buffer.add(null);
            i = i + 1;
        }
        this.head = 0;
        this.tail = 0;
    }

    // Try to push a value. Uses CAS-like logic to reserve a slot.
    // In Titrate (no true atomics), this is sequential but models the algorithm.
    public fn push(value: Variant): bool {
        if (this.isFull()) {
            return false;
        }
        // CAS-like: reserve slot at tail, then write
        let slot: int = this.tail;
        this.tail = (this.tail + 1) % this.capacity;
        this.buffer.set(slot, value);
        return true;
    }

    // Try to pop a value. Returns null if the buffer is empty.
    public fn pop(): Variant {
        if (this.isEmpty()) {
            return null;
        }
        let value: Variant = this.buffer.get(this.head);
        this.buffer.set(this.head, null);
        this.head = (this.head + 1) % this.capacity;
        return value;
    }

    public fn isEmpty(): bool {
        return this.head == this.tail;
    }

    public fn isFull(): bool {
        return (this.tail + 1) % this.capacity == this.head;
    }

    public fn size(): int {
        let diff: int = this.tail - this.head;
        if (diff < 0) {
            return diff + this.capacity;
        }
        return diff;
    }

    public fn toString(): string {
        return "MPSCRingBuffer(capacity=" + Integer.toString(this.capacity) + ", size=" + Integer.toString(this.size()) + ")";
    }
}

// Lock-free stack (Treiber stack).
// Uses a simple array-backed approach since Titrate lacks true atomics.
// Models the Treiber CAS-based push/pop algorithm.
public class LockFreeStack {
    public ArrayList<Variant> items;
    public int top;

    public fn init() {
        this.items = new ArrayList<Variant>();
        this.top = 0;
    }

    // Push a value onto the stack.
    // Models Treiber push: CAS(top, oldTop, oldTop + 1) then write.
    public fn push(value: Variant): void {
        this.items.add(value);
        this.top = this.top + 1;
    }

    // Pop a value from the stack. Returns null if empty.
    // Models Treiber pop: read top, CAS(top, oldTop, oldTop - 1) then read.
    public fn pop(): Variant {
        if (this.isEmpty()) {
            return null;
        }
        this.top = this.top - 1;
        let value: Variant = this.items.get(this.top);
        this.items.removeAt(this.top);
        return value;
    }

    // Peek at the top value without removing it. Returns null if empty.
    public fn peek(): Variant {
        if (this.isEmpty()) {
            return null;
        }
        return this.items.get(this.top - 1);
    }

    public fn isEmpty(): bool {
        return this.top == 0;
    }

    public fn size(): int {
        return this.top;
    }

    public fn toString(): string {
        return "LockFreeStack(size=" + Integer.toString(this.size()) + ")";
    }
}

// Factory function: create an SPSCRingBuffer with the given capacity.
public fn spscRingBuffer(capacity: int): SPSCRingBuffer {
    return new SPSCRingBuffer(capacity);
}

// Factory function: create an MPSCRingBuffer with the given capacity.
public fn mpscRingBuffer(capacity: int): MPSCRingBuffer {
    return new MPSCRingBuffer(capacity);
}

// Factory function: create a LockFreeStack.
public fn lockFreeStack(): LockFreeStack {
    return new LockFreeStack();
}
