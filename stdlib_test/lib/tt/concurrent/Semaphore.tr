// Counting semaphore.
public class Semaphore {
    private int handle;

    public fn init(permits: int) {
        this.handle = Semaphore_new(permits);
    }

    public fn acquire(): void {
        Semaphore_acquire(this.handle);
    }

    public fn release(): void {
        Semaphore_release(this.handle);
    }

    public fn tryAcquire(): bool {
        return Semaphore_tryAcquire(this.handle);
    }

    public fn availablePermits(): int {
        return Semaphore_availablePermits(this.handle);
    }
}
