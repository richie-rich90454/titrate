// Generic Set collection backed by ArrayList.
import tt::lang::Iterable;
import tt::util::ArrayListIterator;

public class Set<E> implements Iterable<E> {
    private ArrayList<E> data;

    public fn Set() {
        this.data = new ArrayList<E>();
    }

    public fn add(item: E): void {
        if (!this.contains(item)) {
            this.data.add(item);
        }
    }

    public fn remove(item: E): bool {
        let idx: int = this.indexOf(item);
        if (idx >= 0) {
            this.data.remove(idx);
            return true;
        }
        return false;
    }

    public fn contains(item: E): bool {
        for (elem in this.data) {
            if (elem == item) {
                return true;
            }
        }
        return false;
    }

    public fn indexOf(item: E): int {
        let i: int = 0;
        while (i < this.data.size()) {
            if (this.data.get(i) == item) {
                return i;
            }
            i = i + 1;
        }
        return -1;
    }

    public fn size(): int {
        return this.data.size();
    }

    public fn isEmpty(): bool {
        return this.data.size() == 0;
    }

    public fn toArray(): ArrayList<E> {
        return this.data;
    }

    public fn union(other: Set<E>): Set<E> {
        let result: Set<E> = new Set<E>();
        for (elem in this.data) {
            result.add(elem);
        }
        for (elem in other.data) {
            result.add(elem);
        }
        return result;
    }

    public fn intersection(other: Set<E>): Set<E> {
        let result: Set<E> = new Set<E>();
        for (elem in this.data) {
            if (other.contains(elem)) {
                result.add(elem);
            }
        }
        return result;
    }

    public fn difference(other: Set<E>): Set<E> {
        let result: Set<E> = new Set<E>();
        for (elem in this.data) {
            if (!other.contains(elem)) {
                result.add(elem);
            }
        }
        return result;
    }

    public fn iterator(): ArrayListIterator<E> {
        return new ArrayListIterator<E>(this.data);
    }

    public fn isSubsetOf(other: Set<E>): bool {
        for (elem in this.data) {
            if (!other.contains(elem)) {
                return false;
            }
        }
        return true;
    }

    public fn isSupersetOf(other: Set<E>): bool {
        return other.isSubsetOf(this);
    }

    public fn toString(): string {
        let s: string = "{";
        let i: int = 0;
        while (i < this.data.size()) {
            if (i > 0) { s = s + ", "; }
            s = s + this.data.get(i);
            i = i + 1;
        }
        s = s + "}";
        return s;
    }

    public fn symmetricDifference(other: Set<E>): Set<E> {
        let result: Set<E> = new Set<E>();
        for (elem in this.data) {
            if (!other.contains(elem)) {
                result.add(elem);
            }
        }
        for (elem in other.data) {
            if (!this.contains(elem)) {
                result.add(elem);
            }
        }
        return result;
    }

    public fn clear(): void {
        this.data = new ArrayList<E>();
    }

    public fn equals(other: Set<E>): bool {
        if (this.size() != other.size()) {
            return false;
        }
        for (elem in this.data) {
            if (!other.contains(elem)) {
                return false;
            }
        }
        return true;
    }

    public fn map(fn: fn(E): E): Set<E> {
        let result: Set<E> = new Set<E>();
        for (elem in this.data) {
            result.add(fn(elem));
        }
        return result;
    }

    public fn filter(fn: fn(E): bool): Set<E> {
        let result: Set<E> = new Set<E>();
        for (elem in this.data) {
            if (fn(elem)) {
                result.add(elem);
            }
        }
        return result;
    }
}
