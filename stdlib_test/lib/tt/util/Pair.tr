public class Pair<F, S> {
    public F first;
    public S second;

    public fn init(first: F, second: S) {
        this.first = first;
        this.second = second;
    }

    public fn toString(): string {
        return "(" + (this.first as string) + ", " + (this.second as string) + ")";
    }

    public fn equals(other: Pair<F, S>): bool {
        return this.first == other.first && this.second == other.second;
    }

    public fn swap(): Pair<S, F> {
        return new Pair<S, F>(this.second, this.first);
    }
}

public fn makePair<F, S>(first: F, second: S): Pair<F, S> {
    return new Pair<F, S>(first, second);
}
