import tt::util::ArrayList;
import tt::util::HashMap;
import tt::util::Pair;

// GraphUtil: adjacency-list graph with optional edge weights.
public class GraphUtil {
    public HashMap<string, ArrayList<string>> adjacency;
    public HashMap<string, double> weights;
    public bool directed;

    public fn init(directed: bool) {
        this.adjacency = new HashMap<string, ArrayList<string>>();
        this.weights = new HashMap<string, double>();
        this.directed = directed;
    }

    // Add a vertex to the graph.
    public fn addVertex(v: string): void {
        if (!this.adjacency.containsKey(v)) {
            this.adjacency.put(v, new ArrayList<string>());
        }
    }

    // Add an edge from u to v with optional weight.
    public fn addEdge(u: string, v: string, weight: double): void {
        this.addVertex(u);
        this.addVertex(v);
        let neighbors: ArrayList<string> = this.adjacency.get(u);
        // Avoid duplicate edges
        var found: bool = false;
        var i: int = 0;
        while (i < neighbors.size()) {
            if (neighbors.get(i) == v) {
                found = true;
            }
            i = i + 1;
        }
        if (!found) {
            neighbors.add(v);
        }
        this.weights.put(u + "->" + v, weight);
        if (!this.directed) {
            let reverseNeighbors: ArrayList<string> = this.adjacency.get(v);
            found = false;
            i = 0;
            while (i < reverseNeighbors.size()) {
                if (reverseNeighbors.get(i) == u) {
                    found = true;
                }
                i = i + 1;
            }
            if (!found) {
                reverseNeighbors.add(u);
            }
            this.weights.put(v + "->" + u, weight);
        }
    }

    // Remove a vertex and all its edges.
    public fn removeVertex(v: string): void {
        if (!this.adjacency.containsKey(v)) { return; }
        // Remove v from all neighbor lists
        let keys: ArrayList<string> = this.adjacency.keys();
        var i: int = 0;
        while (i < keys.size()) {
            let key: string = keys.get(i);
            if (key != v) {
                let neighbors: ArrayList<string> = this.adjacency.get(key);
                var j: int = neighbors.size() - 1;
                while (j >= 0) {
                    if (neighbors.get(j) == v) {
                        neighbors.remove(j);
                    }
                    j = j - 1;
                }
                this.weights.remove(key + "->" + v);
                if (!this.directed) {
                    this.weights.remove(v + "->" + key);
                }
            }
            i = i + 1;
        }
        this.adjacency.remove(v);
    }

    // Remove an edge from u to v.
    public fn removeEdge(u: string, v: string): void {
        if (this.adjacency.containsKey(u)) {
            let neighbors: ArrayList<string> = this.adjacency.get(u);
            var i: int = neighbors.size() - 1;
            while (i >= 0) {
                if (neighbors.get(i) == v) {
                    neighbors.remove(i);
                }
                i = i - 1;
            }
        }
        this.weights.remove(u + "->" + v);
        if (!this.directed) {
            if (this.adjacency.containsKey(v)) {
                let neighbors: ArrayList<string> = this.adjacency.get(v);
                var i: int = neighbors.size() - 1;
                while (i >= 0) {
                    if (neighbors.get(i) == u) {
                        neighbors.remove(i);
                    }
                    i = i - 1;
                }
            }
            this.weights.remove(v + "->" + u);
        }
    }

    // Get the neighbors of a vertex.
    public fn neighbors(v: string): ArrayList<string> {
        if (!this.adjacency.containsKey(v)) {
            return new ArrayList<string>();
        }
        return this.adjacency.get(v);
    }

    // Get the degree of a vertex.
    public fn degree(v: string): int {
        if (!this.adjacency.containsKey(v)) { return 0; }
        return this.adjacency.get(v).size();
    }

    // Check if a vertex exists.
    public fn hasVertex(v: string): bool {
        return this.adjacency.containsKey(v);
    }

    // Check if an edge exists from u to v.
    public fn hasEdge(u: string, v: string): bool {
        if (!this.adjacency.containsKey(u)) { return false; }
        let neighbors: ArrayList<string> = this.adjacency.get(u);
        var i: int = 0;
        while (i < neighbors.size()) {
            if (neighbors.get(i) == v) { return true; }
            i = i + 1;
        }
        return false;
    }

    // Number of vertices.
    public fn vertexCount(): int {
        return this.adjacency.size();
    }

    // Number of edges.
    public fn edgeCount(): int {
        var total: int = 0;
        let keys: ArrayList<string> = this.adjacency.keys();
        var i: int = 0;
        while (i < keys.size()) {
            total = total + this.adjacency.get(keys.get(i)).size();
            i = i + 1;
        }
        if (!this.directed) {
            total = total / 2;
        }
        return total;
    }

    // Find the shortest path from one vertex to another using BFS.
    public fn shortestPath(g: GraphUtil, from: string, to: string): ArrayList<string> {
        if (!g.adjacency.containsKey(from) || !g.adjacency.containsKey(to)) {
            return new ArrayList<string>();
        }
        if (from == to) {
            let result: ArrayList<string> = new ArrayList<string>();
            result.add(from);
            return result;
        }
        let visited: HashMap<string, bool> = new HashMap<string, bool>();
        let parent: HashMap<string, string> = new HashMap<string, string>();
        let queue: ArrayList<string> = new ArrayList<string>();
        visited.put(from, true);
        queue.add(from);
        while (queue.size() > 0) {
            let current: string = queue.get(0);
            queue.remove(0);
            if (current == to) {
                // Reconstruct path
                let path: ArrayList<string> = new ArrayList<string>();
                var node: string = to;
                while (node != null) {
                    path.add(0, node);
                    if (parent.containsKey(node)) {
                        node = parent.get(node);
                    } else {
                        node = null;
                    }
                }
                return path;
            }
            let neighbors: ArrayList<string> = g.adjacency.get(current);
            var i: int = 0;
            while (i < neighbors.size()) {
                let neighbor: string = neighbors.get(i);
                if (!visited.containsKey(neighbor)) {
                    visited.put(neighbor, true);
                    parent.put(neighbor, current);
                    queue.add(neighbor);
                }
                i = i + 1;
            }
        }
        return new ArrayList<string>();
    }

    // Get all vertices.
    public fn vertices(): ArrayList<string> {
        return this.adjacency.keys();
    }

    // Get all edges as pairs.
    public fn edges(): ArrayList<Pair<string, string>> {
        let result: ArrayList<Pair<string, string>> = new ArrayList<Pair<string, string>>();
        let keys: ArrayList<string> = this.adjacency.keys();
        var i: int = 0;
        while (i < keys.size()) {
            let u: string = keys.get(i);
            let neighbors: ArrayList<string> = this.adjacency.get(u);
            var j: int = 0;
            while (j < neighbors.size()) {
                let v: string = neighbors.get(j);
                if (this.directed) {
                    result.add(new Pair<string, string>(u, v));
                } else {
                    // For undirected, only add each edge once (u < v lexicographically)
                    if (String.compareTo(u, v) < 0) {
                        result.add(new Pair<string, string>(u, v));
                    }
                }
                j = j + 1;
            }
            i = i + 1;
        }
        return result;
    }
}
