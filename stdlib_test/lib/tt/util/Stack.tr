// LIFO stack backed by ArrayList.
import tt::util::ArrayList;
import tt::util::ArrayListIterator;

public class Stack<E> {
    private ArrayList<E> data;

    public fn Stack() {
        this.data = new ArrayList<E>();
    }

    public fn push(element: E): void {
        this.data.add(element);
    }

    public fn pop(): E {
        let last: int = this.data.size() - 1;
        let item: E = this.data.get(last);
        this.data.remove(last);
        return item;
    }

    public fn peek(): E {
        return this.data.get(this.data.size() - 1);
    }

    public fn isEmpty(): bool {
        return this.data.size() == 0;
    }

    public fn size(): int {
        return this.data.size();
    }

    public fn toArray(): ArrayList<E> {
        let result: ArrayList<E> = new ArrayList<E>();
        let i: int = 0;
        while (i < this.data.size()) {
            result.add(this.data.get(i));
            i = i + 1;
        }
        return result;
    }

    public fn contains(element: E): bool {
        for (item in this.data) {
            if (item == element) {
                return true;
            }
        }
        return false;
    }

    public fn search(value: E): int {
        let i: int = this.data.size() - 1;
        while (i >= 0) {
            if (this.data.get(i) == value) {
                return this.data.size() - i;
            }
            i = i - 1;
        }
        return -1;
    }

    public fn clear(): void {
        this.data = new ArrayList<E>();
    }

    public fn iterator(): ArrayListIterator<E> {
        return new ArrayListIterator<E>(this.data);
    }

    public fn toString(): string {
        let s: string = "[";
        let i: int = 0;
        while (i < this.data.size()) {
            if (i > 0) { s = s + ", "; }
            s = s + this.data.get(i);
            i = i + 1;
        }
        s = s + "]";
        return s;
    }
}
