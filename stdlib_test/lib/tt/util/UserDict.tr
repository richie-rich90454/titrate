import tt::util::ArrayList;
import tt::util::HashMap;
import tt::lang::Variant;

// UserDict: a wrapper around HashMap that is easier to subclass.
// Users can override methods to customize dict-like behavior.
public class UserDict {
    public HashMap<string, Variant> data;

    public fn init() {
        this.data = new HashMap<string, Variant>();
    }

    // Construct from an existing HashMap.
    public fn initFromMap(map: HashMap<string, Variant>) {
        this.data = map;
    }

    // Return the value for key, or null if not present.
    public fn get(key: string): Variant {
        if (this.data.containsKey(key)) {
            return this.data.get(key);
        }
        return null;
    }

    // Set a key-value pair.
    public fn set(key: string, value: Variant): void {
        this.data.put(key, value);
    }

    // Remove a key. Returns true if the key was present.
    public fn remove(key: string): bool {
        if (this.data.containsKey(key)) {
            this.data.remove(key);
            return true;
        }
        return false;
    }

    // Check if key is present.
    public fn contains(key: string): bool {
        return this.data.containsKey(key);
    }

    // Return all keys.
    public fn keys(): ArrayList<string> {
        return this.data.keys();
    }

    // Return all values.
    public fn values(): ArrayList<Variant> {
        return this.data.values();
    }

    // Number of items.
    public fn size(): int {
        return this.data.size();
    }

    // Check if empty.
    public fn isEmpty(): bool {
        return this.data.isEmpty();
    }

    // Remove all items.
    public fn clear(): void {
        this.data.clear();
    }

    // Update from another UserDict.
    public fn update(other: UserDict): void {
        let keys: ArrayList<string> = other.keys();
        var i: int = 0;
        while (i < keys.size()) {
            let key: string = keys.get(i);
            this.data.put(key, other.get(key));
            i = i + 1;
        }
    }

    // Return a shallow copy.
    public fn copy(): UserDict {
        let result: UserDict = new UserDict();
        let keys: ArrayList<string> = this.keys();
        var i: int = 0;
        while (i < keys.size()) {
            let key: string = keys.get(i);
            result.data.put(key, this.data.get(key));
            i = i + 1;
        }
        return result;
    }

    // Get value for key, or default if not present.
    public fn getOrDefault(key: string, defaultValue: Variant): Variant {
        if (this.data.containsKey(key)) {
            return this.data.get(key);
        }
        return defaultValue;
    }

    // Set default: if key is absent, set it to defaultValue and return it.
    public fn setDefault(key: string, defaultValue: Variant): Variant {
        if (this.data.containsKey(key)) {
            return this.data.get(key);
        }
        this.data.put(key, defaultValue);
        return defaultValue;
    }
}
