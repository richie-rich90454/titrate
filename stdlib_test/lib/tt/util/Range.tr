// Range class for lazy integer sequences.
import tt::util::ArrayList;

// Range represents an immutable sequence of integers from start to stop (exclusive) by step.
public class Range {
    public int start;
    public int stop;
    public int step;

    public fn init(start: int, stop: int, step: int) {
        this.start = start;
        this.stop = stop;
        this.step = step;
    }

    // Returns an iterator over the range.
    public fn iterator(): RangeIterator {
        return new RangeIterator(this.start, this.stop, this.step);
    }

    // Returns true if the value is contained in this range.
    public fn contains(value: int): bool {
        if (this.step > 0) {
            if (value < this.start || value >= this.stop) {
                return false;
            }
            return (value - this.start) % this.step == 0;
        } else if (this.step < 0) {
            if (value > this.start || value <= this.stop) {
                return false;
            }
            return (this.start - value) % (0 - this.step) == 0;
        }
        return false;
    }

    // Returns the number of elements in the range.
    public fn size(): int {
        if (this.step > 0) {
            if (this.start >= this.stop) { return 0; }
            return (this.stop - this.start - 1) / this.step + 1;
        } else if (this.step < 0) {
            if (this.start <= this.stop) { return 0; }
            return (this.start - this.stop - 1) / (0 - this.step) + 1;
        }
        return 0;
    }

    // Returns true if the range contains no elements.
    public fn isEmpty(): bool {
        return this.size() == 0;
    }

    // Returns the element at the given index within the range.
    public fn get(index: int): int {
        return this.start + index * this.step;
    }

    // Convert the range to an ArrayList.
    public fn toArrayList(): ArrayList<int> {
        let result: ArrayList<int> = new ArrayList<int>();
        let iter: RangeIterator = this.iterator();
        while (iter.hasNext()) {
            result.add(iter.next());
        }
        return result;
    }

    // Returns a string representation of this range.
    public fn toString(): string {
        if (this.step == 1) {
            return "Range(" + (this.start as string) + ", " + (this.stop as string) + ")";
        }
        return "Range(" + (this.start as string) + ", " + (this.stop as string) + ", " + (this.step as string) + ")";
    }
}

// RangeIterator walks through a Range one element at a time.
public class RangeIterator {
    private int _current;
    private int _stop;
    private int _step;

    public fn init(start: int, stop: int, step: int) {
        this._current = start;
        this._stop = stop;
        this._step = step;
    }

    public fn hasNext(): bool {
        if (this._step > 0) {
            return this._current < this._stop;
        } else if (this._step < 0) {
            return this._current > this._stop;
        }
        return false;
    }

    public fn next(): int {
        let val: int = this._current;
        this._current = this._current + this._step;
        return val;
    }
}

// Factory functions for convenient range creation.
public fn range(stop: int): Range {
    return new Range(0, stop, 1);
}

public fn rangeWithStart(start: int, stop: int): Range {
    return new Range(start, stop, 1);
}

public fn rangeWithStep(start: int, stop: int, step: int): Range {
    return new Range(start, stop, step);
}
