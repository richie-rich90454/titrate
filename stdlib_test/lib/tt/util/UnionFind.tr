import tt::util::ArrayList;
import tt::lang::Integer;

public class UnionFind {
    public ArrayList<int> parent;
    public ArrayList<int> rank;
    public int count;

    public fn init(n: int) {
        this.parent = new ArrayList<int>();
        this.rank = new ArrayList<int>();
        this.count = n;
        var i: int = 0;
        while (i < n) {
            this.parent.add(i);
            this.rank.add(0);
            i = i + 1;
        }
    }

    public fn find(x: int): int {
        if (this.parent.get(x) != x) {
            this.parent.set(x, this.find(this.parent.get(x)));
        }
        return this.parent.get(x);
    }

    public fn union(x: int, y: int): void {
        let rootX: int = this.find(x);
        let rootY: int = this.find(y);
        if (rootX == rootY) {
            return;
        }
        if (this.rank.get(rootX) < this.rank.get(rootY)) {
            this.parent.set(rootX, rootY);
        } else if (this.rank.get(rootX) > this.rank.get(rootY)) {
            this.parent.set(rootY, rootX);
        } else {
            this.parent.set(rootY, rootX);
            this.rank.set(rootX, this.rank.get(rootX) + 1);
        }
        this.count = this.count - 1;
    }

    public fn connected(x: int, y: int): bool {
        return this.find(x) == this.find(y);
    }

    public fn componentSize(x: int): int {
        let root: int = this.find(x);
        var size: int = 0;
        var i: int = 0;
        while (i < this.parent.size()) {
            if (this.find(i) == root) {
                size = size + 1;
            }
            i = i + 1;
        }
        return size;
    }

    public fn componentCount(): int {
        return this.count;
    }

    public fn setSize(x: int): int {
        return this.componentSize(x);
    }

    public fn reset(): void {
        var i: int = 0;
        while (i < this.parent.size()) {
            this.parent.set(i, i);
            this.rank.set(i, 0);
            i = i + 1;
        }
        this.count = this.parent.size();
    }

    public fn toString(): string {
        return "UnionFind(count=" + Integer.toString(this.count) + ")";
    }
}
