// FixParser.tr — FIX protocol message parser and builder
import tt::lang::DataFile;
import tt::json::JsonValue;
import tt::util::HashMap;
import tt::util::ArrayList;
import tt::lang::String;
import tt::lang::Integer;

var _fixCache: HashMap<string, JsonValue> = new HashMap<string, JsonValue>();
var _fixLoaded: bool = false;

fn _ensureFixLoaded(): void {
    if (_fixLoaded) { return; }
    let data: JsonValue = DataFile.load("hft/fix_dictionary.json");
    if (!data.isNull()) { _fixCache.put("root", data); }
    _fixLoaded = true;
}

public class FixMessage {
    public HashMap<string, string> fields;

    public fn init() {
        this.fields = new HashMap<string, string>();
    }

    public fn setField(tag: string, value: string): void {
        this.fields.put(tag, value);
    }

    public fn getField(tag: string): string {
        if (this.fields.containsKey(tag)) { return this.fields.get(tag); }
        return "";
    }

    public fn msgType(): string {
        return this.getField("35");
    }

    public fn senderCompId(): string {
        return this.getField("49");
    }

    public fn targetCompId(): string {
        return this.getField("56");
    }

    public fn checksum(): string {
        return this.getField("10");
    }
}

public fn parseFixMessage(raw: string): FixMessage {
    let msg: FixMessage = new FixMessage();
    let fields: ArrayList<string> = String.split(raw, "\x01");
    var i: int = 0;
    while (i < fields.size()) {
        let field: string = fields.get(i);
        let eqIdx: int = String.indexOf(field, "=");
        if (eqIdx > 0) {
            let tag: string = String.substring(field, 0, eqIdx);
            let value: string = String.substring(field, eqIdx + 1, String.length(field));
            msg.setField(tag, value);
        }
        i = i + 1;
    }
    return msg;
}

public fn buildFixMessage(msg: FixMessage): string {
    let result: string = "";
    let tags: ArrayList<string> = msg.fields.keys();
    // Sort tags numerically
    var i: int = 0;
    while (i < tags.size()) {
        var j: int = i + 1;
        while (j < tags.size()) {
            if (Integer.parseInt(tags.get(i)) > Integer.parseInt(tags.get(j))) {
                let tmp: string = tags.get(i);
                tags.set(i, tags.get(j));
                tags.set(j, tmp);
            }
            j = j + 1;
        }
        i = i + 1;
    }
    // Compute checksum
    var checksum: int = 0;
    i = 0;
    while (i < tags.size()) {
        let tag: string = tags.get(i);
        if (tag != "10") {
            let field: string = tag + "=" + msg.fields.get(tag) + "\x01";
            result = result + field;
            var k: int = 0;
            while (k < String.length(field)) {
                checksum = checksum + String.charAt(field, k) as int;
                k = k + 1;
            }
        }
        i = i + 1;
    }
    checksum = checksum % 256;
    let cs: string = Integer.toString(checksum);
    if (checksum < 10) { cs = "00" + cs; }
    else { if (checksum < 100) { cs = "0" + cs; } }
    result = result + "10=" + cs + "\x01";
    return result;
}

public fn getFieldName(tag: string): string {
    _ensureFixLoaded();
    let root: JsonValue = _fixCache.get("root");
    if (root.isNull()) { return ""; }
    let fields: JsonValue = root.get("fields");
    if (fields.isNull()) { return ""; }
    if (fields.hasKey(tag)) {
        let field: JsonValue = fields.get(tag);
        if (field.hasKey("name")) { return field.get("name").asString(); }
    }
    return "";
}

// Compute FIX checksum for a raw message string
public fn checksum(msg: string): string {
    var sum: int = 0;
    var i: int = 0;
    while (i < String.length(msg)) {
        sum = sum + String.charAt(msg, i) as int;
        i = i + 1;
    }
    sum = sum % 256;
    let cs: string = Integer.toString(sum);
    if (sum < 10) { cs = "00" + cs; }
    else { if (sum < 100) { cs = "0" + cs; } }
    return cs;
}
