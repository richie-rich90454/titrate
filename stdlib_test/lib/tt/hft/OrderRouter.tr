// OrderRouter.tr — Smart order routing and order management
import tt::util::ArrayList;
import tt::util::HashMap;
import tt::lang::String;

public class Order {
    public string id;
    public string symbol;
    public string side;
    public double price;
    public double quantity;
    public double filledQty;
    public string status;
    public string venue;

    public fn init(id: string, sym: string, s: string, p: double, q: double) {
        this.id = id;
        this.symbol = sym;
        this.side = s;
        this.price = p;
        this.quantity = q;
        this.filledQty = 0.0;
        this.status = "new";
        this.venue = "";
    }
}

public class Venue {
    public string name;
    public double fee;
    public double latency;
    public HashMap<string, double> bids;
    public HashMap<string, double> asks;

    public fn init(n: string, f: double, l: double) {
        this.name = n;
        this.fee = f;
        this.latency = l;
        this.bids = new HashMap<string, double>();
        this.asks = new HashMap<string, double>();
    }
}

public class OrderRouter {
    public ArrayList<Venue> venues;
    public HashMap<string, Order> orders;
    public int nextOrderId;

    public fn init() {
        this.venues = new ArrayList<Venue>();
        this.orders = new HashMap<string, Order>();
        this.nextOrderId = 1;
    }

    public fn addVenue(venue: Venue): void {
        this.venues.add(venue);
    }

    public fn routeOrder(symbol: string, side: string, qty: double): Order {
        let id: string = Integer.toString(this.nextOrderId);
        this.nextOrderId = this.nextOrderId + 1;
        // Find best venue
        var bestVenue: string = "";
        var bestPrice: double = 0.0;
        var i: int = 0;
        while (i < this.venues.size()) {
            let v: Venue = this.venues.get(i);
            if (side == "buy" && v.asks.containsKey(symbol)) {
                let price: double = v.asks.get(symbol);
                if (bestVenue == "" || price < bestPrice) {
                    bestPrice = price;
                    bestVenue = v.name;
                }
            } else {
                if (side == "sell" && v.bids.containsKey(symbol)) {
                    let price: double = v.bids.get(symbol);
                    if (bestVenue == "" || price > bestPrice) {
                        bestPrice = price;
                        bestVenue = v.name;
                    }
                }
            }
            i = i + 1;
        }
        let order: Order = new Order(id, symbol, side, bestPrice, qty);
        order.venue = bestVenue;
        order.status = "routed";
        this.orders.put(id, order);
        return order;
    }

    public fn fillOrder(orderId: string, fillQty: double, fillPrice: double): void {
        if (!this.orders.containsKey(orderId)) { return; }
        let order: Order = this.orders.get(orderId);
        order.filledQty = order.filledQty + fillQty;
        if (order.filledQty >= order.quantity) {
            order.status = "filled";
        } else {
            order.status = "partially_filled";
        }
    }

    public fn cancelOrder(orderId: string): void {
        if (this.orders.containsKey(orderId)) {
            this.orders.get(orderId).status = "cancelled";
        }
    }

    // Cancel order with boolean return indicating success
    public fn tryCancelOrder(orderId: string): bool {
        if (this.orders.containsKey(orderId)) {
            let order: Order = this.orders.get(orderId);
            if (order.status != "filled" && order.status != "cancelled") {
                order.status = "cancelled";
                return true;
            }
        }
        return false;
    }
}
