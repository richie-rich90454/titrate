// Tokenizer.tr — Word, sentence, regex tokenizers with stop words
import tt::lang::DataFile;
import tt::json::JsonValue;
import tt::util::HashMap;
import tt::util::ArrayList;
import tt::lang::String;
import tt::regex::Regex;
import tt::regex::Match;

var _stopWordsCache: HashMap<string, JsonValue> = new HashMap<string, JsonValue>();
var _stopWordsLoaded: bool = false;
var _englishStopWords: HashMap<string, bool> = new HashMap<string, bool>();
var _stopWordsBuilt: bool = false;

fn _ensureStopWordsLoaded(): void {
    if (_stopWordsLoaded) { return; }
    let data: JsonValue = DataFile.load("nlp/stop_words.json");
    if (!data.isNull()) { _stopWordsCache.put("root", data); }
    _stopWordsLoaded = true;
}

fn _ensureEnglishStopWords(): void {
    if (_stopWordsBuilt) { return; }
    _ensureStopWordsLoaded();
    let root: JsonValue = _stopWordsCache.get("root");
    if (root.isNull()) { return; }
    let languages: JsonValue = root.get("languages");
    if (languages.isNull()) { return; }
    let en: JsonValue = languages.get("english");
    if (en.isNull()) { return; }
    let words: ArrayList<string> = en.keys();
    var i: int = 0;
    while (i < words.size()) {
        _englishStopWords.put(words.get(i), true);
        i = i + 1;
    }
    _stopWordsBuilt = true;
}

public fn isStopWord(word: string, language: string): bool {
    if (language == "english") {
        _ensureEnglishStopWords();
        return _englishStopWords.containsKey(String.toLowerCase(word));
    }
    return false;
}

public fn wordTokenize(text: string): ArrayList<string> {
    let tokens: ArrayList<string> = new ArrayList<string>();
    let current: string = "";
    var i: int = 0;
    while (i < String.length(text)) {
        let ch: string = String.charAt(text, i);
        if (ch == " " || ch == "\t" || ch == "\n" || ch == "\r") {
            if (String.length(current) > 0) {
                tokens.add(current);
                current = "";
            }
        } else {
            if (ch == "." || ch == "," || ch == "!" || ch == "?" || ch == ";" || ch == ":" || ch == "(" || ch == ")" || ch == "[" || ch == "]" || ch == "'" || ch == "\"") {
                if (String.length(current) > 0) {
                    tokens.add(current);
                    current = "";
                }
                tokens.add(ch);
            } else {
                current = current + ch;
            }
        }
        i = i + 1;
    }
    if (String.length(current) > 0) { tokens.add(current); }
    return tokens;
}

public fn sentenceTokenize(text: string): ArrayList<string> {
    let sentences: ArrayList<string> = new ArrayList<string>();
    let current: string = "";
    var i: int = 0;
    while (i < String.length(text)) {
        let ch: string = String.charAt(text, i);
        current = current + ch;
        if (ch == "." || ch == "!" || ch == "?") {
            if (i + 1 < String.length(text)) {
                let next: string = String.charAt(text, i + 1);
                if (next == " " || next == "\n" || next == "\t") {
                    sentences.add(current);
                    current = "";
                }
            } else {
                sentences.add(current);
                current = "";
            }
        }
        i = i + 1;
    }
    if (String.length(current) > 0) { sentences.add(current); }
    return sentences;
}

public fn removeStopWords(tokens: ArrayList<string>): ArrayList<string> {
    let result: ArrayList<string> = new ArrayList<string>();
    var i: int = 0;
    while (i < tokens.size()) {
        if (!isStopWord(tokens.get(i), "english")) {
            result.add(tokens.get(i));
        }
        i = i + 1;
    }
    return result;
}

// Tokenize text using a regex pattern as delimiter.
public fn regexTokenize(text: string, pattern: string): ArrayList<string> {
    let result: ArrayList<string> = new ArrayList<string>();
    let regex: Regex = new Regex(pattern);
    let parts: ArrayList<string> = regex.split(text);
    var i: int = 0;
    while (i < parts.size()) {
        let token: string = parts.get(i);
        if (String.length(token) > 0) {
            result.add(token);
        }
        i = i + 1;
    }
    return result;
}

// Find all matches of a regex pattern in text.
public fn regexFindAll(text: string, pattern: string): ArrayList<string> {
    let result: ArrayList<string> = new ArrayList<string>();
    let regex: Regex = new Regex(pattern);
    let matches: ArrayList<Match> = regex.findAll(text);
    var i: int = 0;
    while (i < matches.size()) {
        let m: Match = matches.get(i);
        result.add(m.matched);
        i = i + 1;
    }
    return result;
}
