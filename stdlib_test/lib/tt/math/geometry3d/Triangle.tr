// Triangle provides a 3D triangle defined by three vertices with geometric and intersection operations.
import tt::math::vec::Vec3;
import tt::math::MathAdvanced;
import tt::math::Math;
import tt::lang::Double;

public class Triangle {
    public Vec3 v0;
    public Vec3 v1;
    public Vec3 v2;

    public fn init(v0: Vec3, v1: Vec3, v2: Vec3) {
        this.v0 = v0;
        this.v1 = v1;
        this.v2 = v2;
    }

    public fn area(): double {
        let edge1: Vec3 = this.v1.sub(this.v0);
        let edge2: Vec3 = this.v2.sub(this.v0);
        let cross: Vec3 = edge1.cross(edge2);
        return 0.5 * cross.magnitude();
    }

    public fn normal(): Vec3 {
        let edge1: Vec3 = this.v1.sub(this.v0);
        let edge2: Vec3 = this.v2.sub(this.v0);
        return edge1.cross(edge2).normalize();
    }

    public fn centroid(): Vec3 {
        return this.v0.add(this.v1).add(this.v2).scale(1.0 / 3.0);
    }

    public fn barycentric(point: Vec3): Vec3 {
        let v0: Vec3 = this.v1.sub(this.v0);
        let v1: Vec3 = this.v2.sub(this.v0);
        let v2: Vec3 = point.sub(this.v0);
        let d00: double = v0.dot(v0);
        let d01: double = v0.dot(v1);
        let d11: double = v1.dot(v1);
        let d20: double = v2.dot(v0);
        let d21: double = v2.dot(v1);
        let denom: double = d00 * d11 - d01 * d01;
        if (Math.fabs(denom) < 1e-20) {
            return new Vec3(0.0, 0.0, 0.0);
        }
        let invDenom: double = 1.0 / denom;
        let v: double = (d11 * d20 - d01 * d21) * invDenom;
        let w: double = (d00 * d21 - d01 * d20) * invDenom;
        let u: double = 1.0 - v - w;
        return new Vec3(u, v, w);
    }

    public fn contains(point: Vec3): bool {
        let bary: Vec3 = this.barycentric(point);
        return bary.x >= -1e-10 && bary.y >= -1e-10 && bary.z >= -1e-10;
    }

    public fn intersectsRay(origin: Vec3, direction: Vec3): bool {
        let t: double = this.intersectsRayRange(origin, direction);
        return t >= 0.0;
    }

    public fn intersectsRayRange(origin: Vec3, direction: Vec3): double {
        let edge1: Vec3 = this.v1.sub(this.v0);
        let edge2: Vec3 = this.v2.sub(this.v0);
        let h: Vec3 = direction.cross(edge2);
        let a: double = edge1.dot(h);
        if (Math.fabs(a) < 1e-12) {
            return -1.0;
        }
        let f: double = 1.0 / a;
        let s: Vec3 = origin.sub(this.v0);
        let u: double = f * s.dot(h);
        if (u < 0.0 || u > 1.0) {
            return -1.0;
        }
        let q: Vec3 = s.cross(edge1);
        let v: double = f * direction.dot(q);
        if (v < 0.0 || u + v > 1.0) {
            return -1.0;
        }
        let t: double = f * edge2.dot(q);
        if (t > 1e-10) {
            return t;
        }
        return -1.0;
    }

    public fn equals(other: Triangle): bool {
        return this.v0.equals(other.v0) && this.v1.equals(other.v1) && this.v2.equals(other.v2);
    }

    public fn toString(): string {
        return "Triangle(" + this.v0.toString() + ", " + this.v1.toString() + ", " + this.v2.toString() + ")";
    }
}
