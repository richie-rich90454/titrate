// IntervalArithmetic provides rigorous interval arithmetic for bounding numerical errors.
import tt::math::Math;
import tt::math::MathAdvanced;
import tt::math::MathTrig;
import tt::lang::Double;

public class Interval {
    public double lo;  // lower bound
    public double hi;  // upper bound

    public fn init(lo: double, hi: double) {
        this.lo = lo;
        this.hi = hi;
    }

    // ---- Arithmetic operations (return new Interval with rigorous bounds) ----

    public fn add(other: Interval): Interval {
        return new Interval(this.lo + other.lo, this.hi + other.hi);
    }

    public fn sub(other: Interval): Interval {
        return new Interval(this.lo - other.hi, this.hi - other.lo);
    }

    public fn mul(other: Interval): Interval {
        let p1: double = this.lo * other.lo;
        let p2: double = this.lo * other.hi;
        let p3: double = this.hi * other.lo;
        let p4: double = this.hi * other.hi;
        return new Interval(
            Math.min(Math.min(p1, p2), Math.min(p3, p4)),
            Math.max(Math.max(p1, p2), Math.max(p3, p4))
        );
    }

    // Division by an interval containing zero returns the whole interval [-inf, +inf]
    public fn div(other: Interval): Interval {
        if (other.lo <= 0.0 && other.hi >= 0.0) {
            return wholeInterval();
        }
        let p1: double = this.lo / other.lo;
        let p2: double = this.lo / other.hi;
        let p3: double = this.hi / other.lo;
        let p4: double = this.hi / other.hi;
        return new Interval(
            Math.min(Math.min(p1, p2), Math.min(p3, p4)),
            Math.max(Math.max(p1, p2), Math.max(p3, p4))
        );
    }

    // ---- Unary operations ----

    public fn neg(): Interval {
        return new Interval(-this.hi, -this.lo);
    }

    public fn abs(): Interval {
        if (this.lo >= 0.0) {
            return new Interval(this.lo, this.hi);
        }
        if (this.hi <= 0.0) {
            return new Interval(-this.hi, -this.lo);
        }
        return new Interval(0.0, Math.max(-this.lo, this.hi));
    }

    public fn sqrt(): Interval {
        if (this.hi < 0.0) {
            return new Interval(Math.NAN(), Math.NAN());
        }
        let lo: double = 0.0;
        if (this.lo > 0.0) {
            lo = MathAdvanced.sqrt(this.lo);
        }
        return new Interval(lo, MathAdvanced.sqrt(this.hi));
    }

    public fn exp(): Interval {
        return new Interval(MathAdvanced.exp(this.lo), MathAdvanced.exp(this.hi));
    }

    public fn ln(): Interval {
        if (this.hi <= 0.0) {
            return new Interval(Math.NAN(), Math.NAN());
        }
        let lo: double = 0.0;
        if (this.lo > 0.0) {
            lo = MathAdvanced.ln(this.lo);
        } else {
            lo = -Math.INF();
        }
        return new Interval(lo, MathAdvanced.ln(this.hi));
    }

    // sin over an interval: compute sin(lo) and sin(hi) and check for extrema within
    public fn sin(): Interval {
        let pi: double = Math.PI();
        let twoPi: double = 2.0 * pi;
        let halfPi: double = pi / 2.0;

        if (this.hi - this.lo >= twoPi) {
            return new Interval(-1.0, 1.0);
        }

        let sinLo: double = MathTrig.sin(this.lo);
        let sinHi: double = MathTrig.sin(this.hi);
        var loVal: double = Math.min(sinLo, sinHi);
        var hiVal: double = Math.max(sinLo, sinHi);

        // Check if a maximum (pi/2 + 2k*pi) falls within the interval
        let kMin: int = Math.ceil((this.lo - halfPi) / twoPi) as int;
        let kMax: double = (this.hi - halfPi) / twoPi;
        var k: int = kMin;
        while (k as double <= kMax) {
            let xMax: double = halfPi + k as double * twoPi;
            if (xMax >= this.lo && xMax <= this.hi) {
                hiVal = 1.0;
            }
            k = k + 1;
        }

        // Check if a minimum (3*pi/2 + 2k*pi) falls within the interval
        let jMin: int = Math.ceil((this.lo - 1.5 * pi) / twoPi) as int;
        let jMax: double = (this.hi - 1.5 * pi) / twoPi;
        var j: int = jMin;
        while (j as double <= jMax) {
            let xMin: double = 1.5 * pi + j as double * twoPi;
            if (xMin >= this.lo && xMin <= this.hi) {
                loVal = -1.0;
            }
            j = j + 1;
        }

        return new Interval(loVal, hiVal);
    }

    // cos over an interval: compute cos(lo) and cos(hi) and check for extrema within
    public fn cos(): Interval {
        let pi: double = Math.PI();
        let twoPi: double = 2.0 * pi;

        if (this.hi - this.lo >= twoPi) {
            return new Interval(-1.0, 1.0);
        }

        let cosLo: double = MathTrig.cos(this.lo);
        let cosHi: double = MathTrig.cos(this.hi);
        var loVal: double = Math.min(cosLo, cosHi);
        var hiVal: double = Math.max(cosLo, cosHi);

        // Check if a maximum (2k*pi) falls within the interval
        let kMin: int = Math.ceil(this.lo / twoPi) as int;
        let kMax: double = this.hi / twoPi;
        var k: int = kMin;
        while (k as double <= kMax) {
            let xMax: double = k as double * twoPi;
            if (xMax >= this.lo && xMax <= this.hi) {
                hiVal = 1.0;
            }
            k = k + 1;
        }

        // Check if a minimum (pi + 2k*pi) falls within the interval
        let jMin: int = Math.ceil((this.lo - pi) / twoPi) as int;
        let jMax: double = (this.hi - pi) / twoPi;
        var j: int = jMin;
        while (j as double <= jMax) {
            let xMin: double = pi + j as double * twoPi;
            if (xMin >= this.lo && xMin <= this.hi) {
                loVal = -1.0;
            }
            j = j + 1;
        }

        return new Interval(loVal, hiVal);
    }

    // Integer power: x^n using repeated squaring with interval arithmetic
    public fn pow(n: int): Interval {
        if (n == 0) {
            return new Interval(1.0, 1.0);
        }
        if (n < 0) {
            let recip: Interval = this.div(new Interval(1.0, 1.0));
            return recip.pow(-n);
        }
        // For even powers, the minimum may be at zero if the interval spans zero
        if (n % 2 == 0 && this.lo <= 0.0 && this.hi >= 0.0) {
            let hiBound: double = Math.max(
                MathAdvanced.pow(this.lo, n as double),
                MathAdvanced.pow(this.hi, n as double)
            );
            return new Interval(0.0, hiBound);
        }
        // For odd powers or intervals that don't span zero, bounds are monotonic
        let loVal: double = MathAdvanced.pow(this.lo, n as double);
        let hiVal: double = MathAdvanced.pow(this.hi, n as double);
        return new Interval(Math.min(loVal, hiVal), Math.max(loVal, hiVal));
    }

    // ---- Properties ----

    public fn width(): double {
        return this.hi - this.lo;
    }

    public fn midpoint(): double {
        return (this.lo + this.hi) / 2.0;
    }

    public fn contains(x: double): bool {
        return x >= this.lo && x <= this.hi;
    }

    public fn overlaps(other: Interval): bool {
        return this.lo <= other.hi && other.lo <= this.hi;
    }

    public fn isEmpty(): bool {
        return this.lo > this.hi;
    }

    public fn intersect(other: Interval): Interval {
        return new Interval(
            Math.max(this.lo, other.lo),
            Math.min(this.hi, other.hi)
        );
    }

    public fn hull(other: Interval): Interval {
        return new Interval(
            Math.min(this.lo, other.lo),
            Math.max(this.hi, other.hi)
        );
    }

    public fn toString(): string {
        return "[" + Double.toString(this.lo) + ", " + Double.toString(this.hi) + "]";
    }
}

// ---- Top-level factory and utility functions ----

// Factory function to create an interval
public fn interval(lo: double, hi: double): Interval {
    return new Interval(lo, hi);
}

// Point interval [x, x]
public fn pointInterval(x: double): Interval {
    return new Interval(x, x);
}

// Whole interval [-inf, +inf]
public fn wholeInterval(): Interval {
    return new Interval(-Math.INF(), Math.INF());
}

// Evaluate a function over an interval
public fn evalInterval(f: fn(Interval): Interval, x: Interval): Interval {
    return f(x);
}

// Find an interval containing a root of f in [lo, hi] using bisection
public fn solveInterval(f: fn(double): double, lo: double, hi: double, tol: double): Interval {
    var a: double = lo;
    var b: double = hi;
    var fa: double = f(a);
    var fb: double = f(b);

    // If no sign change, return the original interval
    if (fa * fb > 0.0) {
        return new Interval(a, b);
    }

    while (b - a > tol) {
        let mid: double = (a + b) / 2.0;
        let fm: double = f(mid);
        if (fm == 0.0) {
            return new Interval(mid, mid);
        }
        if (fa * fm < 0.0) {
            b = mid;
            fb = fm;
        } else {
            a = mid;
            fa = fm;
        }
    }

    return new Interval(a, b);
}
