// FFT: Fast Fourier Transform using Cooley-Tukey radix-2 algorithm
import tt::util::ArrayList;
import tt::math::Math;
import tt::math::MathTrig;
import tt::math::MathAdvanced;

// Compute the smallest power of 2 >= n
public fn nextPowerOf2(n: int): int {
    if (n <= 0) { return 1; }
    var v: int = n - 1;
    v = v | (v >> 1);
    v = v | (v >> 2);
    v = v | (v >> 4);
    v = v | (v >> 8);
    v = v | (v >> 16);
    return v + 1;
}

// Bit-reversal permutation index for index j in a sequence of length n
public fn bitReverse(j: int, n: int): int {
    var result: int = 0;
    var idx: int = j;
    var size: int = n;
    while (size > 1) {
        result = (result << 1) | (idx & 1);
        idx = idx >> 1;
        size = size >> 1;
    }
    return result;
}

// Cooley-Tukey radix-2 FFT.
// Returns [re_out, im_out] as an ArrayList<ArrayList<double>>.
// If input length is not a power of 2, zero-pads to the next power of 2.
public fn fft(re: ArrayList<double>, im: ArrayList<double>): ArrayList<ArrayList<double>> {
    let inputLen: int = re.size();
    if (inputLen == 0) {
        let emptyRe: ArrayList<double> = new ArrayList<double>();
        let emptyIm: ArrayList<double> = new ArrayList<double>();
        let result: ArrayList<ArrayList<double>> = new ArrayList<ArrayList<double>>();
        result.add(emptyRe);
        result.add(emptyIm);
        return result;
    }

    let n: int = nextPowerOf2(inputLen);

    // Copy and zero-pad
    var reOut: ArrayList<double> = new ArrayList<double>();
    var imOut: ArrayList<double> = new ArrayList<double>();
    var i: int = 0;
    while (i < n) {
        if (i < inputLen) {
            reOut.add(re.get(i));
            imOut.add(im.get(i));
        } else {
            reOut.add(0.0);
            imOut.add(0.0);
        }
        i = i + 1;
    }

    // Bit-reversal permutation
    var j: int = 0;
    i = 0;
    while (i < n) {
        j = bitReverse(i, n);
        if (j > i) {
            // Swap real parts
            let tmpRe: double = reOut.get(i);
            reOut.set(i, reOut.get(j));
            reOut.set(j, tmpRe);
            // Swap imaginary parts
            let tmpIm: double = imOut.get(i);
            imOut.set(i, imOut.get(j));
            imOut.set(j, tmpIm);
        }
        i = i + 1;
    }

    // Butterfly operations
    var stage: int = 1;
    while (stage < n) {
        stage = stage * 2;
        let halfStage: int = stage / 2;
        let angleStep: double = -2.0 * Math.PI() / (stage as double);
        var k: int = 0;
        while (k < n) {
            var s: int = 0;
            while (s < halfStage) {
                let angle: double = angleStep * (s as double);
                let wr: double = MathTrig.cos(angle);
                let wi: double = MathTrig.sin(angle);

                let evenIdx: int = k + s;
                let oddIdx: int = k + s + halfStage;

                let reEven: double = reOut.get(evenIdx);
                let imEven: double = imOut.get(evenIdx);
                let reOdd: double = reOut.get(oddIdx);
                let imOdd: double = imOut.get(oddIdx);

                // Complex multiply: (wr + wi*i) * (reOdd + imOdd*i)
                let tRe: double = wr * reOdd - wi * imOdd;
                let tIm: double = wr * imOdd + wi * reOdd;

                reOut.set(evenIdx, reEven + tRe);
                imOut.set(evenIdx, imEven + tIm);
                reOut.set(oddIdx, reEven - tRe);
                imOut.set(oddIdx, imEven - tIm);

                s = s + 1;
            }
            k = k + stage;
        }
    }

    let result: ArrayList<ArrayList<double>> = new ArrayList<ArrayList<double>>();
    result.add(reOut);
    result.add(imOut);
    return result;
}

// Inverse FFT: conjugate input, FFT, conjugate output, divide by N
public fn ifft(re: ArrayList<double>, im: ArrayList<double>): ArrayList<ArrayList<double>> {
    let inputLen: int = re.size();
    if (inputLen == 0) {
        let emptyRe: ArrayList<double> = new ArrayList<double>();
        let emptyIm: ArrayList<double> = new ArrayList<double>();
        let result: ArrayList<ArrayList<double>> = new ArrayList<ArrayList<double>>();
        result.add(emptyRe);
        result.add(emptyIm);
        return result;
    }

    // Conjugate input
    let imConj: ArrayList<double> = new ArrayList<double>();
    var i: int = 0;
    while (i < im.size()) {
        imConj.add(-im.get(i));
        i = i + 1;
    }

    // Forward FFT
    let transformed: ArrayList<ArrayList<double>> = fft(re, imConj);
    let reOut: ArrayList<double> = transformed.get(0);
    let imOut: ArrayList<double> = transformed.get(1);

    // Conjugate output and divide by N
    let n: int = reOut.size();
    let finalRe: ArrayList<double> = new ArrayList<double>();
    let finalIm: ArrayList<double> = new ArrayList<double>();
    i = 0;
    while (i < n) {
        finalRe.add(reOut.get(i) / (n as double));
        finalIm.add(-imOut.get(i) / (n as double));
        i = i + 1;
    }

    let result: ArrayList<ArrayList<double>> = new ArrayList<ArrayList<double>>();
    result.add(finalRe);
    result.add(finalIm);
    return result;
}

// Compute magnitude spectrum: sqrt(re^2 + im^2)
public fn fftMagnitude(re: ArrayList<double>, im: ArrayList<double>): ArrayList<double> {
    let transformed: ArrayList<ArrayList<double>> = fft(re, im);
    let reOut: ArrayList<double> = transformed.get(0);
    let imOut: ArrayList<double> = transformed.get(1);
    let n: int = reOut.size();
    let mag: ArrayList<double> = new ArrayList<double>();
    var i: int = 0;
    while (i < n) {
        mag.add(MathAdvanced.sqrt(reOut.get(i) * reOut.get(i) + imOut.get(i) * imOut.get(i)));
        i = i + 1;
    }
    return mag;
}

// Compute phase spectrum: atan2(im, re)
public fn fftPhase(re: ArrayList<double>, im: ArrayList<double>): ArrayList<double> {
    let transformed: ArrayList<ArrayList<double>> = fft(re, im);
    let reOut: ArrayList<double> = transformed.get(0);
    let imOut: ArrayList<double> = transformed.get(1);
    let n: int = reOut.size();
    let phase: ArrayList<double> = new ArrayList<double>();
    var i: int = 0;
    while (i < n) {
        phase.add(MathTrig.atan2(imOut.get(i), reOut.get(i)));
        i = i + 1;
    }
    return phase;
}

// Frequency bins for FFT output.
// Returns frequencies [0, sr/n, 2*sr/n, ..., -sr/2, ...] (FFT-ordered).
public fn fftFreq(n: int, sampleRate: double): ArrayList<double> {
    let freqs: ArrayList<double> = new ArrayList<double>();
    let halfN: int = n / 2;
    var i: int = 0;
    while (i < n) {
        if (i <= halfN) {
            freqs.add((i as double) * sampleRate / (n as double));
        } else {
            freqs.add(((i - n) as double) * sampleRate / (n as double));
        }
        i = i + 1;
    }
    return freqs;
}

// Hann window: 0.5 * (1 - cos(2*pi*i/(n-1)))
public fn windowHann(n: int): ArrayList<double> {
    let w: ArrayList<double> = new ArrayList<double>();
    if (n <= 0) { return w; }
    if (n == 1) {
        w.add(1.0);
        return w;
    }
    var i: int = 0;
    while (i < n) {
        let val: double = 0.5 * (1.0 - MathTrig.cos(2.0 * Math.PI() * (i as double) / ((n - 1) as double)));
        w.add(val);
        i = i + 1;
    }
    return w;
}

// Hamming window: 0.54 - 0.46 * cos(2*pi*i/(n-1))
public fn windowHamming(n: int): ArrayList<double> {
    let w: ArrayList<double> = new ArrayList<double>();
    if (n <= 0) { return w; }
    if (n == 1) {
        w.add(0.54);
        return w;
    }
    var i: int = 0;
    while (i < n) {
        let val: double = 0.54 - 0.46 * MathTrig.cos(2.0 * Math.PI() * (i as double) / ((n - 1) as double));
        w.add(val);
        i = i + 1;
    }
    return w;
}

// Blackman window: 0.42 - 0.5*cos(2*pi*i/(n-1)) + 0.08*cos(4*pi*i/(n-1))
public fn windowBlackman(n: int): ArrayList<double> {
    let w: ArrayList<double> = new ArrayList<double>();
    if (n <= 0) { return w; }
    if (n == 1) {
        w.add(0.42);
        return w;
    }
    var i: int = 0;
    while (i < n) {
        let denom: double = ((n - 1) as double);
        let val: double = 0.42 - 0.5 * MathTrig.cos(2.0 * Math.PI() * (i as double) / denom) + 0.08 * MathTrig.cos(4.0 * Math.PI() * (i as double) / denom);
        w.add(val);
        i = i + 1;
    }
    return w;
}
