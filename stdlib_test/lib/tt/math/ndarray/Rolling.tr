import tt::util::ArrayList;

// Rolling window and expanding window operations

// Apply a function over a rolling window of fixed size.
// For positions where the full window is not available (beginning of data),
// the function is still applied with whatever elements exist.
public fn rolling(data: ArrayList<double>, window: int, f: fn(ArrayList<double>): double): ArrayList<double> {
    let result: ArrayList<double> = new ArrayList<double>();
    let n: int = data.size();
    if (n == 0 || window <= 0) { return result; }
    var i: int = 0;
    while (i < n) {
        let start: int = i - window + 1;
        if (start < 0) { start = 0; }
        let windowData: ArrayList<double> = new ArrayList<double>();
        var j: int = start;
        while (j <= i) {
            windowData.add(data.get(j));
            j = j + 1;
        }
        result.add(f(windowData));
        i = i + 1;
    }
    return result;
}

// Expanding window: apply a function over all data from the beginning up to each position.
public fn expanding(data: ArrayList<double>, f: fn(ArrayList<double>): double): ArrayList<double> {
    let result: ArrayList<double> = new ArrayList<double>();
    let n: int = data.size();
    let windowData: ArrayList<double> = new ArrayList<double>();
    var i: int = 0;
    while (i < n) {
        windowData.add(data.get(i));
        result.add(f(windowData));
        i = i + 1;
    }
    return result;
}

// Rolling maximum: compute the maximum value over a rolling window of fixed size.
// For positions where the full window is not available, uses whatever elements exist.
public fn rollingMax(data: ArrayList<double>, window: int): ArrayList<double> {
    let result: ArrayList<double> = new ArrayList<double>();
    let n: int = data.size();
    if (n == 0 || window <= 0) { return result; }
    var i: int = 0;
    while (i < n) {
        let start: int = i - window + 1;
        if (start < 0) { start = 0; }
        var maxVal: double = data.get(start);
        var j: int = start + 1;
        while (j <= i) {
            if (data.get(j) > maxVal) {
                maxVal = data.get(j);
            }
            j = j + 1;
        }
        result.add(maxVal);
        i = i + 1;
    }
    return result;
}

// Exponentially weighted mean.
// alpha is the smoothing factor (0 < alpha <= 1).
// EWM_t = alpha * x_t + (1 - alpha) * EWM_{t-1}
public fn ewm(data: ArrayList<double>, alpha: double): ArrayList<double> {
    let result: ArrayList<double> = new ArrayList<double>();
    let n: int = data.size();
    if (n == 0) { return result; }
    var ewmVal: double = data.get(0);
    result.add(ewmVal);
    var i: int = 1;
    while (i < n) {
        ewmVal = alpha * data.get(i) + (1.0 - alpha) * ewmVal;
        result.add(ewmVal);
        i = i + 1;
    }
    return result;
}

// Create sliding window views of the data.
// Returns a list of windows, each of length `window`.
// Only full windows are produced (result size = max(0, n - window + 1)).
public fn slidingWindowView(data: ArrayList<double>, window: int): ArrayList<ArrayList<double>> {
    let result: ArrayList<ArrayList<double>> = new ArrayList<ArrayList<double>>();
    let n: int = data.size();
    if (window <= 0 || n < window) { return result; }
    let numWindows: int = n - window + 1;
    var i: int = 0;
    while (i < numWindows) {
        let w: ArrayList<double> = new ArrayList<double>();
        var j: int = 0;
        while (j < window) {
            w.add(data.get(i + j));
            j = j + 1;
        }
        result.add(w);
        i = i + 1;
    }
    return result;
}
