// MathTrig: trigonometric and hyperbolic functions

// Trigonometric
public fn sin(x: double): double {
    return Math_sin(x);
}

public fn cos(x: double): double {
    return Math_cos(x);
}

public fn tan(x: double): double {
    return Math_tan(x);
}

public fn asin(x: double): double {
    return Math_asin(x);
}

public fn acos(x: double): double {
    return Math_acos(x);
}

public fn atan(x: double): double {
    return Math_atan(x);
}

public fn atan2(y: double, x: double): double {
    return Math_atan2(y, x);
}

// Hyperbolic
public fn sinh(x: double): double {
    return (Math_exp(x) - Math_exp(-x)) / 2.0;
}

public fn cosh(x: double): double {
    return (Math_exp(x) + Math_exp(-x)) / 2.0;
}

public fn tanh(x: double): double {
    return sinh(x) / cosh(x);
}

public fn asinh(x: double): double {
    return Math_ln(x + Math_sqrt(x * x + 1.0));
}

public fn acosh(x: double): double {
    if (x < 1.0) { return Math_nan(); }
    return Math_ln(x + Math_sqrt(x * x - 1.0));
}

public fn atanh(x: double): double {
    if (x <= -1.0 || x >= 1.0) { return Math_nan(); }
    return 0.5 * Math_ln((1.0 + x) / (1.0 - x));
}
