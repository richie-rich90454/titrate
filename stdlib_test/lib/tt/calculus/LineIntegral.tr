// LineIntegral module: line integrals, surface integrals, and Green's theorem.
// Provides numerical computation of line integrals for scalar and vector fields,
// surface integrals, and applications of Green's theorem.
import tt::util::ArrayList;
import tt::math::Math;
import tt::math::MathAdvanced;

// ==================== Helper: Vector operations ====================

// Compute Euclidean distance between two points
fn pointDistance(a: ArrayList<double>, b: ArrayList<double>): double {
    var sum: double = 0.0;
    var i: int = 0;
    while (i < a.size()) {
        let diff: double = a.get(i) - b.get(i);
        sum = sum + diff * diff;
        i = i + 1;
    }
    return MathAdvanced.sqrt(sum);
}

// Compute the tangent vector (direction) from point a to point b, normalized
fn tangentVector(a: ArrayList<double>, b: ArrayList<double>): ArrayList<double> {
    let result: ArrayList<double> = new ArrayList<double>();
    let dist: double = pointDistance(a, b);
    if (dist < 1e-15) {
        var i: int = 0;
        while (i < a.size()) {
            result.add(0.0);
            i = i + 1;
        }
        return result;
    }
    var i: int = 0;
    while (i < a.size()) {
        result.add((b.get(i) - a.get(i)) / dist);
        i = i + 1;
    }
    return result;
}

// Dot product of two vectors
fn dotProduct(a: ArrayList<double>, b: ArrayList<double>): double {
    var sum: double = 0.0;
    var i: int = 0;
    while (i < a.size()) {
        sum = sum + a.get(i) * b.get(i);
        i = i + 1;
    }
    return sum;
}

// Cross product of two 3D vectors
fn cross3d(a: ArrayList<double>, b: ArrayList<double>): ArrayList<double> {
    let result: ArrayList<double> = new ArrayList<double>();
    result.add(a.get(1) * b.get(2) - a.get(2) * b.get(1));
    result.add(a.get(2) * b.get(0) - a.get(0) * b.get(2));
    result.add(a.get(0) * b.get(1) - a.get(1) * b.get(0));
    return result;
}

// Vector magnitude
fn vecMagnitude(v: ArrayList<double>): double {
    var sum: double = 0.0;
    var i: int = 0;
    while (i < v.size()) {
        sum = sum + v.get(i) * v.get(i);
        i = i + 1;
    }
    return MathAdvanced.sqrt(sum);
}

// ==================== Line Integral of Scalar Field ====================

// Line integral of a scalar field f along a path.
// The path is given as an ArrayList of points (vertices of a polyline).
// n is the number of subdivisions per segment for numerical integration.
// Computes: integral_C f ds = integral f(r(t)) * |r'(t)| dt
public fn lineIntegral(f: fn(ArrayList<double>): double, path: ArrayList<ArrayList<double>>, n: int): double {
    let numSegments: int = path.size() - 1;
    var total: double = 0.0;
    var seg: int = 0;
    while (seg < numSegments) {
        let p0: ArrayList<double> = path.get(seg);
        let p1: ArrayList<double> = path.get(seg + 1);
        let dim: int = p0.size();

        // Integrate along this segment using n subdivisions
        var subTotal: double = 0.0;
        var i: int = 0;
        while (i < n) {
            // Parameter t goes from 0 to 1, subdivided into n intervals
            let t0: double = (i as double) / (n as double);
            let t1: double = ((i + 1) as double) / (n as double);
            let tMid: double = (t0 + t1) / 2.0;

            // Point at tMid
            let midPoint: ArrayList<double> = new ArrayList<double>();
            var d: int = 0;
            while (d < dim) {
                midPoint.add(p0.get(d) + tMid * (p1.get(d) - p0.get(d)));
                d = d + 1;
            }

            // Arc length of this sub-segment (approximate as straight line)
            // |r'(t)| * dt where r'(t) = p1 - p0 (constant for linear segment)
            let segLength: double = pointDistance(p0, p1) / (n as double);

            subTotal = subTotal + f(midPoint) * segLength;
            i = i + 1;
        }

        total = total + subTotal;
        seg = seg + 1;
    }
    return total;
}

// ==================== Line Integral of Vector Field (Work) ====================

// Line integral of a vector field F along a path (work done by the field).
// The path is given as an ArrayList of points (vertices of a polyline).
// n is the number of subdivisions per segment.
// Computes: integral_C F . dr = integral F(r(t)) . r'(t) dt
public fn lineIntegralVector(f: fn(ArrayList<double>): ArrayList<double>, path: ArrayList<ArrayList<double>>, n: int): double {
    let numSegments: int = path.size() - 1;
    var total: double = 0.0;
    var seg: int = 0;
    while (seg < numSegments) {
        let p0: ArrayList<double> = path.get(seg);
        let p1: ArrayList<double> = path.get(seg + 1);
        let dim: int = p0.size();

        // Integrate along this segment using n subdivisions
        var subTotal: double = 0.0;
        var i: int = 0;
        while (i < n) {
            let t0: double = (i as double) / (n as double);
            let t1: double = ((i + 1) as double) / (n as double);
            let tMid: double = (t0 + t1) / 2.0;

            // Point at tMid
            let midPoint: ArrayList<double> = new ArrayList<double>();
            var d: int = 0;
            while (d < dim) {
                midPoint.add(p0.get(d) + tMid * (p1.get(d) - p0.get(d)));
                d = d + 1;
            }

            // r'(t) = p1 - p0 (constant for linear segment), scaled by 1/n for dt
            let dr: ArrayList<double> = new ArrayList<double>();
            d = 0;
            while (d < dim) {
                dr.add((p1.get(d) - p0.get(d)) / (n as double));
                d = d + 1;
            }

            // F(r(t)) . dr
            let fVal: ArrayList<double> = f(midPoint);
            subTotal = subTotal + dotProduct(fVal, dr);
            i = i + 1;
        }

        total = total + subTotal;
        seg = seg + 1;
    }
    return total;
}

// ==================== Surface Integral ====================

// Surface integral of a scalar field f over a parametric surface.
// The surface is parameterized by paramU and paramV mapping [u0,u1] x [v0,v1] to 3D.
// paramU(u) returns the point on the surface for a given u (with v fixed at some value).
// Actually, the surface is parameterized as S(u,v) where:
//   paramU(u) returns a function that maps v to the 3D point
// Since Titrate doesn't support fn(double): fn(double): ArrayList<double>,
// we use a simpler approach: the surface is a grid of points.
//
// Instead, we use a direct numerical approach:
// The surface is defined by a height function z = f(x,y) over a rectangular domain.
// But for generality, we accept paramU and paramV as the two boundary curves
// and interpolate linearly between them.
//
// For a proper parametric surface, we approximate using a grid:
// S(u,v) = (1-v)*paramU(u) + v*paramV(u) for u in [u0,u1], v in [v0,v1]
// This creates a ruled surface between the two curves.
public fn surfaceIntegral(f: fn(ArrayList<double>): double, paramU: fn(double): ArrayList<double>, paramV: fn(double): ArrayList<double>, u0: double, u1: double, v0: double, v1: double, n: int): double {
    let du: double = (u1 - u0) / (n as double);
    let dv: double = (v1 - v0) / (n as double);
    var total: double = 0.0;

    var i: int = 0;
    while (i < n) {
        var j: int = 0;
        while (j < n) {
            let u: double = u0 + ((i as double) + 0.5) * du;
            let v: double = v0 + ((j as double) + 0.5) * dv;

            // Surface point: S(u,v) = (1-v)*paramU(u) + v*paramV(u)
            let pU: ArrayList<double> = paramU(u);
            let pV: ArrayList<double> = paramV(u);
            let dim: int = pU.size();
            let surfacePoint: ArrayList<double> = new ArrayList<double>();
            var d: int = 0;
            while (d < dim) {
                surfacePoint.add((1.0 - v) * pU.get(d) + v * pV.get(d));
                d = d + 1;
            }

            // Compute partial derivatives for surface element dS
            // dS/du = (1-v)*paramU'(u) + v*paramV'(u)
            // dS/dv = paramV(u) - paramU(u)
            let h: double = 1e-6;
            let pUPlus: ArrayList<double> = paramU(u + h);
            let pVPlus: ArrayList<double> = paramV(u + h);

            let dsDu: ArrayList<double> = new ArrayList<double>();
            let dsDv: ArrayList<double> = new ArrayList<double>();
            d = 0;
            while (d < dim) {
                let duComp: double = ((1.0 - v) * (pUPlus.get(d) - pU.get(d)) + v * (pVPlus.get(d) - pV.get(d))) / h;
                dsDu.add(duComp);
                dsDv.add(pV.get(d) - pU.get(d));
                d = d + 1;
            }

            // Surface element magnitude: |dS/du x dS/dv| for 3D
            var dSMag: double;
            if (dim == 3) {
                let normal: ArrayList<double> = cross3d(dsDu, dsDv);
                dSMag = vecMagnitude(normal);
            } else {
                // 2D: use the 2D cross product (scalar)
                dSMag = Math.abs(dsDu.get(0) * dsDv.get(1) - dsDu.get(1) * dsDv.get(0));
            }

            total = total + f(surfacePoint) * dSMag * du * dv;
            j = j + 1;
        }
        i = i + 1;
    }

    return total;
}

// ==================== Green's Theorem ====================

// Apply Green's theorem to compute the line integral of a vector field
// around a closed curve using the double integral over the enclosed region.
//
// Green's theorem: integral_C (P dx + Q dy) = integral integral_D (dQ/dx - dP/dy) dA
//
// The vector field F = [P, Q] is given as a function mapping 2D points to 2D vectors.
// The boundary is a closed polygon (ArrayList of vertices, assumed to be positively oriented).
// n is the number of subdivisions for the double integral.
//
// Returns the value of the double integral of (dQ/dx - dP/dy) over the region.
public fn greensTheorem(f: fn(ArrayList<double>): ArrayList<double>, boundary: ArrayList<ArrayList<double>>, n: int): double {
    // Find bounding box of the region
    let xMin: double = boundary.get(0).get(0);
    let xMax: double = boundary.get(0).get(0);
    let yMin: double = boundary.get(0).get(1);
    let yMax: double = boundary.get(0).get(1);
    var i: int = 1;
    while (i < boundary.size()) {
        let x: double = boundary.get(i).get(0);
        let y: double = boundary.get(i).get(1);
        if (x < xMin) { xMin = x; }
        if (x > xMax) { xMax = x; }
        if (y < yMin) { yMin = y; }
        if (y > yMax) { yMax = y; }
        i = i + 1;
    }

    // Add small margin
    let margin: double = 1e-10;

    // Compute dQ/dx - dP/dy numerically at each point
    let h: double = 1e-6;

    // Use midpoint rule over the bounding box, checking if each point is inside the polygon
    let dx: double = (xMax - xMin + 2.0 * margin) / (n as double);
    let dy: double = (yMax - yMin + 2.0 * margin) / (n as double);
    var total: double = 0.0;

    var ix: int = 0;
    while (ix < n) {
        var iy: int = 0;
        while (iy < n) {
            let x: double = xMin - margin + ((ix as double) + 0.5) * dx;
            let y: double = yMin - margin + ((iy as double) + 0.5) * dy;

            // Check if point is inside the polygon using ray casting
            if (pointInPolygon(x, y, boundary)) {
                // Compute dQ/dx using central difference
                let pPlusX: ArrayList<double> = new ArrayList<double>();
                pPlusX.add(x + h);
                pPlusX.add(y);
                let pMinusX: ArrayList<double> = new ArrayList<double>();
                pMinusX.add(x - h);
                pMinusX.add(y);
                let fPlusX: ArrayList<double> = f(pPlusX);
                let fMinusX: ArrayList<double> = f(pMinusX);
                let dQDx: double = (fPlusX.get(1) - fMinusX.get(1)) / (2.0 * h);

                // Compute dP/dy using central difference
                let pPlusY: ArrayList<double> = new ArrayList<double>();
                pPlusY.add(x);
                pPlusY.add(y + h);
                let pMinusY: ArrayList<double> = new ArrayList<double>();
                pMinusY.add(x);
                pMinusY.add(y - h);
                let fPlusY: ArrayList<double> = f(pPlusY);
                let fMinusY: ArrayList<double> = f(pMinusY);
                let dPDy: double = (fPlusY.get(0) - fMinusY.get(0)) / (2.0 * h);

                let integrand: double = dQDx - dPDy;
                total = total + integrand * dx * dy;
            }
            iy = iy + 1;
        }
        ix = ix + 1;
    }

    return total;
}

// ==================== Helper: Point-in-Polygon Test ====================

// Ray casting algorithm to test if point (x, y) is inside a polygon.
// Returns true if the point is inside the polygon defined by the boundary vertices.
fn pointInPolygon(x: double, y: double, polygon: ArrayList<ArrayList<double>>): bool {
    let n: int = polygon.size();
    var inside: bool = false;
    var j: int = n - 1;
    var i: int = 0;
    while (i < n) {
        let xi: double = polygon.get(i).get(0);
        let yi: double = polygon.get(i).get(1);
        let xj: double = polygon.get(j).get(0);
        let yj: double = polygon.get(j).get(1);

        if (((yi > y) != (yj > y)) && (x < (xj - xi) * (y - yi) / (yj - yi) + xi)) {
            inside = !inside;
        }
        j = i;
        i = i + 1;
    }
    return inside;
}
