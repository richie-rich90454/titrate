// Binary JSON encoding (MessagePack-compatible).
// Encodes JsonValue to/from MessagePack binary format using ArrayList<int>
// where each int is a byte value (0-255).
import tt::json::JsonValue;
import tt::util::ArrayList;
import tt::util::HashMap;
import tt::lang::String;

public class JsonBinary {
    // Extension type registry
    private ArrayList<int> _extTypeIds;
    private ArrayList<fn(JsonValue): ArrayList<int>> _extEncoders;
    private ArrayList<fn(ArrayList<int>): JsonValue> _extDecoders;

    public fn init() {
        this._extTypeIds = new ArrayList<int>();
        this._extEncoders = new ArrayList<fn(JsonValue): ArrayList<int>>();
        this._extDecoders = new ArrayList<fn(ArrayList<int>): JsonValue>();
    }

    public fn registerExtType(typeId: int, encoder: fn(JsonValue): ArrayList<int>, decoder: fn(ArrayList<int>): JsonValue): void {
        this._extTypeIds.add(typeId);
        this._extEncoders.add(encoder);
        this._extDecoders.add(decoder);
    }

    public fn encode(value: JsonValue): ArrayList<int> {
        let bytes: ArrayList<int> = new ArrayList<int>();
        this._encodeValue(value, bytes);
        return bytes;
    }

    public fn decode(bytes: ArrayList<int>): JsonValue {
        let ctx: ArrayList<int> = bytes;
        let pos: ArrayList<int> = new ArrayList<int>();
        pos.add(0);
        return this._decodeValue(ctx, pos);
    }

    public fn encodeToHex(value: JsonValue): string {
        let bytes: ArrayList<int> = this.encode(value);
        let result: string = "";
        let i: int = 0;
        while (i < bytes.size()) {
            result = result + _hexByte(bytes.get(i));
            i = i + 1;
        }
        return result;
    }

    public fn decodeFromHex(hex: string): JsonValue {
        let bytes: ArrayList<int> = new ArrayList<int>();
        let i: int = 0;
        while (i + 1 < String.length(hex)) {
            let high: int = _hexVal(String.charAt(hex, i));
            let low: int = _hexVal(String.charAt(hex, i + 1));
            bytes.add(high * 16 + low);
            i = i + 2;
        }
        return this.decode(bytes);
    }

    // ---- Encoding ----

    private fn _encodeValue(value: JsonValue, bytes: ArrayList<int>): void {
        if (value.isNull()) {
            bytes.add(0xc0);
            return;
        }
        if (value.isBool()) {
            if (value.asBool()) {
                bytes.add(0xc3);
            } else {
                bytes.add(0xc2);
            }
            return;
        }
        if (value.isNumber()) {
            this._encodeNumber(value.asNumber(), bytes);
            return;
        }
        if (value.isString()) {
            this._encodeString(value.asString(), bytes);
            return;
        }
        if (value.isArray()) {
            this._encodeArray(value, bytes);
            return;
        }
        if (value.isObject()) {
            this._encodeObject(value, bytes);
            return;
        }
        // Fallback: null
        bytes.add(0xc0);
    }

    private fn _encodeNumber(n: double, bytes: ArrayList<int>): void {
        // Check if the number is a non-negative integer that fits in fixint
        if (n >= 0.0 && n <= 127.0 && n == _floor(n)) {
            bytes.add(n as int);
            return;
        }
        // Check if it's a negative integer that fits in negative fixint
        if (n >= -32.0 && n < 0.0 && n == _floor(n)) {
            bytes.add((256 + (n as int)) % 256);
            return;
        }
        // Check if integer fits in unsigned types
        if (n >= 0.0 && n == _floor(n)) {
            let intVal: long = n as long;
            if (intVal <= 255) {
                bytes.add(0xcc);
                bytes.add(intVal as int);
                return;
            }
            if (intVal <= 65535) {
                bytes.add(0xcd);
                _writeU16(intVal as int, bytes);
                return;
            }
            if (intVal <= 4294967295) {
                bytes.add(0xce);
                _writeU32(intVal as int, bytes);
                return;
            }
            bytes.add(0xcf);
            _writeU64(intVal, bytes);
            return;
        }
        // Check if integer fits in signed types (negative)
        if (n < 0.0 && n == _floor(n)) {
            let intVal: long = n as long;
            if (intVal >= -128) {
                bytes.add(0xd0);
                bytes.add((intVal + 256) % 256 as int);
                return;
            }
            if (intVal >= -32768) {
                bytes.add(0xd1);
                _writeI16(intVal as int, bytes);
                return;
            }
            if (intVal >= -2147483648) {
                bytes.add(0xd2);
                _writeI32(intVal as int, bytes);
                return;
            }
            bytes.add(0xd3);
            _writeI64(intVal, bytes);
            return;
        }
        // Float: use float64
        bytes.add(0xcb);
        _writeF64(n, bytes);
    }

    private fn _encodeString(s: string, bytes: ArrayList<int>): void {
        let len: int = String.length(s);
        // Encode string as UTF-8 bytes
        let strBytes: ArrayList<int> = _stringToUtf8(s);
        let byteLen: int = strBytes.size();
        if (byteLen <= 31) {
            bytes.add(0xa0 + byteLen);
        } else if (byteLen <= 255) {
            bytes.add(0xd9);
            bytes.add(byteLen);
        } else if (byteLen <= 65535) {
            bytes.add(0xda);
            _writeU16(byteLen, bytes);
        } else {
            bytes.add(0xdb);
            _writeU32(byteLen, bytes);
        }
        let i: int = 0;
        while (i < strBytes.size()) {
            bytes.add(strBytes.get(i));
            i = i + 1;
        }
    }

    private fn _encodeArray(value: JsonValue, bytes: ArrayList<int>): void {
        let arr: ArrayList<JsonValue> = value.asArray();
        let len: int = arr.size();
        if (len <= 15) {
            bytes.add(0x90 + len);
        } else if (len <= 65535) {
            bytes.add(0xdc);
            _writeU16(len, bytes);
        } else {
            bytes.add(0xdd);
            _writeU32(len, bytes);
        }
        let i: int = 0;
        while (i < len) {
            this._encodeValue(arr.get(i), bytes);
            i = i + 1;
        }
    }

    private fn _encodeObject(value: JsonValue, bytes: ArrayList<int>): void {
        let obj: HashMap<string, JsonValue> = value.asObject();
        let keys: ArrayList<string> = obj.keys();
        let len: int = keys.size();
        if (len <= 15) {
            bytes.add(0x80 + len);
        } else if (len <= 65535) {
            bytes.add(0xde);
            _writeU16(len, bytes);
        } else {
            bytes.add(0xdf);
            _writeU32(len, bytes);
        }
        let i: int = 0;
        while (i < len) {
            let key: string = keys.get(i);
            this._encodeString(key, bytes);
            this._encodeValue(obj.get(key), bytes);
            i = i + 1;
        }
    }

    // ---- Decoding ----

    private fn _decodeValue(ctx: ArrayList<int>, pos: ArrayList<int>): JsonValue {
        if (pos.get(0) >= ctx.size()) {
            return JsonValue.ofNull();
        }
        let b: int = ctx.get(pos.get(0));
        pos.set(0, pos.get(0) + 1);

        // Positive fixint: 0x00-0x7f
        if (b <= 0x7f) {
            return JsonValue.ofNum(b as double);
        }
        // Fixmap: 0x80-0x8f
        if (b >= 0x80 && b <= 0x8f) {
            let len: int = b - 0x80;
            return this._decodeMap(ctx, pos, len);
        }
        // Fixarray: 0x90-0x9f
        if (b >= 0x90 && b <= 0x9f) {
            let len: int = b - 0x90;
            return this._decodeArray(ctx, pos, len);
        }
        // Fixstr: 0xa0-0xbf
        if (b >= 0xa0 && b <= 0xbf) {
            let len: int = b - 0xa0;
            return JsonValue.ofStr(this._decodeStr(ctx, pos, len));
        }
        // Nil
        if (b == 0xc0) {
            return JsonValue.ofNull();
        }
        // False
        if (b == 0xc2) {
            return JsonValue.ofBool(false);
        }
        // True
        if (b == 0xc3) {
            return JsonValue.ofBool(true);
        }
        // Float 32
        if (b == 0xca) {
            return JsonValue.ofNum(_readF32(ctx, pos));
        }
        // Float 64
        if (b == 0xcb) {
            return JsonValue.ofNum(_readF64(ctx, pos));
        }
        // Uint 8
        if (b == 0xcc) {
            let val: int = ctx.get(pos.get(0));
            pos.set(0, pos.get(0) + 1);
            return JsonValue.ofNum(val as double);
        }
        // Uint 16
        if (b == 0xcd) {
            return JsonValue.ofNum(_readU16(ctx, pos) as double);
        }
        // Uint 32
        if (b == 0xce) {
            return JsonValue.ofNum(_readU32(ctx, pos) as double);
        }
        // Uint 64
        if (b == 0xcf) {
            return JsonValue.ofNum(_readU64(ctx, pos) as double);
        }
        // Int 8
        if (b == 0xd0) {
            let val: int = ctx.get(pos.get(0));
            pos.set(0, pos.get(0) + 1);
            if (val > 127) { val = val - 256; }
            return JsonValue.ofNum(val as double);
        }
        // Int 16
        if (b == 0xd1) {
            return JsonValue.ofNum(_readI16(ctx, pos) as double);
        }
        // Int 32
        if (b == 0xd2) {
            return JsonValue.ofNum(_readI32(ctx, pos) as double);
        }
        // Int 64
        if (b == 0xd3) {
            return JsonValue.ofNum(_readI64(ctx, pos) as double);
        }
        // Str 8
        if (b == 0xd9) {
            let len: int = ctx.get(pos.get(0));
            pos.set(0, pos.get(0) + 1);
            return JsonValue.ofStr(this._decodeStr(ctx, pos, len));
        }
        // Str 16
        if (b == 0xda) {
            let len: int = _readU16(ctx, pos);
            return JsonValue.ofStr(this._decodeStr(ctx, pos, len));
        }
        // Str 32
        if (b == 0xdb) {
            let len: int = _readU32(ctx, pos);
            return JsonValue.ofStr(this._decodeStr(ctx, pos, len));
        }
        // Array 16
        if (b == 0xdc) {
            let len: int = _readU16(ctx, pos);
            return this._decodeArray(ctx, pos, len);
        }
        // Array 32
        if (b == 0xdd) {
            let len: int = _readU32(ctx, pos);
            return this._decodeArray(ctx, pos, len);
        }
        // Map 16
        if (b == 0xde) {
            let len: int = _readU16(ctx, pos);
            return this._decodeMap(ctx, pos, len);
        }
        // Map 32
        if (b == 0xdf) {
            let len: int = _readU32(ctx, pos);
            return this._decodeMap(ctx, pos, len);
        }
        // Negative fixint: 0xe0-0xff
        if (b >= 0xe0) {
            return JsonValue.ofNum((b - 256) as double);
        }
        return JsonValue.ofNull();
    }

    private fn _decodeArray(ctx: ArrayList<int>, pos: ArrayList<int>, len: int): JsonValue {
        let arr: ArrayList<JsonValue> = new ArrayList<JsonValue>();
        let i: int = 0;
        while (i < len) {
            arr.add(this._decodeValue(ctx, pos));
            i = i + 1;
        }
        return JsonValue.ofArray(arr);
    }

    private fn _decodeMap(ctx: ArrayList<int>, pos: ArrayList<int>, len: int): JsonValue {
        let obj: HashMap<string, JsonValue> = new HashMap<string, JsonValue>();
        let i: int = 0;
        while (i < len) {
            // Key must be a string
            let key: string = "";
            let b: int = ctx.get(pos.get(0));
            if (b >= 0xa0 && b <= 0xbf) {
                pos.set(0, pos.get(0) + 1);
                let strLen: int = b - 0xa0;
                key = this._decodeStr(ctx, pos, strLen);
            } else if (b == 0xd9) {
                pos.set(0, pos.get(0) + 1);
                let strLen: int = ctx.get(pos.get(0));
                pos.set(0, pos.get(0) + 1);
                key = this._decodeStr(ctx, pos, strLen);
            } else if (b == 0xda) {
                pos.set(0, pos.get(0) + 1);
                let strLen: int = _readU16(ctx, pos);
                key = this._decodeStr(ctx, pos, strLen);
            } else if (b == 0xdb) {
                pos.set(0, pos.get(0) + 1);
                let strLen: int = _readU32(ctx, pos);
                key = this._decodeStr(ctx, pos, strLen);
            } else {
                // Fallback: decode as value and use toString as key
                let keyVal: JsonValue = this._decodeValue(ctx, pos);
                key = keyVal.asString();
            }
            let val: JsonValue = this._decodeValue(ctx, pos);
            obj.put(key, val);
            i = i + 1;
        }
        return JsonValue.ofObject(obj);
    }

    private fn _decodeStr(ctx: ArrayList<int>, pos: ArrayList<int>, len: int): string {
        let bytes: ArrayList<int> = new ArrayList<int>();
        let i: int = 0;
        while (i < len) {
            bytes.add(ctx.get(pos.get(0)));
            pos.set(0, pos.get(0) + 1);
            i = i + 1;
        }
        return _utf8ToString(bytes);
    }
}

// ---- Module-level binary helpers ----

fn _floor(n: double): double {
    return Math.floor(n);
}

fn _writeU16(val: int, bytes: ArrayList<int>): void {
    bytes.add((val >> 8) & 0xff);
    bytes.add(val & 0xff);
}

fn _writeU32(val: int, bytes: ArrayList<int>): void {
    bytes.add((val >> 24) & 0xff);
    bytes.add((val >> 16) & 0xff);
    bytes.add((val >> 8) & 0xff);
    bytes.add(val & 0xff);
}

fn _writeU64(val: long, bytes: ArrayList<int>): void {
    bytes.add(((val >> 56) & 0xff) as int);
    bytes.add(((val >> 48) & 0xff) as int);
    bytes.add(((val >> 40) & 0xff) as int);
    bytes.add(((val >> 32) & 0xff) as int);
    bytes.add(((val >> 24) & 0xff) as int);
    bytes.add(((val >> 16) & 0xff) as int);
    bytes.add(((val >> 8) & 0xff) as int);
    bytes.add((val & 0xff) as int);
}

fn _writeI16(val: int, bytes: ArrayList<int>): void {
    let uval: int = val + 65536;
    bytes.add((uval >> 8) & 0xff);
    bytes.add(uval & 0xff);
}

fn _writeI32(val: int, bytes: ArrayList<int>): void {
    _writeU32(val, bytes);
}

fn _writeI64(val: long, bytes: ArrayList<int>): void {
    _writeU64(val, bytes);
}

fn _writeF64(val: double, bytes: ArrayList<int>): void {
    // Encode float64 using Double.doubleToRawLongBits
    let bits: long = Double.doubleToRawLongBits(val);
    _writeU64(bits, bytes);
}

fn _readU16(ctx: ArrayList<int>, pos: ArrayList<int>): int {
    let b0: int = ctx.get(pos.get(0));
    pos.set(0, pos.get(0) + 1);
    let b1: int = ctx.get(pos.get(0));
    pos.set(0, pos.get(0) + 1);
    return (b0 << 8) | b1;
}

fn _readU32(ctx: ArrayList<int>, pos: ArrayList<int>): int {
    let b0: int = ctx.get(pos.get(0));
    pos.set(0, pos.get(0) + 1);
    let b1: int = ctx.get(pos.get(0));
    pos.set(0, pos.get(0) + 1);
    let b2: int = ctx.get(pos.get(0));
    pos.set(0, pos.get(0) + 1);
    let b3: int = ctx.get(pos.get(0));
    pos.set(0, pos.get(0) + 1);
    return (b0 << 24) | (b1 << 16) | (b2 << 8) | b3;
}

fn _readU64(ctx: ArrayList<int>, pos: ArrayList<int>): long {
    let b0: int = ctx.get(pos.get(0));
    pos.set(0, pos.get(0) + 1);
    let b1: int = ctx.get(pos.get(0));
    pos.set(0, pos.get(0) + 1);
    let b2: int = ctx.get(pos.get(0));
    pos.set(0, pos.get(0) + 1);
    let b3: int = ctx.get(pos.get(0));
    pos.set(0, pos.get(0) + 1);
    let b4: int = ctx.get(pos.get(0));
    pos.set(0, pos.get(0) + 1);
    let b5: int = ctx.get(pos.get(0));
    pos.set(0, pos.get(0) + 1);
    let b6: int = ctx.get(pos.get(0));
    pos.set(0, pos.get(0) + 1);
    let b7: int = ctx.get(pos.get(0));
    pos.set(0, pos.get(0) + 1);
    return ((b0 as long) << 56) | ((b1 as long) << 48) | ((b2 as long) << 40) | ((b3 as long) << 32) | ((b4 as long) << 24) | ((b5 as long) << 16) | ((b6 as long) << 8) | (b7 as long);
}

fn _readI16(ctx: ArrayList<int>, pos: ArrayList<int>): int {
    let val: int = _readU16(ctx, pos);
    if (val >= 32768) {
        return val - 65536;
    }
    return val;
}

fn _readI32(ctx: ArrayList<int>, pos: ArrayList<int>): int {
    return _readU32(ctx, pos);
}

fn _readI64(ctx: ArrayList<int>, pos: ArrayList<int>): long {
    return _readU64(ctx, pos);
}

fn _readF32(ctx: ArrayList<int>, pos: ArrayList<int>): double {
    let bits: int = _readU32(ctx, pos);
    return Float.intBitsToFloat(bits);
}

fn _readF64(ctx: ArrayList<int>, pos: ArrayList<int>): double {
    let bits: long = _readU64(ctx, pos);
    return Double.longBitsToDouble(bits);
}

// Convert a string to UTF-8 bytes
fn _stringToUtf8(s: string): ArrayList<int> {
    let bytes: ArrayList<int> = new ArrayList<int>();
    let i: int = 0;
    while (i < String.length(s)) {
        let code: int = String.charAt(s, i) as int;
        if (code < 0x80) {
            bytes.add(code);
        } else if (code < 0x800) {
            bytes.add(0xc0 | (code >> 6));
            bytes.add(0x80 | (code & 0x3f));
        } else if (code < 0x10000) {
            bytes.add(0xe0 | (code >> 12));
            bytes.add(0x80 | ((code >> 6) & 0x3f));
            bytes.add(0x80 | (code & 0x3f));
        } else {
            bytes.add(0xf0 | (code >> 18));
            bytes.add(0x80 | ((code >> 12) & 0x3f));
            bytes.add(0x80 | ((code >> 6) & 0x3f));
            bytes.add(0x80 | (code & 0x3f));
        }
        i = i + 1;
    }
    return bytes;
}

// Convert UTF-8 bytes back to a string
fn _utf8ToString(bytes: ArrayList<int>): string {
    let result: string = "";
    let i: int = 0;
    while (i < bytes.size()) {
        let b0: int = bytes.get(i);
        if (b0 < 0x80) {
            result = result + String.fromCharCode(b0);
            i = i + 1;
        } else if ((b0 & 0xe0) == 0xc0) {
            let b1: int = bytes.get(i + 1);
            let code: int = ((b0 & 0x1f) << 6) | (b1 & 0x3f);
            result = result + String.fromCharCode(code);
            i = i + 2;
        } else if ((b0 & 0xf0) == 0xe0) {
            let b1: int = bytes.get(i + 1);
            let b2: int = bytes.get(i + 2);
            let code: int = ((b0 & 0x0f) << 12) | ((b1 & 0x3f) << 6) | (b2 & 0x3f);
            result = result + String.fromCharCode(code);
            i = i + 3;
        } else if ((b0 & 0xf8) == 0xf0) {
            let b1: int = bytes.get(i + 1);
            let b2: int = bytes.get(i + 2);
            let b3: int = bytes.get(i + 3);
            let code: int = ((b0 & 0x07) << 18) | ((b1 & 0x3f) << 12) | ((b2 & 0x3f) << 6) | (b3 & 0x3f);
            result = result + String.fromCharCode(code);
            i = i + 4;
        } else {
            result = result + String.fromCharCode(b0);
            i = i + 1;
        }
    }
    return result;
}

// Convert a byte value (0-255) to two hex characters
fn _hexByte(b: int): string {
    return _hexDigit(b >> 4) + _hexDigit(b & 0x0f);
}

fn _hexDigit(v: int): string {
    if (v < 10) {
        return String.fromCharCode(48 + v);
    }
    return String.fromCharCode(97 + v - 10);
}

// Convert a hex character to its integer value
fn _hexVal(c: string): int {
    let code: int = String.charAt(c, 0) as int;
    if (code >= 48 && code <= 57) {
        return code - 48;
    }
    if (code >= 65 && code <= 70) {
        return code - 65 + 10;
    }
    if (code >= 97 && code <= 102) {
        return code - 97 + 10;
    }
    return 0;
}
