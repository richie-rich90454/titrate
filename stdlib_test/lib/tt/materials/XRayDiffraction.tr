// XRayDiffraction.tr — X-ray diffraction: Bragg's law, structure factor, powder diffraction
import tt::lang::DataFile;
import tt::json::JsonValue;
import tt::util::HashMap;
import tt::util::ArrayList;
import tt::lang::String;
import tt::lang::Integer;
import tt::lang::Double;
import tt::math::MathAdvanced;
import tt::math::MathTrig;

var _sfCache: HashMap<string, JsonValue> = new HashMap<string, JsonValue>();
var _sfLoaded: bool = false;
var _sfMap: HashMap<string, JsonValue> = new HashMap<string, JsonValue>();
var _sfMapBuilt: bool = false;

fn _ensureSFLoaded(): void {
    if (_sfLoaded) { return; }
    let data: JsonValue = DataFile.load("materials/scattering_factors.json");
    if (!data.isNull()) { _sfCache.put("root", data); }
    _sfLoaded = true;
}

fn _ensureSFMapBuilt(): void {
    if (_sfMapBuilt) { return; }
    _ensureSFLoaded();
    let root: JsonValue = _sfCache.get("root");
    if (root.isNull()) { return; }
    let elements: JsonValue = root.get("elements");
    if (elements.isNull()) { return; }
    let arr: ArrayList<JsonValue> = elements.values();
    var i: int = 0;
    while (i < arr.size()) {
        let elem: JsonValue = arr.get(i);
        if (elem.hasKey("symbol")) {
            _sfMap.put(elem.get("symbol").asString(), elem);
        }
        i = i + 1;
    }
    _sfMapBuilt = true;
}

// Bragg's law: n*lambda = 2*d*sin(theta)
public fn braggAngle(dSpacing: double, wavelength: double): double {
    return braggAngle(dSpacing, wavelength, 1);
}

public fn braggAngle(dSpacing: double, wavelength: double, n: int): double {
    let sinTheta: double = n as double * wavelength / (2.0 * dSpacing);
    if (sinTheta > 1.0 || sinTheta < -1.0) { return -1.0; }
    return MathTrig.asin(sinTheta);
}

public fn braggDSpacing(theta: double, wavelength: double, n: int): double {
    let sinT: double = MathTrig.sin(theta);
    if (sinT == 0.0) { return 0.0; }
    return n as double * wavelength / (2.0 * sinT);
}

// Atomic scattering factor using Cromer-Mann coefficients
public fn scatteringFactor(symbol: string, sinThetaOverLambda: double): double {
    _ensureSFMapBuilt();
    if (!_sfMap.containsKey(symbol)) { return 0.0; }
    let elem: JsonValue = _sfMap.get(symbol);
    let s2: double = sinThetaOverLambda * sinThetaOverLambda;
    let a1: double = elem.get("a1").asNumber();
    let a2: double = elem.get("a2").asNumber();
    let a3: double = elem.get("a3").asNumber();
    let a4: double = elem.get("a4").asNumber();
    let b1: double = elem.get("b1").asNumber();
    let b2: double = elem.get("b2").asNumber();
    let b3: double = elem.get("b3").asNumber();
    let b4: double = elem.get("b4").asNumber();
    let c: double = elem.get("c").asNumber();
    return a1 * MathAdvanced.exp(-b1 * s2) + a2 * MathAdvanced.exp(-b2 * s2) + a3 * MathAdvanced.exp(-b3 * s2) + a4 * MathAdvanced.exp(-b4 * s2) + c;
}

public class AtomPosition {
    public string symbol;
    public double x;
    public double y;
    public double z;

    public fn init(sym: string, px: double, py: double, pz: double) {
        this.symbol = sym;
        this.x = px;
        this.y = py;
        this.z = pz;
    }
}

// Structure factor F(hkl)
public fn structureFactor(h: int, k: int, l: int, atoms: ArrayList<AtomPosition>, sinThetaOverLambda: double): double {
    var fReal: double = 0.0;
    var fImag: double = 0.0;
    var i: int = 0;
    while (i < atoms.size()) {
        let atom: AtomPosition = atoms.get(i);
        let f0: double = scatteringFactor(atom.symbol, sinThetaOverLambda);
        let phase: double = 2.0 * Math.PI() * (h as double * atom.x + k as double * atom.y + l as double * atom.z);
        fReal = fReal + f0 * MathTrig.cos(phase);
        fImag = fImag + f0 * MathTrig.sin(phase);
        i = i + 1;
    }
    return MathAdvanced.sqrt(fReal * fReal + fImag * fImag);
}

// Powder diffraction intensity
public fn powderIntensity(fHkl: double, theta: double, multiplicity: int, lpFactor: double): double {
    let sinT: double = MathTrig.sin(theta);
    let cosT: double = MathTrig.cos(theta);
    if (cosT <= 0.0) { return 0.0; }
    let lorentz: double = 1.0 / (sinT * sinT * cosT);
    return fHkl * fHkl * multiplicity as double * lorentz * lpFactor;
}
