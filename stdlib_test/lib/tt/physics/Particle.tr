// Particle.tr — Particle with mass, charge, position, velocity, acceleration
import tt::math::MathAdvanced;

public class Particle {
    public double mass;
    public double charge;
    public double x;
    public double y;
    public double z;
    public double vx;
    public double vy;
    public double vz;
    public double ax;
    public double ay;
    public double az;

    public fn init(m: double, q: double) {
        this.mass = m;
        this.charge = q;
        this.x = 0.0;
        this.y = 0.0;
        this.z = 0.0;
        this.vx = 0.0;
        this.vy = 0.0;
        this.vz = 0.0;
        this.ax = 0.0;
        this.ay = 0.0;
        this.az = 0.0;
    }

    public fn setPosition(px: double, py: double, pz: double): void {
        this.x = px;
        this.y = py;
        this.z = pz;
    }

    public fn setVelocity(vx: double, vy: double, vz: double): void {
        this.vx = vx;
        this.vy = vy;
        this.vz = vz;
    }

    public fn setAcceleration(ax: double, ay: double, az: double): void {
        this.ax = ax;
        this.ay = ay;
        this.az = az;
    }

    public fn applyForce(fx: double, fy: double, fz: double): void {
        if (this.mass > 0.0) {
            this.ax = this.ax + fx / this.mass;
            this.ay = this.ay + fy / this.mass;
            this.az = this.az + fz / this.mass;
        }
    }

    public fn update(dt: double): void {
        this.vx = this.vx + this.ax * dt;
        this.vy = this.vy + this.ay * dt;
        this.vz = this.vz + this.az * dt;
        this.x = this.x + this.vx * dt;
        this.y = this.y + this.vy * dt;
        this.z = this.z + this.vz * dt;
        // Reset acceleration for next step
        this.ax = 0.0;
        this.ay = 0.0;
        this.az = 0.0;
    }

    public fn kineticEnergy(): double {
        let v2: double = this.vx * this.vx + this.vy * this.vy + this.vz * this.vz;
        return 0.5 * this.mass * v2;
    }

    public fn potentialEnergy(g: double): double {
        return this.mass * g * this.z;
    }

    public fn momentum(): double {
        let v2: double = this.vx * this.vx + this.vy * this.vy + this.vz * this.vz;
        return this.mass * MathAdvanced.sqrt(v2);
    }

    public fn distanceTo(other: Particle): double {
        let dx: double = this.x - other.x;
        let dy: double = this.y - other.y;
        let dz: double = this.z - other.z;
        return MathAdvanced.sqrt(dx * dx + dy * dy + dz * dz);
    }

    public fn speed(): double {
        return MathAdvanced.sqrt(this.vx * this.vx + this.vy * this.vy + this.vz * this.vz);
    }
}
