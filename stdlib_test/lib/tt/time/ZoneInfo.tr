// IANA timezone support with predefined timezone constants.
import tt::util::ArrayList;
import tt::util::HashMap;
import tt::time::DateTime;
import tt::time::Duration;
import tt::lang::String;
import tt::lang::DataFile;
import tt::json::JsonValue;

public class ZoneInfo {
    private string _name;
    private double _offset;

    public fn init(name: string, offsetHours: double) {
        this._name = name;
        this._offset = offsetHours;
    }

    public fn name(): string {
        return this._name;
    }

    public fn offset(): double {
        return this._offset;
    }

    public fn offsetSeconds(): int {
        return (this._offset * 3600) as int;
    }

    public fn toString(): string {
        let sign: string = "+";
        var hours: double = this._offset;
        if (hours < 0) {
            sign = "-";
            hours = -hours;
        }
        let h: int = hours as int;
        let m: int = ((hours - (h as double)) * 60) as int;
        return this._name + " (UTC" + sign + Integer.toString(h) + ":" + _pad(m) + ")";
    }

    // Convert a DateTime from one timezone to this timezone
    public fn convert(dt: DateTime, fromZone: ZoneInfo): DateTime {
        let diffHours: double = this._offset - fromZone._offset;
        let diffMillis: long = (diffHours * 3600000.0) as long;
        return new DateTime(dt.epochMillis + diffMillis);
    }
}

// Pad an integer to 2 digits with leading zero
fn _pad(n: int): string {
    if (n < 10) {
        return "0" + Integer.toString(n);
    }
    return Integer.toString(n);
}

// ---- Data loaded from external JSON via DataFile ----

var _tzByNameCache: HashMap<string, ZoneInfo> = new HashMap<string, ZoneInfo>();
var _tzLoaded: bool = false;

fn _ensureTimezonesLoaded(): void {
    if (_tzLoaded) {
        return;
    }
    let data: JsonValue = DataFile.load("datetime/timezones.json");
    if (data.isNull() || !data.isObject()) {
        _tzLoaded = true;
        return;
    }
    if (!data.hasKey("timezones")) {
        _tzLoaded = true;
        return;
    }
    let timezones: JsonValue = data.get("timezones");
    if (!timezones.isArray()) {
        _tzLoaded = true;
        return;
    }
    var i: int = 0;
    while (i < timezones.size()) {
        let entry: JsonValue = timezones.getAt(i);
        if (entry.isObject() && entry.hasKey("name") && entry.hasKey("offset")) {
            let tzName: string = entry.get("name").asString();
            let tzOffset: double = entry.get("offset").asNumber();
            let tz: ZoneInfo = new ZoneInfo(tzName, tzOffset);
            // Cache by canonical name
            _tzByNameCache.put(tzName, tz);
            // Cache by all aliases
            if (entry.hasKey("aliases")) {
                let aliases: JsonValue = entry.get("aliases");
                if (aliases.isArray()) {
                    var j: int = 0;
                    while (j < aliases.size()) {
                        let alias: string = aliases.getAt(j).asString();
                        _tzByNameCache.put(alias, tz);
                        j = j + 1;
                    }
                }
            }
        }
        i = i + 1;
    }
    _tzLoaded = true;
}

// Get a timezone by common name
public fn timezone(name: string): ZoneInfo {
    _ensureTimezonesLoaded();
    if (_tzByNameCache.containsKey(name)) {
        return _tzByNameCache.get(name);
    }
    // Default: return UTC
    return utc();
}

// Predefined timezone: UTC
public fn utc(): ZoneInfo {
    _ensureTimezonesLoaded();
    if (_tzByNameCache.containsKey("UTC")) {
        return _tzByNameCache.get("UTC");
    }
    // Fallback if data file is unavailable
    return new ZoneInfo("UTC", 0.0);
}

// Predefined timezone: US Eastern (UTC-5)
public fn eastern(): ZoneInfo {
    return timezone("US/Eastern");
}

// Predefined timezone: US Central (UTC-6)
public fn central(): ZoneInfo {
    return timezone("US/Central");
}

// Predefined timezone: US Mountain (UTC-7)
public fn mountain(): ZoneInfo {
    return timezone("US/Mountain");
}

// Predefined timezone: US Pacific (UTC-8)
public fn pacific(): ZoneInfo {
    return timezone("US/Pacific");
}

// Predefined timezone: GMT (UTC+0)
public fn gmt(): ZoneInfo {
    return timezone("GMT");
}

// Predefined timezone: Central European Time (UTC+1)
public fn cet(): ZoneInfo {
    return timezone("CET");
}

// Predefined timezone: Japan Standard Time (UTC+9)
public fn jst(): ZoneInfo {
    return timezone("JST");
}

// Predefined timezone: China Standard Time (UTC+8)
public fn cst(): ZoneInfo {
    return timezone("CST");
}

// Predefined timezone: India Standard Time (UTC+5:30)
public fn ist(): ZoneInfo {
    return timezone("IST");
}

// Predefined timezone: Australian Eastern Standard Time (UTC+10)
public fn aest(): ZoneInfo {
    return timezone("AEST");
}
