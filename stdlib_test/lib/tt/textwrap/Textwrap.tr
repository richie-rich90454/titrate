// Textwrap provides text wrapping and filling utilities, mirroring Python's textwrap module.
import tt::util::ArrayList;
import tt::lang::String;

public class Textwrap {
    // Wrap text to the given width, returning a list of lines.
    public fn wrap(text: string, width: int): ArrayList<string> {
        let lines: ArrayList<string> = new ArrayList<string>();
        if (String.length(text) == 0) {
            lines.add("");
            return lines;
        }
        if (width <= 0) { width = 1; }
        let words: ArrayList<string> = String::split(text, " ");
        let currentLine: string = "";
        let i: int = 0;
        while (i < words.size()) {
            let word: string = words.get(i);
            if (String.length(currentLine) == 0) {
                currentLine = word;
            } else if (String.length(currentLine) + 1 + String.length(word) <= width) {
                currentLine = currentLine + " " + word;
            } else {
                lines.add(currentLine);
                currentLine = word;
            }
            i = i + 1;
        }
        if (String.length(currentLine) > 0) {
            lines.add(currentLine);
        }
        return lines;
    }

    // Wrap text and join the lines with newlines.
    public fn fill(text: string, width: int): string {
        let lines: ArrayList<string> = Textwrap.wrap(text, width);
        let result: string = "";
        let i: int = 0;
        while (i < lines.size()) {
            if (i > 0) { result = result + "\n"; }
            result = result + lines.get(i);
            i = i + 1;
        }
        return result;
    }

    // Remove common leading whitespace from all lines in text.
    public fn dedent(text: string): string {
        let lines: ArrayList<string> = String::split(text, "\n");
        if (lines.size() == 0) { return text; }
        // Find minimum indentation (ignoring blank lines)
        let minIndent: int = -1;
        let i: int = 0;
        while (i < lines.size()) {
            let line: string = lines.get(i);
            if (String.length(line) > 0) {
                let spaces: int = 0;
                while (spaces < String.length(line) && String.charAt(line, spaces) == " ") {
                    spaces = spaces + 1;
                }
                if (minIndent == -1 || spaces < minIndent) {
                    minIndent = spaces;
                }
            }
            i = i + 1;
        }
        if (minIndent <= 0) { return text; }
        // Remove common indent
        let result: string = "";
        i = 0;
        while (i < lines.size()) {
            if (i > 0) { result = result + "\n"; }
            let line: string = lines.get(i);
            if (String.length(line) > 0) {
                result = result + String.substring(line, minIndent, String.length(line));
            }
            i = i + 1;
        }
        return result;
    }

    // Add prefix to every line in text.
    public fn indent(text: string, prefix: string): string {
        let lines: ArrayList<string> = String::split(text, "\n");
        let result: string = "";
        let i: int = 0;
        while (i < lines.size()) {
            if (i > 0) { result = result + "\n"; }
            let line: string = lines.get(i);
            if (String.length(line) > 0) {
                result = result + prefix + line;
            } else {
                result = result + line;
            }
            i = i + 1;
        }
        return result;
    }

    // Truncate text to at most width characters, adding ellipsis if truncated.
    public fn shorten(text: string, width: int): string {
        if (String.length(text) <= width) { return text; }
        if (width <= 3) {
            let result: string = "";
            let i: int = 0;
            while (i < width) {
                result = result + ".";
                i = i + 1;
            }
            return result;
        }
        let result: string = String.substring(text, 0, width - 3);
        return result + "...";
    }
}
