// Unix-style filename pattern matching.
import tt::util::ArrayList;
import tt::lang::String;

// Match a filename against a shell-style pattern (case-insensitive on some platforms)
public fn fnmatch(name: string, pattern: string): bool {
    return _match(name, pattern, 0, 0);
}

// Case-sensitive matching
public fn fnmatchCase(name: string, pattern: string): bool {
    return _matchExact(name, pattern, 0, 0);
}

// Filter a list of names, returning only those that match the pattern
public fn filter(names: ArrayList<string>, pattern: string): ArrayList<string> {
    let result: ArrayList<string> = new ArrayList<string>();
    var i: int = 0;
    while (i < names.size()) {
        if (fnmatch(names.get(i), pattern)) {
            result.add(names.get(i));
        }
        i = i + 1;
    }
    return result;
}

// Convert a shell-style glob pattern to a regex pattern string
public fn translate(pattern: string): string {
    let result: string = "";
    var i: int = 0;
    while (i < String.length(pattern)) {
        let ch: string = String.charAt(pattern, i);
        if (ch == "*") {
            result = result + ".*";
        } else if (ch == "?") {
            result = result + ".";
        } else if (ch == "[") {
            let j: int = i + 1;
            var bracketContent: string = "[";
            if (j < String.length(pattern) && String.charAt(pattern, j) == "!") {
                bracketContent = bracketContent + "^";
                j = j + 1;
            }
            if (j < String.length(pattern) && String.charAt(pattern, j) == "]") {
                bracketContent = bracketContent + "]";
                j = j + 1;
            }
            while (j < String.length(pattern) && String.charAt(pattern, j) != "]") {
                let c: string = String.charAt(pattern, j);
                if (c == "\\") {
                    bracketContent = bracketContent + "\\";
                    j = j + 1;
                    if (j < String.length(pattern)) {
                        bracketContent = bracketContent + String.charAt(pattern, j);
                    }
                } else {
                    bracketContent = bracketContent + c;
                }
                j = j + 1;
            }
            bracketContent = bracketContent + "]";
            result = result + bracketContent;
            i = j;
        } else if (ch == "\\") {
            i = i + 1;
            if (i < String.length(pattern)) {
                result = result + "\\" + String.charAt(pattern, i);
            }
        } else {
            // Escape regex special characters
            if (ch == "." || ch == "+" || ch == "(" || ch == ")" || ch == "{" || ch == "}" || ch == "|" || ch == "^" || ch == "$") {
                result = result + "\\" + ch;
            } else {
                result = result + ch;
            }
        }
        i = i + 1;
    }
    return result;
}

// Internal: case-insensitive matching
fn _match(name: string, pattern: string, ni: int, pi: int): bool {
    while (pi < String.length(pattern)) {
        let ch: string = String.charAt(pattern, pi);
        if (ch == "*") {
            // * matches any sequence (including empty)
            pi = pi + 1;
            // Skip consecutive *s
            while (pi < String.length(pattern) && String.charAt(pattern, pi) == "*") {
                pi = pi + 1;
            }
            if (pi >= String.length(pattern)) {
                return true;
            }
            // Try matching * against 0..N characters
            var k: int = ni;
            while (k <= String.length(name)) {
                if (_match(name, pattern, k, pi)) {
                    return true;
                }
                k = k + 1;
            }
            return false;
        } else if (ch == "?") {
            // ? matches any single character
            if (ni >= String.length(name)) {
                return false;
            }
            ni = ni + 1;
            pi = pi + 1;
        } else if (ch == "[") {
            if (ni >= String.length(name)) {
                return false;
            }
            pi = pi + 1;
            let negate: bool = false;
            if (pi < String.length(pattern) && String.charAt(pattern, pi) == "!") {
                negate = true;
                pi = pi + 1;
            }
            var matched: bool = false;
            let nameCh: string = String.toUpperCase(String.charAt(name, ni));
            while (pi < String.length(pattern) && String.charAt(pattern, pi) != "]") {
                let lo: string = String.toUpperCase(String.charAt(pattern, pi));
                pi = pi + 1;
                if (pi < String.length(pattern) && String.charAt(pattern, pi) == "-" && pi + 1 < String.length(pattern) && String.charAt(pattern, pi + 1) != "]") {
                    let hi: string = String.toUpperCase(String.charAt(pattern, pi + 1));
                    if (nameCh >= lo && nameCh <= hi) {
                        matched = true;
                    }
                    pi = pi + 2;
                } else {
                    if (nameCh == lo) {
                        matched = true;
                    }
                }
            }
            if (pi < String.length(pattern) && String.charAt(pattern, pi) == "]") {
                pi = pi + 1;
            }
            if (negate) {
                matched = !matched;
            }
            if (!matched) {
                return false;
            }
            ni = ni + 1;
        } else if (ch == "\\") {
            pi = pi + 1;
            if (pi < String.length(pattern)) {
                let esc: string = String.charAt(pattern, pi);
                if (ni >= String.length(name)) {
                    return false;
                }
                if (String.toUpperCase(String.charAt(name, ni)) != String.toUpperCase(esc)) {
                    return false;
                }
                ni = ni + 1;
                pi = pi + 1;
            }
        } else {
            if (ni >= String.length(name)) {
                return false;
            }
            if (String.toUpperCase(String.charAt(name, ni)) != String.toUpperCase(ch)) {
                return false;
            }
            ni = ni + 1;
            pi = pi + 1;
        }
    }
    return ni >= String.length(name);
}

// Internal: case-sensitive matching
fn _matchExact(name: string, pattern: string, ni: int, pi: int): bool {
    while (pi < String.length(pattern)) {
        let ch: string = String.charAt(pattern, pi);
        if (ch == "*") {
            pi = pi + 1;
            while (pi < String.length(pattern) && String.charAt(pattern, pi) == "*") {
                pi = pi + 1;
            }
            if (pi >= String.length(pattern)) {
                return true;
            }
            var k: int = ni;
            while (k <= String.length(name)) {
                if (_matchExact(name, pattern, k, pi)) {
                    return true;
                }
                k = k + 1;
            }
            return false;
        } else if (ch == "?") {
            if (ni >= String.length(name)) {
                return false;
            }
            ni = ni + 1;
            pi = pi + 1;
        } else if (ch == "[") {
            if (ni >= String.length(name)) {
                return false;
            }
            pi = pi + 1;
            let negate: bool = false;
            if (pi < String.length(pattern) && String.charAt(pattern, pi) == "!") {
                negate = true;
                pi = pi + 1;
            }
            var matched: bool = false;
            let nameCh: string = String.charAt(name, ni);
            while (pi < String.length(pattern) && String.charAt(pattern, pi) != "]") {
                let lo: string = String.charAt(pattern, pi);
                pi = pi + 1;
                if (pi < String.length(pattern) && String.charAt(pattern, pi) == "-" && pi + 1 < String.length(pattern) && String.charAt(pattern, pi + 1) != "]") {
                    let hi: string = String.charAt(pattern, pi + 1);
                    if (nameCh >= lo && nameCh <= hi) {
                        matched = true;
                    }
                    pi = pi + 2;
                } else {
                    if (nameCh == lo) {
                        matched = true;
                    }
                }
            }
            if (pi < String.length(pattern) && String.charAt(pattern, pi) == "]") {
                pi = pi + 1;
            }
            if (negate) {
                matched = !matched;
            }
            if (!matched) {
                return false;
            }
            ni = ni + 1;
        } else if (ch == "\\") {
            pi = pi + 1;
            if (pi < String.length(pattern)) {
                let esc: string = String.charAt(pattern, pi);
                if (ni >= String.length(name)) {
                    return false;
                }
                if (String.charAt(name, ni) != esc) {
                    return false;
                }
                ni = ni + 1;
                pi = pi + 1;
            }
        } else {
            if (ni >= String.length(name)) {
                return false;
            }
            if (String.charAt(name, ni) != ch) {
                return false;
            }
            ni = ni + 1;
            pi = pi + 1;
        }
    }
    return ni >= String.length(name);
}
