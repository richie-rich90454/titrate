// Bisect provides binary search insertion points for sorted arrays, mirroring Python's bisect module.
import tt::util::ArrayList;

// Returns the leftmost index where x should be inserted to keep arr sorted.
public fn bisectLeft(arr: ArrayList<int>, x: int): int {
    var lo: int = 0;
    var hi: int = arr.size();
    while (lo < hi) {
        let mid: int = lo + (hi - lo) / 2;
        if (arr.get(mid) < x) {
            lo = mid + 1;
        } else {
            hi = mid;
        }
    }
    return lo;
}

// Returns the rightmost index where x should be inserted to keep arr sorted.
public fn bisectRight(arr: ArrayList<int>, x: int): int {
    var lo: int = 0;
    var hi: int = arr.size();
    while (lo < hi) {
        let mid: int = lo + (hi - lo) / 2;
        if (arr.get(mid) <= x) {
            lo = mid + 1;
        } else {
            hi = mid;
        }
    }
    return lo;
}

// Inserts x into arr at the leftmost position to maintain sorted order.
public fn insortLeft(arr: ArrayList<int>, x: int) {
    let idx: int = bisectLeft(arr, x);
    arr.add(idx, x);
}

// Inserts x into arr at the rightmost position to maintain sorted order.
public fn insortRight(arr: ArrayList<int>, x: int) {
    let idx: int = bisectRight(arr, x);
    arr.add(idx, x);
}

// Returns the leftmost index where x should be inserted to keep arr sorted (double variant).
public fn bisectLeftD(arr: ArrayList<double>, x: double): int {
    var lo: int = 0;
    var hi: int = arr.size();
    while (lo < hi) {
        let mid: int = lo + (hi - lo) / 2;
        if (arr.get(mid) < x) {
            lo = mid + 1;
        } else {
            hi = mid;
        }
    }
    return lo;
}

// Returns the rightmost index where x should be inserted to keep arr sorted (double variant).
public fn bisectRightD(arr: ArrayList<double>, x: double): int {
    var lo: int = 0;
    var hi: int = arr.size();
    while (lo < hi) {
        let mid: int = lo + (hi - lo) / 2;
        if (arr.get(mid) <= x) {
            lo = mid + 1;
        } else {
            hi = mid;
        }
    }
    return lo;
}
