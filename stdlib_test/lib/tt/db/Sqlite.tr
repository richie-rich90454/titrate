// Embedded SQL database interface.
import tt::util::ArrayList;
import tt::util::HashMap;
import tt::lang::Variant;

public class SqliteConnection {
    private int handle;
    private bool closed;

    public fn init(path: string) {
        this.handle = Sqlite_open(path);
        this.closed = false;
    }

    public fn execute(sql: string): void {
        Sqlite_execute(this.handle, sql);
    }

    public fn query(sql: string): SqliteResultSet {
        let rsHandle: int = Sqlite_query(this.handle, sql);
        return new SqliteResultSet(rsHandle);
    }

    public fn lastInsertId(): int {
        return Sqlite_lastInsertId(this.handle);
    }

    public fn close(): void {
        if (!this.closed) {
            Sqlite_close(this.handle);
            this.closed = true;
        }
    }

    public fn beginTransaction(): void {
        this.execute("BEGIN");
    }

    public fn commit(): void {
        this.execute("COMMIT");
    }

    public fn rollback(): void {
        this.execute("ROLLBACK");
    }

    public fn isClosed(): bool {
        return this.closed;
    }

    // Execute a SQL statement multiple times with different parameter sets.
    // Each element of params is an ArrayList of values bound positionally.
    public fn executeMany(sql: string, params: ArrayList<ArrayList<Variant>>): void {
        var i: int = 0;
        while (i < params.size()) {
            let row: ArrayList<Variant> = params.get(i);
            Sqlite_executePrepared(this.handle, sql, row);
            i = i + 1;
        }
    }

    // Execute a script containing multiple SQL statements separated by semicolons.
    public fn executeScript(script: string): void {
        let statements: ArrayList<string> = String.split(script, ";");
        var i: int = 0;
        while (i < statements.size()) {
            let stmt: string = String.trim(statements.get(i));
            if (String.length(stmt) > 0) {
                Sqlite_execute(this.handle, stmt);
            }
            i = i + 1;
        }
    }

    // Back up this database to a target database path.
    public fn backup(targetPath: string): void {
        Sqlite_backup(this.handle, targetPath);
    }
}

public class SqliteResultSet {
    private int handle;
    private bool closed;
    private bool hasRow;

    public fn init(handle: int) {
        this.handle = handle;
        this.closed = false;
        this.hasRow = false;
    }

    public fn next(): bool {
        this.hasRow = Sqlite_nextRow(this.handle);
        return this.hasRow;
    }

    public fn getInt(col: int): int {
        return Sqlite_getInt(this.handle, col);
    }

    public fn getString(col: int): string {
        return Sqlite_getString(this.handle, col);
    }

    public fn getDouble(col: int): double {
        return Sqlite_getDouble(this.handle, col);
    }

    public fn getColumnCount(): int {
        return Sqlite_columnCount(this.handle);
    }

    public fn getColumnName(col: int): string {
        return Sqlite_columnName(this.handle, col);
    }

    public fn close(): void {
        if (!this.closed) {
            Sqlite_closeResult(this.handle);
            this.closed = true;
        }
    }
}

// Row represents a single result row with column-name access.
// Modeled after Python's sqlite3.Row for key-based value lookup.
public class Row {
    public ArrayList<string> columnNames;
    public ArrayList<Variant> values;

    public fn init(columnNames: ArrayList<string>, values: ArrayList<Variant>) {
        this.columnNames = columnNames;
        this.values = values;
    }

    // Return the list of column names (keys) for this row.
    public fn keys(): ArrayList<string> {
        return this.columnNames;
    }

    // Get a value by column name. Returns null if the column is not found.
    public fn getValueByName(name: string): Variant {
        var i: int = 0;
        while (i < this.columnNames.size()) {
            if (this.columnNames.get(i) == name) {
                return this.values.get(i);
            }
            i = i + 1;
        }
        return null;
    }

    // Get a value by column index.
    public fn getValueByIndex(index: int): Variant {
        return this.values.get(index);
    }

    public fn toString(): string {
        let result: string = "Row{";
        var i: int = 0;
        while (i < this.columnNames.size()) {
            if (i > 0) {
                result = result + ", ";
            }
            result = result + this.columnNames.get(i) + "=" + this.values.get(i);
            i = i + 1;
        }
        return result + "}";
    }
}

// Base exception for SQLite database errors.
public class DatabaseError {
    public string message;

    public fn init(message: string) {
        this.message = message;
    }

    public fn getMessage(): string {
        return this.message;
    }

    public fn toString(): string {
        return "DatabaseError: " + this.message;
    }
}

// Raised when a relational integrity constraint is violated.
public class IntegrityError {
    public string message;

    public fn init(message: string) {
        this.message = message;
    }

    public fn getMessage(): string {
        return this.message;
    }

    public fn toString(): string {
        return "IntegrityError: " + this.message;
    }
}

// Raised for database operation errors (e.g. locked, disconnected).
public class OperationalError {
    public string message;

    public fn init(message: string) {
        this.message = message;
    }

    public fn getMessage(): string {
        return this.message;
    }

    public fn toString(): string {
        return "OperationalError: " + this.message;
    }
}
