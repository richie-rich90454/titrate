// File locking for concurrent access control.
public class FileLock {
    private string path;
    private bool shared;
    private bool locked;
    private string lockFile;

    public fn init(path: string, shared: bool) {
        this.path = path;
        this.shared = shared;
        this.locked = false;
        this.lockFile = path + ".lock";
    }

    public fn tryLock(): bool {
        if (this.locked) {
            return true;
        }
        let lockType: string = this.shared ? "SHARED" : "EXCLUSIVE";
        let result: bool = File_tryLock(this.path, lockType);
        if (result) {
            this.locked = true;
        }
        return result;
    }

    public fn lock(timeoutMs: long): bool {
        if (this.locked) {
            return true;
        }
        let lockType: string = this.shared ? "SHARED" : "EXCLUSIVE";
        let deadline: long = System_currentTimeMillis() + timeoutMs;
        while (true) {
            let result: bool = File_tryLock(this.path, lockType);
            if (result) {
                this.locked = true;
                return true;
            }
            let now: long = System_currentTimeMillis();
            if (now >= deadline) {
                return false;
            }
            Thread_sleep(10);
        }
    }

    public fn unlock(): void {
        if (this.locked) {
            File_unlock(this.path);
            this.locked = false;
        }
    }

    public fn isLocked(): bool {
        return this.locked;
    }

    public fn getPath(): string {
        return this.path;
    }

    public fn isShared(): bool {
        return this.shared;
    }

    public fn isExclusive(): bool {
        return !this.shared;
    }

    public fn getLockFile(): string {
        return this.lockFile;
    }
}

// Execute function with lock, auto-unlock when done.
public fn withLock(path: string, shared: bool, f: fn(): void): void {
    let lock: FileLock = new FileLock(path, shared);
    if (lock.tryLock()) {
        try {
            f();
        } finally {
            lock.unlock();
        }
    }
}

// Execute function with lock timeout, returns false if couldn't acquire.
public fn withLockTimeout(path: string, shared: bool, timeoutMs: long, f: fn(): void): bool {
    let lock: FileLock = new FileLock(path, shared);
    if (lock.lock(timeoutMs)) {
        try {
            f();
        } finally {
            lock.unlock();
        }
        return true;
    }
    return false;
}
