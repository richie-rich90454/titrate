// Asynchronous file I/O operations.
import tt::util::ArrayList;

public class AsyncFileReader {
    private string path;
    private int bufferSize;
    private long position;
    private bool eof;
    private long fileSize;

    public fn init(path: string, bufferSize: int) {
        this.path = path;
        this.bufferSize = bufferSize;
        this.position = 0;
        this.eof = false;
        this.fileSize = File_size(path);
    }

    public fn readAll(callback: fn(string): void): void {
        while (!this.eof) {
            let chunk: string = this._readChunkInternal();
            if (String.length(chunk) > 0) {
                callback(chunk);
            }
        }
    }

    public fn readChunk(offset: long, length: int, callback: fn(string): void): void {
        let data: string = File_readChunk(this.path, offset, length);
        if (data != null && String.length(data) > 0) {
            callback(data);
        }
    }

    public fn readLines(callback: fn(string): void, onComplete: fn(): void): void {
        let remaining: string = "";
        while (!this.eof) {
            let chunk: string = this._readChunkInternal();
            if (String.length(chunk) == 0) {
                break;
            }
            remaining = remaining + chunk;
            while (true) {
                let idx: int = String.indexOf(remaining, "\n");
                if (idx < 0) {
                    break;
                }
                let line: string = String.substring(remaining, 0, idx);
                callback(line);
                remaining = String.substring(remaining, idx + 1);
            }
        }
        // Emit any remaining data as the last line
        if (String.length(remaining) > 0) {
            callback(remaining);
        }
        onComplete();
    }

    public fn getProgress(): double {
        if (this.fileSize <= 0) {
            return 0.0;
        }
        let pos: long = this.position;
        if (pos >= this.fileSize) {
            return 1.0;
        }
        return Double.fromLong(pos) / Double.fromLong(this.fileSize);
    }

    public fn getPosition(): long {
        return this.position;
    }

    public fn isEof(): bool {
        return this.eof;
    }

    public fn getPath(): string {
        return this.path;
    }

    public fn getBufferSize(): int {
        return this.bufferSize;
    }

    public fn reset(): void {
        this.position = 0;
        this.eof = false;
    }

    // --- Private helpers ---

    private fn _readChunkInternal(): string {
        if (this.eof) {
            return "";
        }
        let data: string = File_readChunk(this.path, this.position, this.bufferSize);
        if (data == null || String.length(data) == 0) {
            this.eof = true;
            return "";
        }
        this.position = this.position + String.length(data);
        if (String.length(data) < this.bufferSize) {
            this.eof = true;
        }
        return data;
    }
}

// Read a file with progress tracking. Calls onChunk for each chunk read,
// and onProgress with the progress ratio (0.0 to 1.0) after each chunk.
public fn readWithProgress(path: string, bufferSize: int, onChunk: fn(string): void, onProgress: fn(double): void): void {
    let reader: AsyncFileReader = new AsyncFileReader(path, bufferSize);
    while (!reader.isEof()) {
        let chunk: string = File_readChunk(path, reader.getPosition(), bufferSize);
        if (chunk == null || String.length(chunk) == 0) {
            break;
        }
        onChunk(chunk);
        reader.getPosition();
        onProgress(reader.getProgress());
    }
}

public class AsyncFileWriter {
    private string path;
    private ArrayList<string> buffer;
    private bool flushing;

    public fn init(path: string) {
        this.path = path;
        this.buffer = new ArrayList<string>();
        this.flushing = false;
    }

    public fn write(data: string): void {
        this.buffer.add(data);
    }

    public fn writeLine(data: string): void {
        this.buffer.add(data + "\n");
    }

    public fn flush(callback: fn(): void): void {
        this.flushing = true;
        var i: int = 0;
        while (i < this.buffer.size()) {
            File_append(this.path, this.buffer.get(i));
            i = i + 1;
        }
        this.buffer = new ArrayList<string>();
        this.flushing = false;
        if (callback != null) {
            callback();
        }
    }

    public fn close(): void {
        this.flush(null);
    }

    public fn getPath(): string {
        return this.path;
    }

    public fn bufferedChunks(): int {
        return this.buffer.size();
    }

    public fn isFlushing(): bool {
        return this.flushing;
    }
}
