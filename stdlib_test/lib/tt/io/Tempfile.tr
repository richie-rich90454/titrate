// Tempfile — extended temporary file utilities with SpooledTemporaryFile and mkstemp/mkdtemp.
import tt::util::ArrayList;
import tt::util::Pair;
import tt::lang::String;

// TemporaryFile provides a temporary file with automatic cleanup.
public class TemporaryFile {
    public string path;
    public string stream;
    public bool closed;
    public bool deleted;
    public bool deleteOnClose;

    public fn init(prefix: string, suffix: string, deleteOnClose: bool) {
        let baseDir: string = getTempDir();
        let randomHex: string = Os_urandom(8);
        this.path = Path_join(baseDir, prefix + randomHex + suffix);
        this.stream = "";
        this.closed = false;
        this.deleted = false;
        this.deleteOnClose = deleteOnClose;
        File_writeFile(this.path, "");
    }

    // Write data to the temporary file.
    public fn write(data: string): void {
        if (this.closed) {
            throw "IOError: cannot write to closed temporary file";
        }
        this.stream = this.stream + data;
        File_writeFile(this.path, this.stream);
    }

    // Read the entire contents of the temporary file.
    public fn read(): string {
        if (this.closed) {
            throw "IOError: cannot read from closed temporary file";
        }
        return File_readFile(this.path);
    }

    // Close the temporary file. If deleteOnClose is true, delete the file.
    public fn close(): void {
        if (this.closed) { return; }
        this.closed = true;
        if (this.deleteOnClose && !this.deleted) {
            this._delete();
        }
    }

    // Delete the temporary file.
    private fn _delete(): void {
        if (!this.deleted) {
            Dir_remove(this.path);
            this.deleted = true;
        }
    }

    // Get the file path.
    public fn getName(): string {
        return this.path;
    }
}

// SpooledTemporaryFile buffers data in memory until a size threshold, then rolls over to disk.
public class SpooledTemporaryFile {
    public int maxSize;
    public ArrayList<string> buffer;
    public bool rolledOver;
    public string path;

    public fn init(maxSize: int) {
        this.maxSize = maxSize;
        this.buffer = new ArrayList<string>();
        this.rolledOver = false;
        this.path = "";
    }

    // Write data to the spooled file.
    public fn write(data: string): void {
        if (this.rolledOver) {
            File_append(this.path, data);
        } else {
            this.buffer.add(data);
            // Check if we need to roll over
            let totalSize: int = this._bufferSize();
            if (totalSize > this.maxSize) {
                this.rollover();
            }
        }
    }

    // Read all data from the spooled file.
    public fn read(): string {
        if (this.rolledOver) {
            return File_readFile(this.path);
        }
        let result: string = "";
        var i: int = 0;
        while (i < this.buffer.size()) {
            result = result + this.buffer.get(i);
            i = i + 1;
        }
        return result;
    }

    // Roll over from memory buffer to a disk file.
    public fn rollover(): void {
        if (this.rolledOver) { return; }
        let baseDir: string = getTempDir();
        let randomHex: string = Os_urandom(8);
        this.path = Path_join(baseDir, "spool_" + randomHex + ".tmp");
        // Write buffered data to disk
        let content: string = "";
        var i: int = 0;
        while (i < this.buffer.size()) {
            content = content + this.buffer.get(i);
            i = i + 1;
        }
        File_writeFile(this.path, content);
        this.buffer = new ArrayList<string>();
        this.rolledOver = true;
    }

    // Compute the total size of the in-memory buffer.
    private fn _bufferSize(): int {
        var total: int = 0;
        var i: int = 0;
        while (i < this.buffer.size()) {
            total = total + String.length(this.buffer.get(i));
            i = i + 1;
        }
        return total;
    }
}

// Get the system's temporary directory path.
fn getTempDir(): string {
    var tmp: string = Sys_env("TEMP");
    if (tmp != null && String.length(tmp) > 0) {
        return tmp;
    }
    tmp = Sys_env("TMP");
    if (tmp != null && String.length(tmp) > 0) {
        return tmp;
    }
    tmp = Sys_env("TMPDIR");
    if (tmp != null && String.length(tmp) > 0) {
        return tmp;
    }
    return "/tmp";
}

// Create a temporary file and return a Pair of (fd, path).
public fn mkstemp(prefix: string, suffix: string): Pair<string, string> {
    let baseDir: string = getTempDir();
    let randomHex: string = Os_urandom(8);
    let path: string = Path_join(baseDir, prefix + randomHex + suffix);
    File_writeFile(path, "");
    let fd: string = path;
    return new Pair<string, string>(fd, path);
}

// Create a temporary directory and return its path.
public fn mkdtemp(prefix: string): string {
    let baseDir: string = getTempDir();
    let randomHex: string = Os_urandom(8);
    let dirPath: string = Path_join(baseDir, prefix + randomHex);
    Dir_create(dirPath);
    return dirPath;
}
