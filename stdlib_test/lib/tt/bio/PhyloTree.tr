// PhyloTree.tr — Phylogenetic tree construction and Newick format I/O
import tt::util::ArrayList;
import tt::util::HashMap;
import tt::lang::String;
import tt::lang::Integer;
import tt::math::Math;
import tt::math::MathAdvanced;

public class PhyloNode {
    public string name;
    public double distance;
    public ArrayList<PhyloNode> children;
    public PhyloNode parent;

    public fn init(n: string, d: double) {
        this.name = n;
        this.distance = d;
        this.children = new ArrayList<PhyloNode>();
        this.parent = null;
    }

    public fn isLeaf(): bool {
        return this.children.size() == 0;
    }

    public fn addChild(child: PhyloNode): void {
        child.parent = this;
        this.children.add(child);
    }

    public fn leafCount(): int {
        if (this.isLeaf()) { return 1; }
        var count: int = 0;
        var i: int = 0;
        while (i < this.children.size()) {
            count = count + this.children.get(i).leafCount();
            i = i + 1;
        }
        return count;
    }
}

public class PhyloTree {
    public PhyloNode root;

    public fn init(r: PhyloNode) {
        this.root = r;
    }

    public fn getLeaves(): ArrayList<PhyloNode> {
        let leaves: ArrayList<PhyloNode> = new ArrayList<PhyloNode>();
        _collectLeaves(this.root, leaves);
        return leaves;
    }

    fn _collectLeaves(node: PhyloNode, leaves: ArrayList<PhyloNode>): void {
        if (node.isLeaf()) {
            leaves.add(node);
            return;
        }
        var i: int = 0;
        while (i < node.children.size()) {
            _collectLeaves(node.children.get(i), leaves);
            i = i + 1;
        }
    }

    public fn toNewick(): string {
        return _nodeToNewick(this.root) + ";";
    }

    public fn depth(): int {
        return _nodeDepth(this.root);
    }

    fn _nodeDepth(node: PhyloNode): int {
        if (node.isLeaf()) { return 0; }
        var maxD: int = 0;
        var i: int = 0;
        while (i < node.children.size()) {
            let d: int = _nodeDepth(node.children.get(i));
            if (d > maxD) { maxD = d; }
            i = i + 1;
        }
        return maxD + 1;
    }

    fn _nodeToNewick(node: PhyloNode): string {
        if (node.isLeaf()) {
            if (node.distance > 0.0) {
                return node.name + ":" + Double.toString(node.distance);
            }
            return node.name;
        }
        let parts: string = "";
        var i: int = 0;
        while (i < node.children.size()) {
            if (i > 0) { parts = parts + ","; }
            parts = parts + _nodeToNewick(node.children.get(i));
            i = i + 1;
        }
        let result: string = "(" + parts + ")";
        if (String.length(node.name) > 0) {
            result = result + node.name;
        }
        if (node.distance > 0.0) {
            result = result + ":" + Double.toString(node.distance);
        }
        return result;
    }
}

public fn parseNewick(s: string): PhyloTree {
    let parser: _NewickParser = new _NewickParser(s);
    let root: PhyloNode = parser.parse();
    return new PhyloTree(root);
}

class _NewickParser {
    public string input;
    public int pos;

    public fn init(s: string) {
        this.input = s;
        this.pos = 0;
    }

    public fn parse(): PhyloNode {
        let node: PhyloNode = _parseNode();
        // Skip trailing semicolon
        if (this.pos < String.length(this.input) && String.charAt(this.input, this.pos) == ";") {
            this.pos = this.pos + 1;
        }
        return node;
    }

    fn _parseNode(): PhyloNode {
        let node: PhyloNode;
        if (this.pos < String.length(this.input) && String.charAt(this.input, this.pos) == "(") {
            this.pos = this.pos + 1; // skip (
            node = new PhyloNode("", 0.0);
            let child: PhyloNode = _parseNode();
            node.addChild(child);
            while (this.pos < String.length(this.input) && String.charAt(this.input, this.pos) == ",") {
                this.pos = this.pos + 1; // skip ,
                let nextChild: PhyloNode = _parseNode();
                node.addChild(nextChild);
            }
            if (this.pos < String.length(this.input) && String.charAt(this.input, this.pos) == ")") {
                this.pos = this.pos + 1; // skip )
            }
        } else {
            node = new PhyloNode("", 0.0);
        }
        // Parse label
        let label: string = _parseLabel();
        node.name = label;
        // Parse distance
        if (this.pos < String.length(this.input) && String.charAt(this.input, this.pos) == ":") {
            this.pos = this.pos + 1; // skip :
            let dist: string = _parseLabel();
            node.distance = Double.parseDouble(dist);
        }
        return node;
    }

    fn _parseLabel(): string {
        let start: int = this.pos;
        while (this.pos < String.length(this.input)) {
            let ch: string = String.charAt(this.input, this.pos);
            if (ch == "," || ch == ")" || ch == ":" || ch == ";" || ch == "(") { break; }
            this.pos = this.pos + 1;
        }
        if (this.pos == start) { return ""; }
        return String.substring(this.input, start, this.pos);
    }
}

public fn upgma(distanceMatrix: ArrayList<ArrayList<double>>, names: ArrayList<string>): PhyloTree {
    let n: int = names.size();
    // Create leaf nodes
    let nodes: ArrayList<PhyloNode> = new ArrayList<PhyloNode>();
    let active: ArrayList<bool> = new ArrayList<bool>();
    let heights: ArrayList<double> = new ArrayList<double>();
    var i: int = 0;
    while (i < n) {
        nodes.add(new PhyloNode(names.get(i), 0.0));
        active.add(true);
        heights.add(0.0);
        i = i + 1;
    }

    var remaining: int = n;
    while (remaining > 1) {
        // Find minimum distance
        var minDist: double = 1e30;
        var minI: int = -1;
        var minJ: int = -1;
        i = 0;
        while (i < n) {
            if (!active.get(i)) { i = i + 1; continue; }
            var j: int = i + 1;
            while (j < n) {
                if (!active.get(j)) { j = j + 1; continue; }
                let d: double = distanceMatrix.get(i).get(j);
                if (d < minDist) {
                    minDist = d;
                    minI = i;
                    minJ = j;
                }
                j = j + 1;
            }
            i = i + 1;
        }
        if (minI < 0) { break; }

        // Merge clusters
        let newHeight: double = minDist / 2.0;
        let parent: PhyloNode = new PhyloNode("", 0.0);
        let leftChild: PhyloNode = nodes.get(minI);
        let rightChild: PhyloNode = nodes.get(minJ);
        leftChild.distance = newHeight - heights.get(minI);
        rightChild.distance = newHeight - heights.get(minJ);
        parent.addChild(leftChild);
        parent.addChild(rightChild);

        // Update distances
        var k: int = 0;
        while (k < n) {
            if (!active.get(k) || k == minI || k == minJ) { k = k + 1; continue; }
            let di: double = distanceMatrix.get(minI).get(k);
            let dj: double = distanceMatrix.get(minJ).get(k);
            let ni: int = nodes.get(minI).leafCount();
            let nj: int = nodes.get(minJ).leafCount();
            let newDist: double = (di * ni + dj * nj) / (ni + nj);
            distanceMatrix.get(minI).set(k, newDist);
            distanceMatrix.get(k).set(minI, newDist);
            k = k + 1;
        }

        nodes.set(minI, parent);
        heights.set(minI, newHeight);
        active.set(minJ, false);
        remaining = remaining - 1;
    }

    // Find the last active node
    i = 0;
    while (i < n) {
        if (active.get(i)) {
            return new PhyloTree(nodes.get(i));
        }
        i = i + 1;
    }
    return new PhyloTree(new PhyloNode("empty", 0.0));
}

public fn neighborJoining(distanceMatrix: ArrayList<ArrayList<double>>, names: ArrayList<string>): PhyloTree {
    let n: int = names.size();
    if (n <= 1) {
        return new PhyloTree(new PhyloNode(names.get(0), 0.0));
    }
    if (n == 2) {
        let root: PhyloNode = new PhyloNode("", 0.0);
        let left: PhyloNode = new PhyloNode(names.get(0), distanceMatrix.get(0).get(1) / 2.0);
        let right: PhyloNode = new PhyloNode(names.get(1), distanceMatrix.get(0).get(1) / 2.0);
        root.addChild(left);
        root.addChild(right);
        return new PhyloTree(root);
    }

    // NJ algorithm - simplified implementation
    let nodes: ArrayList<PhyloNode> = new ArrayList<PhyloNode>();
    let active: ArrayList<bool> = new ArrayList<bool>();
    var i: int = 0;
    while (i < n) {
        nodes.add(new PhyloNode(names.get(i), 0.0));
        active.add(true);
        i = i + 1;
    }

    var remaining: int = n;
    while (remaining > 2) {
        // Compute row sums
        let rowSums: ArrayList<double> = new ArrayList<double>();
        i = 0;
        while (i < n) {
            var sum: double = 0.0;
            if (active.get(i)) {
                var j: int = 0;
                while (j < n) {
                    if (active.get(j) && j != i) {
                        sum = sum + distanceMatrix.get(i).get(j);
                    }
                    j = j + 1;
                }
            }
            rowSums.add(sum);
            i = i + 1;
        }

        // Find minimum Q value
        var minQ: double = 1e30;
        var minI: int = -1;
        var minJ: int = -1;
        i = 0;
        while (i < n) {
            if (!active.get(i)) { i = i + 1; continue; }
            var j: int = i + 1;
            while (j < n) {
                if (!active.get(j)) { j = j + 1; continue; }
                let q: double = (remaining - 2) * distanceMatrix.get(i).get(j) - rowSums.get(i) - rowSums.get(j);
                if (q < minQ) {
                    minQ = q;
                    minI = i;
                    minJ = j;
                }
                j = j + 1;
            }
            i = i + 1;
        }
        if (minI < 0) { break; }

        // Compute branch lengths
        let delta: double = (rowSums.get(minI) - rowSums.get(minJ)) / (remaining - 2);
        let distIJ: double = distanceMatrix.get(minI).get(minJ);
        let branchI: double = (distIJ + delta) / 2.0;
        let branchJ: double = (distIJ - delta) / 2.0;
        if (branchI < 0.0) { branchI = 0.0; }
        if (branchJ < 0.0) { branchJ = 0.0; }

        let parent: PhyloNode = new PhyloNode("", 0.0);
        let leftChild: PhyloNode = nodes.get(minI);
        let rightChild: PhyloNode = nodes.get(minJ);
        leftChild.distance = branchI;
        rightChild.distance = branchJ;
        parent.addChild(leftChild);
        parent.addChild(rightChild);

        // Update distances to new node
        var k: int = 0;
        while (k < n) {
            if (!active.get(k) || k == minI || k == minJ) { k = k + 1; continue; }
            let newDist: double = (distanceMatrix.get(minI).get(k) + distanceMatrix.get(minJ).get(k) - distIJ) / 2.0;
            distanceMatrix.get(minI).set(k, newDist);
            distanceMatrix.get(k).set(minI, newDist);
            k = k + 1;
        }

        nodes.set(minI, parent);
        active.set(minJ, false);
        remaining = remaining - 1;
    }

    // Connect last two nodes
    let lastNodes: ArrayList<int> = new ArrayList<int>();
    i = 0;
    while (i < n) {
        if (active.get(i)) { lastNodes.add(i); }
        i = i + 1;
    }
    if (lastNodes.size() == 2) {
        let root: PhyloNode = new PhyloNode("", 0.0);
        let left: PhyloNode = nodes.get(lastNodes.get(0));
        let right: PhyloNode = nodes.get(lastNodes.get(1));
        let dist: double = distanceMatrix.get(lastNodes.get(0)).get(lastNodes.get(1));
        left.distance = dist / 2.0;
        right.distance = dist / 2.0;
        root.addChild(left);
        root.addChild(right);
        return new PhyloTree(root);
    }
    return new PhyloTree(nodes.get(lastNodes.get(0)));
}
