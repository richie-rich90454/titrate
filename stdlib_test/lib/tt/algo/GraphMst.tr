// Graph algorithms part 2: MST, topological sort, SCC, cycle detection, DAG check.
import tt::util::ArrayList;
import tt::util::Pair;
import tt::util::Queue;
import tt::util::UnionFind;
import tt::algo::Graph;

public fn kruskalMst(g: Graph): ArrayList<Pair<int, int>> {
    let n: int = g.vertexCount();
    let result: ArrayList<Pair<int, int>> = new ArrayList<Pair<int, int>>();
    // Collect all edges as (weight, u, v)
    let edges: ArrayList<Pair<double, Pair<int, int>>> = new ArrayList<Pair<double, Pair<int, int>>>();
    var u: int = 0;
    while (u < n) {
        let neighbors: ArrayList<Pair<int, double>> = g.getNeighbors(u);
        var j: int = 0;
        while (j < neighbors.size()) {
            let v: int = neighbors.get(j).first;
            let w: double = neighbors.get(j).second;
            // For undirected, only add u < v to avoid duplicates
            if (u < v || g.isDirected()) {
                edges.add(new Pair<double, Pair<int, int>>(w, new Pair<int, int>(u, v)));
            }
            j = j + 1;
        }
        u = u + 1;
    }
    // Sort edges by weight (simple selection sort)
    var i: int = 0;
    while (i < edges.size()) {
        var minIdx: int = i;
        var j: int = i + 1;
        while (j < edges.size()) {
            if (edges.get(j).first < edges.get(minIdx).first) {
                minIdx = j;
            }
            j = j + 1;
        }
        if (minIdx != i) {
            let tmp: Pair<double, Pair<int, int>> = edges.get(i);
            edges.set(i, edges.get(minIdx));
            edges.set(minIdx, tmp);
        }
        i = i + 1;
    }
    // Kruskal with UnionFind
    let uf: UnionFind = new UnionFind(n);
    i = 0;
    while (i < edges.size()) {
        let edge: Pair<int, int> = edges.get(i).second;
        let eu: int = edge.first;
        let ev: int = edge.second;
        if (!uf.connected(eu, ev)) {
            uf.union(eu, ev);
            result.add(new Pair<int, int>(eu, ev));
        }
        i = i + 1;
    }
    return result;
}

public fn primMst(g: Graph, start: int): ArrayList<Pair<int, int>> {
    let n: int = g.vertexCount();
    let result: ArrayList<Pair<int, int>> = new ArrayList<Pair<int, int>>();
    let inMst: ArrayList<bool> = new ArrayList<bool>();
    let key: ArrayList<double> = new ArrayList<double>();
    let parent: ArrayList<int> = new ArrayList<int>();
    var i: int = 0;
    while (i < n) {
        inMst.add(false);
        key.add(999999999.0);
        parent.add(-1);
        i = i + 1;
    }
    key.set(start, 0.0);
    var count: int = 0;
    while (count < n) {
        // Find minimum key vertex not in MST
        var u: int = -1;
        var minKey: double = 999999999.0;
        var j: int = 0;
        while (j < n) {
            if (!inMst.get(j) && key.get(j) < minKey) {
                minKey = key.get(j);
                u = j;
            }
            j = j + 1;
        }
        if (u == -1) {
            break;
        }
        inMst.set(u, true);
        if (parent.get(u) != -1) {
            result.add(new Pair<int, int>(parent.get(u), u));
        }
        let neighbors: ArrayList<Pair<int, double>> = g.getNeighbors(u);
        var k: int = 0;
        while (k < neighbors.size()) {
            let v: int = neighbors.get(k).first;
            let w: double = neighbors.get(k).second;
            if (!inMst.get(v) && w < key.get(v)) {
                key.set(v, w);
                parent.set(v, u);
            }
            k = k + 1;
        }
        count = count + 1;
    }
    return result;
}

public fn topologicalSort(g: Graph): ArrayList<int> {
    let n: int = g.vertexCount();
    let result: ArrayList<int> = new ArrayList<int>();
    let inDegree: ArrayList<int> = new ArrayList<int>();
    var i: int = 0;
    while (i < n) {
        inDegree.add(0);
        i = i + 1;
    }
    // Compute in-degrees
    i = 0;
    while (i < n) {
        let neighbors: ArrayList<Pair<int, double>> = g.getNeighbors(i);
        var j: int = 0;
        while (j < neighbors.size()) {
            let v: int = neighbors.get(j).first;
            inDegree.set(v, inDegree.get(v) + 1);
            j = j + 1;
        }
        i = i + 1;
    }
    // Kahn's algorithm
    let queue: Queue<int> = new Queue<int>();
    i = 0;
    while (i < n) {
        if (inDegree.get(i) == 0) {
            queue.enqueue(i);
        }
        i = i + 1;
    }
    while (!queue.isEmpty()) {
        let current: int = queue.dequeue();
        result.add(current);
        let neighbors: ArrayList<Pair<int, double>> = g.getNeighbors(current);
        var j: int = 0;
        while (j < neighbors.size()) {
            let v: int = neighbors.get(j).first;
            inDegree.set(v, inDegree.get(v) - 1);
            if (inDegree.get(v) == 0) {
                queue.enqueue(v);
            }
            j = j + 1;
        }
    }
    return result;
}

public fn stronglyConnectedComponents(g: Graph): ArrayList<ArrayList<int>> {
    let n: int = g.vertexCount();
    let result: ArrayList<ArrayList<int>> = new ArrayList<ArrayList<int>>();
    // Step 1: Compute finish order via DFS
    let visited: ArrayList<bool> = new ArrayList<bool>();
    let finishOrder: ArrayList<int> = new ArrayList<int>();
    var i: int = 0;
    while (i < n) {
        visited.add(false);
        i = i + 1;
    }
    i = 0;
    while (i < n) {
        if (!visited.get(i)) {
            _sccDfs1(g, i, visited, finishOrder);
        }
        i = i + 1;
    }
    // Step 2: Build reverse graph
    let rev: Graph = new Graph(n, true);
    i = 0;
    while (i < n) {
        let neighbors: ArrayList<Pair<int, double>> = g.getNeighbors(i);
        var j: int = 0;
        while (j < neighbors.size()) {
            let v: int = neighbors.get(j).first;
            let w: double = neighbors.get(j).second;
            rev.addEdge(v, i, w);
            j = j + 1;
        }
        i = i + 1;
    }
    // Step 3: DFS on reverse graph in reverse finish order
    let visited2: ArrayList<bool> = new ArrayList<bool>();
    i = 0;
    while (i < n) {
        visited2.add(false);
        i = i + 1;
    }
    i = finishOrder.size() - 1;
    while (i >= 0) {
        let v: int = finishOrder.get(i);
        if (!visited2.get(v)) {
            let component: ArrayList<int> = new ArrayList<int>();
            _sccDfs2(rev, v, visited2, component);
            result.add(component);
        }
        i = i - 1;
    }
    return result;
}

fn _sccDfs1(g: Graph, v: int, visited: ArrayList<bool>, finishOrder: ArrayList<int>): void {
    visited.set(v, true);
    let neighbors: ArrayList<Pair<int, double>> = g.getNeighbors(v);
    var i: int = 0;
    while (i < neighbors.size()) {
        let u: int = neighbors.get(i).first;
        if (!visited.get(u)) {
            _sccDfs1(g, u, visited, finishOrder);
        }
        i = i + 1;
    }
    finishOrder.add(v);
}

fn _sccDfs2(g: Graph, v: int, visited: ArrayList<bool>, component: ArrayList<int>): void {
    visited.set(v, true);
    component.add(v);
    let neighbors: ArrayList<Pair<int, double>> = g.getNeighbors(v);
    var i: int = 0;
    while (i < neighbors.size()) {
        let u: int = neighbors.get(i).first;
        if (!visited.get(u)) {
            _sccDfs2(g, u, visited, component);
        }
        i = i + 1;
    }
}

public fn cycleDetection(g: Graph): bool {
    let n: int = g.vertexCount();
    let visited: ArrayList<bool> = new ArrayList<bool>();
    let recStack: ArrayList<bool> = new ArrayList<bool>();
    var i: int = 0;
    while (i < n) {
        visited.add(false);
        recStack.add(false);
        i = i + 1;
    }
    i = 0;
    while (i < n) {
        if (!visited.get(i)) {
            if (_cycleDfs(g, i, visited, recStack)) {
                return true;
            }
        }
        i = i + 1;
    }
    return false;
}

fn _cycleDfs(g: Graph, v: int, visited: ArrayList<bool>, recStack: ArrayList<bool>): bool {
    visited.set(v, true);
    recStack.set(v, true);
    let neighbors: ArrayList<Pair<int, double>> = g.getNeighbors(v);
    var i: int = 0;
    while (i < neighbors.size()) {
        let u: int = neighbors.get(i).first;
        if (!visited.get(u)) {
            if (_cycleDfs(g, u, visited, recStack)) {
                return true;
            }
        } else if (recStack.get(u)) {
            return true;
        }
        i = i + 1;
    }
    recStack.set(v, false);
    return false;
}

public fn isDag(g: Graph): bool {
    return !cycleDetection(g);
}
