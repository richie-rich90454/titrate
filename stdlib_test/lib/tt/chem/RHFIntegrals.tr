import tt::chem::Atom;
import tt::math::Math;
import tt::math::MathAdvanced;
import tt::lang::DataFile;
import tt::json::JsonValue;
import tt::util::HashMap;
import tt::lang::Integer;
import tt::lang::Double;

// RHF two-electron integrals, orbital exponent, basis-to-atom mapping

// ---- Data loaded from external JSON via DataFile ----

var _zetaCache: HashMap<string, double> = new HashMap<string, double>();
var _zetaLoaded: bool = false;

fn _ensureZetaLoaded(): void {
    if (_zetaLoaded) {
        return;
    }
    let data: JsonValue = DataFile.load("chem/orbital_exponents.json");
    if (data.isNull() || !data.isObject()) {
        _zetaLoaded = true;
        return;
    }
    if (!data.hasKey("exponents")) {
        _zetaLoaded = true;
        return;
    }
    let exps: JsonValue = data.get("exponents");
    if (!exps.isArray()) {
        _zetaLoaded = true;
        return;
    }
    var i: int = 0;
    while (i < exps.size()) {
        let entry: JsonValue = exps.getAt(i);
        if (entry.isObject() && entry.hasKey("symbol")) {
            let sym: string = entry.get("symbol").asString();
            // Use zeta for H/He, zeta_2s for others (valence exponent)
            if (entry.hasKey("zeta")) {
                _zetaCache.put(sym, entry.get("zeta").asNumber());
            } else if (entry.hasKey("zeta_2s")) {
                _zetaCache.put(sym, entry.get("zeta_2s").asNumber());
            }
        }
        i = i + 1;
    }
    _zetaLoaded = true;
}

// Get effective orbital exponent (zeta) for STO-3G-like basis
// Uses Slater rules approximation: zeta = (Z - sigma) / n*
public fn orbitalExponent(atomicNumber: int): double {
    _ensureZetaLoaded();
    // Map atomic number to symbol for lookup
    let sym: string = _atomicSymbol(atomicNumber);
    if (_zetaCache.containsKey(sym)) {
        return _zetaCache.get(sym);
    }
    return atomicNumber as double * 0.95;
}

// Map atomic number to element symbol
fn _atomicSymbol(z: int): string {
    if (z == 1) { return "H"; }
    if (z == 2) { return "He"; }
    if (z == 3) { return "Li"; }
    if (z == 4) { return "Be"; }
    if (z == 5) { return "B"; }
    if (z == 6) { return "C"; }
    if (z == 7) { return "N"; }
    if (z == 8) { return "O"; }
    if (z == 9) { return "F"; }
    if (z == 10) { return "Ne"; }
    return "";
}

// Map basis function index to atom index
public fn basisToAtom(rhf: RHF, mu: int): int {
    let nAtoms: int = rhf.molecule.atomCount();
    if (nAtoms == 0) { return 0; }
    // Distribute basis functions evenly across atoms
    var perAtom: int = rhf.basisSize / nAtoms;
    if (perAtom < 1) { perAtom = 1; }
    var atomIdx: int = mu / perAtom;
    if (atomIdx >= nAtoms) { atomIdx = nAtoms - 1; }
    return atomIdx;
}

// Compute two-electron integral (mu nu | lambda sigma) approximation
// Using the Mulliken approximation: (mu nu | lam sig) ~ 0.5 * S_mu_nu * S_lam_sig * J_avg
// where J_avg depends on the orbital exponents and distances
public fn twoElectronIntegral(rhf: RHF, mu: int, nu: int, lam: int, sig: int): double {
    let am: int = basisToAtom(rhf, mu);
    let an: int = basisToAtom(rhf, nu);
    let al: int = basisToAtom(rhf, lam);
    let as_: int = basisToAtom(rhf, sig);

    let atomM: Atom = rhf.molecule.getAtom(am);
    let atomN: Atom = rhf.molecule.getAtom(an);
    let atomL: Atom = rhf.molecule.getAtom(al);
    let atomS: Atom = rhf.molecule.getAtom(as_);

    let zM: double = orbitalExponent(atomM.atomicNumber);
    let zN: double = orbitalExponent(atomN.atomicNumber);
    let zL: double = orbitalExponent(atomL.atomicNumber);
    let zS: double = orbitalExponent(atomS.atomicNumber);

    let sMN: double = rhf.overlapMatrix.get(mu).get(nu);
    let sLS: double = rhf.overlapMatrix.get(lam).get(sig);

    // Average orbital exponent for the charge distributions
    let zeta1: double = (zM + zN) * 0.5;
    let zeta2: double = (zL + zS) * 0.5;

    // Distance between centroids of charge distributions
    let cx1: double = (atomM.x + atomN.x) * 0.5;
    let cy1: double = (atomM.y + atomN.y) * 0.5;
    let cz1: double = (atomM.z + atomN.z) * 0.5;
    let cx2: double = (atomL.x + atomS.x) * 0.5;
    let cy2: double = (atomL.y + atomS.y) * 0.5;
    let cz2: double = (atomL.z + atomS.z) * 0.5;
    let dx: double = cx1 - cx2;
    let dy: double = cy1 - cy2;
    let dz: double = cz1 - cz2;
    let R: double = MathAdvanced.sqrt(dx * dx + dy * dy + dz * dz);

    // Coulomb integral: (ab|cd) ~ S_ab * S_cd * 2 * sqrt(zeta1*zeta2) / (zeta1 + zeta2) * F0(R12 * (zeta1+zeta2)/2)
    let rho: double = (zeta1 + zeta2) * 0.5;
    let arg: double = R * rho;
    var f0: double = 0.0;
    if (arg < 1e-10) {
        f0 = 1.0;
    } else {
        f0 = (1.0 - MathAdvanced.exp(-arg)) / arg;
    }
    let coulomb: double = 2.0 * MathAdvanced.sqrt(zeta1 * zeta2) / (zeta1 + zeta2) * f0;

    // Scale by overlap factors (Mulliken-type approximation)
    var result: double = sMN * sLS * coulomb;

    // For same-center distributions, add a correction
    if (am == an && al == as_ && am == al) {
        // On-center: (mu mu | mu mu) ~ 5/8 * zeta for 1s STO
        let zeta: double = zM;
        result = 0.625 * zeta;
    }

    return result;
}
