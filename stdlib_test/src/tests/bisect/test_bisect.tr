public fn run_all_bisect_tests(): void {
    io::println("=== Bisect.tr Tests ===");
    test_bisect_left_basic();
    test_bisect_left_not_found();
    test_bisect_left_empty();
    test_bisect_left_first();
    test_bisect_left_last();
    test_bisect_left_duplicates();
    test_bisect_right_basic();
    test_bisect_right_not_found();
    test_bisect_right_duplicates();
    test_bisect_insortLeft();
    test_bisect_insortRight();
    test_bisect_insortLeft_empty();
    test_bisect_leftD();
    test_bisect_rightD();
    test_bisect_leftD_not_found();
}
