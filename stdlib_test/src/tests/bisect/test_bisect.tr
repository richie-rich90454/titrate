// Test file for Bisect.tr
// Exercises the public API of the Bisect module's top-level functions.
import tt::bisect::Bisect;
import tt::util::ArrayList;
import tt::lang::Integer;
import tt::lang::Double;

public fn test_bisect_left_basic(): void {
    let arr: ArrayList<int> = new ArrayList<int>();
    arr.add(1);
    arr.add(3);
    arr.add(5);
    if (Bisect.bisectLeft(arr, 3) != 1) {
        io::println("FAIL: Bisect.bisectLeft(arr, 3) returned " + Integer.toString(Bisect.bisectLeft(arr, 3)));
    } else {
        io::println("PASS: Bisect.bisectLeft basic works");
    }
}

public fn test_bisect_left_not_found(): void {
    let arr: ArrayList<int> = new ArrayList<int>();
    arr.add(1);
    arr.add(3);
    arr.add(5);
    if (Bisect.bisectLeft(arr, 4) != 2) {
        io::println("FAIL: Bisect.bisectLeft(arr, 4) returned " + Integer.toString(Bisect.bisectLeft(arr, 4)));
    } else {
        io::println("PASS: Bisect.bisectLeft not found works");
    }
}

