    arr.add(1);
    arr.add(3);
    arr.add(3);
    arr.add(3);
    arr.add(5);
    if (Bisect.bisectRight(arr, 3) != 4) {
        io::println("FAIL: Bisect.bisectRight duplicates returned " + Integer.toString(Bisect.bisectRight(arr, 3)));
    } else {
