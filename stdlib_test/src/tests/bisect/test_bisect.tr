public fn test_bisect_insortLeft(): void {
    let arr: ArrayList<int> = new ArrayList<int>();
    arr.add(1);
    arr.add(3);
    arr.add(5);
    Bisect.insortLeft(arr, 3);
    if (arr.size() != 4) {
        io::println("FAIL: Bisect.insortLeft size wrong");
    } else if (arr.get(1) != 3 || arr.get(2) != 3) {
        io::println("FAIL: Bisect.insortLeft values wrong");
    } else {
        io::println("PASS: Bisect.insortLeft works");
    }
}

public fn test_bisect_insortRight(): void {
    let arr: ArrayList<int> = new ArrayList<int>();
    arr.add(1);
    arr.add(3);
    arr.add(5);
    Bisect.insortRight(arr, 3);
    if (arr.size() != 4) {
        io::println("FAIL: Bisect.insortRight size wrong");
    } else if (arr.get(2) != 3 || arr.get(3) != 5) {
        io::println("FAIL: Bisect.insortRight values wrong");
    } else {
        io::println("PASS: Bisect.insortRight works");
    }
}

public fn test_bisect_insortLeft_empty(): void {
    let arr: ArrayList<int> = new ArrayList<int>();
    Bisect.insortLeft(arr, 42);
    if (arr.size() != 1 || arr.get(0) != 42) {
        io::println("FAIL: Bisect.insortLeft empty wrong");
    } else {
        io::println("PASS: Bisect.insortLeft empty works");
    }
}

