public fn test_bisect_left_duplicates(): void {
    let arr: ArrayList<int> = new ArrayList<int>();
    arr.add(1);
    arr.add(3);
    arr.add(3);
    arr.add(3);
    arr.add(5);
    if (Bisect.bisectLeft(arr, 3) != 1) {
        io::println("FAIL: Bisect.bisectLeft duplicates returned " + Integer.toString(Bisect.bisectLeft(arr, 3)));
    } else {
        io::println("PASS: Bisect.bisectLeft duplicates works");
    }
}

