public fn run_all_stemmer_tests(): void {
    io::println("=== nlp/Stemmer.tr Tests ===");
    test_porterStem_cats();
    test_porterStem_running();
    test_porterStem_caresses();
    test_porterStem_agreed();
    test_porterStem_lowercase();
    test_porterStem_short();
    test_porterStem_empty();
    test_lancaster_skipping();
    test_lancaster_department();
    test_lancaster_short();
    test_lancaster_lowercase();
    test_snowballStem_cats();
    test_snowballStem_caresses();
    test_snowballStem_running();
    test_snowballStem_short();
    test_snowballStem_empty();
}
