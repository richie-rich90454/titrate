// Test file for profile/Profile.tr
import tt::profile::Profile;
import tt::profile::Profile::ProfileStats;
import tt::lang::Variant;
import tt::lang::String;
import tt::lang::Integer;

public fn test_profile_run(): void {
    Profile.run("let x = 42", Variant.empty("void"));
    io::println("PASS: Profile run completes");
}

public fn test_profile_class(): void {
    let p: Profile.Profile = new Profile.Profile();
    p.run("let x = 1", Variant.empty("void"));
    let stats: ProfileStats = p.results();
    if (stats != null) {
        io::println("PASS: Profile class run/results works");
    } else {
        io::println("FAIL: Profile results null");
    }
}

public fn test_profile_enable_disable(): void {
    let p: Profile.Profile = new Profile.Profile();
    p.enable();
    p.disable();
    io::println("PASS: Profile enable/disable works");
}

public fn run_all_profile_tests(): void {
    io::println("=== Profile.tr Tests ===");
    test_profile_run();
    test_profile_class();
    test_profile_enable_disable();
}
