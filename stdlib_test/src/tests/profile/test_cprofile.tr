// Test file for profile/CProfile.tr
import tt::profile::CProfile;
import tt::profile::Profile;
import tt::lang::Variant;
import tt::lang::String;
import tt::lang::Integer;

public fn test_cprofile_run(): void {
    CProfile.run("let x = 42", Variant.empty("void"));
    io::println("PASS: CProfile run completes without error");
}

public fn test_cprofile_class(): void {
    let p: CProfile.CProfile = new CProfile.CProfile();
    p.run("let x = 1", Variant.empty("void"));
    let stats: Profile.ProfileStats = p.results();
    if (stats != null) {
        io::println("PASS: CProfile class run/results works");
    } else {
        io::println("FAIL: CProfile results returned null");
    }
}

public fn test_cprofile_enable_disable(): void {
    let p: CProfile.CProfile = new CProfile.CProfile();
    p.enable();
    p.disable();
    io::println("PASS: CProfile enable/disable works");
}

public fn run_all_cprofile_tests(): void {
    io::println("=== CProfile.tr Tests ===");
    test_cprofile_run();
    test_cprofile_class();
    test_cprofile_enable_disable();
}
