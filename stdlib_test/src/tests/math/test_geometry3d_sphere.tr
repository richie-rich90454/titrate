// Test file for geometry3d/Sphere.tr
// Exercises the public API for 3D spheres.
import tt::math::geometry3d::Sphere;
import tt::math::geometry3d::AABB;
import tt::lang::Double;

public fn test_sphere_creation(): void {
    let s: Sphere = new Sphere(0.0, 0.0, 0.0, 5.0);
    if (Math.abs(s.radius - 5.0) > 1e-9) {
        io::println("FAIL: Sphere radius");
    } else {
        io::println("PASS: Sphere creation works");
    }
}

public fn test_sphere_contains_point(): void {
    let s: Sphere = new Sphere(0.0, 0.0, 0.0, 5.0);
    if (!s.contains(0.0, 0.0, 0.0)) {
        io::println("FAIL: Sphere should contain origin");
    } else if (s.contains(10.0, 0.0, 0.0)) {
        io::println("FAIL: Sphere should not contain (10,0,0)");
    } else {
        io::println("PASS: Sphere contains works");
    }
}

public fn test_sphere_contains_sphere(): void {
    let outer: Sphere = new Sphere(0.0, 0.0, 0.0, 10.0);
    let inner: Sphere = new Sphere(0.0, 0.0, 0.0, 5.0);
    if (!outer.containsSphere(inner)) {
        io::println("FAIL: outer sphere should contain inner");
    } else {
        io::println("PASS: Sphere containsSphere works");
    }
}

public fn test_sphere_intersects(): void {
    let a: Sphere = new Sphere(0.0, 0.0, 0.0, 2.0);
    let b: Sphere = new Sphere(1.0, 0.0, 0.0, 2.0);
    let c: Sphere = new Sphere(100.0, 0.0, 0.0, 1.0);
    if (!a.intersects(b)) {
        io::println("FAIL: spheres should intersect");
    } else if (a.intersects(c)) {
        io::println("FAIL: spheres should not intersect");
    } else {
        io::println("PASS: Sphere intersects works");
    }
}

public fn test_sphere_volume(): void {
    let s: Sphere = new Sphere(0.0, 0.0, 0.0, 1.0);
    let v: double = s.volume();
    // (4/3) * pi * r^3
    if (Math.abs(v - 4.18879020478639) > 1e-6) {
        io::println("FAIL: Sphere volume = " + Double.toString(v));
    } else {
        io::println("PASS: Sphere volume works");
    }
}

public fn test_sphere_surface_area(): void {
    let s: Sphere = new Sphere(0.0, 0.0, 0.0, 1.0);
    let sa: double = s.surfaceArea();
    // 4 * pi * r^2
    if (Math.abs(sa - 12.56637061435917) > 1e-6) {
        io::println("FAIL: Sphere surfaceArea = " + Double.toString(sa));
    } else {
        io::println("PASS: Sphere surfaceArea works");
    }
}

public fn test_sphere_intersects_aabb(): void {
    let s: Sphere = new Sphere(0.0, 0.0, 0.0, 5.0);
    let box: AABB = new AABB(1.0, 1.0, 1.0, 2.0, 2.0, 2.0);
    if (!s.intersectsAABB(box)) {
        io::println("FAIL: sphere should intersect box");
    } else {
        io::println("PASS: Sphere intersectsAABB works");
    }
}

public fn test_sphere_merge(): void {
    let a: Sphere = new Sphere(-2.0, 0.0, 0.0, 1.0);
    let b: Sphere = new Sphere(2.0, 0.0, 0.0, 1.0);
    let merged: Sphere = a.merge(b);
    // Merged sphere should contain both: center at 0, radius >= 3
    if (merged.radius < 3.0) {
        io::println("FAIL: merged sphere radius = " + Double.toString(merged.radius));
    } else {
        io::println("PASS: Sphere merge works");
    }
}

public fn test_sphere_equals(): void {
    let a: Sphere = new Sphere(0.0, 0.0, 0.0, 1.0);
    let b: Sphere = new Sphere(0.0, 0.0, 0.0, 1.0);
    let c: Sphere = new Sphere(0.0, 0.0, 0.0, 2.0);
    if (!a.equals(b)) {
        io::println("FAIL: equal spheres not equal");
    } else if (a.equals(c)) {
        io::println("FAIL: unequal spheres equal");
    } else {
        io::println("PASS: Sphere equals works");
    }
}

public fn test_sphere_to_string(): void {
    let s: Sphere = new Sphere(0.0, 0.0, 0.0, 1.0);
    let str: string = s.toString();
    if (String.length(str) == 0) {
        io::println("FAIL: Sphere toString empty");
    } else {
        io::println("PASS: Sphere toString works");
    }
}

public fn run_all_geometry3d_sphere_tests(): void {
    io::println("=== geometry3d/Sphere.tr Tests ===");
    test_sphere_creation();
    test_sphere_contains_point();
    test_sphere_contains_sphere();
    test_sphere_intersects();
    test_sphere_volume();
    test_sphere_surface_area();
    test_sphere_intersects_aabb();
    test_sphere_merge();
    test_sphere_equals();
    test_sphere_to_string();
}
