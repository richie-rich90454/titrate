// ==================== Equality / hashing helpers ====================

public fn test_equals_helper(): void {
    let a: Ratio = new Ratio(1, 2);
    let b: Ratio = new Ratio(2, 4);
    if (Ratio.equals(a, b)) {
        io::println("PASS: equals helper 1/2 == 2/4");
    } else {
        io::println("FAIL: equals helper");
    }
}

public fn test_equals_null(): void {
    let a: Ratio = new Ratio(1, 2);
    if (!Ratio.equals(a, null) && !Ratio.equals(null, a)) {
        io::println("PASS: equals null returns false");
    } else {
        io::println("FAIL: equals null");
    }
}

public fn test_hash(): void {
    let r: Ratio = new Ratio(3, 4);
    let h: int = Ratio.hash(r);
    if (h == 97) {
        io::println("PASS: hash 3/4 = 97");
    } else {
        io::println("FAIL: hash 3/4 = " + Integer.toString(h));
    }
}

public fn test_hash_null(): void {
    let h: int = Ratio.hash(null);
    if (h == 0) {
        io::println("PASS: hash null = 0");
    } else {
        io::println("FAIL: hash null = " + Integer.toString(h));
    }
}

// ==================== parse ====================

public fn test_parse_simple(): void {
    let r: Ratio = Ratio.parse("3/4");
    if (r.numerator() == 3 && r.denominator() == 4) {
        io::println("PASS: parse '3/4'");
    } else {
        io::println("FAIL: parse '3/4'");
    }
}

public fn test_parse_integer(): void {
    let r: Ratio = Ratio.parse("5");
    if (r.numerator() == 5 && r.denominator() == 1) {
        io::println("PASS: parse '5' = 5/1");
    } else {
        io::println("FAIL: parse '5'");
    }
}

public fn test_parse_with_spaces(): void {
    let r: Ratio = Ratio.parse("  3 / 4  ");
    if (r.numerator() == 3 && r.denominator() == 4) {
        io::println("PASS: parse '  3 / 4  ' = 3/4");
    } else {
        io::println("FAIL: parse with spaces");
    }
}

public fn test_parse_negative(): void {
    let r: Ratio = Ratio.parse("-3/4");
    if (r.numerator() == -3 && r.denominator() == 4) {
        io::println("PASS: parse '-3/4' = -3/4");
    } else {
        io::println("FAIL: parse '-3/4'");
    }
}

public fn test_parse_reduces(): void {
    let r: Ratio = Ratio.parse("6/8");
    if (r.numerator() == 3 && r.denominator() == 4) {
        io::println("PASS: parse '6/8' reduces to 3/4");
    } else {
        io::println("FAIL: parse '6/8'");
    }
}

