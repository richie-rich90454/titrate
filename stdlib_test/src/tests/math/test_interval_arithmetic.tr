// Test file for IntervalArithmetic.tr
// Exercises the public API for interval arithmetic.
import tt::util::ArrayList;
import tt::math::IntervalArithmetic;
import tt::math::IntervalArithmetic::Interval;
import tt::lang::Double;
import tt::lang::Integer;
import tt::math::Math;

public fn test_interval_creation(): void {
    let i: Interval = new Interval(1.0, 3.0);
    let loVal: double = i.lo;
    let hiVal: double = i.hi;
    if (Math.abs(loVal - 1.0) > 1e-9 || Math.abs(hiVal - 3.0) > 1e-9) {
        io::println("FAIL: interval creation");
    } else {
        io::println("PASS: interval creation works");
    }
}

public fn test_point_interval(): void {
    let i: Interval = new Interval(5.0, 5.0);
    let loVal: double = i.lo;
    let hiVal: double = i.hi;
    if (Math.abs(loVal - 5.0) > 1e-9 || Math.abs(hiVal - 5.0) > 1e-9) {
        io::println("FAIL: pointInterval");
    } else {
        io::println("PASS: pointInterval works");
    }
}

public fn test_interval_width(): void {
    let i: Interval = new Interval(1.0, 4.0);
    let w: double = i.width();
    if (Math.abs(w - 3.0) > 1e-9) {
        io::println("FAIL: interval width = " + Double.toString(w));
    } else {
        io::println("PASS: interval width works");
    }
}

public fn test_interval_midpoint(): void {
    let i: Interval = new Interval(1.0, 5.0);
    let m: double = i.midpoint();
    if (Math.abs(m - 3.0) > 1e-9) {
        io::println("FAIL: interval midpoint = " + Double.toString(m));
    } else {
        io::println("PASS: interval midpoint works");
    }
}

public fn test_interval_contains(): void {
    let i: Interval = new Interval(1.0, 5.0);
    if (!i.contains(3.0)) {
        io::println("FAIL: interval should contain 3.0");
    } else if (i.contains(10.0)) {
        io::println("FAIL: interval should not contain 10.0");
    } else {
        io::println("PASS: interval contains works");
    }
}

public fn test_interval_overlaps(): void {
    let a: Interval = new Interval(1.0, 5.0);
    let b: Interval = new Interval(3.0, 7.0);
    let c: Interval = new Interval(10.0, 20.0);
    if (!a.overlaps(b)) {
        io::println("FAIL: interval should overlap");
    } else if (a.overlaps(c)) {
        io::println("FAIL: interval should not overlap");
    } else {
        io::println("PASS: interval overlaps works");
    }
}

public fn test_interval_intersect(): void {
    let a: Interval = new Interval(1.0, 5.0);
    let b: Interval = new Interval(3.0, 7.0);
    let i: Interval = a.intersect(b);
    let loVal: double = i.lo;
    let hiVal: double = i.hi;
    if (Math.abs(loVal - 3.0) > 1e-9 || Math.abs(hiVal - 5.0) > 1e-9) {
        io::println("FAIL: intersect result = [" + Double.toString(loVal) + ", " + Double.toString(hiVal) + "]");
    } else {
        io::println("PASS: interval intersect works");
    }
}

public fn test_interval_hull(): void {
    let a: Interval = new Interval(1.0, 5.0);
    let b: Interval = new Interval(3.0, 7.0);
    let h: Interval = a.hull(b);
    let loVal: double = h.lo;
    let hiVal: double = h.hi;
    if (Math.abs(loVal - 1.0) > 1e-9 || Math.abs(hiVal - 7.0) > 1e-9) {
        io::println("FAIL: hull result = [" + Double.toString(loVal) + ", " + Double.toString(hiVal) + "]");
    } else {
        io::println("PASS: interval hull works");
    }
}

public fn test_interval_add(): void {
    let a: Interval = new Interval(1.0, 2.0);
    let b: Interval = new Interval(3.0, 4.0);
    let c: Interval = a.add(b);
    let loVal: double = c.lo;
    let hiVal: double = c.hi;
    if (Math.abs(loVal - 4.0) > 1e-9 || Math.abs(hiVal - 6.0) > 1e-9) {
        io::println("FAIL: interval add");
    } else {
        io::println("PASS: interval add works");
    }
}

public fn test_interval_sub(): void {
    let a: Interval = new Interval(1.0, 2.0);
    let b: Interval = new Interval(3.0, 4.0);
    let c: Interval = a.sub(b);
    // [1,2] - [3,4] = [1-4, 2-3] = [-3, -1]
    let loVal: double = c.lo;
    let hiVal: double = c.hi;
    if (Math.abs(loVal - (-3.0)) > 1e-9 || Math.abs(hiVal - (-1.0)) > 1e-9) {
        io::println("FAIL: interval sub");
    } else {
        io::println("PASS: interval sub works");
    }
}

public fn test_interval_mul(): void {
    let a: Interval = new Interval(1.0, 2.0);
    let b: Interval = new Interval(3.0, 4.0);
    let c: Interval = a.mul(b);
    // [1,2] * [3,4] = [3, 8]
    let loVal: double = c.lo;
    let hiVal: double = c.hi;
    if (Math.abs(loVal - 3.0) > 1e-9 || Math.abs(hiVal - 8.0) > 1e-9) {
        io::println("FAIL: interval mul");
    } else {
        io::println("PASS: interval mul works");
    }
}

public fn test_interval_sqrt(): void {
    let a: Interval = new Interval(4.0, 9.0);
    let r: Interval = a.sqrt();
    let loVal: double = r.lo;
    let hiVal: double = r.hi;
    if (Math.abs(loVal - 2.0) > 1e-9 || Math.abs(hiVal - 3.0) > 1e-9) {
        io::println("FAIL: interval sqrt");
    } else {
        io::println("PASS: interval sqrt works");
    }
}

public fn test_interval_exp(): void {
    let a: Interval = new Interval(0.0, 0.0);
    let r: Interval = a.exp();
    // exp(0) = 1
    let loVal: double = r.lo;
    let hiVal: double = r.hi;
    if (Math.abs(loVal - 1.0) > 1e-9 || Math.abs(hiVal - 1.0) > 1e-9) {
        io::println("FAIL: interval exp at 0");
    } else {
        io::println("PASS: interval exp works");
    }
}

public fn test_interval_to_string(): void {
    let i: Interval = new Interval(1.0, 2.0);
    let s: string = i.toString();
    if (String.length(s) == 0) {
        io::println("FAIL: interval toString empty");
    } else {
        io::println("PASS: interval toString works");
    }
}

public fn test_eval_interval(): void {
    // Evaluate f(x) = x + 1 over interval [0, 1] -> [1, 2]
    let f: fn(Interval): Interval = fn(x: Interval): Interval { return x.add(new Interval(1.0, 1.0)); };
    let input: Interval = new Interval(0.0, 1.0);
    let result: Interval = IntervalArithmetic.evalInterval(f, input);
    let loVal: double = result.lo;
    let hiVal: double = result.hi;
    if (Math.abs(loVal - 1.0) > 1e-6 || Math.abs(hiVal - 2.0) > 1e-6) {
        io::println("FAIL: evalInterval");
    } else {
        io::println("PASS: evalInterval works");
    }
}

public fn run_all_interval_arithmetic_tests(): void {
    io::println("=== IntervalArithmetic.tr Tests ===");
    test_interval_creation();
    test_point_interval();
    test_interval_width();
    test_interval_midpoint();
    test_interval_contains();
    test_interval_overlaps();
    test_interval_intersect();
    test_interval_hull();
    test_interval_add();
    test_interval_sub();
    test_interval_mul();
    test_interval_sqrt();
    test_interval_exp();
    test_interval_to_string();
    test_eval_interval();
}
