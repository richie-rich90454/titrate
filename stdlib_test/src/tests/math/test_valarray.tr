// ==================== ValArray shift/cshift ====================

public fn test_va_shift_positive(): void {
    let va: ValArray = new ValArray();
    va.data.add(1.0);
    va.data.add(2.0);
    va.data.add(3.0);
    va.data.add(4.0);
    // shift(1): shifts left by 1, zeros fill in
    // result[0] = data[1] = 2, result[1] = data[2] = 3, result[2] = data[3] = 4, result[3] = 0
    let result: ValArray = va.shift(1);
    if (result.get(0) == 2.0 && result.get(1) == 3.0 && result.get(2) == 4.0 && result.get(3) == 0.0) {
        io::println("PASS: ValArray.shift(1) shifts left with zero fill");
    } else {
        io::println("FAIL: ValArray.shift(1)");
    }
}

public fn test_va_shift_negative(): void {
    let va: ValArray = new ValArray();
    va.data.add(1.0);
    va.data.add(2.0);
    va.data.add(3.0);
    va.data.add(4.0);
    // shift(-1): shifts right by 1, zeros fill in
    // result[0] = 0, result[1] = data[0] = 1, result[2] = data[1] = 2, result[3] = data[2] = 3
    let result: ValArray = va.shift(-1);
    if (result.get(0) == 0.0 && result.get(1) == 1.0 && result.get(2) == 2.0 && result.get(3) == 3.0) {
        io::println("PASS: ValArray.shift(-1) shifts right with zero fill");
    } else {
        io::println("FAIL: ValArray.shift(-1)");
    }
}

public fn test_va_shift_zero(): void {
    let va: ValArray = new ValArray();
    va.data.add(1.0);
    va.data.add(2.0);
    let result: ValArray = va.shift(0);
    if (result.get(0) == 1.0 && result.get(1) == 2.0) {
        io::println("PASS: ValArray.shift(0) returns copy");
    } else {
        io::println("FAIL: ValArray.shift(0)");
    }
}

public fn test_va_shift_large(): void {
    let va: ValArray = new ValArray();
    va.data.add(1.0);
    va.data.add(2.0);
    let result: ValArray = va.shift(5);
    if (result.get(0) == 0.0 && result.get(1) == 0.0) {
        io::println("PASS: ValArray.shift(n>=size) all zeros");
    } else {
        io::println("FAIL: ValArray.shift large");
    }
}

public fn test_va_cshift_positive(): void {
    let va: ValArray = new ValArray();
    va.data.add(1.0);
    va.data.add(2.0);
    va.data.add(3.0);
    va.data.add(4.0);
    // cshift(1): circular shift left by 1
    // result[0] = data[1] = 2, result[1] = data[2] = 3, result[2] = data[3] = 4, result[3] = data[0] = 1
    let result: ValArray = va.cshift(1);
    if (result.get(0) == 2.0 && result.get(1) == 3.0 && result.get(2) == 4.0 && result.get(3) == 1.0) {
        io::println("PASS: ValArray.cshift(1) circular left");
    } else {
        io::println("FAIL: ValArray.cshift(1)");
    }
}

public fn test_va_cshift_negative(): void {
    let va: ValArray = new ValArray();
    va.data.add(1.0);
    va.data.add(2.0);
    va.data.add(3.0);
    va.data.add(4.0);
    // cshift(-1): circular shift right by 1
    // result[0] = data[3] = 4, result[1] = data[0] = 1, result[2] = data[1] = 2, result[3] = data[2] = 3
    let result: ValArray = va.cshift(-1);
    if (result.get(0) == 4.0 && result.get(1) == 1.0 && result.get(2) == 2.0 && result.get(3) == 3.0) {
        io::println("PASS: ValArray.cshift(-1) circular right");
    } else {
        io::println("FAIL: ValArray.cshift(-1)");
    }
}

public fn test_va_cshift_zero(): void {
    let va: ValArray = new ValArray();
    va.data.add(1.0);
    va.data.add(2.0);
    let result: ValArray = va.cshift(0);
    if (result.get(0) == 1.0 && result.get(1) == 2.0) {
        io::println("PASS: ValArray.cshift(0) returns copy");
    } else {
        io::println("FAIL: ValArray.cshift(0)");
    }
}

public fn test_va_cshift_full_rotation(): void {
    let va: ValArray = new ValArray();
    va.data.add(1.0);
    va.data.add(2.0);
    va.data.add(3.0);
    // cshift(3) on length-3 array = full rotation = identity
    let result: ValArray = va.cshift(3);
    if (result.get(0) == 1.0 && result.get(1) == 2.0 && result.get(2) == 3.0) {
        io::println("PASS: ValArray.cshift(size) is identity");
    } else {
        io::println("FAIL: ValArray.cshift full rotation");
    }
}

