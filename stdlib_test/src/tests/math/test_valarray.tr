// ==================== ValArray assignment ====================

public fn test_va_assignSlice_scalar(): void {
    let va: ValArray = new ValArray();
    va.data.add(1.0);
    va.data.add(2.0);
    va.data.add(3.0);
    va.data.add(4.0);
    va.data.add(5.0);
    let s: ValArray.Slice = new ValArray.Slice(0, 3, 2);
    va.assignSlice(s, 99.0);
    // indices 0, 2, 4 -> 99.0
    if (va.get(0) == 99.0 && va.get(2) == 99.0 && va.get(4) == 99.0 && va.get(1) == 2.0 && va.get(3) == 4.0) {
        io::println("PASS: ValArray.assignSlice scalar");
    } else {
        io::println("FAIL: ValArray.assignSlice scalar");
    }
}

public fn test_va_assignSliceArray(): void {
    let va: ValArray = new ValArray();
    va.data.add(1.0);
    va.data.add(2.0);
    va.data.add(3.0);
    va.data.add(4.0);
    let src: ValArray = new ValArray();
    src.data.add(10.0);
    src.data.add(20.0);
    let s: ValArray.Slice = new ValArray.Slice(0, 2, 2);
    va.assignSliceArray(s, src);
    // indices 0, 2 -> 10.0, 20.0
    if (va.get(0) == 10.0 && va.get(2) == 20.0) {
        io::println("PASS: ValArray.assignSliceArray from ValArray");
    } else {
        io::println("FAIL: ValArray.assignSliceArray");
    }
}

