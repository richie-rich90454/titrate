public fn test_va_cosh(): void {
    let va: ValArray = new ValArray();
    va.data.add(0.0);
    let r: ValArray = ValArray.cosh(va);
    if (_approx(r.get(0), 1.0)) {
        io::println("PASS: ValArray.cosh element-wise");
    } else {
        io::println("FAIL: ValArray.cosh");
    }
}

public fn test_va_tanh(): void {
    let va: ValArray = new ValArray();
    va.data.add(0.0);
    let r: ValArray = ValArray.tanh(va);
    if (_approx(r.get(0), 0.0)) {
        io::println("PASS: ValArray.tanh element-wise");
    } else {
        io::println("FAIL: ValArray.tanh");
    }
}

public fn test_va_transcendentals_empty(): void {
    let va: ValArray = new ValArray();
    let r1: ValArray = ValArray.abs(va);
    let r2: ValArray = ValArray.exp(va);
    let r3: ValArray = ValArray.sin(va);
    if (r1.size() == 0 && r2.size() == 0 && r3.size() == 0) {
        io::println("PASS: transcendental overloads on empty ValArray");
    } else {
        io::println("FAIL: transcendental empty");
    }
}

// ==================== Aggregator ====================

public fn run_all_valarray_tests(): void {
    io::println("=== ValArray.tr Tests ===");
    // Slice
    test_slice_construct();
    test_slice_getters();
    test_slice_index();
    test_slice_equals();
    test_slice_toString();
    test_slice_factory();
    // GSlice
    test_gslice_construct();
    test_gslice_getters();
    test_gslice_totalSize();
    test_gslice_indices_single_dim();
    test_gslice_indices_multi_dim();
    test_gslice_indices_empty();
    test_gslice_equals();
    test_gslice_toString();
    // ValArray construction & access
    test_va_construct_empty();
    test_va_get_set();
    test_va_at_in_bounds();
    test_va_at_out_of_bounds_throws();
    test_va_at_negative_throws();
    // ValArray factories
    test_va_of();
    test_va_of_empty();
    test_va_zeros();
    test_va_filled();
    // ValArray slicing
    test_va_applySlice();
    test_va_applySlice_contiguous();
    test_va_applyGSlice();
    test_va_applyIndirect();
    test_va_applyMask();
    test_va_applyMask_all_false();
    test_va_applyMask_all_true();
    // ValArray assignment
    test_va_assignSlice_scalar();
    test_va_assignSliceArray();
    test_va_assignMask_scalar();
    test_va_assignMaskArray();
    test_va_assignIndirect_scalar();
    test_va_assignIndirectArray();
    // ValArray shift/cshift
    test_va_shift_positive();
    test_va_shift_negative();
    test_va_shift_zero();
    test_va_shift_large();
    test_va_cshift_positive();
    test_va_cshift_negative();
    test_va_cshift_zero();
    test_va_cshift_full_rotation();
    // ValArray reductions
    test_va_sum();
    test_va_sum_empty();
    test_va_min();
    test_va_max();
    test_va_min_max_empty();
    test_va_min_negative();
    // ValArray arithmetic
    test_va_add();
    test_va_subtract();
    test_va_multiply();
    test_va_divide();
    test_va_add_diff_lengths();
    test_va_addScalar();
    test_va_multiplyScalar();
    // ValArray equals/toString
    test_va_equals_same();
    test_va_equals_diff();
    test_va_equals_diff_length();
    test_va_equals_null();
    test_va_toString();
    // SliceArray proxy
    test_sliceArray_assign_scalar();
    test_sliceArray_assignArray();
    test_sliceArray_toArray();
    test_sliceArray_toString();
    // MaskArray proxy
    test_maskArray_assign_scalar();
    test_maskArray_assignArray();
    test_maskArray_toArray();
    test_maskArray_toString();
    // IndirectArray proxy
    test_indirectArray_assign_scalar();
    test_indirectArray_assignArray();
    test_indirectArray_toArray();
    test_indirectArray_toString();
    // Transcendental overloads
    test_va_abs();
    test_va_exp();
    test_va_log();
    test_va_log10();
    test_va_log2();
    test_va_sqrt();
    test_va_cbrt();
    test_va_sin();
    test_va_cos();
    test_va_tan();
    test_va_asin();
    test_va_acos();
    test_va_atan();
    test_va_sinh();
    test_va_cosh();
    test_va_tanh();
    test_va_transcendentals_empty();
}
