// Test file for math/ValArray.tr
// Exercises C++ <valarray> parity: Slice, GSlice, ValArray, proxy types
// (SliceArray, MaskArray, IndirectArray), element-wise arithmetic, slicing,
// shifting, reductions, and element-wise transcendental overloads.
import tt::math::ValArray;
import tt::util::ArrayList;
import tt::lang::Integer;
import tt::lang::Double;
import tt::lang::String;
import tt::math::Math;

// ==================== Helpers ====================

fn _approx(a: double, b: double): bool {
    return Math.abs(a - b) < 1e-9;
}

fn _vaEqual(a: ValArray, b: ValArray): bool {
    if (a.size() != b.size()) { return false; }
    var i: int = 0;
    while (i < a.size()) {
        if (!_approx(a.get(i), b.get(i))) { return false; }
        i = i + 1;
    }
    return true;
}

fn _buildVa(values: ArrayList<double>): ValArray {
    return ValArray.of(values);
}

// ==================== Slice ====================

public fn test_slice_construct(): void {
    let s: ValArray.Slice = new ValArray.Slice(2, 3, 4);
    if (s.start == 2 && s.size == 3 && s.stride == 4) {
        io::println("PASS: Slice construct preserves start/size/stride");
    } else {
        io::println("FAIL: Slice construct");
    }
}

public fn test_slice_getters(): void {
    let s: ValArray.Slice = new ValArray.Slice(1, 5, 2);
    if (s.getStart() == 1 && s.getSize() == 5 && s.getStride() == 2) {
        io::println("PASS: Slice getters work");
    } else {
        io::println("FAIL: Slice getters");
    }
}

public fn test_slice_index(): void {
    let s: ValArray.Slice = new ValArray.Slice(3, 4, 5);
    // index(i) = start + i * stride
    // index(0)=3, index(1)=8, index(2)=13, index(3)=18
    if (s.index(0) == 3 && s.index(1) == 8 && s.index(2) == 13 && s.index(3) == 18) {
        io::println("PASS: Slice.index computes start + i*stride");
    } else {
        io::println("FAIL: Slice.index");
    }
}

public fn test_slice_equals(): void {
    let s1: ValArray.Slice = new ValArray.Slice(1, 2, 3);
    let s2: ValArray.Slice = new ValArray.Slice(1, 2, 3);
    let s3: ValArray.Slice = new ValArray.Slice(1, 2, 4);
    if (s1.equals(s2) && !s1.equals(s3) && !s1.equals(null)) {
        io::println("PASS: Slice.equals works");
    } else {
        io::println("FAIL: Slice.equals");
    }
}

public fn test_slice_toString(): void {
    let s: ValArray.Slice = new ValArray.Slice(1, 2, 3);
    let str: string = s.toString();
    if (String.length(str) > 0) {
        io::println("PASS: Slice.toString returns non-empty");
    } else {
        io::println("FAIL: Slice.toString empty");
    }
}

public fn test_slice_factory(): void {
    let s: ValArray.Slice = ValArray.slice(2, 3, 4);
    if (s.start == 2 && s.size == 3 && s.stride == 4) {
        io::println("PASS: slice() factory widens int to long");
    } else {
        io::println("FAIL: slice() factory");
    }
}

// ==================== GSlice ====================

public fn test_gslice_construct(): void {
    let sizes: ArrayList<long> = new ArrayList<long>();
    sizes.add(2);
    sizes.add(3);
    let strides: ArrayList<long> = new ArrayList<long>();
    strides.add(6);
    strides.add(2);
    let gs: ValArray.GSlice = new ValArray.GSlice(0, sizes, strides);
    if (gs.start == 0 && gs.sizes.size() == 2 && gs.strides.size() == 2) {
        io::println("PASS: GSlice construct preserves start/sizes/strides");
    } else {
        io::println("FAIL: GSlice construct");
    }
}

public fn test_gslice_getters(): void {
    let sizes: ArrayList<long> = new ArrayList<long>();
    sizes.add(2);
    let strides: ArrayList<long> = new ArrayList<long>();
    strides.add(3);
    let gs: ValArray.GSlice = new ValArray.GSlice(1, sizes, strides);
    if (gs.getStart() == 1 && gs.getSizes().size() == 1 && gs.getStrides().size() == 1) {
        io::println("PASS: GSlice getters work");
    } else {
        io::println("FAIL: GSlice getters");
    }
}

public fn test_gslice_totalSize(): void {
    // 2x3x4 = 24
    let sizes: ArrayList<long> = new ArrayList<long>();
    sizes.add(2);
    sizes.add(3);
    sizes.add(4);
    let strides: ArrayList<long> = new ArrayList<long>();
    strides.add(12);
    strides.add(4);
    strides.add(1);
    let gs: ValArray.GSlice = new ValArray.GSlice(0, sizes, strides);
    if (gs.totalSize() == 24) {
        io::println("PASS: GSlice.totalSize = product of sizes");
    } else {
        io::println("FAIL: GSlice.totalSize = " + Integer.toString(gs.totalSize() as int));
    }
}

public fn test_gslice_indices_single_dim(): void {
    // Single dimension: start=2, size=3, stride=2 -> [2, 4, 6]
    let sizes: ArrayList<long> = new ArrayList<long>();
    sizes.add(3);
    let strides: ArrayList<long> = new ArrayList<long>();
    strides.add(2);
    let gs: ValArray.GSlice = new ValArray.GSlice(2, sizes, strides);
    let idxs: ArrayList<long> = gs.indices();
    if (idxs.size() == 3 && idxs.get(0) == 2 && idxs.get(1) == 4 && idxs.get(2) == 6) {
        io::println("PASS: GSlice.indices single-dim");
    } else {
        io::println("FAIL: GSlice.indices single-dim");
    }
}

public fn test_gslice_indices_multi_dim(): void {
    // 2D: start=0, sizes=[2,2], strides=[4,2]
    // indices: 0+0*4+0*2=0, 0+0*4+1*2=2, 0+1*4+0*2=4, 0+1*4+1*2=6 -> [0,2,4,6]
    let sizes: ArrayList<long> = new ArrayList<long>();
    sizes.add(2);
    sizes.add(2);
    let strides: ArrayList<long> = new ArrayList<long>();
    strides.add(4);
    strides.add(2);
    let gs: ValArray.GSlice = new ValArray.GSlice(0, sizes, strides);
    let idxs: ArrayList<long> = gs.indices();
    if (idxs.size() == 4 && idxs.get(0) == 0 && idxs.get(1) == 2 && idxs.get(2) == 4 && idxs.get(3) == 6) {
        io::println("PASS: GSlice.indices multi-dim row-major");
    } else {
        io::println("FAIL: GSlice.indices multi-dim");
    }
}

public fn test_gslice_indices_empty(): void {
    // Empty sizes -> just [start]
    let sizes: ArrayList<long> = new ArrayList<long>();
    let strides: ArrayList<long> = new ArrayList<long>();
    let gs: ValArray.GSlice = new ValArray.GSlice(5, sizes, strides);
    let idxs: ArrayList<long> = gs.indices();
    if (idxs.size() == 1 && idxs.get(0) == 5) {
        io::println("PASS: GSlice.indices empty dims returns [start]");
    } else {
        io::println("FAIL: GSlice.indices empty");
    }
}

