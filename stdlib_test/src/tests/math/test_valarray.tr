public fn test_sliceArray_assign_scalar(): void {
    let va: ValArray = new ValArray();
    va.data.add(1.0);
    va.data.add(2.0);
    va.data.add(3.0);
    va.data.add(4.0);
    let s: ValArray.Slice = new ValArray.Slice(0, 2, 2);
    let proxy: ValArray.SliceArray = va.sliceProxy(s);
    proxy.assign(99.0);
    if (va.get(0) == 99.0 && va.get(2) == 99.0 && va.get(1) == 2.0) {
        io::println("PASS: SliceArray.assign scalar");
    } else {
        io::println("FAIL: SliceArray.assign scalar");
    }
}

