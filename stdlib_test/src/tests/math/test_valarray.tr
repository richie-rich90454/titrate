// ==================== ValArray slicing ====================

public fn test_va_applySlice(): void {
    let va: ValArray = new ValArray();
    va.data.add(10.0);
    va.data.add(20.0);
    va.data.add(30.0);
    va.data.add(40.0);
    va.data.add(50.0);
    // slice(start=1, size=3, stride=2) -> indices 1, 3, 5? No, 1, 3 (size=3 means 3 elements: 1,3,5)
    // Actually index(i) = start + i*stride -> 1, 3, 5. But 5 is out of bounds.
    // Let me use start=0, size=3, stride=2 -> 0, 2, 4
    let s: ValArray.Slice = new ValArray.Slice(0, 3, 2);
    let result: ValArray = va.applySlice(s);
    if (result.size() == 3 && result.get(0) == 10.0 && result.get(1) == 30.0 && result.get(2) == 50.0) {
        io::println("PASS: ValArray.applySlice strided");
    } else {
        io::println("FAIL: ValArray.applySlice");
    }
}

public fn test_va_applySlice_contiguous(): void {
    let va: ValArray = new ValArray();
    va.data.add(1.0);
    va.data.add(2.0);
    va.data.add(3.0);
    va.data.add(4.0);
    let s: ValArray.Slice = new ValArray.Slice(1, 2, 1);
    let result: ValArray = va.applySlice(s);
    if (result.size() == 2 && result.get(0) == 2.0 && result.get(1) == 3.0) {
        io::println("PASS: ValArray.applySlice contiguous");
    } else {
        io::println("FAIL: ValArray.applySlice contiguous");
    }
}

public fn test_va_applyGSlice(): void {
    let va: ValArray = new ValArray();
    // 6 elements representing a 2x3 matrix: [10, 20, 30, 40, 50, 60]
    va.data.add(10.0);
    va.data.add(20.0);
    va.data.add(30.0);
    va.data.add(40.0);
    va.data.add(50.0);
    va.data.add(60.0);
    // gslice: start=0, sizes=[2,2], strides=[3,1] -> indices 0,1,3,4
    let sizes: ArrayList<long> = new ArrayList<long>();
    sizes.add(2);
    sizes.add(2);
    let strides: ArrayList<long> = new ArrayList<long>();
    strides.add(3);
    strides.add(1);
    let gs: ValArray.GSlice = new ValArray.GSlice(0, sizes, strides);
    let result: ValArray = va.applyGSlice(gs);
    if (result.size() == 4 && result.get(0) == 10.0 && result.get(1) == 20.0 && result.get(2) == 40.0 && result.get(3) == 50.0) {
        io::println("PASS: ValArray.applyGSlice 2D");
    } else {
        io::println("FAIL: ValArray.applyGSlice");
    }
}

public fn test_va_applyIndirect(): void {
    let va: ValArray = new ValArray();
    va.data.add(10.0);
    va.data.add(20.0);
    va.data.add(30.0);
    va.data.add(40.0);
    let idxs: ArrayList<int> = new ArrayList<int>();
    idxs.add(3);
    idxs.add(1);
    idxs.add(0);
    let result: ValArray = va.applyIndirect(idxs);
    if (result.size() == 3 && result.get(0) == 40.0 && result.get(1) == 20.0 && result.get(2) == 10.0) {
        io::println("PASS: ValArray.applyIndirect out-of-order");
    } else {
        io::println("FAIL: ValArray.applyIndirect");
    }
}

public fn test_va_applyMask(): void {
    let va: ValArray = new ValArray();
    va.data.add(10.0);
    va.data.add(20.0);
    va.data.add(30.0);
    va.data.add(40.0);
    let mask: ArrayList<bool> = new ArrayList<bool>();
    mask.add(false);
    mask.add(true);
    mask.add(false);
    mask.add(true);
    let result: ValArray = va.applyMask(mask);
    if (result.size() == 2 && result.get(0) == 20.0 && result.get(1) == 40.0) {
        io::println("PASS: ValArray.applyMask selects true positions");
    } else {
        io::println("FAIL: ValArray.applyMask");
    }
}

