// Test file for geometry3d/Ray.tr
// Exercises the public API for 3D rays.
import tt::math::geometry3d::Ray;
import tt::math::geometry3d::AABB;
import tt::math::geometry3d::Plane;
import tt::math::geometry3d::Sphere;
import tt::math::vec::Vec3;
import tt::math::Math;
import tt::lang::Double;

public fn test_ray_creation(): void {
    let r: Ray = new Ray(new Vec3(0.0, 0.0, 0.0), new Vec3(1.0, 0.0, 0.0));
    io::println("PASS: Ray creation works");
}

public fn test_ray_point_at(): void {
    // Ray from origin in +x direction, point at t=5 should be (5,0,0)
    let r: Ray = new Ray(new Vec3(0.0, 0.0, 0.0), new Vec3(1.0, 0.0, 0.0));
    let p: Vec3 = r.pointAt(5.0);
    if (Math.abs(p.x - 5.0) > 1e-9) {
        io::println("FAIL: pointAt x = " + Double.toString(p.x));
    } else {
        io::println("PASS: pointAt works");
    }
}

public fn test_ray_intersects_plane(): void {
    // Ray from (0,1,0) going down (0,-1,0) hits plane y=0 at t=1
    let r: Ray = new Ray(new Vec3(0.0, 1.0, 0.0), new Vec3(0.0, -1.0, 0.0));
    let plane: Plane = new Plane(new Vec3(0.0, 1.0, 0.0), 0.0);
    let t: double = r.intersectsPlaneRange(plane.normal, plane.d);
    if (Math.abs(t - 1.0) > 1e-9) {
        io::println("FAIL: intersectsPlane t = " + Double.toString(t));
    } else {
        io::println("PASS: intersectsPlane works");
    }
}

public fn test_ray_intersects_aabb(): void {
    // Ray from (-5, 0, 0) going +x hits box at origin with size 2
    let r: Ray = new Ray(new Vec3(-5.0, 0.0, 0.0), new Vec3(1.0, 0.0, 0.0));
    let box: AABB = new AABB(new Vec3(-1.0, -1.0, -1.0), new Vec3(2.0, 2.0, 2.0));
    let t: double = r.intersectsAABBRange(box);
    if (t < 0.0) {
        io::println("FAIL: intersectsAABB t = " + Double.toString(t));
    } else {
        io::println("PASS: intersectsAABB works");
    }
}

public fn test_ray_intersects_sphere(): void {
    // Ray from origin going +x hits unit sphere centered at (5,0,0) at t=4
    let r: Ray = new Ray(new Vec3(0.0, 0.0, 0.0), new Vec3(1.0, 0.0, 0.0));
    let s: Sphere = new Sphere(new Vec3(5.0, 0.0, 0.0), 1.0);
    let t: double = r.intersectsSphereRange(s.center, s.radius);
    if (Math.abs(t - 4.0) > 1e-6) {
        io::println("FAIL: intersectsSphere t = " + Double.toString(t));
    } else {
        io::println("PASS: intersectsSphere works");
    }
}

public fn test_ray_intersects_aabb_miss(): void {
    // Ray going in opposite direction should miss
    let r: Ray = new Ray(new Vec3(-5.0, 0.0, 0.0), new Vec3(-1.0, 0.0, 0.0));
    let box: AABB = new AABB(new Vec3(-1.0, -1.0, -1.0), new Vec3(2.0, 2.0, 2.0));
    let t: double = r.intersectsAABBRange(box);
    if (t >= 0.0) {
        io::println("FAIL: ray should miss box but got t = " + Double.toString(t));
    } else {
        io::println("PASS: ray miss works");
    }
}

public fn test_ray_equals(): void {
    let a: Ray = new Ray(new Vec3(0.0, 0.0, 0.0), new Vec3(1.0, 0.0, 0.0));
    let b: Ray = new Ray(new Vec3(0.0, 0.0, 0.0), new Vec3(1.0, 0.0, 0.0));
    let c: Ray = new Ray(new Vec3(1.0, 0.0, 0.0), new Vec3(1.0, 0.0, 0.0));
    if (!a.equals(b)) {
        io::println("FAIL: equal rays not equal");
    } else if (a.equals(c)) {
        io::println("FAIL: unequal rays equal");
    } else {
        io::println("PASS: Ray equals works");
    }
}

public fn test_ray_to_string(): void {
    let r: Ray = new Ray(new Vec3(0.0, 0.0, 0.0), new Vec3(1.0, 0.0, 0.0));
    let s: string = r.toString();
    if (String.length(s) == 0) {
        io::println("FAIL: Ray toString empty");
    } else {
        io::println("PASS: Ray toString works");
    }
}

public fn run_all_geometry3d_ray_tests(): void {
    io::println("=== geometry3d/Ray.tr Tests ===");
    test_ray_creation();
    test_ray_point_at();
    test_ray_intersects_plane();
    test_ray_intersects_aabb();
    test_ray_intersects_sphere();
    test_ray_intersects_aabb_miss();
    test_ray_equals();
    test_ray_to_string();
}
