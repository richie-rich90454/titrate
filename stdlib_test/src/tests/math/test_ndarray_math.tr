    let a: NDArray<double> = fromData<double>(shape1(1), data);
    let b: NDArray<double> = NDArrayMath.ndLog2(a);
    if (approxEq(b.getFlat(0), 3.0, 1e-9)) {
        io::println("PASS test_ndLog2: log2(8) = 3");
