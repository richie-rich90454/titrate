    let data: ArrayList<double> = new ArrayList<double>();
    data.add(100.0);
    let a: NDArray<double> = fromData<double>(shape1(1), data);
    let b: NDArray<double> = NDArrayMath.ndLog10(a);
    if (approxEq(b.getFlat(0), 2.0, 1e-9)) {
        io::println("PASS test_ndLog10: log10(100) = 2");
