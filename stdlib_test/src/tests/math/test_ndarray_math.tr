fn test_ndCbrt(): void {
    let data: ArrayList<double> = new ArrayList<double>();
    data.add(27.0);
    let a: NDArray<double> = fromData<double>(shape1(1), data);
    let b: NDArray<double> = NDArrayMath.ndCbrt(a);
    if (approxEq(b.getFlat(0), 3.0, 1e-9)) {
        io::println("PASS test_ndCbrt: cbrt(27) = 3");
    } else {
        io::println("FAIL test_ndCbrt: expected 3.0, got " + Double.toString(b.getFlat(0)));
    }
}

fn test_ndSign(): void {
    let data: ArrayList<double> = new ArrayList<double>();
    data.add(-5.0); data.add(0.0); data.add(5.0);
    let a: NDArray<double> = fromData<double>(shape1(3), data);
    let b: NDArray<double> = NDArrayMath.ndSign(a);
    if (approxEq(b.getFlat(0), -1.0, 1e-9) && approxEq(b.getFlat(2), 1.0, 1e-9)) {
        io::println("PASS test_ndSign: sign(-5)=-1, sign(5)=1");
    } else {
        io::println("FAIL test_ndSign: incorrect");
    }
}

public fn run_all_ndarray_math_tests(): void {
    io::println("=== NDArrayMath tests ===");
    test_map();
    test_zipMap();
    test_dot();
    test_norm();
    test_ndSin();
    test_ndCos();
    test_ndExp();
    test_ndLog();
    test_ndSqrt();
    test_ndAbs();
    test_ndSquare();
    test_ndNegative();
    test_ndReciprocal();
    test_ndFloor();
    test_ndCeil();
    test_ndTanh();
    test_ndLog2();
    test_ndLog10();
    test_ndCbrt();
    test_ndSign();
}
