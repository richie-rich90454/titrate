// Test file for ContinuedFraction.tr
// Exercises the public API for continued fractions.
import tt::util::ArrayList;
import tt::util::Pair;
import tt::math::ContinuedFraction;
import tt::lang::Integer;
import tt::lang::Double;
import tt::math::Math;

public fn test_continued_fraction_creation(): void {
    let cf: ContinuedFraction = new ContinuedFraction(new ArrayList<long>());
    cf.terms.add(1);
    cf.terms.add(2);
    cf.terms.add(3);
    let val: double = cf.toDouble();
    // 1 + 1/(2 + 1/3) = 1 + 1/(7/3) = 1 + 3/7 = 10/7
    if (Math.abs(val - 10.0 / 7.0) > 1e-9) {
        io::println("FAIL: ContinuedFraction.toDouble = " + Double.toString(val));
    } else {
        io::println("PASS: ContinuedFraction.toDouble works");
    }
}

public fn test_from_double(): void {
    // 0.5 = 1/2 -> continued fraction [0; 2]
    let cf: ContinuedFraction = ContinuedFraction.fromDouble(0.5, 10);
    if (cf.terms.size() < 2) {
        io::println("FAIL: fromDouble terms size = " + Integer.toString(cf.terms.size()));
        return;
    }
    io::println("PASS: fromDouble works");
}

public fn test_from_rational(): void {
    // 22/7 -> continued fraction [3; 7]
    let cf: ContinuedFraction = ContinuedFraction.fromRational(22, 7);
    if (cf.terms.size() < 2) {
        io::println("FAIL: fromRational terms size = " + Integer.toString(cf.terms.size()));
        return;
    }
    if (cf.terms.get(0) != 3) {
        io::println("FAIL: fromRational first term = " + Integer.toString(cf.terms.get(0) as int));
    } else {
        io::println("PASS: fromRational works");
    }
}

public fn test_best_rational_approximation(): void {
    // Best rational approximation of pi is 22/7
    let result: Pair<long, long> = ContinuedFraction.bestRationalApproximation(3.14159265358979, 10);
    if (result.first != 22 || result.second != 7) {
        io::println("FAIL: bestRationalApproximation of pi = " + Integer.toString(result.first as int) + "/" + Integer.toString(result.second as int));
    } else {
        io::println("PASS: bestRationalApproximation of pi is 22/7");
    }
}

public fn test_best_rational_approximation_int(): void {
    let result: Pair<int, int> = ContinuedFraction.bestRationalApproximationInt(3.14159265358979, 100);
    if (result.second > 100) {
        io::println("FAIL: bestRationalApproximationInt denominator > maxDenom");
    } else {
        io::println("PASS: bestRationalApproximationInt works");
    }
}

public fn test_golden_ratio(): void {
    // Golden ratio continued fraction is [1; 1, 1, 1, ...] with 20 terms
    let cf: ContinuedFraction = ContinuedFraction.goldenRatio();
    if (cf.terms.size() != 20) {
        io::println("FAIL: goldenRatio terms size = " + Integer.toString(cf.terms.size()));
        return;
    }
    var allOnes: bool = true;
    var i: int = 0;
    while (i < cf.terms.size()) {
        if (cf.terms.get(i) != 1) { allOnes = false; }
        i = i + 1;
    }
    if (!allOnes) {
        io::println("FAIL: goldenRatio not all ones");
    } else {
        io::println("PASS: goldenRatio works");
    }
}

public fn test_sqrt_continued(): void {
    // sqrt(2) continued fraction is [1; 2, 2, 2, ...]
    let cf: ContinuedFraction = ContinuedFraction.sqrtContinued(2, 5);
    if (cf.terms.size() < 2) {
        io::println("FAIL: sqrtContinued terms size = " + Integer.toString(cf.terms.size()));
        return;
    }
    if (cf.terms.get(0) != 1) {
        io::println("FAIL: sqrtContinued(2) first term = " + Integer.toString(cf.terms.get(0) as int));
    } else {
        io::println("PASS: sqrtContinued works");
    }
}

public fn test_pi_continued(): void {
    let cf: ContinuedFraction = ContinuedFraction.piContinued();
    if (cf.terms.size() == 0) {
        io::println("FAIL: piContinued empty");
    } else {
        io::println("PASS: piContinued works");
    }
}

public fn test_e_continued(): void {
    // e continued fraction is [2; 1, 2, 1, 1, 4, 1, 1, 6, ...]
    let cf: ContinuedFraction = ContinuedFraction.eContinued();
    if (cf.terms.size() == 0) {
        io::println("FAIL: eContinued empty");
    } else if (cf.terms.get(0) != 2) {
        io::println("FAIL: eContinued first term = " + Integer.toString(cf.terms.get(0) as int));
    } else {
        io::println("PASS: eContinued works");
    }
}

public fn test_continued_fraction_convergents(): void {
    let cf: ContinuedFraction = new ContinuedFraction(new ArrayList<long>());
    cf.terms.add(1);
    cf.terms.add(2);
    cf.terms.add(3);
    let convergents: ArrayList<Pair<long, long>> = cf.convergents();
    if (convergents.size() != 3) {
        io::println("FAIL: convergents size = " + Integer.toString(convergents.size()));
        return;
    }
    io::println("PASS: convergents returns proper count");
}

public fn test_continued_fraction_to_string(): void {
    let cf: ContinuedFraction = new ContinuedFraction(new ArrayList<long>());
    cf.terms.add(1);
    cf.terms.add(2);
    let s: string = cf.toString();
    if (String.length(s) == 0) {
        io::println("FAIL: toString empty");
    } else {
        io::println("PASS: toString works");
    }
}

public fn run_all_continued_fraction_tests(): void {
    io::println("=== ContinuedFraction.tr Tests ===");
    test_continued_fraction_creation();
    test_from_double();
    test_from_rational();
    test_best_rational_approximation();
    test_best_rational_approximation_int();
    test_golden_ratio();
    test_sqrt_continued();
    test_pi_continued();
    test_e_continued();
    test_continued_fraction_convergents();
    test_continued_fraction_to_string();
}
