    let result: ArrayList<ArrayList<double>> = PDE.heatEquation1DImplicit(nx, 0.1, 0.01, 10, initial, leftBC, rightBC);
    if (result.size() == 0) {
        io::println("FAIL: heatEquation1DImplicit empty result");
