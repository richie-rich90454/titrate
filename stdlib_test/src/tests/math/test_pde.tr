        io::println("PASS: heatEquation1DImplicit works");
    }
}

public fn test_wave_equation_1d(): void {
    // 1D wave equation: initial condition u(x, 0) = sin(pi*x), zero initial velocity
    // waveEquation1D(nx, dx, dt, steps, initial, initialVelocity, leftBC, rightBC)
    let nx: int = 11;
    let initial: ArrayList<double> = new ArrayList<double>();
    var i: int = 0;
    while (i < nx) {
        let x: double = (i as double) / 10.0;
        initial.add(MathTrig.sin(3.14159265358979 * x));
        i = i + 1;
    }
    let initialVel: ArrayList<double> = new ArrayList<double>();
    i = 0;
    while (i < nx) {
        initialVel.add(0.0);
        i = i + 1;
    }
    let leftBC: BoundaryCondition = new BoundaryCondition("dirichlet", 0.0, 0.0);
    let rightBC: BoundaryCondition = new BoundaryCondition("dirichlet", 0.0, 0.0);
    let result: ArrayList<ArrayList<double>> = PDE.waveEquation1D(nx, 0.1, 0.01, 10, initial, initialVel, leftBC, rightBC);
    if (result.size() == 0) {
        io::println("FAIL: waveEquation1D empty result");
    } else {
        io::println("PASS: waveEquation1D works");
    }
}

public fn test_poisson_2d(): void {
    // Poisson equation on unit square with zero boundary
    // poisson2D(nx, ny, dx, dy, source, bc, maxIter, tol)
    let n: int = 5;
    let f: ArrayList<ArrayList<double>> = new ArrayList<ArrayList<double>>();
    var i: int = 0;
    while (i < n) {
        let row: ArrayList<double> = new ArrayList<double>();
        var j: int = 0;
        while (j < n) {
            row.add(-1.0);
            j = j + 1;
        }
        f.add(row);
        i = i + 1;
    }
    let bcs: ArrayList<BoundaryCondition> = new ArrayList<BoundaryCondition>();
    bcs.add(new BoundaryCondition("dirichlet", 0.0, 0.0));
    bcs.add(new BoundaryCondition("dirichlet", 0.0, 0.0));
    bcs.add(new BoundaryCondition("dirichlet", 0.0, 0.0));
    bcs.add(new BoundaryCondition("dirichlet", 0.0, 0.0));
    let result: ArrayList<ArrayList<double>> = PDE.poisson2D(n, n, 0.25, 0.25, f, bcs, 100, 1e-6);
    if (result.size() == 0) {
        io::println("FAIL: poisson2D empty result");
    } else {
        io::println("PASS: poisson2D works");
    }
}

public fn test_laplace_2d(): void {
    // Laplace equation on unit square with boundary condition
    // laplace2D(nx, ny, dx, dy, bc, maxIter, tol)
    let n: int = 5;
    let bcs: ArrayList<BoundaryCondition> = new ArrayList<BoundaryCondition>();
    bcs.add(new BoundaryCondition("dirichlet", 0.0, 0.0));
    bcs.add(new BoundaryCondition("dirichlet", 0.0, 0.0));
    bcs.add(new BoundaryCondition("dirichlet", 0.0, 0.0));
    bcs.add(new BoundaryCondition("dirichlet", 0.0, 0.0));
    let result: ArrayList<ArrayList<double>> = PDE.laplace2D(n, n, 0.25, 0.25, bcs, 100, 1e-6);
    if (result.size() == 0) {
        io::println("FAIL: laplace2D empty result");
    } else {
        io::println("PASS: laplace2D works");
    }
}

public fn test_finite_difference_1d(): void {
    // 1D finite difference for u'' = f
    // finiteDifference1D(f, x0, x1, nx, t0, t1, nt, bc)
    let f: fn(double, double): double = fn(x: double, t: double): double => MathTrig.sin(3.14159265358979 * x);
    let result: ArrayList<ArrayList<double>> = PDE.finiteDifference1D(f, 0.0, 1.0, 5, 0.0, 0.1, 10, "dirichlet");
    if (result.size() == 0) {
        io::println("FAIL: finiteDifference1D empty result");
    } else {
        io::println("PASS: finiteDifference1D works");
    }
}

public fn test_finite_difference_2d(): void {
    // finiteDifference2D(f, x0, x1, y0, y1, nx, ny, bc)
    let f: fn(double, double): double = fn(x: double, y: double): double => -1.0;
    let result: ArrayList<ArrayList<ArrayList<double>>> = PDE.finiteDifference2D(f, 0.0, 1.0, 0.0, 1.0, 4, 4, "dirichlet");
    if (result.size() == 0) {
        io::println("FAIL: finiteDifference2D empty result");
    } else {
        io::println("PASS: finiteDifference2D works");
    }
}

public fn run_all_pde_tests(): void {
    io::println("=== pde/PDE.tr Tests ===");
    test_dirichlet_bc();
    test_neumann_bc();
    test_robin_bc();
    test_heat_equation_1d();
    test_heat_equation_1d_implicit();
    test_wave_equation_1d();
    test_poisson_2d();
    test_laplace_2d();
    test_finite_difference_1d();
    test_finite_difference_2d();
}
