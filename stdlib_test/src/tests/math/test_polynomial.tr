import tt::util::ArrayList;
import tt::math::polynomial::Polynomial;
import tt::math::Math;
import tt::math::MathAdvanced;

fn absDiff(a: double, b: double): double {
    let d: double = a - b;
    if (d < 0.0) { return -d; }
    return d;
}

fn approxEq(a: double, b: double, tol: double): bool {
    return absDiff(a, b) < tol;
}

fn makeCoeffs(): ArrayList<double> {
    let c: ArrayList<double> = new ArrayList<double>();
    c.add(3.0);
    c.add(0.0);
    c.add(-2.0);
    return c;
}

fn test_degree(): void {
    let p: Polynomial = new Polynomial(makeCoeffs());
    if (p.degree() == 2) {
        io::println("PASS test_degree: 3x^2 - 2 has degree 2");
    } else {
        io::println("FAIL test_degree: expected 2, got " + Integer.toString(p.degree()));
    }
}

fn test_degree_zero_poly(): void {
    let c: ArrayList<double> = new ArrayList<double>();
    c.add(0.0);
    c.add(0.0);
    let p: Polynomial = new Polynomial(c);
    if (p.degree() == 0) {
        io::println("PASS test_degree_zero_poly: zero polynomial has degree 0");
    } else {
        io::println("FAIL test_degree_zero_poly: expected 0, got " + Integer.toString(p.degree()));
    }
}

fn test_eval(): void {
    // p(x) = 3x^2 - 2; p(2) = 10
    let p: Polynomial = new Polynomial(makeCoeffs());
    let v: double = p.eval(2.0);
    if (approxEq(v, 10.0, 1e-9)) {
        io::println("PASS test_eval: 3*(2)^2 - 2 = 10");
    } else {
        io::println("FAIL test_eval: expected 10.0, got " + Double.toString(v));
    }
}

fn test_eval_at_zero(): void {
    let p: Polynomial = new Polynomial(makeCoeffs());
    let v: double = p.eval(0.0);
    if (approxEq(v, -2.0, 1e-9)) {
        io::println("PASS test_eval_at_zero: p(0) = -2 (constant term)");
    } else {
        io::println("FAIL test_eval_at_zero: expected -2.0, got " + Double.toString(v));
    }
}

fn test_evalAt_static(): void {
    let c: ArrayList<double> = new ArrayList<double>();
    c.add(1.0);
    c.add(2.0);
    c.add(1.0);
    let v: double = Polynomial.evalAt(c, 3.0);
    if (approxEq(v, 16.0, 1e-9)) {
        io::println("PASS test_evalAt_static: x^2 + 2x + 1 at x=3 = 16");
    } else {
        io::println("FAIL test_evalAt_static: expected 16.0, got " + Double.toString(v));
    }
}

fn test_add(): void {
    // (x + 1) + (x + 2) = 2x + 3
    let c1: ArrayList<double> = new ArrayList<double>();
    c1.add(1.0); c1.add(1.0);
    let c2: ArrayList<double> = new ArrayList<double>();
    c2.add(1.0); c2.add(2.0);
    let p1: Polynomial = new Polynomial(c1);
    let p2: Polynomial = new Polynomial(c2);
    let sum: Polynomial = p1.add(p2);
    let v: double = sum.eval(5.0);
    if (approxEq(v, 13.0, 1e-9)) {
        io::println("PASS test_add: (x+1)+(x+2) at x=5 = 13");
    } else {
        io::println("FAIL test_add: expected 13.0, got " + Double.toString(v));
    }
}

fn test_sub(): void {
    // (2x + 3) - (x + 1) = x + 2
    let c1: ArrayList<double> = new ArrayList<double>();
    c1.add(2.0); c1.add(3.0);
    let c2: ArrayList<double> = new ArrayList<double>();
    c2.add(1.0); c2.add(1.0);
    let p1: Polynomial = new Polynomial(c1);
    let p2: Polynomial = new Polynomial(c2);
    let diff: Polynomial = p1.sub(p2);
    let v: double = diff.eval(7.0);
    if (approxEq(v, 9.0, 1e-9)) {
        io::println("PASS test_sub: (2x+3)-(x+1) at x=7 = 9");
    } else {
        io::println("FAIL test_sub: expected 9.0, got " + Double.toString(v));
    }
}

fn test_mul(): void {
    // (x + 1)(x + 2) = x^2 + 3x + 2
    let c1: ArrayList<double> = new ArrayList<double>();
    c1.add(1.0); c1.add(1.0);
    let c2: ArrayList<double> = new ArrayList<double>();
    c2.add(1.0); c2.add(2.0);
    let p1: Polynomial = new Polynomial(c1);
    let p2: Polynomial = new Polynomial(c2);
    let prod: Polynomial = p1.mul(p2);
    let v: double = prod.eval(4.0);
    if (approxEq(v, 30.0, 1e-9)) {
        io::println("PASS test_mul: (x+1)(x+2) at x=4 = 30");
    } else {
        io::println("FAIL test_mul: expected 30.0, got " + Double.toString(v));
    }
}

fn test_scale(): void {
    let p: Polynomial = new Polynomial(makeCoeffs());
    let s: Polynomial = p.scale(2.0);
    let v: double = s.eval(2.0);
    if (approxEq(v, 20.0, 1e-9)) {
        io::println("PASS test_scale: 2*(3x^2 - 2) at x=2 = 20");
    } else {
        io::println("FAIL test_scale: expected 20.0, got " + Double.toString(v));
    }
}

fn test_div(): void {
    // (x^2 - 1) / (x - 1) = (x + 1) remainder 0
    let c1: ArrayList<double> = new ArrayList<double>();
    c1.add(1.0); c1.add(0.0); c1.add(-1.0);
    let c2: ArrayList<double> = new ArrayList<double>();
    c2.add(1.0); c2.add(-1.0);
    let p1: Polynomial = new Polynomial(c1);
    let p2: Polynomial = new Polynomial(c2);
    let qr: ArrayList<Polynomial> = p1.div(p2);
    let q: Polynomial = qr.get(0);
    let v: double = q.eval(5.0);
    if (approxEq(v, 6.0, 1e-9)) {
        io::println("PASS test_div: (x^2-1)/(x-1) quotient at x=5 = 6");
    } else {
        io::println("FAIL test_div: expected 6.0, got " + Double.toString(v));
    }
}

fn test_derivative(): void {
    // d/dx (3x^2 - 2) = 6x
    let p: Polynomial = new Polynomial(makeCoeffs());
    let d: Polynomial = p.derivative();
    let v: double = d.eval(2.0);
    if (approxEq(v, 12.0, 1e-9)) {
        io::println("PASS test_derivative: d/dx(3x^2-2) at x=2 = 12");
    } else {
        io::println("FAIL test_derivative: expected 12.0, got " + Double.toString(v));
    }
}

fn test_derivative_constant(): void {
    let c: ArrayList<double> = new ArrayList<double>();
    c.add(5.0);
    let p: Polynomial = new Polynomial(c);
    let d: Polynomial = p.derivative();
    let v: double = d.eval(100.0);
    if (approxEq(v, 0.0, 1e-9)) {
        io::println("PASS test_derivative_constant: derivative of constant is 0");
    } else {
        io::println("FAIL test_derivative_constant: expected 0.0, got " + Double.toString(v));
    }
}

fn test_integral(): void {
    // integral of 3x^2 - 2 = x^3 - 2x + C; with C=1, at x=2 = 8 - 4 + 1 = 5
    let p: Polynomial = new Polynomial(makeCoeffs());
    let i: Polynomial = p.integral(1.0);
    let v: double = i.eval(2.0);
    if (approxEq(v, 5.0, 1e-9)) {
        io::println("PASS test_integral: integral(3x^2-2) with C=1 at x=2 = 5");
    } else {
        io::println("FAIL test_integral: expected 5.0, got " + Double.toString(v));
    }
}

fn test_roots_linear(): void {
    // 2x - 6 = 0 => x = 3
    let c: ArrayList<double> = new ArrayList<double>();
    c.add(2.0); c.add(-6.0);
    let p: Polynomial = new Polynomial(c);
    let r: ArrayList<double> = p.roots();
    if (r.size() == 1 && approxEq(r.get(0), 3.0, 1e-9)) {
        io::println("PASS test_roots_linear: 2x-6 root = 3");
    } else {
        io::println("FAIL test_roots_linear: expected [3.0], got size " + Integer.toString(r.size()));
    }
}

fn test_roots_quadratic(): void {
    // x^2 - 5x + 6 = (x-2)(x-3)
    let c: ArrayList<double> = new ArrayList<double>();
    c.add(1.0); c.add(-5.0); c.add(6.0);
    let p: Polynomial = new Polynomial(c);
    let r: ArrayList<double> = p.roots();
    if (r.size() == 2) {
        let s: double = r.get(0) + r.get(1);
        let prod: double = r.get(0) * r.get(1);
        if (approxEq(s, 5.0, 1e-6) && approxEq(prod, 6.0, 1e-6)) {
            io::println("PASS test_roots_quadratic: x^2-5x+6 roots sum=5, prod=6");
        } else {
            io::println("FAIL test_roots_quadratic: sum=" + Double.toString(s) + " prod=" + Double.toString(prod));
        }
    } else {
        io::println("FAIL test_roots_quadratic: expected 2 roots, got " + Integer.toString(r.size()));
    }
}

fn test_roots_complex(): void {
    // x^2 + 1 = 0 has no real roots
    let c: ArrayList<double> = new ArrayList<double>();
    c.add(1.0); c.add(0.0); c.add(1.0);
    let p: Polynomial = new Polynomial(c);
    let r: ArrayList<double> = p.roots();
    if (r.size() == 0) {
        io::println("PASS test_roots_complex: x^2+1 has no real roots");
    } else {
        io::println("FAIL test_roots_complex: expected 0 real roots, got " + Integer.toString(r.size()));
    }
}

fn test_isRoot(): void {
    // (x-3) is a factor of x^2 - 5x + 6, so x=3 is a root
    let c: ArrayList<double> = new ArrayList<double>();
    c.add(1.0); c.add(-5.0); c.add(6.0);
    let p: Polynomial = new Polynomial(c);
    if (p.isRoot(3.0, 1e-6)) {
        io::println("PASS test_isRoot: x=3 is a root of x^2-5x+6");
    } else {
        io::println("FAIL test_isRoot: x=3 should be a root");
    }
}

fn test_isRoot_false(): void {
    let c: ArrayList<double> = new ArrayList<double>();
    c.add(1.0); c.add(-5.0); c.add(6.0);
    let p: Polynomial = new Polynomial(c);
    if (!p.isRoot(4.0, 1e-6)) {
        io::println("PASS test_isRoot_false: x=4 is not a root of x^2-5x+6");
    } else {
        io::println("FAIL test_isRoot_false: x=4 should not be a root");
    }
}

fn test_compose(): void {
    // p(x) = x + 1, q(x) = x + 2; p(q(x)) = (x+2) + 1 = x + 3
    let c1: ArrayList<double> = new ArrayList<double>();
    c1.add(1.0); c1.add(1.0);
    let c2: ArrayList<double> = new ArrayList<double>();
    c2.add(1.0); c2.add(2.0);
    let p: Polynomial = new Polynomial(c1);
    let q: Polynomial = new Polynomial(c2);
    let comp: Polynomial = p.compose(q);
    let v: double = comp.eval(5.0);
    if (approxEq(v, 8.0, 1e-9)) {
        io::println("PASS test_compose: (x+1) o (x+2) at x=5 = 8");
    } else {
        io::println("FAIL test_compose: expected 8.0, got " + Double.toString(v));
    }
}

fn test_fromRoots(): void {
    let roots: ArrayList<double> = new ArrayList<double>();
    roots.add(2.0);
    roots.add(3.0);
    let p: Polynomial = fromRoots(roots);
    // (x-2)(x-3) = x^2 - 5x + 6
    let v2: double = p.eval(2.0);
    let v3: double = p.eval(3.0);
    if (approxEq(v2, 0.0, 1e-9) && approxEq(v3, 0.0, 1e-9)) {
        io::println("PASS test_fromRoots: fromRoots([2,3]) vanishes at 2 and 3");
    } else {
        io::println("FAIL test_fromRoots: v2=" + Double.toString(v2) + " v3=" + Double.toString(v3));
    }
}

fn test_lagrangeInterpolation(): void {
    // Interpolate points (0,1), (1,2), (2,5) -> polynomial x^2 + 1
    let xs: ArrayList<double> = new ArrayList<double>();
    xs.add(0.0); xs.add(1.0); xs.add(2.0);
    let ys: ArrayList<double> = new ArrayList<double>();
    ys.add(1.0); ys.add(2.0); ys.add(5.0);
    let p: Polynomial = lagrangeInterpolation(xs, ys);
    let v3: double = p.eval(3.0);
    if (approxEq(v3, 10.0, 1e-6)) {
        io::println("PASS test_lagrangeInterpolation: interpolated poly at x=3 = 10");
    } else {
        io::println("FAIL test_lagrangeInterpolation: expected 10.0, got " + Double.toString(v3));
    }
}

fn test_polyfit(): void {
    // Fit a line y = 2x + 1 through points (0,1), (1,3), (2,5)
    let xs: ArrayList<double> = new ArrayList<double>();
    xs.add(0.0); xs.add(1.0); xs.add(2.0);
    let ys: ArrayList<double> = new ArrayList<double>();
    ys.add(1.0); ys.add(3.0); ys.add(5.0);
    let p: Polynomial = polyfit(xs, ys, 1);
    let v10: double = p.eval(10.0);
    if (approxEq(v10, 21.0, 1e-6)) {
        io::println("PASS test_polyfit: fitted line y=2x+1 at x=10 = 21");
    } else {
        io::println("FAIL test_polyfit: expected 21.0, got " + Double.toString(v10));
    }
}

fn test_companionMatrix(): void {
    // For x^2 - 5x + 6, companion matrix is 2x2
    let c: ArrayList<double> = new ArrayList<double>();
    c.add(1.0); c.add(-5.0); c.add(6.0);
    let p: Polynomial = new Polynomial(c);
    let m: ArrayList<ArrayList<double>> = companionMatrix(p);
    if (m.size() == 2) {
        io::println("PASS test_companionMatrix: degree-2 poly gives 2x2 companion matrix");
    } else {
        io::println("FAIL test_companionMatrix: expected size 2, got " + Integer.toString(m.size()));
    }
}

fn test_toString(): void {
    let p: Polynomial = new Polynomial(makeCoeffs());
    let s: string = p.toString();
    // Should contain "x^2" and "3"
    if (String.indexOf(s, "x^2") >= 0) {
        io::println("PASS test_toString: toString contains 'x^2'");
    } else {
        io::println("FAIL test_toString: missing 'x^2' in '" + s + "'");
    }
}

fn test_toString_zero(): void {
    let c: ArrayList<double> = new ArrayList<double>();
    c.add(0.0);
    let p: Polynomial = new Polynomial(c);
    let s: string = p.toString();
    if (s == "0") {
        io::println("PASS test_toString_zero: zero polynomial toString = '0'");
    } else {
        io::println("FAIL test_toString_zero: expected '0', got '" + s + "'");
    }
}

public fn run_all_polynomial_tests(): void {
    io::println("=== Polynomial tests ===");
    test_degree();
    test_degree_zero_poly();
    test_eval();
    test_eval_at_zero();
    test_evalAt_static();
    test_add();
    test_sub();
    test_mul();
    test_scale();
    test_div();
    test_derivative();
    test_derivative_constant();
    test_integral();
    test_roots_linear();
    test_roots_quadratic();
    test_roots_complex();
    test_isRoot();
    test_isRoot_false();
    test_compose();
    test_fromRoots();
    test_lagrangeInterpolation();
    test_polyfit();
    test_companionMatrix();
    test_toString();
    test_toString_zero();
}
