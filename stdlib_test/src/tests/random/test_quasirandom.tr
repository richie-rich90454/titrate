public fn test_latinHypercube_basic(): void {
    let seq: ArrayList<ArrayList<double>> = latinHypercube(2, 10);
    if (seq.size() != 10) {
        io::println("FAIL: latinHypercube returned " + Integer.toString(seq.size()) + " points");
    } else if (seq.get(0).size() != 2) {
        io::println("FAIL: latinHypercube dimension wrong");
    } else {
        io::println("PASS: latinHypercube returns 10 points of dim 2");
