// Test file for random/QuasiRandom.tr
// Exercises the public API of the QuasiRandom module: low-discrepancy sequence
// generators (Sobol, Halton, Latin Hypercube, Antithetic Variates).
import tt::random::QuasiRandom;
import tt::util::ArrayList;
import tt::lang::Integer;

public fn test_sobolSequence_basic(): void {
    let seq: ArrayList<ArrayList<double>> = sobolSequence(2, 10);
    if (seq.size() != 10) {
        io::println("FAIL: sobolSequence returned " + Integer.toString(seq.size()) + " points");
    } else if (seq.get(0).size() != 2) {
        io::println("FAIL: sobolSequence dimension wrong");
    } else {
        io::println("PASS: sobolSequence returns 10 points of dim 2");
    }
}

public fn test_sobolSequence_in_unit_cube(): void {
    let seq: ArrayList<ArrayList<double>> = sobolSequence(3, 20);
    var ok: bool = true;
    var i: int = 0;
    while (i < seq.size()) {
        var d: int = 0;
        while (d < seq.get(i).size()) {
            let v: double = seq.get(i).get(d);
            if (v < 0.0 || v >= 1.0) { ok = false; break; }
            d = d + 1;
        }
        if (!ok) { break; }
        i = i + 1;
    }
    if (!ok) {
        io::println("FAIL: sobolSequence point out of [0,1)");
    } else {
        io::println("PASS: sobolSequence points in unit cube");
    }
}

public fn test_sobolSequence_zero_dim(): void {
    let seq: ArrayList<ArrayList<double>> = sobolSequence(0, 10);
    if (seq.size() != 0) {
        io::println("FAIL: sobolSequence dim=0 should be empty");
    } else {
        io::println("PASS: sobolSequence dim=0 returns empty");
    }
}

public fn test_sobolSequence_zero_n(): void {
    let seq: ArrayList<ArrayList<double>> = sobolSequence(2, 0);
