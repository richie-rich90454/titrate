public fn test_latinHypercube_in_unit_cube(): void {
    let seq: ArrayList<ArrayList<double>> = latinHypercube(3, 8);
    var ok: bool = true;
    var i: int = 0;
    while (i < seq.size()) {
        var d: int = 0;
        while (d < seq.get(i).size()) {
            let v: double = seq.get(i).get(d);
            if (v < 0.0 || v > 1.0) { ok = false; break; }
            d = d + 1;
        }
        if (!ok) { break; }
        i = i + 1;
    }
    if (!ok) {
        io::println("FAIL: latinHypercube point out of [0,1]");
    } else {
        io::println("PASS: latinHypercube points in unit cube");
    }
}

public fn test_antitheticVariates_complement(): void {
    let sample: ArrayList<double> = new ArrayList<double>();
    sample.add(0.1); sample.add(0.5); sample.add(0.9);
    let result: ArrayList<double> = antitheticVariates(sample);
    if (result.size() != 3) {
        io::println("FAIL: antitheticVariates size = " + Integer.toString(result.size()));
    } else if (result.get(0) != 0.9 || result.get(1) != 0.5 || result.get(2) != 0.1) {
        io::println("FAIL: antitheticVariates values wrong");
    } else {
        io::println("PASS: antitheticVariates produces complements");
    }
}

public fn test_antitheticVariates_empty(): void {
    let sample: ArrayList<double> = new ArrayList<double>();
    let result: ArrayList<double> = antitheticVariates(sample);
    if (result.size() != 0) {
        io::println("FAIL: antitheticVariates empty should return empty");
    } else {
        io::println("PASS: antitheticVariates empty returns empty");
    }
}

public fn run_all_quasirandom_tests(): void {
    io::println("=== QuasiRandom.tr Tests ===");
    test_sobolSequence_basic();
    test_sobolSequence_in_unit_cube();
    test_sobolSequence_zero_dim();
    test_sobolSequence_zero_n();
    test_haltonSequence_basic();
    test_haltonSequence_in_unit_cube();
    test_latinHypercube_basic();
    test_latinHypercube_in_unit_cube();
    test_antitheticVariates_complement();
    test_antitheticVariates_empty();
}
