// Test file for statistics/Statistics.tr
// Exercises descriptive statistics, probability distributions, hypothesis testing,
// ANOVA, Bayesian inference, and helper functions.
import tt::statistics::Statistics;
import tt::util::ArrayList;
import tt::util::HashMap;
import tt::random::Random;

fn absDiff(a: double, b: double): double {
    let d: double = a - b;
    if (d < 0.0) { return -d; }
    return d;
}

fn makeList(): ArrayList<double> {
    let data: ArrayList<double> = new ArrayList<double>();
    data.add(1.0);
    data.add(2.0);
    data.add(3.0);
    data.add(4.0);
    data.add(5.0);
    return data;
}

// ==================== Descriptive Statistics ====================

public fn test_mean(): void {
    let data: ArrayList<double> = makeList();
    let m: double = Statistics.mean(data);
    if (absDiff(m, 3.0) > 1e-9) {
        io::println("FAIL: mean expected 3.0");
    } else {
        io::println("PASS: mean = 3.0");
    }
    let empty: ArrayList<double> = new ArrayList<double>();
    if (Statistics.mean(empty) != 0.0) {
        io::println("FAIL: mean of empty expected 0.0");
    } else {
        io::println("PASS: mean of empty = 0.0");
    }
}

public fn test_median(): void {
    let data: ArrayList<double> = makeList();
    let med: double = Statistics.median(data);
    if (absDiff(med, 3.0) > 1e-9) {
        io::println("FAIL: median expected 3.0");
    } else {
        io::println("PASS: median = 3.0");
    }
    let even: ArrayList<double> = new ArrayList<double>();
    even.add(1.0);
    even.add(2.0);
    even.add(3.0);
    even.add(4.0);
    let med2: double = Statistics.median(even);
    if (absDiff(med2, 2.5) > 1e-9) {
        io::println("FAIL: median of even list expected 2.5");
    } else {
        io::println("PASS: median of even list = 2.5");
    }
}

public fn test_mode(): void {
    let data: ArrayList<double> = new ArrayList<double>();
    data.add(1.0);
    data.add(2.0);
    data.add(2.0);
    data.add(3.0);
    let m: double = Statistics.mode(data);
    if (absDiff(m, 2.0) > 1e-9) {
        io::println("FAIL: mode expected 2.0");
    } else {
        io::println("PASS: mode = 2.0");
    }
}

public fn test_variance_stdev(): void {
    let data: ArrayList<double> = makeList();
    let v: double = Statistics.variance(data);
    // sample variance of 1,2,3,4,5 = 2.5
    if (absDiff(v, 2.5) > 1e-9) {
        io::println("FAIL: variance expected 2.5");
    } else {
        io::println("PASS: variance = 2.5");
    }
    let s: double = Statistics.stdev(data);
    if (absDiff(s, 1.5811388300841898) > 1e-6) {
        io::println("FAIL: stdev expected ~1.5811");
    } else {
        io::println("PASS: stdev = ~1.5811");
    }
}

public fn test_pvariance_pstdev(): void {
    let data: ArrayList<double> = makeList();
    let pv: double = Statistics.pvariance(data);
    // population variance of 1,2,3,4,5 = 2.0
    if (absDiff(pv, 2.0) > 1e-9) {
        io::println("FAIL: pvariance expected 2.0");
    } else {
        io::println("PASS: pvariance = 2.0");
    }
    let ps: double = Statistics.pstdev(data);
    if (absDiff(ps, 1.4142135623730951) > 1e-6) {
        io::println("FAIL: pstdev expected ~1.4142");
    } else {
        io::println("PASS: pstdev = ~1.4142");
    }
}

public fn test_quantiles(): void {
    let data: ArrayList<double> = makeList();
    let qs: ArrayList<double> = Statistics.quantiles(data, 4);
    // quantiles(data, 4) returns [Q1, Q2, Q3] = 3 cut points
    if (qs.size() != 3) {
        io::println("FAIL: quantiles size expected 3");
    } else {
        io::println("PASS: quantiles size = 3");
    }
    // Q2 (median) should be 3.0
    if (qs.size() >= 2 && absDiff(qs.get(1), 3.0) > 1e-9) {
        io::println("FAIL: Q2 expected 3.0");
    } else {
        io::println("PASS: Q2 = 3.0");
    }
}

public fn test_correlation(): void {
    let x: ArrayList<double> = makeList();
    let y: ArrayList<double> = new ArrayList<double>();
    y.add(2.0);
    y.add(4.0);
    y.add(6.0);
    y.add(8.0);
    y.add(10.0);
    let r: double = Statistics.correlation(x, y);
    // Perfect positive correlation
    if (absDiff(r, 1.0) > 1e-9) {
        io::println("FAIL: correlation expected 1.0");
    } else {
        io::println("PASS: correlation = 1.0");
    }
}

public fn test_linear_regression(): void {
    let x: ArrayList<double> = makeList();
    let y: ArrayList<double> = new ArrayList<double>();
    y.add(2.0);
    y.add(4.0);
    y.add(6.0);
    y.add(8.0);
    y.add(10.0);
    let result: ArrayList<double> = Statistics.linearRegression(x, y);
    // y = 2x, slope=2, intercept=0
    if (result.size() >= 2 && absDiff(result.get(0), 2.0) > 1e-9) {
        io::println("FAIL: slope expected 2.0");
    } else {
        io::println("PASS: slope = 2.0");
    }
    if (result.size() >= 2 && absDiff(result.get(1), 0.0) > 1e-9) {
        io::println("FAIL: intercept expected 0.0");
    } else {
        io::println("PASS: intercept = 0.0");
    }
}

public fn test_geometric_mean(): void {
    let data: ArrayList<double> = new ArrayList<double>();
    data.add(1.0);
    data.add(3.0);
    data.add(9.0);
    let gm: double = Statistics.geometricMean(data);
    // geometric mean of 1, 3, 9 = 3
    if (absDiff(gm, 3.0) > 1e-6) {
        io::println("FAIL: geometricMean expected 3.0");
    } else {
        io::println("PASS: geometricMean = 3.0");
    }
}

public fn test_harmonic_mean(): void {
    let data: ArrayList<double> = new ArrayList<double>();
    data.add(1.0);
    data.add(2.0);
    data.add(4.0);
    let hm: double = Statistics.harmonicMean(data);
    // harmonic mean of 1, 2, 4 = 3 / (1 + 0.5 + 0.25) = 3/1.75 = 1.714...
    let expected: double = 3.0 / 1.75;
    if (absDiff(hm, expected) > 1e-9) {
        io::println("FAIL: harmonicMean expected " + expected);
    } else {
        io::println("PASS: harmonicMean = " + hm);
    }
}

public fn test_fmean(): void {
    let data: ArrayList<double> = makeList();
    let m: double = Statistics.fmean(data);
    if (absDiff(m, 3.0) > 1e-9) {
        io::println("FAIL: fmean expected 3.0");
    } else {
        io::println("PASS: fmean = 3.0");
    }
    // Weighted fmean
    let weights: ArrayList<double> = new ArrayList<double>();
    weights.add(1.0);
    weights.add(1.0);
    weights.add(1.0);
    weights.add(1.0);
    weights.add(1.0);
    let wm: double = Statistics.fmean(data, weights);
    if (absDiff(wm, 3.0) > 1e-9) {
        io::println("FAIL: weighted fmean expected 3.0");
    } else {
        io::println("PASS: weighted fmean = 3.0");
    }
}

public fn test_median_grouped(): void {
    let data: ArrayList<double> = new ArrayList<double>();
    data.add(1.0);
    data.add(2.0);
    data.add(3.0);
    data.add(4.0);
    let mg: double = Statistics.medianGrouped(data, 1.0);
    // Should be around 2.5
    if (mg <= 0.0) {
        io::println("FAIL: medianGrouped returned non-positive");
    } else {
        io::println("PASS: medianGrouped = " + mg);
    }
}

public fn test_covariance(): void {
    let x: ArrayList<double> = makeList();
    let y: ArrayList<double> = new ArrayList<double>();
    y.add(2.0);
    y.add(4.0);
    y.add(6.0);
    y.add(8.0);
    y.add(10.0);
    let cov: double = Statistics.covariance(x, y);
    // covariance of (1..5) and (2,4,6,8,10) = 2.5 * 2 = 5.0
    if (absDiff(cov, 5.0) > 1e-9) {
        io::println("FAIL: covariance expected 5.0");
    } else {
        io::println("PASS: covariance = 5.0");
    }
}

public fn test_multimode(): void {
    let data: ArrayList<double> = new ArrayList<double>();
    data.add(1.0);
    data.add(2.0);
    data.add(2.0);
    data.add(3.0);
    data.add(3.0);
    let modes: ArrayList<double> = Statistics.multimode(data);
    // Both 2.0 and 3.0 appear twice
    if (modes.size() != 2) {
        io::println("FAIL: multimode size expected 2");
    } else {
        io::println("PASS: multimode size = 2");
    }
}

// ==================== Extended Descriptive Statistics ====================

public fn test_skewness(): void {
    let data: ArrayList<double> = makeList();
    let sk: double = Statistics.skewness(data);
    // Symmetric data has skewness ~0
    if (absDiff(sk, 0.0) > 1e-9) {
        io::println("FAIL: skewness expected 0.0");
    } else {
        io::println("PASS: skewness = 0.0");
    }
}

public fn test_kurtosis(): void {
    let data: ArrayList<double> = makeList();
    let k: double = Statistics.kurtosis(data);
    // Excess kurtosis of uniform-ish data
    if (k >= 0.0) {
        io::println("FAIL: kurtosis of uniform data should be negative");
    } else {
        io::println("PASS: kurtosis = " + k);
    }
}

public fn test_moment(): void {
    let data: ArrayList<double> = makeList();
    let m2: double = Statistics.moment(data, 2);
    // Second central moment = population variance = 2.0
    if (absDiff(m2, 2.0) > 1e-9) {
        io::println("FAIL: moment(2) expected 2.0");
    } else {
        io::println("PASS: moment(2) = 2.0");
    }
    let m1: double = Statistics.moment(data, 1);
    // First central moment = 0
    if (absDiff(m1, 0.0) > 1e-9) {
        io::println("FAIL: moment(1) expected 0.0");
    } else {
        io::println("PASS: moment(1) = 0.0");
    }
}

public fn test_standard_error(): void {
    let data: ArrayList<double> = makeList();
    let se: double = Statistics.standardError(data);
    // se = stdev / sqrt(5) = 1.5811... / 2.236... = 0.7071...
    if (se <= 0.0) {
        io::println("FAIL: standardError expected positive");
    } else {
        io::println("PASS: standardError = " + se);
    }
}

public fn test_coefficient_of_variation(): void {
    let data: ArrayList<double> = makeList();
    let cv: double = Statistics.coefficientOfVariation(data);
    // cv = stdev / mean = 1.5811... / 3.0
    if (cv <= 0.0) {
        io::println("FAIL: coefficientOfVariation expected positive");
    } else {
        io::println("PASS: coefficientOfVariation = " + cv);
    }
}

public fn test_zscore(): void {
    let z: double = Statistics.zScore(5.0, 3.0, 2.0);
    // (5 - 3) / 2 = 1.0
    if (absDiff(z, 1.0) > 1e-9) {
        io::println("FAIL: zScore expected 1.0");
    } else {
        io::println("PASS: zScore = 1.0");
    }
    // stdev = 0 should return 0
    let z0: double = Statistics.zScore(5.0, 3.0, 0.0);
    if (z0 != 0.0) {
        io::println("FAIL: zScore with zero stdev expected 0.0");
    } else {
        io::println("PASS: zScore with zero stdev = 0.0");
    }
}

public fn test_interquartile_range(): void {
    let data: ArrayList<double> = new ArrayList<double>();
    data.add(1.0);
    data.add(2.0);
    data.add(3.0);
    data.add(4.0);
    data.add(5.0);
    data.add(6.0);
    data.add(7.0);
    data.add(8.0);
    let iqr: double = Statistics.interquartileRange(data);
    if (iqr <= 0.0) {
        io::println("FAIL: interquartileRange expected positive");
    } else {
        io::println("PASS: interquartileRange = " + iqr);
    }
}

// ==================== Confidence Intervals ====================

public fn test_z_value_for_confidence(): void {
    let z95: double = Statistics.zValueForConfidence(0.95);
    if (absDiff(z95, 1.96) > 1e-9) {
        io::println("FAIL: zValueForConfidence(0.95) expected 1.96");
    } else {
        io::println("PASS: zValueForConfidence(0.95) = 1.96");
    }
    let z99: double = Statistics.zValueForConfidence(0.99);
    if (absDiff(z99, 2.576) > 1e-9) {
        io::println("FAIL: zValueForConfidence(0.99) expected 2.576");
    } else {
        io::println("PASS: zValueForConfidence(0.99) = 2.576");
    }
}

public fn test_mean_confidence_interval(): void {
    let data: ArrayList<double> = makeList();
    let ci: ArrayList<double> = Statistics.meanConfidenceInterval(data, 0.95);
    if (ci.size() != 2) {
        io::println("FAIL: meanConfidenceInterval size expected 2");
    } else {
        io::println("PASS: meanConfidenceInterval size = 2");
    }
    if (ci.size() == 2 && ci.get(0) >= ci.get(1)) {
        io::println("FAIL: lower bound should be less than upper bound");
    } else {
        io::println("PASS: lower < upper");
    }
}

public fn test_proportion_confidence_interval(): void {
    let ci: ArrayList<double> = Statistics.proportionConfidenceInterval(0.5, 100, 0.95);
    if (ci.size() != 2) {
        io::println("FAIL: proportionConfidenceInterval size expected 2");
    } else {
        io::println("PASS: proportionConfidenceInterval size = 2");
    }
    // For p=0.5, n=100, the interval should contain 0.5
    if (ci.size() == 2 && (ci.get(0) > 0.5 || ci.get(1) < 0.5)) {
        io::println("FAIL: interval should contain 0.5");
    } else {
        io::println("PASS: interval contains 0.5");
    }
}

// ==================== Hypothesis Testing ====================

public fn test_one_sample_t_test(): void {
    let data: ArrayList<double> = makeList();
    let result: HashMap<string, double> = Statistics.oneSampleTTest(data, 3.0);
    // Mean is 3.0, testing against 3.0, t should be 0
    let t: double = result.get("t");
    if (absDiff(t, 0.0) > 1e-9) {
        io::println("FAIL: oneSampleTTest t expected 0.0");
    } else {
        io::println("PASS: oneSampleTTest t = 0.0");
    }
    let p: double = result.get("p");
    if (absDiff(p, 1.0) > 1e-6) {
        io::println("FAIL: oneSampleTTest p expected ~1.0");
    } else {
        io::println("PASS: oneSampleTTest p = ~1.0");
    }
}

public fn test_two_sample_t_test(): void {
    let data1: ArrayList<double> = makeList();
    let data2: ArrayList<double> = new ArrayList<double>();
    data2.add(6.0);
    data2.add(7.0);
    data2.add(8.0);
    data2.add(9.0);
    data2.add(10.0);
    let result: HashMap<string, double> = Statistics.twoSampleTTest(data1, data2);
    let t: double = result.get("t");
    // Means differ by 5, so t should be significantly negative
    if (t >= 0.0) {
        io::println("FAIL: twoSampleTTest t expected negative");
    } else {
        io::println("PASS: twoSampleTTest t is negative");
    }
}

public fn test_chi_squared_test(): void {
    let observed: ArrayList<double> = new ArrayList<double>();
    observed.add(50.0);
    observed.add(30.0);
    observed.add(20.0);
    let expected: ArrayList<double> = new ArrayList<double>();
    expected.add(33.33);
    expected.add(33.33);
    expected.add(33.34);
    let result: HashMap<string, double> = Statistics.chiSquaredTest(observed, expected);
    let chi2: double = result.get("chi2");
    if (chi2 <= 0.0) {
        io::println("FAIL: chiSquaredTest chi2 expected positive");
    } else {
        io::println("PASS: chiSquaredTest chi2 = " + chi2);
    }
}

public fn test_paired_t_test(): void {
    let before: ArrayList<double> = new ArrayList<double>();
    before.add(1.0);
    before.add(2.0);
    before.add(3.0);
    before.add(4.0);
    let after: ArrayList<double> = new ArrayList<double>();
    after.add(1.0);
    after.add(2.0);
    after.add(3.0);
    after.add(4.0);
    let result: HashMap<string, double> = Statistics.pairedTTest(before, after);
    // No difference, t should be 0
    let t: double = result.get("tStatistic");
    if (absDiff(t, 0.0) > 1e-9) {
        io::println("FAIL: pairedTTest t expected 0.0");
    } else {
        io::println("PASS: pairedTTest t = 0.0");
    }
}

public fn test_mann_whitney_u_test(): void {
    let x: ArrayList<double> = new ArrayList<double>();
    x.add(1.0);
    x.add(2.0);
    x.add(3.0);
    let y: ArrayList<double> = new ArrayList<double>();
    y.add(4.0);
    y.add(5.0);
    y.add(6.0);
    let result: HashMap<string, double> = Statistics.mannWhitneyUTest(x, y);
    let u: double = result.get("uStatistic");
    if (u < 0.0) {
        io::println("FAIL: mannWhitneyUTest u expected non-negative");
    } else {
        io::println("PASS: mannWhitneyUTest u = " + u);
    }
}

public fn test_wilcoxon_test(): void {
    let x: ArrayList<double> = new ArrayList<double>();
    x.add(1.0);
    x.add(2.0);
    x.add(3.0);
    x.add(4.0);
    let y: ArrayList<double> = new ArrayList<double>();
    y.add(2.0);
    y.add(3.0);
    y.add(4.0);
    y.add(5.0);
    let result: HashMap<string, double> = Statistics.wilcoxonTest(x, y);
    let w: double = result.get("wStatistic");
    if (w < 0.0) {
        io::println("FAIL: wilcoxonTest w expected non-negative");
    } else {
        io::println("PASS: wilcoxonTest w = " + w);
    }
}

public fn test_f_test(): void {
    let s1: ArrayList<double> = new ArrayList<double>();
    s1.add(1.0);
    s1.add(2.0);
    s1.add(3.0);
    s1.add(4.0);
    s1.add(5.0);
    let s2: ArrayList<double> = new ArrayList<double>();
    s2.add(1.0);
    s2.add(1.0);
    s2.add(1.0);
    s2.add(1.0);
    s2.add(1.0);
    let result: ArrayList<double> = Statistics.fTest(s1, s2);
    if (result.size() != 4) {
        io::println("FAIL: fTest size expected 4");
    } else {
        io::println("PASS: fTest size = 4");
    }
}

// ==================== NormalDist Class ====================

public fn test_normal_dist_pdf(): void {
    let nd: NormalDist = new NormalDist(0.0, 1.0);
    let p: double = nd.pdf(0.0);
    // Standard normal at 0: 1/sqrt(2*pi) = 0.3989...
    if (absDiff(p, 0.3989422804014327) > 1e-6) {
        io::println("FAIL: NormalDist.pdf(0) expected 0.3989");
    } else {
        io::println("PASS: NormalDist.pdf(0) = 0.3989");
    }
}

public fn test_normal_dist_cdf(): void {
    let nd: NormalDist = new NormalDist(0.0, 1.0);
    let c: double = nd.cdf(0.0);
    // CDF at mean = 0.5
    if (absDiff(c, 0.5) > 1e-9) {
        io::println("FAIL: NormalDist.cdf(0) expected 0.5");
    } else {
        io::println("PASS: NormalDist.cdf(0) = 0.5");
    }
}

public fn test_normal_dist_inv_cdf(): void {
    let nd: NormalDist = new NormalDist(0.0, 1.0);
    let x: double = nd.invCdf(0.5);
    // Inverse CDF at 0.5 = 0 (mean)
    if (absDiff(x, 0.0) > 1e-6) {
        io::println("FAIL: NormalDist.invCdf(0.5) expected 0.0");
    } else {
        io::println("PASS: NormalDist.invCdf(0.5) = 0.0");
    }
    let x975: double = nd.invCdf(0.975);
    // Should be ~1.96
    if (absDiff(x975, 1.96) > 1e-2) {
        io::println("FAIL: NormalDist.invCdf(0.975) expected ~1.96");
    } else {
        io::println("PASS: NormalDist.invCdf(0.975) = ~1.96");
    }
}

public fn test_normal_dist_overlap(): void {
    let nd1: NormalDist = new NormalDist(0.0, 1.0);
    let nd2: NormalDist = new NormalDist(0.0, 1.0);
    let ov: double = nd1.overlap(nd2);
    // Identical distributions overlap = 1.0
    if (absDiff(ov, 1.0) > 1e-3) {
        io::println("FAIL: overlap of identical distributions expected ~1.0");
    } else {
        io::println("PASS: overlap of identical distributions = ~1.0");
    }
}

public fn test_normal_dist_quantiles(): void {
    let nd: NormalDist = new NormalDist(0.0, 1.0);
    let qs: ArrayList<double> = nd.quantiles(4);
    // 4-quantiles returns 3 cut points
    if (qs.size() != 3) {
        io::println("FAIL: NormalDist.quantiles(4) size expected 3");
    } else {
        io::println("PASS: NormalDist.quantiles(4) size = 3");
    }
    // Second quantile (median) should be 0
    if (qs.size() == 3 && absDiff(qs.get(1), 0.0) > 1e-6) {
        io::println("FAIL: NormalDist.quantiles(4)[1] expected 0.0");
    } else {
        io::println("PASS: NormalDist.quantiles(4)[1] = 0.0");
    }
}

public fn test_normal_dist_zscore(): void {
    let nd: NormalDist = new NormalDist(5.0, 2.0);
    let z: double = nd.zscore(7.0);
    // (7 - 5) / 2 = 1.0
    if (absDiff(z, 1.0) > 1e-9) {
        io::println("FAIL: NormalDist.zscore(7) expected 1.0");
    } else {
        io::println("PASS: NormalDist.zscore(7) = 1.0");
    }
}

public fn test_normal_dist_samples(): void {
    let nd: NormalDist = new NormalDist(0.0, 1.0);
    let rng: Random = new Random();
    let samples: ArrayList<double> = nd.samples(rng, 100);
    if (samples.size() != 100) {
        io::println("FAIL: NormalDist.samples size expected 100");
    } else {
        io::println("PASS: NormalDist.samples size = 100");
    }
}

// ==================== Other Distributions ====================

public fn test_uniform_dist(): void {
    let ud: UniformDist = new UniformDist(0.0, 10.0);
    let m: double = ud.mean();
    if (absDiff(m, 5.0) > 1e-9) {
        io::println("FAIL: UniformDist.mean expected 5.0");
    } else {
        io::println("PASS: UniformDist.mean = 5.0");
    }
    let v: double = ud.variance();
    // variance = (b-a)^2/12 = 100/12 = 8.333...
    if (absDiff(v, 8.333333333333334) > 1e-6) {
        io::println("FAIL: UniformDist.variance expected 8.333");
    } else {
        io::println("PASS: UniformDist.variance = 8.333");
    }
    let pdfInside: double = ud.pdf(5.0);
    if (absDiff(pdfInside, 0.1) > 1e-9) {
        io::println("FAIL: UniformDist.pdf(5) expected 0.1");
    } else {
        io::println("PASS: UniformDist.pdf(5) = 0.1");
    }
    let pdfOutside: double = ud.pdf(15.0);
    if (pdfOutside != 0.0) {
        io::println("FAIL: UniformDist.pdf(15) expected 0.0");
    } else {
        io::println("PASS: UniformDist.pdf(15) = 0.0");
    }
    let cdf: double = ud.cdf(5.0);
    if (absDiff(cdf, 0.5) > 1e-9) {
        io::println("FAIL: UniformDist.cdf(5) expected 0.5");
    } else {
        io::println("PASS: UniformDist.cdf(5) = 0.5");
    }
}

public fn test_exponential_dist(): void {
    let ed: ExponentialDist = new ExponentialDist(2.0);
    let m: double = ed.mean();
    // mean = 1/lambda = 0.5
    if (absDiff(m, 0.5) > 1e-9) {
        io::println("FAIL: ExponentialDist.mean expected 0.5");
    } else {
        io::println("PASS: ExponentialDist.mean = 0.5");
    }
    let pdf: double = ed.pdf(0.0);
    // pdf(0) = lambda = 2.0
    if (absDiff(pdf, 2.0) > 1e-9) {
        io::println("FAIL: ExponentialDist.pdf(0) expected 2.0");
    } else {
        io::println("PASS: ExponentialDist.pdf(0) = 2.0");
    }
    let cdf: double = ed.cdf(0.0);
    if (absDiff(cdf, 0.0) > 1e-9) {
        io::println("FAIL: ExponentialDist.cdf(0) expected 0.0");
    } else {
        io::println("PASS: ExponentialDist.cdf(0) = 0.0");
    }
}

public fn test_poisson_dist(): void {
    let pd: PoissonDist = new PoissonDist(3.0);
    let m: double = pd.mean();
    if (absDiff(m, 3.0) > 1e-9) {
        io::println("FAIL: PoissonDist.mean expected 3.0");
    } else {
        io::println("PASS: PoissonDist.mean = 3.0");
    }
    let pmf0: double = pd.pmf(0);
    // pmf(0) = exp(-3) = 0.0498...
    if (absDiff(pmf0, 0.049787068367863944) > 1e-6) {
        io::println("FAIL: PoissonDist.pmf(0) expected 0.0498");
    } else {
        io::println("PASS: PoissonDist.pmf(0) = 0.0498");
    }
    let cdf0: double = pd.cdf(0);
    if (absDiff(cdf0, pmf0) > 1e-9) {
        io::println("FAIL: PoissonDist.cdf(0) should equal pmf(0)");
    } else {
        io::println("PASS: PoissonDist.cdf(0) = pmf(0)");
    }
}

public fn test_binomial_dist(): void {
    let bd: BinomialDist = new BinomialDist(10, 0.5);
    let m: double = bd.mean();
    // mean = n*p = 5.0
    if (absDiff(m, 5.0) > 1e-9) {
        io::println("FAIL: BinomialDist.mean expected 5.0");
    } else {
        io::println("PASS: BinomialDist.mean = 5.0");
    }
    let pmf5: double = bd.pmf(5);
    if (pmf5 <= 0.0) {
        io::println("FAIL: BinomialDist.pmf(5) expected positive");
    } else {
        io::println("PASS: BinomialDist.pmf(5) = " + pmf5);
    }
    let cdf10: double = bd.cdf(10);
    // CDF at n should be 1.0
    if (absDiff(cdf10, 1.0) > 1e-6) {
        io::println("FAIL: BinomialDist.cdf(10) expected 1.0");
    } else {
        io::println("PASS: BinomialDist.cdf(10) = 1.0");
    }
}

public fn test_gamma_dist(): void {
    let gd: GammaDist = new GammaDist(2.0, 1.0);
    let m: double = gd.mean();
    // mean = alpha/beta = 2.0
    if (absDiff(m, 2.0) > 1e-9) {
        io::println("FAIL: GammaDist.mean expected 2.0");
    } else {
        io::println("PASS: GammaDist.mean = 2.0");
    }
    let pdf: double = gd.pdf(2.0);
    if (pdf <= 0.0) {
        io::println("FAIL: GammaDist.pdf(2) expected positive");
    } else {
        io::println("PASS: GammaDist.pdf(2) = " + pdf);
    }
}

public fn test_beta_dist(): void {
    let bd: BetaDist = new BetaDist(2.0, 2.0);
    let m: double = bd.mean();
    // mean = alpha/(alpha+beta) = 0.5
    if (absDiff(m, 0.5) > 1e-9) {
        io::println("FAIL: BetaDist.mean expected 0.5");
    } else {
        io::println("PASS: BetaDist.mean = 0.5");
    }
    let pdf: double = bd.pdf(0.5);
    if (pdf <= 0.0) {
        io::println("FAIL: BetaDist.pdf(0.5) expected positive");
    } else {
        io::println("PASS: BetaDist.pdf(0.5) = " + pdf);
    }
}

// ==================== Helper Functions ====================

public fn test_factorial(): void {
    let f5: double = Statistics.factorial(5);
    if (absDiff(f5, 120.0) > 1e-9) {
        io::println("FAIL: factorial(5) expected 120.0");
    } else {
        io::println("PASS: factorial(5) = 120.0");
    }
    let f0: double = Statistics.factorial(0);
    if (absDiff(f0, 1.0) > 1e-9) {
        io::println("FAIL: factorial(0) expected 1.0");
    } else {
        io::println("PASS: factorial(0) = 1.0");
    }
}

public fn test_log_gamma(): void {
    let lg: double = Statistics.logGamma(1.0);
    // logGamma(1) = 0
    if (absDiff(lg, 0.0) > 1e-9) {
        io::println("FAIL: logGamma(1) expected 0.0");
    } else {
        io::println("PASS: logGamma(1) = 0.0");
    }
    let lg5: double = Statistics.logGamma(5.0);
    // logGamma(5) = ln(24) = 3.178...
    if (absDiff(lg5, 3.1780538303479458) > 1e-6) {
        io::println("FAIL: logGamma(5) expected 3.178");
    } else {
        io::println("PASS: logGamma(5) = 3.178");
    }
}

public fn test_gamma_fn(): void {
    let g: double = Statistics.gammaFn(5.0);
    // gamma(5) = 4! = 24
    if (absDiff(g, 24.0) > 1e-6) {
        io::println("FAIL: gammaFn(5) expected 24.0");
    } else {
        io::println("PASS: gammaFn(5) = 24.0");
    }
}

public fn test_log_beta(): void {
    let lb: double = Statistics.logBeta(1.0, 1.0);
    // B(1,1) = 1, log(1) = 0
    if (absDiff(lb, 0.0) > 1e-9) {
        io::println("FAIL: logBeta(1,1) expected 0.0");
    } else {
        io::println("PASS: logBeta(1,1) = 0.0");
    }
}

public fn test_binom_coeff(): void {
    let c: double = Statistics.binomCoeff(5, 2);
    // C(5,2) = 10
    if (absDiff(c, 10.0) > 1e-9) {
        io::println("FAIL: binomCoeff(5,2) expected 10.0");
    } else {
        io::println("PASS: binomCoeff(5,2) = 10.0");
    }
    let c0: double = Statistics.binomCoeff(5, 0);
    if (absDiff(c0, 1.0) > 1e-9) {
        io::println("FAIL: binomCoeff(5,0) expected 1.0");
    } else {
        io::println("PASS: binomCoeff(5,0) = 1.0");
    }
    let cn: double = Statistics.binomCoeff(5, 5);
    if (absDiff(cn, 1.0) > 1e-9) {
        io::println("FAIL: binomCoeff(5,5) expected 1.0");
    } else {
        io::println("PASS: binomCoeff(5,5) = 1.0");
    }
}

// ==================== ANOVA ====================

public fn test_one_way_anova(): void {
    let groups: ArrayList<ArrayList<double>> = new ArrayList<ArrayList<double>>();
    let g1: ArrayList<double> = new ArrayList<double>();
    g1.add(1.0);
    g1.add(2.0);
    g1.add(3.0);
    let g2: ArrayList<double> = new ArrayList<double>();
    g2.add(4.0);
    g2.add(5.0);
    g2.add(6.0);
    let g3: ArrayList<double> = new ArrayList<double>();
    g3.add(7.0);
    g3.add(8.0);
    g3.add(9.0);
    groups.add(g1);
    groups.add(g2);
    groups.add(g3);
    let result: HashMap<string, double> = Statistics.oneWayANOVA(groups);
    let f: double = result.get("fStatistic");
    // Groups have clearly different means, F should be large
    if (f <= 0.0) {
        io::println("FAIL: oneWayANOVA fStatistic expected positive");
    } else {
        io::println("PASS: oneWayANOVA fStatistic = " + f);
    }
    let dfB: double = result.get("dfBetween");
    if (absDiff(dfB, 2.0) > 1e-9) {
        io::println("FAIL: oneWayANOVA dfBetween expected 2.0");
    } else {
        io::println("PASS: oneWayANOVA dfBetween = 2.0");
    }
    let dfW: double = result.get("dfWithin");
    if (absDiff(dfW, 6.0) > 1e-9) {
        io::println("FAIL: oneWayANOVA dfWithin expected 6.0");
    } else {
        io::println("PASS: oneWayANOVA dfWithin = 6.0");
    }
}

public fn test_two_way_anova(): void {
    let data: ArrayList<double> = new ArrayList<double>();
    data.add(1.0);
    data.add(2.0);
    data.add(3.0);
    data.add(4.0);
    data.add(5.0);
    data.add(6.0);
    let factorA: ArrayList<int> = new ArrayList<int>();
    factorA.add(0);
    factorA.add(0);
    factorA.add(0);
    factorA.add(1);
    factorA.add(1);
    factorA.add(1);
    let factorB: ArrayList<int> = new ArrayList<int>();
    factorB.add(0);
    factorB.add(1);
    factorB.add(0);
    factorB.add(1);
    factorB.add(0);
    factorB.add(1);
    let result: HashMap<string, double> = Statistics.twoWayANOVA(data, factorA, factorB);
    let fA: double = result.get("fA");
    let dfA: double = result.get("dfA");
    if (absDiff(dfA, 1.0) > 1e-9) {
        io::println("FAIL: twoWayANOVA dfA expected 1.0");
    } else {
        io::println("PASS: twoWayANOVA dfA = 1.0");
    }
    io::println("PASS: twoWayANOVA ran, fA = " + fA);
}

public fn test_tukey_hsd(): void {
    let groups: ArrayList<ArrayList<double>> = new ArrayList<ArrayList<double>>();
    let g1: ArrayList<double> = new ArrayList<double>();
    g1.add(1.0);
    g1.add(2.0);
    g1.add(3.0);
    let g2: ArrayList<double> = new ArrayList<double>();
    g2.add(4.0);
    g2.add(5.0);
    g2.add(6.0);
    let g3: ArrayList<double> = new ArrayList<double>();
    g3.add(7.0);
    g3.add(8.0);
    g3.add(9.0);
    groups.add(g1);
    groups.add(g2);
    groups.add(g3);
    let result: ArrayList<HashMap<string, double>> = Statistics.tukeyHSD(groups, 0.05);
    // 3 groups -> 3 pairwise comparisons
    if (result.size() != 3) {
        io::println("FAIL: tukeyHSD size expected 3");
    } else {
        io::println("PASS: tukeyHSD size = 3");
    }
}

public fn test_bonferroni_correction(): void {
    let pValues: ArrayList<double> = new ArrayList<double>();
    pValues.add(0.01);
    pValues.add(0.04);
    pValues.add(0.03);
    let result: ArrayList<bool> = Statistics.bonferroniCorrection(pValues, 0.05);
    // adjusted alpha = 0.05/3 = 0.0166...
    // Only 0.01 < 0.0166 is significant
    if (result.size() != 3) {
        io::println("FAIL: bonferroniCorrection size expected 3");
    } else {
        io::println("PASS: bonferroniCorrection size = 3");
    }
    if (result.size() == 3 && !result.get(0)) {
        io::println("FAIL: bonferroniCorrection[0] expected true");
    } else {
        io::println("PASS: bonferroniCorrection[0] = true");
    }
}

// ==================== Bayesian Statistics ====================

public fn test_beta_binomial_posterior(): void {
    let result: HashMap<string, double> = Statistics.betaBinomialPosterior(3, 10, 1.0, 1.0);
    // Posterior: Beta(1+3, 1+7) = Beta(4, 8)
    let alpha: double = result.get("alpha");
    let beta: double = result.get("beta");
    if (absDiff(alpha, 4.0) > 1e-9) {
        io::println("FAIL: betaBinomialPosterior alpha expected 4.0");
    } else {
        io::println("PASS: betaBinomialPosterior alpha = 4.0");
    }
    if (absDiff(beta, 8.0) > 1e-9) {
        io::println("FAIL: betaBinomialPosterior beta expected 8.0");
    } else {
        io::println("PASS: betaBinomialPosterior beta = 8.0");
    }
    let m: double = result.get("mean");
    // mean = 4/12 = 0.333...
    if (absDiff(m, 0.3333333333333333) > 1e-6) {
        io::println("FAIL: betaBinomialPosterior mean expected 0.333");
    } else {
        io::println("PASS: betaBinomialPosterior mean = 0.333");
    }
}

public fn test_normal_normal_posterior(): void {
    let data: ArrayList<double> = makeList();
    let result: HashMap<string, double> = Statistics.normalNormalPosterior(data, 0.0, 100.0, 1.0);
    let pm: double = result.get("posteriorMean");
    // Posterior mean should be between prior mean (0) and data mean (3)
    if (pm <= 0.0 || pm >= 3.0) {
        io::println("FAIL: normalNormalPosterior mean should be between 0 and 3");
    } else {
        io::println("PASS: normalNormalPosterior mean = " + pm);
    }
    let pv: double = result.get("posteriorVar");
    // Posterior variance should be less than prior variance
    if (pv >= 100.0) {
        io::println("FAIL: normalNormalPosterior var should be less than prior");
    } else {
        io::println("PASS: normalNormalPosterior var < prior var");
    }
}

public fn test_gamma_poisson_posterior(): void {
    let counts: ArrayList<int> = new ArrayList<int>();
    counts.add(3);
    counts.add(5);
    counts.add(2);
    let result: HashMap<string, double> = Statistics.gammaPoissonPosterior(counts, 1.0, 1.0);
    // Posterior shape = 1 + 10 = 11, rate = 1 + 3 = 4
    let shape: double = result.get("shape");
    let rate: double = result.get("rate");
    if (absDiff(shape, 11.0) > 1e-9) {
        io::println("FAIL: gammaPoissonPosterior shape expected 11.0");
    } else {
        io::println("PASS: gammaPoissonPosterior shape = 11.0");
    }
    if (absDiff(rate, 4.0) > 1e-9) {
        io::println("FAIL: gammaPoissonPosterior rate expected 4.0");
    } else {
        io::println("PASS: gammaPoissonPosterior rate = 4.0");
    }
    let m: double = result.get("mean");
    // mean = 11/4 = 2.75
    if (absDiff(m, 2.75) > 1e-9) {
        io::println("FAIL: gammaPoissonPosterior mean expected 2.75");
    } else {
        io::println("PASS: gammaPoissonPosterior mean = 2.75");
    }
}

public fn test_credible_interval(): void {
    let ci: ArrayList<double> = Statistics.credibleInterval(2.0, 2.0, 0.95);
    if (ci.size() != 2) {
        io::println("FAIL: credibleInterval size expected 2");
    } else {
        io::println("PASS: credibleInterval size = 2");
    }
    // For Beta(2,2), the 95% CI should be roughly [0.05, 0.95]
    if (ci.size() == 2 && (ci.get(0) >= ci.get(1))) {
        io::println("FAIL: credibleInterval lower should be < upper");
    } else {
        io::println("PASS: credibleInterval lower < upper");
    }
}

// ==================== CDF Helpers ====================

public fn test_normal_cdf(): void {
    let c0: double = Statistics.normalCDF(0.0);
    if (absDiff(c0, 0.5) > 1e-9) {
        io::println("FAIL: normalCDF(0) expected 0.5");
    } else {
        io::println("PASS: normalCDF(0) = 0.5");
    }
}

public fn test_t_cdf(): void {
    let c: double = Statistics.tCDF(0.0, 10);
    // t-distribution CDF at 0 = 0.5
    if (absDiff(c, 0.5) > 1e-9) {
        io::println("FAIL: tCDF(0, 10) expected 0.5");
    } else {
        io::println("PASS: tCDF(0, 10) = 0.5");
    }
}

public fn test_chi_squared_cdf(): void {
    let c: double = Statistics.chiSquaredCDF(0.0, 5);
    // CDF at 0 = 0
    if (absDiff(c, 0.0) > 1e-9) {
        io::println("FAIL: chiSquaredCDF(0, 5) expected 0.0");
    } else {
        io::println("PASS: chiSquaredCDF(0, 5) = 0.0");
    }
}

public fn test_ks_critical(): void {
    let k: double = Statistics.ksCritical(100, 0.05);
    // D_crit = sqrt(-ln(0.025) / 200) = sqrt(3.6889/200) = sqrt(0.01844) = 0.1358
    if (k <= 0.0) {
        io::println("FAIL: ksCritical expected positive");
    } else {
        io::println("PASS: ksCritical(100, 0.05) = " + k);
    }
}

public fn run_all_statistics_tests(): void {
    io::println("=== statistics/Statistics.tr Tests ===");

    // Descriptive statistics
    test_mean();
    test_median();
    test_mode();
    test_variance_stdev();
    test_pvariance_pstdev();
    test_quantiles();
    test_correlation();
    test_linear_regression();
    test_geometric_mean();
    test_harmonic_mean();
    test_fmean();
    test_median_grouped();
    test_covariance();
    test_multimode();

    // Extended descriptive
    test_skewness();
    test_kurtosis();
    test_moment();
    test_standard_error();
    test_coefficient_of_variation();
    test_zscore();
    test_interquartile_range();

    // Confidence intervals
    test_z_value_for_confidence();
    test_mean_confidence_interval();
    test_proportion_confidence_interval();

    // Hypothesis testing
    test_one_sample_t_test();
    test_two_sample_t_test();
    test_chi_squared_test();
    test_paired_t_test();
    test_mann_whitney_u_test();
    test_wilcoxon_test();
    test_f_test();

    // NormalDist
    test_normal_dist_pdf();
    test_normal_dist_cdf();
    test_normal_dist_inv_cdf();
    test_normal_dist_overlap();
    test_normal_dist_quantiles();
    test_normal_dist_zscore();
    test_normal_dist_samples();

    // Other distributions
    test_uniform_dist();
    test_exponential_dist();
    test_poisson_dist();
    test_binomial_dist();
    test_gamma_dist();
    test_beta_dist();

    // Helper functions
    test_factorial();
    test_log_gamma();
    test_gamma_fn();
    test_log_beta();
    test_binom_coeff();

    // ANOVA
    test_one_way_anova();
    test_two_way_anova();
    test_tukey_hsd();
    test_bonferroni_correction();

    // Bayesian
    test_beta_binomial_posterior();
    test_normal_normal_posterior();
    test_gamma_poisson_posterior();
    test_credible_interval();

    // CDF helpers
    test_normal_cdf();
    test_t_cdf();
    test_chi_squared_cdf();
    test_ks_critical();
}
