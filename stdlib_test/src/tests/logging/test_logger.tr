// Test file for logging/Logger.tr
// Exercises the public API: Formatter, LevelFilter, NameFilter, ConsoleHandler,
// FileHandler, RotatingFileHandler, Logger, getLogger, getRootLogger, basicConfig,
// debug/info/warning/error/critical, disable, shutdown, level constants.
import tt::logging::Logger;

public fn test_formatter_basic(): void {
    let f: Formatter = new Formatter();
    let r: string = f.format("INFO", "hello", "2026-01-01");
    if (r != "[2026-01-01] INFO: hello") {
        io::println("FAIL: formatter basic r=" + r);
    } else {
        io::println("PASS: formatter basic");
    }
}

public fn test_levelFilter_passes(): void {
    let f: LevelFilter = new LevelFilter(20);
    if (!f.filter(30, "msg", "name")) {
        io::println("FAIL: levelFilter passes");
    } else {
        io::println("PASS: levelFilter passes");
    }
}

public fn test_levelFilter_blocks(): void {
    let f: LevelFilter = new LevelFilter(30);
    if (f.filter(20, "msg", "name")) {
        io::println("FAIL: levelFilter blocks");
    } else {
        io::println("PASS: levelFilter blocks");
    }
}

public fn test_levelFilter_threshold_field(): void {
    let f: LevelFilter = new LevelFilter(40);
    if (f.threshold != 40) {
        io::println("FAIL: levelFilter threshold field");
    } else {
        io::println("PASS: levelFilter threshold field");
    }
}

public fn test_nameFilter_passes(): void {
    let f: NameFilter = new NameFilter("mylogger");
    if (!f.filter(10, "msg", "mylogger")) {
        io::println("FAIL: nameFilter passes");
    } else {
        io::println("PASS: nameFilter passes");
    }
}

public fn test_nameFilter_blocks(): void {
    let f: NameFilter = new NameFilter("mylogger");
    if (f.filter(10, "msg", "other")) {
        io::println("FAIL: nameFilter blocks");
    } else {
        io::println("PASS: nameFilter blocks");
    }
}

public fn test_nameFilter_field(): void {
    let f: NameFilter = new NameFilter("test");
    if (f.allowedName != "test") {
        io::println("FAIL: nameFilter field");
    } else {
        io::println("PASS: nameFilter field");
    }
}

public fn test_consoleHandler_init(): void {
    let h: ConsoleHandler = new ConsoleHandler();
    if (h.formatter == null) {
        io::println("FAIL: consoleHandler init");
    } else {
        io::println("PASS: consoleHandler init");
    }
}

public fn test_consoleHandler_addFilter(): void {
    let h: ConsoleHandler = new ConsoleHandler();
    let f: LevelFilter = new LevelFilter(20);
    h.addFilter(f);
    if (h.filters.size() != 1) {
        io::println("FAIL: consoleHandler addFilter");
    } else {
        io::println("PASS: consoleHandler addFilter");
    }
}

public fn test_consoleHandler_passesFilters(): void {
    let h: ConsoleHandler = new ConsoleHandler();
    let f: LevelFilter = new LevelFilter(20);
    h.addFilter(f);
    if (!h.passesFilters(30, "msg", "name")) {
        io::println("FAIL: consoleHandler passesFilters");
    } else {
        io::println("PASS: consoleHandler passesFilters");
    }
}

public fn test_consoleHandler_passesFilters_blocked(): void {
    let h: ConsoleHandler = new ConsoleHandler();
    let f: LevelFilter = new LevelFilter(40);
    h.addFilter(f);
    if (h.passesFilters(20, "msg", "name")) {
        io::println("FAIL: consoleHandler passesFilters blocked");
    } else {
        io::println("PASS: consoleHandler passesFilters blocked");
    }
}

public fn test_consoleHandler_handle(): void {
    let h: ConsoleHandler = new ConsoleHandler();
    h.handle("INFO", "test message", "2026-01-01");
    io::println("PASS: consoleHandler handle");
}

public fn test_logger_init(): void {
    let logger: Logger = new Logger("test");
    if (logger.name != "test" || logger.level != "NOTSET") {
        io::println("FAIL: logger init");
    } else {
        io::println("PASS: logger init");
    }
}

public fn test_logger_init_with_level(): void {
    let logger: Logger = new Logger("test", "DEBUG");
    if (logger.level != "DEBUG") {
        io::println("FAIL: logger init with level");
    } else {
        io::println("PASS: logger init with level");
    }
}

public fn test_logger_setLevel(): void {
    let logger: Logger = new Logger("test");
    logger.setLevel("ERROR");
    if (logger.level != "ERROR") {
        io::println("FAIL: logger setLevel");
    } else {
        io::println("PASS: logger setLevel");
    }
}

public fn test_logger_addHandler(): void {
    let logger: Logger = new Logger("test");
    let h: ConsoleHandler = new ConsoleHandler();
    logger.addHandler(h);
    if (logger.handlers.size() != 1) {
        io::println("FAIL: logger addHandler");
    } else {
        io::println("PASS: logger addHandler");
    }
}

public fn test_logger_addFilter(): void {
    let logger: Logger = new Logger("test");
    let f: LevelFilter = new LevelFilter(20);
    logger.addFilter(f);
    if (logger.filters.size() != 1) {
        io::println("FAIL: logger addFilter");
    } else {
        io::println("PASS: logger addFilter");
    }
}

public fn test_logger_propagate_field(): void {
    let logger: Logger = new Logger("test");
    if (!logger.propagate) {
        io::println("FAIL: logger propagate field");
