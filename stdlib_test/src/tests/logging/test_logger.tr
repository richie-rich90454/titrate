public fn test_getLogger_basic(): void {
    let logger: Logger = getLogger("myapp");
    if (logger.name != "myapp") {
        io::println("FAIL: getLogger basic");
    } else {
        io::println("PASS: getLogger basic");
    }
}

public fn test_getLogger_cached(): void {
    let a: Logger = getLogger("cached_app");
    let b: Logger = getLogger("cached_app");
    if (a != b) {
        io::println("FAIL: getLogger cached");
    } else {
        io::println("PASS: getLogger cached");
    }
}

public fn test_getLogger_hierarchy(): void {
    let parent: Logger = getLogger("hier");
    let child: Logger = getLogger("hier.child");
    if (child.parent == null || child.parent.name != "hier") {
        io::println("FAIL: getLogger hierarchy");
    } else {
        io::println("PASS: getLogger hierarchy");
    }
}

public fn test_getRootLogger(): void {
    let root: Logger = getRootLogger();
    if (root.name != "root") {
        io::println("FAIL: getRootLogger");
    } else {
        io::println("PASS: getRootLogger");
    }
}

public fn test_basicConfig(): void {
    basicConfig("ERROR");
    let root: Logger = getRootLogger();
    if (root.level != "ERROR") {
        io::println("FAIL: basicConfig");
    } else {
        io::println("PASS: basicConfig");
    }
}

public fn test_level_constants(): void {
    if (NOTSET != 0 || DEBUG != 10 || INFO != 20 || WARNING != 30 || ERROR != 40 || CRITICAL != 50) {
        io::println("FAIL: level constants");
    } else {
        io::println("PASS: level constants");
    }
}

public fn test_disable(): void {
    disable(CRITICAL);
    let root: Logger = getRootLogger();
    let h: ConsoleHandler = new ConsoleHandler();
    root.addHandler(h);
    root.setLevel("DEBUG");
    root.debug("should be disabled");
    disable(NOTSET);
    io::println("PASS: disable");
}

public fn test_shutdown(): void {
    let logger: Logger = getLogger("shutdown_test");
    let h: ConsoleHandler = new ConsoleHandler();
    logger.addHandler(h);
    shutdown();
    if (logger.handlers.size() != 0) {
        io::println("FAIL: shutdown");
    } else {
        io::println("PASS: shutdown");
    }
}

public fn test_rotatingFileHandler_init(): void {
    let h: RotatingFileHandler = new RotatingFileHandler("test.log", 1000, 3);
    if (h.formatter == null) {
        io::println("FAIL: rotatingFileHandler init");
    } else {
        io::println("PASS: rotatingFileHandler init");
    }
}

public fn test_rotatingFileHandler_shouldRollover(): void {
    let h: RotatingFileHandler = new RotatingFileHandler("nonexistent_file.log", 1000, 3);
    if (h.shouldRollover()) {
        io::println("FAIL: rotatingFileHandler shouldRollover");
    } else {
        io::println("PASS: rotatingFileHandler shouldRollover");
    }
}

public fn run_all_logger_tests(): void {
    test_formatter_basic();
    test_levelFilter_passes();
    test_levelFilter_blocks();
    test_levelFilter_threshold_field();
    test_nameFilter_passes();
    test_nameFilter_blocks();
    test_nameFilter_field();
    test_consoleHandler_init();
    test_consoleHandler_addFilter();
    test_consoleHandler_passesFilters();
    test_consoleHandler_passesFilters_blocked();
    test_consoleHandler_handle();
    test_logger_init();
    test_logger_init_with_level();
    test_logger_setLevel();
    test_logger_addHandler();
    test_logger_addFilter();
    test_logger_propagate_field();
    test_logger_children_field();
    test_logger_debug();
    test_logger_info();
    test_logger_warning();
    test_logger_error();
    test_logger_critical();
    test_getLogger_basic();
    test_getLogger_cached();
    test_getLogger_hierarchy();
    test_getRootLogger();
    test_basicConfig();
    test_level_constants();
    test_disable();
    test_shutdown();
    test_rotatingFileHandler_init();
    test_rotatingFileHandler_shouldRollover();
}
