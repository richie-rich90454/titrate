// Test file for Smtpd.tr
// Exercises the public API of SMTPChannel, SMTPServer, DebuggingServer,
// and PureProxy.
import tt::net::Smtpd;
import tt::util::ArrayList;
import tt::lang::Integer;
import tt::lang::String;

public fn test_smtp_channel_init(): void {
    let server: SMTPServer = new SMTPServer("mail.example.com", 25);
    let channel: SMTPChannel = new SMTPChannel(server, null);
    if (channel.server != server) {
        io::println("FAIL: SMTPChannel.server does not match");
    } else {
        io::println("PASS: SMTPChannel.server works");
    }
    if (channel.state != "init") {
        io::println("FAIL: SMTPChannel.state should be 'init'");
    } else {
        io::println("PASS: SMTPChannel.state is 'init'");
    }
    if (channel.closed) {
        io::println("FAIL: SMTPChannel.closed should be false");
    } else {
        io::println("PASS: SMTPChannel.closed false initially");
    }
    if (channel.mailFrom != "") {
        io::println("FAIL: SMTPChannel.mailFrom should be empty");
    } else {
        io::println("PASS: SMTPChannel.mailFrom empty initially");
    }
    if (channel.rcptTos.size() != 0) {
        io::println("FAIL: SMTPChannel.rcptTos should be empty");
    } else {
        io::println("PASS: SMTPChannel.rcptTos empty initially");
    }
    if (channel.mailData != "") {
        io::println("FAIL: SMTPChannel.mailData should be empty");
    } else {
        io::println("PASS: SMTPChannel.mailData empty initially");
    }
}

public fn test_smtp_channel_send(): void {
    let server: SMTPServer = new SMTPServer("mail.example.com", 25);
    let channel: SMTPChannel = new SMTPChannel(server, null);
    // send with no client should not throw (client.write is guarded)
    channel.send(220, "OK");
    io::println("PASS: SMTPChannel.send does not throw with null client");
}

public fn test_smtp_channel_greet(): void {
    let server: SMTPServer = new SMTPServer("mail.example.com", 25);
    let channel: SMTPChannel = new SMTPChannel(server, null);
    channel.greet();
    if (channel.state != "command") {
        io::println("FAIL: SMTPChannel.greet should set state='command'");
    } else {
        io::println("PASS: SMTPChannel.greet sets state correctly");
    }
}

public fn test_smtp_channel_handle_command_helo(): void {
    let server: SMTPServer = new SMTPServer("mail.example.com", 25);
    let channel: SMTPChannel = new SMTPChannel(server, null);
    channel.greet();
    // After greet state should be command; handleCommand shouldn't throw
    channel.handleCommand("HELO client.example.com");
    io::println("PASS: SMTPChannel.handleCommand HELO works");
}

public fn test_smtp_channel_handle_command_quit(): void {
    let server: SMTPServer = new SMTPServer("mail.example.com", 25);
    let channel: SMTPChannel = new SMTPChannel(server, null);
    channel.greet();
    channel.handleCommand("QUIT");
    if (!channel.closed) {
        io::println("FAIL: SMTPChannel.handleCommand QUIT should set closed");
    } else {
        io::println("PASS: SMTPChannel.handleCommand QUIT closes");
    }
}

public fn test_smtp_channel_handle_command_rset(): void {
    let server: SMTPServer = new SMTPServer("mail.example.com", 25);
    let channel: SMTPChannel = new SMTPChannel(server, null);
    channel.greet();
    channel.mailFrom = "test@test.com";
    channel.handleCommand("RSET");
    if (channel.mailFrom != "") {
        io::println("FAIL: RSET should clear mailFrom");
    } else {
        io::println("PASS: RSET clears mailFrom");
    }
}

public fn test_smtp_channel_handle_command_noop(): void {
    let server: SMTPServer = new SMTPServer("mail.example.com", 25);
    let channel: SMTPChannel = new SMTPChannel(server, null);
    channel.greet();
    channel.handleCommand("NOOP");
    io::println("PASS: NOOP handled without error");
}

public fn test_smtp_channel_handle_command_unknown(): void {
    let server: SMTPServer = new SMTPServer("mail.example.com", 25);
    let channel: SMTPChannel = new SMTPChannel(server, null);
    channel.greet();
    channel.handleCommand("UNKNOWN");
    io::println("PASS: Unknown command handled without error");
}

public fn test_smtp_channel_handle_data(): void {
    let server: SMTPServer = new SMTPServer("mail.example.com", 25);
    let channel: SMTPChannel = new SMTPChannel(server, null);
    channel.greet();
    channel.handleCommand("MAIL FROM:<from@test.com>");
    channel.handleCommand("RCPT TO:<to@test.com>");
    channel.handleCommand("DATA");
    if (channel.state != "data") {
        io::println("FAIL: DATA should set state='data'");
    } else {
        io::println("PASS: DATA sets state correctly");
    }
}

public fn test_smtp_channel_close(): void {
    let server: SMTPServer = new SMTPServer("mail.example.com", 25);
    let channel: SMTPChannel = new SMTPChannel(server, null);
    channel.close();
    if (!channel.closed) {
        io::println("FAIL: SMTPChannel.close should set closed");
    } else {
        io::println("PASS: SMTPChannel.close works");
    }
}

public fn test_smtp_server_init(): void {
    let server: SMTPServer = new SMTPServer("mail.example.com", 2525);
    if (server.hostname != "mail.example.com") {
        io::println("FAIL: SMTPServer.hostname = " + server.hostname);
    } else {
        io::println("PASS: SMTPServer.hostname works");
    }
    if (server.port != 2525) {
        io::println("FAIL: SMTPServer.port = " + Integer.toString(server.port));
    } else {
        io::println("PASS: SMTPServer.port works");
    }
}

public fn test_debugging_server_init(): void {
    let server: DebuggingServer = new DebuggingServer("debug.local", 2525);
    if (server.hostname != "debug.local") {
        io::println("FAIL: DebuggingServer.hostname");
    } else {
        io::println("PASS: DebuggingServer.init works");
    }
}

public fn test_pure_proxy_init(): void {
    let proxy: PureProxy = new PureProxy("local.local", 2525, "remote.example.com", 25);
    if (proxy.hostname != "local.local") {
        io::println("FAIL: PureProxy.hostname");
    } else {
        io::println("PASS: PureProxy.hostname works");
    }
    if (proxy.remoteHost != "remote.example.com") {
        io::println("FAIL: PureProxy.remoteHost");
    } else {
        io::println("PASS: PureProxy.remoteHost works");
    }
    if (proxy.remotePort != 25) {
        io::println("FAIL: PureProxy.remotePort");
    } else {
        io::println("PASS: PureProxy.remotePort works");
    }
}

public fn run_all_smtpd_tests(): void {
    io::println("=== Smtpd.tr Tests ===");
    test_smtp_channel_init();
    test_smtp_channel_send();
    test_smtp_channel_greet();
    test_smtp_channel_handle_command_helo();
    test_smtp_channel_handle_command_quit();
    test_smtp_channel_handle_command_rset();
    test_smtp_channel_handle_command_noop();
    test_smtp_channel_handle_command_unknown();
    test_smtp_channel_handle_data();
    test_smtp_channel_close();
    test_smtp_server_init();
    test_debugging_server_init();
    test_pure_proxy_init();
}
