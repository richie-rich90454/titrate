// Test file for Asynchat.tr
// Exercises the public API of Fifo, SimpleProducer, AsyncChat, and
// the module-level convenience helpers.
import tt::net::Asynchat;
import tt::util::ArrayList;
import tt::lang::Integer;
import tt::lang::String;

public fn test_fifo_init_empty(): void {
    let f: Fifo = fifo();
    if (f.size() != 0) {
        io::println("FAIL: Fifo.size should be 0 after init");
    } else {
        io::println("PASS: Fifo.init creates empty fifo");
    }
    if (!f.isEmpty()) {
        io::println("FAIL: Fifo.isEmpty should be true for empty fifo");
    } else {
        io::println("PASS: Fifo.isEmpty returns true for empty fifo");
    }
}

public fn test_fifo_push_pop_string(): void {
    let f: Fifo = fifo();
    f.push("hello");
    if (f.size() != 1) {
        io::println("FAIL: Fifo.size should be 1 after push");
    } else {
        io::println("PASS: Fifo.size is 1 after push");
    }
    let chunk: string = f.pop();
    if (chunk != "hello") {
        io::println("FAIL: Fifo.pop returned " + chunk);
    } else {
        io::println("PASS: Fifo.pop returns pushed string");
    }
    if (!f.isEmpty()) {
        io::println("FAIL: Fifo.isEmpty should be true after popping all");
    } else {
        io::println("PASS: Fifo.isEmpty true after draining");
    }
}

public fn test_fifo_pop_empty_returns_empty_string(): void {
    let f: Fifo = fifo();
    let chunk: string = f.pop();
    if (chunk != "") {
        io::println("FAIL: Fifo.pop on empty should return empty string");
    } else {
        io::println("PASS: Fifo.pop on empty returns \"\"");
    }
}

public fn test_simpleproducer_init(): void {
    let sp: SimpleProducer = simpleProducer("data");
    if (sp.data != "data") {
        io::println("FAIL: SimpleProducer.data = " + sp.data);
    } else {
        io::println("PASS: SimpleProducer.data works");
    }
    if (sp.isFinished()) {
        io::println("FAIL: SimpleProducer.isFinished should be false initially");
    } else {
        io::println("PASS: SimpleProducer.isFinished false initially");
    }
}

public fn test_simpleproducer_more(): void {
    let sp: SimpleProducer = simpleProducer("abc");
    let first: string = sp.more();
    if (first != "abc") {
        io::println("FAIL: SimpleProducer.more() returned " + first);
    } else {
        io::println("PASS: SimpleProducer.more() returns data");
    }
    let second: string = sp.more();
    if (second != "") {
        io::println("FAIL: SimpleProducer.more() after finished should return \"\"");
    } else {
        io::println("PASS: SimpleProducer.more() returns \"\" after finish");
    }
    if (!sp.isFinished()) {
        io::println("FAIL: SimpleProducer.isFinished should be true after more()");
    } else {
        io::println("PASS: SimpleProducer.isFinished true after more()");
    }
}

public fn test_asyncchat_init(): void {
    let chat: AsyncChat = new AsyncChat();
    if (chat.terminator != null) {
        io::println("FAIL: AsyncChat.terminator should be null initially");
    } else {
        io::println("PASS: AsyncChat.terminator is null initially");
    }
    if (chat.closeWhenDone) {
        io::println("FAIL: AsyncChat.closeWhenDone should be false");
    } else {
        io::println("PASS: AsyncChat.closeWhenDone false initially");
    }
}

public fn test_asyncchat_set_terminator_string(): void {
    let chat: AsyncChat = new AsyncChat();
    chat.setTerminator("\r\n");
    let term: Variant = chat.getTerminator();
    if (term != "\r\n") {
        io::println("FAIL: AsyncChat.getTerminator() after setTerminator(\"\\r\\n\")");
    } else {
        io::println("PASS: AsyncChat.setTerminator(string) works");
    }
}

public fn test_asyncchat_set_terminator_int(): void {
    let chat: AsyncChat = new AsyncChat();
    chat.setTerminator(1024);
    let term: Variant = chat.getTerminator();
    if (term != 1024) {
        io::println("FAIL: AsyncChat.getTerminator() after setTerminator(1024)");
    } else {
        io::println("PASS: AsyncChat.setTerminator(int) works");
    }
}

public fn test_asyncchat_set_terminator_null(): void {
    let chat: AsyncChat = new AsyncChat();
    chat.setTerminator("\r\n");
    chat.setTerminator(null);
    if (chat.useTerminator) {
        io::println("FAIL: AsyncChat.useTerminator should be false after null");
    } else {
        io::println("PASS: AsyncChat.setTerminator(null) disables terminator");
    }
}

public fn test_asyncchat_push_data(): void {
    let chat: AsyncChat = new AsyncChat();
    chat.push("test data");
    if (chat.outBuffer.size() != 1) {
        io::println("FAIL: AsyncChat.outBuffer.size should be 1 after push");
    } else {
        io::println("PASS: AsyncChat.push queues data");
    }
}

public fn test_asyncchat_push_with_producer(): void {
    let chat: AsyncChat = new AsyncChat();
    let sp: SimpleProducer = simpleProducer("producer data");
    chat.pushWithProducer(sp);
    if (chat.outBuffer.size() != 1) {
        io::println("FAIL: AsyncChat.outBuffer.size should be 1 after pushWithProducer");
    } else {
        io::println("PASS: AsyncChat.pushWithProducer queues producer");
    }
}

public fn test_asyncchat_close_when_done(): void {
    let chat: AsyncChat = new AsyncChat();
    if (chat.closeWhenDone) {
        io::println("FAIL: AsyncChat.closeWhenDone should be false before call");
    } else {
        io::println("PASS: AsyncChat.closeWhenDone false before closeWhenDone()");
    }
    chat.closeWhenDone();
    if (!chat.closeWhenDone) {
        io::println("FAIL: AsyncChat.closeWhenDone should be true after call");
    } else {
        io::println("PASS: AsyncChat.closeWhenDone() sets flag");
    }
}

public fn test_wrap_socket(): void {
    let chat: AsyncChat = wrapSocket(null);
    if (chat.socket != null) {
        io::println("FAIL: wrapSocket(null).socket should be null");
    } else {
        io::println("PASS: wrapSocket(null) works");
    }
    if (!chat.connected) {
        io::println("FAIL: wrapSocket should set connected=true");
    } else {
        io::println("PASS: wrapSocket sets connected=true");
    }
}

public fn run_all_asynchat_tests(): void {
    io::println("=== Asynchat.tr Tests ===");
    test_fifo_init_empty();
    test_fifo_push_pop_string();
    test_fifo_pop_empty_returns_empty_string();
    test_simpleproducer_init();
    test_simpleproducer_more();
    test_asyncchat_init();
    test_asyncchat_set_terminator_string();
    test_asyncchat_set_terminator_int();
    test_asyncchat_set_terminator_null();
    test_asyncchat_push_data();
    test_asyncchat_push_with_producer();
    test_asyncchat_close_when_done();
    test_wrap_socket();
}
