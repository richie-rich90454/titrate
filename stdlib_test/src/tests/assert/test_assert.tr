public fn test_assertInRange_double_boundaries(): void {
    let threw: bool = false;
    try {
        Assert.assertInRange(0.0, 0.0, 5.0);
        Assert.assertInRange(5.0, 0.0, 5.0);
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("FAIL: Assert.assertInRange double boundaries threw");
    } else {
        io::println("PASS: Assert.assertInRange double boundaries pass");
    }
}

public fn run_all_assert_tests(): void {
    io::println("=== assert/Assert.tr Tests ===");
    test_assertTrue_pass();
    test_assertTrue_fail();
    test_assertTrue_message_pass();
    test_assertTrue_message_fail();
    test_assertFalse_pass();
    test_assertFalse_fail();
    test_assertFalse_message_pass();
    test_assertFalse_message_fail();
    test_assertEqual_pass();
    test_assertEqual_fail();
    test_assertEqual_message_pass();
    test_assertEqual_message_fail();
    test_assertNotEqual_pass();
    test_assertNotEqual_fail();
    test_assertNull_pass();
    test_assertNull_fail();
    test_assertNotNull_pass();
    test_assertNotNull_fail();
    test_fail_throws();
    test_assertInRange_int_pass();
    test_assertInRange_int_fail_low();
    test_assertInRange_int_fail_high();
    test_assertInRange_int_boundaries();
    test_assertInRange_double_pass();
    test_assertInRange_double_fail();
    test_assertInRange_double_boundaries();
}
