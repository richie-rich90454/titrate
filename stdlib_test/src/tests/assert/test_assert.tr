public fn test_assertInRange_int_boundaries(): void {
    let threw: bool = false;
    try {
        Assert.assertInRange(1, 1, 10);
        Assert.assertInRange(10, 1, 10);
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("FAIL: Assert.assertInRange int boundaries threw");
    } else {
        io::println("PASS: Assert.assertInRange int boundaries pass");
    }
}

public fn test_assertInRange_double_pass(): void {
    let threw: bool = false;
    try {
        Assert.assertInRange(3.14, 0.0, 5.0);
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("FAIL: Assert.assertInRange double pass threw");
    } else {
        io::println("PASS: Assert.assertInRange double pass");
    }
}

public fn test_assertInRange_double_fail(): void {
    let threw: bool = false;
    try {
