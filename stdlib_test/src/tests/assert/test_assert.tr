// Test file for assert/Assert.tr
// Exercises the public API: assertTrue, assertFalse, assertEqual, assertNotEqual,
// assertNull, assertNotNull, fail, assertInRange (int and double overloads).
// All assertion functions throw on failure, so tests use try/catch to verify behavior.
import tt::assert::Assert;
import tt::lang::Integer;

public fn test_assertTrue_pass(): void {
    let threw: bool = false;
    try {
        Assert.assertTrue(true);
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("FAIL: Assert.assertTrue(true) threw");
    } else {
        io::println("PASS: Assert.assertTrue(true) passes");
    }
}

public fn test_assertTrue_fail(): void {
    let threw: bool = false;
    try {
        Assert.assertTrue(false);
    } catch (e: string) {
        threw = true;
    }
    if (!threw) {
        io::println("FAIL: Assert.assertTrue(false) did not throw");
    } else {
        io::println("PASS: Assert.assertTrue(false) throws");
    }
}

public fn test_assertTrue_message_pass(): void {
    let threw: bool = false;
    try {
        Assert.assertTrue(true, "should be true");
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("FAIL: Assert.assertTrue(true, msg) threw");
    } else {
        io::println("PASS: Assert.assertTrue(true, msg) passes");
    }
}

