// Test file for ui/Turtle.tr
import tt::ui::Turtle;
import tt::ui::Turtle::Screen;
import tt::ui::Turtle::Turtle;
import tt::math::MathTrig;
import tt::lang::String;

public fn test_turtle_getscreen(): void {
    let s: Screen = Turtle.getscreen();
    if (s != null) {
        io::println("PASS: getscreen returns Screen");
    } else {
        io::println("FAIL: getscreen returned null");
    }
}

public fn test_turtle_getturtle(): void {
    let t: Turtle = Turtle.getturtle();
    if (t != null) {
        io::println("PASS: getturtle returns Turtle");
    } else {
        io::println("FAIL: getturtle returned null");
    }
}

public fn test_turtle_screen_render(): void {
    let s: Screen = Turtle.getscreen();
    let svg: string = s.renderSvg();
    if (String.length(svg) > 0) {
        io::println("PASS: Screen renderSvg returns output");
    } else {
        io::println("FAIL: Screen renderSvg empty");
    }
}

public fn run_all_turtle_tests(): void {
    io::println("=== Turtle.tr Tests ===");
    test_turtle_getscreen();
    test_turtle_getturtle();
    test_turtle_screen_render();
}
