// Test file for ui/IdleLib.tr
import tt::ui::IdleLib;
import tt::ui::IdleLib::EditorWindow;
import tt::ui::IdleLib::IdleShell;
import tt::ui::IdleLib::AutoComplete;
import tt::ui::IdleLib::Calltip;
import tt::ui::IdleLib::IndentHandler;
import tt::lang::String;
import tt::util::ArrayList;

public fn test_idlelib_editor_window(): void {
    let ed: EditorWindow = new EditorWindow();
    if (ed.getLineCount() == 1) {
        io::println("PASS: EditorWindow starts with one line");
    } else {
        io::println("FAIL: EditorWindow lineCount=" + (ed.getLineCount() as string));
    }
}

public fn test_idlelib_editor_set_text(): void {
    let ed: EditorWindow = new EditorWindow();
    ed.setText("line1\nline2\nline3");
    if (ed.getLineCount() == 3) {
        io::println("PASS: EditorWindow setText creates 3 lines");
    } else {
        io::println("FAIL: EditorWindow setText count=" + (ed.getLineCount() as string));
    }
}

public fn test_idlelib_editor_insert(): void {
    let ed: EditorWindow = new EditorWindow();
    ed.insert("hello");
    let text: string = ed.getText();
    if (text == "hello") {
        io::println("PASS: EditorWindow insert works");
    } else {
        io::println("FAIL: EditorWindow insert text=" + text);
    }
}

public fn test_idlelib_shell_push(): void {
    let shell: IdleShell = new IdleShell();
    let echoed: string = shell.push("1 + 1");
    if (String.length(echoed) > 0) {
        io::println("PASS: IdleShell push works");
    } else {
        io::println("FAIL: IdleShell push empty");
    }
}

public fn test_idlelib_autocomplete(): void {
    let ac: AutoComplete = new AutoComplete();
    let count: int = ac.getNameCount();
    if (count > 0) {
        io::println("PASS: AutoComplete loads keywords from data file");
    } else {
        io::println("FAIL: AutoComplete loaded 0 keywords");
    }
}

public fn run_all_idlelib_tests(): void {
    io::println("=== IdleLib.tr Tests ===");
    test_idlelib_editor_window();
    test_idlelib_editor_set_text();
    test_idlelib_editor_insert();
    test_idlelib_shell_push();
    test_idlelib_autocomplete();
}
