// Test file for ui/Curses.tr
import tt::ui::Curses;
import tt::ui::Curses::Window;
import tt::lang::Integer;
import tt::util::ArrayList;

public fn test_curses_initscr(): void {
    let win: Window = Curses.initscr();
    if (win != null) {
        io::println("PASS: initscr returns Window");
    } else {
        io::println("FAIL: initscr returned null");
    }
}

public fn test_curses_endwin(): void {
    Curses.initscr();
    Curses.endwin();
    let stdscr: Window = Curses.getStdscr();
    if (stdscr == null) {
        io::println("PASS: endwin clears stdscr");
    } else {
        io::println("FAIL: endwin did not clear stdscr");
    }
}

public fn test_curses_color_constants(): void {
    if (Curses.COLOR_RED == 1 && Curses.COLOR_BLUE == 4) {
        io::println("PASS: color constants correct");
    } else {
        io::println("FAIL: color constants");
    }
}

public fn test_curses_key_constants(): void {
    if (Curses.KEY_UP == 259 && Curses.KEY_DOWN == 258) {
        io::println("PASS: KEY_UP/KEY_DOWN correct");
    } else {
        io::println("FAIL: key constants");
    }
}

public fn test_curses_window_addstr(): void {
    let win: Window = Curses.initscr();
    win.addstr(0, 0, "hello", Curses.A_NORMAL);
    let render: string = win.render();
    if (String.length(render) > 0) {
        io::println("PASS: Window addstr/render works");
    } else {
        io::println("FAIL: Window render empty");
    }
}

public fn run_all_curses_tests(): void {
    io::println("=== Curses.tr Tests ===");
    test_curses_initscr();
    test_curses_endwin();
    test_curses_color_constants();
    test_curses_key_constants();
    test_curses_window_addstr();
}
