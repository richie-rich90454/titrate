// Test file for ui/Tkinter.tr
import tt::ui::Tkinter;
import tt::ui::Tkinter::Tk;
import tt::ui::Tkinter::Widget;
import tt::ui::Tkinter::Frame;
import tt::ui::Tkinter::Label;
import tt::ui::Tkinter::Button;
import tt::ui::Tkinter::Entry;
import tt::ui::Tkinter::Canvas;
import tt::lang::String;
import tt::lang::Integer;
import tt::util::HashMap;

public fn test_tkinter_tk_init(): void {
    let root: Tk = new Tk();
    if (root.getTitle() == "tk") {
        io::println("PASS: Tk default title is 'tk'");
    } else {
        io::println("FAIL: Tk title=" + root.getTitle());
    }
}

public fn test_tkinter_tk_title(): void {
    let root: Tk = new Tk();
    root.title("MyApp");
    if (root.getTitle() == "MyApp") {
        io::println("PASS: Tk title set/get works");
    } else {
        io::println("FAIL: Tk title=" + root.getTitle());
    }
}

public fn test_tkinter_frame(): void {
    let root: Tk = new Tk();
    let frame: Frame = new Frame(root);
    if (frame.master == root) {
        io::println("PASS: Frame master linked");
    } else {
        io::println("FAIL: Frame master not linked");
    }
}

public fn test_tkinter_label_text(): void {
    let root: Tk = new Tk();
    let label: Label = new Label(root);
    label.setText("Hello");
    if (label.getText() == "Hello") {
        io::println("PASS: Label setText/getText works");
    } else {
        io::println("FAIL: Label text=" + label.getText());
    }
}

public fn test_tkinter_button_invoke(): void {
    let root: Tk = new Tk();
    let btn: Button = new Button(root);
    btn.setText("Click");
    var called: bool = false;
    btn.setCommand(fn(): void { called = true; });
    btn.invoke();
    if (called) {
        io::println("PASS: Button invoke calls command");
    } else {
        io::println("FAIL: Button invoke did not call command");
    }
}

public fn run_all_tkinter_tests(): void {
    io::println("=== Tkinter.tr Tests ===");
    test_tkinter_tk_init();
    test_tkinter_tk_title();
    test_tkinter_frame();
    test_tkinter_label_text();
    test_tkinter_button_invoke();
}
