// Test file for tooling/TabNanny.tr
import tt::tooling::TabNanny;
import tt::tooling::TabNanny::NannyNag;
import tt::util::ArrayList;
import tt::lang::String;
import tt::lang::Integer;

public fn test_tabnanny_process_tokens_clean(): void {
    let lines: ArrayList<string> = new ArrayList<string>();
    lines.add("let x = 1");
    lines.add("let y = 2");
    let issues: ArrayList<NannyNag> = TabNanny.process_tokens(lines);
    if (issues.size() == 0) {
        io::println("PASS: process_tokens clean has no issues");
    } else {
        io::println("FAIL: process_tokens had " + Integer.toString(issues.size()) + " issues");
    }
}

public fn test_tabnanny_process_tokens_mixed(): void {
    let lines: ArrayList<string> = new ArrayList<string>();
    lines.add("    let x = 1");
    lines.add("\tlet y = 2");
    let issues: ArrayList<NannyNag> = TabNanny.process_tokens(lines);
    if (issues.size() > 0) {
        io::println("PASS: process_tokens detects mixed indent");
    } else {
        io::println("FAIL: process_tokens did not detect mixed indent");
    }
}

public fn test_tabnanny_check_string(): void {
    let source: string = "let x = 1\n  let y = 2";
    let issues: ArrayList<NannyNag> = TabNanny.checkString(source, "test.tr");
    if (issues.size() >= 0) {
        io::println("PASS: checkString returns");
    } else {
        io::println("FAIL: checkString failed");
    }
}

public fn test_tabnanny_nannynag(): void {
    let nag: NannyNag = new NannyNag(5, "inconsistent indent", "spaces");
    if (nag.getLineNumber() == 5 && nag.getMessage() == "inconsistent indent") {
        io::println("PASS: NannyNag fields work");
    } else {
        io::println("FAIL: NannyNag fields");
    }
}

public fn run_all_tabnanny_tests(): void {
    io::println("=== TabNanny.tr Tests ===");
    test_tabnanny_process_tokens_clean();
    test_tabnanny_process_tokens_mixed();
    test_tabnanny_check_string();
    test_tabnanny_nannynag();
}
