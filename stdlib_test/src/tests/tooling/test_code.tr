// Test file for tooling/Code.tr
import tt::tooling::Code;
import tt::tooling::Code::InteractiveInterpreter;
import tt::tooling::Code::InteractiveConsole;
import tt::lang::String;

public fn test_code_interpreter_init(): void {
    let interp: InteractiveInterpreter = new InteractiveInterpreter();
    if (interp.filename == "<console>") {
        io::println("PASS: InteractiveInterpreter filename default");
    } else {
        io::println("FAIL: InteractiveInterpreter filename=" + interp.filename);
    }
}

public fn test_code_interpreter_runsource(): void {
    let interp: InteractiveInterpreter = new InteractiveInterpreter();
    let more: bool = interp.runsource("let x = 42");
    if (!more) {
        io::println("PASS: runsource complete code returns false");
    } else {
        io::println("FAIL: runsource returned true for complete code");
    }
}

public fn test_code_interpreter_runsource_incomplete(): void {
    let interp: InteractiveInterpreter = new InteractiveInterpreter();
    let more: bool = interp.runsource("if (true) {");
    if (more) {
        io::println("PASS: runsource incomplete code returns true");
    } else {
        io::println("FAIL: runsource incomplete returned false");
    }
}

public fn test_code_console_push(): void {
    let console: InteractiveConsole = new InteractiveConsole();
    let more: bool = console.push("let x = 42");
    if (!more) {
        io::println("PASS: console push complete returns false");
    } else {
        io::println("FAIL: console push returned true");
    }
}

public fn test_code_compile_command(): void {
    let result: string = Code.compile_command("let x = 42");
    if (result == "let x = 42") {
        io::println("PASS: compile_command returns source for valid code");
    } else {
        io::println("FAIL: compile_command=" + (result == null ? "null" : result));
    }
}

public fn run_all_code_tests(): void {
    io::println("=== Code.tr Tests ===");
    test_code_interpreter_init();
    test_code_interpreter_runsource();
    test_code_interpreter_runsource_incomplete();
    test_code_console_push();
    test_code_compile_command();
}
