// Test for Email — basic construction
import tt::mail::Email::Message;

public fn test_message_init(): void {
    let m = new Message();
    if (m == null) {
        io::println("FAIL: Message constructor returned null");
    } else {
        io::println("PASS: Message construction works");
    }
}

public fn run_all_email_tests(): void {
    io::println("=== Email.tr Tests ===");
    test_message_init();
}
