public fn test_testsuite_fail_directly(): void {
    let suite: TestSuite = new TestSuite("S");
    suite.fail("manual failure");
    if (suite.failed != 1) {
        io::println("FAIL: TestSuite.fail wrong");
    } else {
        io::println("PASS: TestSuite.fail works");
    }
}

public fn test_testsuite_summary(): void {
    let suite: TestSuite = new TestSuite("Sum");
    suite.passed = 3;
    suite.failed = 1;
    let s: string = suite.summary();
    // Summary should mention "Sum", "3 passed", "1 failed"
    if (String.length(s) == 0) {
        io::println("FAIL: TestSuite.summary empty");
    } else {
        io::println("PASS: TestSuite.summary returns string");
    }
}

public fn test_testsuite_timeout_executes(): void {
    let suite: TestSuite = new TestSuite("S");
    var counter: int = 0;
    suite.timeout(100, fn(): void { counter = 42; });
    if (counter != 42) {
        io::println("FAIL: TestSuite.timeout did not execute fn");
    } else {
        io::println("PASS: TestSuite.timeout executes fn");
    }
}

public fn test_testsuite_run_no_crash(): void {
    // Run a suite with a passing test; ensure no crash
    let suite: TestSuite = new TestSuite("RunSuite");
    suite.addTest("passing", fn(): void { });
    suite.run();
    // If we get here without throwing, the test passes
    io::println("PASS: TestSuite.run does not crash");
}

public fn test_testcase_init(): void {
    let tc: TestCase = new TestCase("case1", fn(): void { });
    if (tc.name != "case1") {
        io::println("FAIL: TestCase.name wrong");
    } else {
        io::println("PASS: TestCase.init works");
    }
}

public fn run_all_assay_tests(): void {
    io::println("=== Assay.tr Tests ===");
    test_testsuite_init();
    test_testsuite_addTest();
    test_testsuite_addTest_name();
    test_assertEqual_pass();
    test_assertEqual_fail();
    test_assertNotEqual_pass();
    test_assertNotEqual_fail();
    test_assertTrue_pass();
    test_assertTrue_fail();
    test_assertFalse_pass();
    test_assertFalse_fail();
    test_assertApproxEqual_pass();
    test_assertApproxEqual_fail();
    test_assertGreaterThan_pass();
    test_assertGreaterThan_fail();
    test_assertLessThan_pass();
    test_assertLessThan_fail();
    test_assertContains_pass();
    test_assertContains_fail();
    test_assertNull_pass();
    test_assertNull_fail();
    test_assertNotNull_pass();
    test_assertNotNull_fail();
    test_assertThrows_pass();
    test_assertThrows_fail();
    test_testsuite_fail_directly();
    test_testsuite_summary();
    test_testsuite_timeout_executes();
    test_testsuite_run_no_crash();
    test_testcase_init();
}
