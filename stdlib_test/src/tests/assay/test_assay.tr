// Test file for assay/Assay.tr
// Exercises the public API: TestCase, TestSuite, and assertion functions.
import tt::assay::Assay;
import tt::util::ArrayList;
import tt::lang::Integer;
import tt::lang::String;

public fn test_testsuite_init(): void {
    let suite: TestSuite = new TestSuite("MySuite");
    if (suite.name != "MySuite") {
        io::println("FAIL: TestSuite.name wrong");
    } else if (suite.passed != 0 || suite.failed != 0) {
        io::println("FAIL: TestSuite initial counters wrong");
    } else {
        io::println("PASS: TestSuite.init works");
    }
}

public fn test_testsuite_addTest(): void {
    let suite: TestSuite = new TestSuite("S");
    suite.addTest("dummy", fn(): void { });
    if (suite.tests.size() != 1) {
        io::println("FAIL: TestSuite.addTest size=" + Integer.toString(suite.tests.size()));
    } else {
        io::println("PASS: TestSuite.addTest works");
    }
}

public fn test_testsuite_addTest_name(): void {
    let suite: TestSuite = new TestSuite("S");
    suite.addTest("myTestName", fn(): void { });
    if (suite.tests.size() != 1 || suite.tests.get(0).name != "myTestName") {
        io::println("FAIL: TestSuite.addTest name not stored");
    } else {
        io::println("PASS: TestSuite.addTest stores name");
    }
}

public fn test_assertEqual_pass(): void {
    let suite: TestSuite = new TestSuite("S");
    suite.assertEqual(5, 5, "ints equal");
    if (suite.passed != 1 || suite.failed != 0) {
        io::println("FAIL: assertEqual pass counters wrong passed=" + Integer.toString(suite.passed));
    } else {
        io::println("PASS: assertEqual pass works");
    }
}

public fn test_assertEqual_fail(): void {
    let suite: TestSuite = new TestSuite("S");
    suite.assertEqual(5, 6, "ints not equal");
    if (suite.failed != 1 || suite.passed != 0) {
        io::println("FAIL: assertEqual fail counters wrong failed=" + Integer.toString(suite.failed));
    } else {
        io::println("PASS: assertEqual fail works");
    }
}

public fn test_assertNotEqual_pass(): void {
    let suite: TestSuite = new TestSuite("S");
