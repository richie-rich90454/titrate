public fn test_assertThrows_pass(): void {
    let suite: TestSuite = new TestSuite("S");
    suite.assertThrows(fn(): void { throw "boom"; }, "should throw");
    if (suite.passed != 1) {
        io::println("FAIL: assertThrows pass wrong");
    } else {
        io::println("PASS: assertThrows pass works");
    }
}

