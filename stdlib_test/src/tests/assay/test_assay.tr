public fn test_assertContains_pass(): void {
    let suite: TestSuite = new TestSuite("S");
    let list: ArrayList<int> = new ArrayList<int>();
    list.add(1);
    list.add(2);
    list.add(3);
    suite.assertContains(list, 2, "contains 2");
    if (suite.passed != 1) {
        io::println("FAIL: assertContains pass wrong");
    } else {
        io::println("PASS: assertContains pass works");
    }
}

public fn test_assertContains_fail(): void {
    let suite: TestSuite = new TestSuite("S");
    let list: ArrayList<int> = new ArrayList<int>();
    list.add(1);
    list.add(2);
    suite.assertContains(list, 99, "missing 99");
    if (suite.failed != 1) {
        io::println("FAIL: assertContains fail wrong");
    } else {
        io::println("PASS: assertContains fail works");
    }
}

