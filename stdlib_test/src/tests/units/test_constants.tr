// Test file for units/Constants.tr
// Exercises the public API of the units/Constants module: physical constants.
import tt::units::Constants;
import tt::lang::Double;

public fn test_BOLTZMANN_positive(): void {
    let v: double = BOLTZMANN();
    if (v <= 0.0) {
        io::println("FAIL: BOLTZMANN should be positive");
    } else {
        io::println("PASS: BOLTZMANN returns positive value");
    }
}

