public fn test_PI_in_expected_range(): void {
    let v: double = PI();
    if (v < 3.14 || v > 3.15) {
        io::println("FAIL: PI out of [3.14, 3.15] = " + Double.toString(v));
    } else {
        io::println("PASS: PI in expected range");
    }
}

