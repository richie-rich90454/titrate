public fn test_constants_are_deterministic(): void {
    // Each call should return the same value
    let v1: double = BOLTZMANN();
    let v2: double = BOLTZMANN();
    if (v1 != v2) {
        io::println("FAIL: BOLTZMANN should return same value on each call");
    } else {
        io::println("PASS: Constants are deterministic");
    }
}

public fn run_all_constants_tests(): void {
    io::println("=== units/Constants.tr Tests ===");
    test_BOLTZMANN_positive();
    test_AVOGADRO_positive();
    test_GAS_CONSTANT_positive();
    test_PLANCK_positive();
    test_SPEED_OF_LIGHT_positive();
    test_ELEMENTARY_CHARGE_positive();
    test_COULOMB_CONSTANT_positive();
    test_GRAVITATIONAL_positive();
    test_PI_in_expected_range();
    test_ELECTRON_MASS_positive();
    test_PROTON_MASS_positive();
    test_NEUTRON_MASS_positive();
    test_ATOMIC_MASS_UNIT_positive();
    test_RYDBERG_positive();
    test_BOHR_RADIUS_positive();
    test_FINE_STRUCTURE_positive();
    test_STEFAN_BOLTZMANN_positive();
    test_WIEN_DISPLACEMENT_positive();
    test_PERMEABILITY_VACUUM_positive();
    test_PERMITTIVITY_VACUUM_positive();
    test_MOLAR_GAS_VOLUME_positive();
    test_constants_are_deterministic();
}
