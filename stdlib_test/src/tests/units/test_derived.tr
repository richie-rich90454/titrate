public fn test_watt_times_second_yields_joule(): void {
    let w: Watt = new Watt(10.0);
    let s: Second = new Second(5.0);
    let j: Joule = w.times(s);
    if (j.getValue() != 50.0) {
        io::println("FAIL: Watt.times(Second) = " + Double.toString(j.getValue()));
    } else {
        io::println("PASS: Watt.times(Second) yields Joule");
    }
}

public fn test_wattFromBase(): void {
    let j: Joule = new Joule(100.0);
    let s: Second = new Second(10.0);
    let w: Watt = wattFromBase(j, s);
    if (w.getValue() != 10.0) {
        io::println("FAIL: wattFromBase = " + Double.toString(w.getValue()));
    } else {
        io::println("PASS: wattFromBase works");
    }
}

