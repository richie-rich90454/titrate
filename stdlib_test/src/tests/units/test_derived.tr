public fn run_all_derived_tests(): void {
    io::println("=== units/Derived.tr Tests ===");
    test_joule_init_and_value();
    test_joule_plus_minus();
    test_joule_times_div_scalar();
    test_joule_div_second_yields_watt();
    test_jouleFromBase();
    test_newton_arithmetic();
    test_newton_times_meter_yields_joule();
    test_newtonFromBase();
    test_pascal_arithmetic();
    test_pascalFromBase();
    test_watt_arithmetic();
    test_watt_times_second_yields_joule();
    test_wattFromBase();
    test_coulomb_arithmetic();
    test_coulombFromBase();
    test_volt_arithmetic();
    test_volt_times_coulomb_yields_joule();
    test_volt_div_ampere_yields_ohm();
    test_voltFromBase();
    test_ohm_arithmetic();
    test_ohmFromBase();
    test_farad_arithmetic();
    test_faradFromBase();
    test_henry_arithmetic();
    test_henryFromBase();
    test_tesla_arithmetic();
    test_weber_arithmetic();
    test_hertz_arithmetic();
    test_hertzFromBase();
    test_becquerel_arithmetic();
    test_gray_arithmetic();
    test_grayFromBase();
    test_sievert_arithmetic();
    test_lux_arithmetic();
    test_lumen_arithmetic();
    test_lumenFromBase();
    test_katal_arithmetic();
    test_katalFromBase();
}
