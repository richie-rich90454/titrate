public fn test_volt_arithmetic(): void {
    let a: Volt = new Volt(10.0);
    let b: Volt = new Volt(3.0);
    if (a.plus(b).getValue() != 13.0) {
        io::println("FAIL: Volt.plus");
    } else if (a.minus(b).getValue() != 7.0) {
        io::println("FAIL: Volt.minus");
    } else if (a.times(2.0).getValue() != 20.0) {
        io::println("FAIL: Volt.times scalar");
    } else if (a.div(2.0).getValue() != 5.0) {
        io::println("FAIL: Volt.div scalar");
    } else {
        io::println("PASS: Volt arithmetic works");
    }
}

public fn test_volt_times_coulomb_yields_joule(): void {
    let v: Volt = new Volt(10.0);
    let c: Coulomb = new Coulomb(2.0);
    let j: Joule = v.times(c);
    if (j.getValue() != 20.0) {
        io::println("FAIL: Volt.times(Coulomb) = " + Double.toString(j.getValue()));
    } else {
        io::println("PASS: Volt.times(Coulomb) yields Joule");
    }
}

public fn test_volt_div_ampere_yields_ohm(): void {
    let v: Volt = new Volt(10.0);
    let a: Ampere = new Ampere(2.0);
    let o: Ohm = v.div(a);
    if (o.getValue() != 5.0) {
        io::println("FAIL: Volt.div(Ampere) = " + Double.toString(o.getValue()));
    } else {
        io::println("PASS: Volt.div(Ampere) yields Ohm");
    }
}

public fn test_voltFromBase(): void {
    let j: Joule = new Joule(20.0);
    let c: Coulomb = new Coulomb(4.0);
    let v: Volt = voltFromBase(j, c);
    if (v.getValue() != 5.0) {
        io::println("FAIL: voltFromBase = " + Double.toString(v.getValue()));
    } else {
        io::println("PASS: voltFromBase works");
    }
}

