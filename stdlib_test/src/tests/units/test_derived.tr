// Test file for units/Derived.tr
// Exercises the public API of the units/Derived module: SI derived unit classes
// (Joule, Newton, Pascal, Watt, Coulomb, Volt, Ohm, Farad, Henry, Tesla, Weber,
// Hertz, Becquerel, Gray, Sievert, Lux, Lumen, Katal) and the *FromBase factory
// functions.
import tt::units::Derived;
import tt::units::Base;
import tt::lang::Double;

public fn test_joule_init_and_value(): void {
    let j: Joule = new Joule(100.0);
    if (j.getValue() != 100.0) {
        io::println("FAIL: Joule.getValue");
    } else {
        io::println("PASS: Joule init/getValue works");
    }
}

public fn test_joule_plus_minus(): void {
    let a: Joule = new Joule(50.0);
    let b: Joule = new Joule(30.0);
    if (a.plus(b).getValue() != 80.0) {
        io::println("FAIL: Joule.plus");
    } else if (a.minus(b).getValue() != 20.0) {
        io::println("FAIL: Joule.minus");
    } else {
        io::println("PASS: Joule plus/minus work");
    }
}

public fn test_joule_times_div_scalar(): void {
    let j: Joule = new Joule(10.0);
    if (j.times(3.0).getValue() != 30.0) {
        io::println("FAIL: Joule.times scalar");
    } else if (j.div(2.0).getValue() != 5.0) {
        io::println("FAIL: Joule.div scalar");
    } else {
        io::println("PASS: Joule times/div scalar work");
    }
}

public fn test_joule_div_second_yields_watt(): void {
    let j: Joule = new Joule(100.0);
    let s: Second = new Second(10.0);
    let w: Watt = j.div(s);
    if (w.getValue() != 10.0) {
        io::println("FAIL: Joule.div(Second) = " + Double.toString(w.getValue()));
    } else {
        io::println("PASS: Joule.div(Second) yields Watt");
    }
}

public fn test_jouleFromBase(): void {
    let m: Meter = new Meter(2.0);
    let kg: Kilogram = new Kilogram(3.0);
    let s: Second = new Second(1.0);
    let j: Joule = jouleFromBase(m, kg, s);
    // J = kg * m^2 / s^2 = 3 * 4 / 1 = 12
    if (j.getValue() != 12.0) {
        io::println("FAIL: jouleFromBase = " + Double.toString(j.getValue()));
    } else {
        io::println("PASS: jouleFromBase works");
    }
}

public fn test_newton_arithmetic(): void {
    let a: Newton = new Newton(10.0);
    let b: Newton = new Newton(4.0);
    if (a.plus(b).getValue() != 14.0) {
        io::println("FAIL: Newton.plus");
    } else if (a.minus(b).getValue() != 6.0) {
        io::println("FAIL: Newton.minus");
    } else if (a.times(2.0).getValue() != 20.0) {
        io::println("FAIL: Newton.times scalar");
    } else if (a.div(2.0).getValue() != 5.0) {
        io::println("FAIL: Newton.div scalar");
    } else {
        io::println("PASS: Newton arithmetic works");
    }
}

public fn test_newton_times_meter_yields_joule(): void {
    let n: Newton = new Newton(5.0);
    let m: Meter = new Meter(4.0);
    let j: Joule = n.times(m);
    if (j.getValue() != 20.0) {
        io::println("FAIL: Newton.times(Meter) = " + Double.toString(j.getValue()));
    } else {
        io::println("PASS: Newton.times(Meter) yields Joule");
    }
}

public fn test_newtonFromBase(): void {
    let m: Meter = new Meter(2.0);
    let kg: Kilogram = new Kilogram(3.0);
    let s: Second = new Second(1.0);
    let n: Newton = newtonFromBase(m, kg, s);
    // N = kg * m / s^2 = 3 * 2 / 1 = 6
    if (n.getValue() != 6.0) {
        io::println("FAIL: newtonFromBase = " + Double.toString(n.getValue()));
    } else {
        io::println("PASS: newtonFromBase works");
    }
}

public fn test_pascal_arithmetic(): void {
    let a: Pascal = new Pascal(100.0);
    let b: Pascal = new Pascal(40.0);
    if (a.plus(b).getValue() != 140.0) {
        io::println("FAIL: Pascal.plus");
    } else if (a.minus(b).getValue() != 60.0) {
        io::println("FAIL: Pascal.minus");
    } else {
        io::println("PASS: Pascal arithmetic works");
    }
}

public fn test_pascalFromBase(): void {
    let n: Newton = new Newton(20.0);
    let m: Meter = new Meter(2.0);
    let p: Pascal = pascalFromBase(n, m);
    // P = N / m^2 = 20 / 4 = 5
    if (p.getValue() != 5.0) {
        io::println("FAIL: pascalFromBase = " + Double.toString(p.getValue()));
    } else {
        io::println("PASS: pascalFromBase works");
    }
}

