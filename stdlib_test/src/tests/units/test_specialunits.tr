    let p: double = toPlanckUnits(1.0, "unknown");
    if (p != 0.0) {
        io::println("FAIL: toPlanckUnits unknown should return 0");
    } else {
        io::println("PASS: toPlanckUnits unknown returns 0");
    }
}

public fn test_toPlanckUnits_zero_value(): void {
    let p: double = toPlanckUnits(0.0, "length");
    if (p != 0.0) {
        io::println("FAIL: toPlanckUnits(0, length) should be 0");
    } else {
        io::println("PASS: toPlanckUnits zero value returns 0");
    }
}

public fn run_all_specialunits_tests(): void {
    io::println("=== units/SpecialUnits.tr Tests ===");
    test_currencyUnit_init();
    test_currencyUnit_convertTo();
    test_currencyUnit_add();
    test_currencyUnit_subtract();
    test_astronomicalUnit_value();
    test_auToKm();
    test_auToKm_multiple();
    test_kmToAu();
    test_au_km_round_trip();
    test_lightYearToKm();
    test_kmToLightYear();
    test_parsecToKm();
    test_kmToParsec();
    test_toPlanckUnits_length();
    test_toPlanckUnits_mass();
    test_toPlanckUnits_time();
    test_toPlanckUnits_temperature();
    test_toPlanckUnits_charge();
    test_toPlanckUnits_energy();
    test_toPlanckUnits_unknown_returns_zero();
    test_toPlanckUnits_zero_value();
}
