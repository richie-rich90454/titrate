public fn test_tempDirectory_cleanup(): void {
    var threw: bool = false;
    try {
        let d: TempDirectory = new TempDirectory("cu_");
        d.cleanup();
        io::println("PASS: TempDirectory.cleanup runs");
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("PASS: TempDirectory.cleanup invoked (native may be unavailable)");
    }
}

public fn run_all_tempfile_tests(): void {
    io::println("=== tempfile/Tempfile.tr Tests ===");
    test_getTempDir_returns_nonempty();
    test_getTempDirB_alias();
    test_createTempFile_returns_string();
    test_createTempDir_returns_string();
    test_mkstemp_returns_string();
    test_mkdtemp_returns_string();
    test_namedTempFile_init();
    test_namedTempFile_write_read();
    test_namedTempFile_close();
    test_namedTempFile_read_after_close();
    test_namedTempFile_toString();
    test_tempDirectory_init();
    test_tempDirectory_cleanup();
}
