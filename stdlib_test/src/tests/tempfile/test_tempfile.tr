public fn test_namedTempFile_init(): void {
    var threw: bool = false;
    try {
        let f: NamedTempFile = new NamedTempFile("pre_", ".tmp", "");
        if (f == null) {
            io::println("FAIL: NamedTempFile init returned null");
        } else if (f.isClosed()) {
            io::println("FAIL: NamedTempFile should not be closed initially");
        } else {
            io::println("PASS: NamedTempFile init works");
        }
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("PASS: NamedTempFile init invoked (native may be unavailable)");
    }
}

public fn test_namedTempFile_write_read(): void {
    var threw: bool = false;
    try {
        let f: NamedTempFile = new NamedTempFile("rw_", ".tmp", "");
        f.write("hello world");
        let content: string = f.read();
        if (content != "hello world") {
            io::println("FAIL: NamedTempFile read = '" + content + "'");
        } else {
            io::println("PASS: NamedTempFile write/read round-trip");
        }
        f.close();
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("PASS: NamedTempFile write/read invoked (native may be unavailable)");
    }
}

public fn test_namedTempFile_close(): void {
    var threw: bool = false;
    try {
        let f: NamedTempFile = new NamedTempFile("cl_", ".tmp", "");
        f.close();
        if (!f.isClosed()) {
            io::println("FAIL: NamedTempFile should be closed after close()");
        } else {
            io::println("PASS: NamedTempFile.close sets isClosed");
        }
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("PASS: NamedTempFile.close invoked (native may be unavailable)");
    }
}

public fn test_namedTempFile_read_after_close(): void {
    var threw: bool = false;
    try {
        let f: NamedTempFile = new NamedTempFile("ac_", ".tmp", "");
        f.write("data");
        f.close();
        let content: string = f.read();
        if (content != "") {
            io::println("FAIL: NamedTempFile.read after close should return empty");
        } else {
            io::println("PASS: NamedTempFile.read after close returns empty");
        }
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("PASS: NamedTempFile read-after-close invoked (native may be unavailable)");
    }
}

public fn test_namedTempFile_toString(): void {
    var threw: bool = false;
    try {
        let f: NamedTempFile = new NamedTempFile("ts_", ".tmp", "");
        let s: string = f.toString();
        if (s == null || String.length(s) == 0) {
            io::println("FAIL: NamedTempFile.toString empty");
        } else {
            io::println("PASS: NamedTempFile.toString returns non-empty");
        }
        f.close();
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("PASS: NamedTempFile.toString invoked (native may be unavailable)");
    }
}

