public fn test_pack_unpack_string(): void {
    let p: Packer = new Packer();
    p.pack_string("hello");
    let buf: string = p.get_buffer();
    // 4 bytes length + 5 bytes string + 3 bytes padding = 12
    if (String.length(buf) != 12) {
        io::println("FAIL: pack_string length = " + Integer.toString(String.length(buf)));
        return;
    }
    let u: Unpacker = new Unpacker(buf);
    let s: string = u.unpack_string();
    if (s != "hello") {
        io::println("FAIL: unpack_string = " + s);
    } else {
        io::println("PASS: pack/unpack string roundtrip");
    }
}

public fn test_pack_unpack_string_aligned(): void {
    let p: Packer = new Packer();
    p.pack_string("abcd");
    let buf: string = p.get_buffer();
    // 4 bytes length + 4 bytes string + 0 padding = 8 (already aligned)
    if (String.length(buf) != 8) {
        io::println("FAIL: pack_string aligned length = " + Integer.toString(String.length(buf)));
        return;
    }
    let u: Unpacker = new Unpacker(buf);
    let s: string = u.unpack_string();
    if (s != "abcd") {
        io::println("FAIL: unpack_string aligned = " + s);
    } else {
        io::println("PASS: pack/unpack string aligned roundtrip");
    }
}

