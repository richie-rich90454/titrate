// Test file for binary/XdrLib.tr
// Exercises the public API: Packer, Unpacker, pack_data, unpack_data.
// Validates RFC 4504 XDR encoding/decoding parity with Python xdrlib.
import tt::binary::XdrLib;
import tt::util::ArrayList;
import tt::util::Pair;
import tt::lang::Variant;
import tt::lang::Integer;
import tt::lang::Double;

public fn test_packer_init(): void {
    let p: Packer = new Packer();
    if (String.length(p.get_buffer()) != 0) {
        io::println("FAIL: Packer init buffer not empty");
    } else {
        io::println("PASS: Packer init empty");
    }
}

public fn test_packer_reset(): void {
    let p: Packer = new Packer();
    p.pack_int(42);
    p.reset();
    if (String.length(p.get_buffer()) != 0) {
        io::println("FAIL: Packer reset did not clear buffer");
    } else {
        io::println("PASS: Packer reset works");
    }
}

public fn test_pack_unpack_int_zero(): void {
    let p: Packer = new Packer();
    p.pack_int(0);
    let buf: string = p.get_buffer();
    if (String.length(buf) != 4) {
        io::println("FAIL: pack_int(0) buffer length = " + Integer.toString(String.length(buf)));
        return;
    }
    let u: Unpacker = new Unpacker(buf);
    let v: int = u.unpack_int();
    if (v != 0) {
        io::println("FAIL: unpack_int(0) roundtrip = " + Integer.toString(v));
    } else {
        io::println("PASS: pack/unpack int zero roundtrip");
    }
}

