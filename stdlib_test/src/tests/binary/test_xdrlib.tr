public fn test_pack_unpack_double_simple(): void {
    let p: Packer = new Packer();
    p.pack_double(3.141592653589793);
    let u: Unpacker = new Unpacker(p.get_buffer());
    let v: double = u.unpack_double();
    let diff: double = v - 3.141592653589793;
    if (diff < 0.0) {
        diff = -diff;
    }
    if (diff > 1.0e-15) {
        io::println("FAIL: unpack_double pi = " + Double.toString(v));
    } else {
        io::println("PASS: pack/unpack double pi roundtrip");
    }
}

