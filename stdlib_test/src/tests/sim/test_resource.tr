// Test file for sim/Resource.tr
// Exercises the public API of the SimResource class: request/release,
// utilization, queue length, and capacity tracking.
//
// NOTE: The SimResource source has both a public `available` field and a
// public `available()` method with the same name. These tests treat
// available as a method call site. If the compiler rejects the name
// collision, that is a source bug, not a test bug.
import tt::sim::Resource;
import tt::util::ArrayList;
import tt::lang::Integer;
import tt::lang::Double;

public fn test_resource_init(): void {
    let r: SimResource = new SimResource("server", 3);
    if (r.name != "server") {
        io::println("FAIL: SimResource name not set");
    } else if (r.capacity != 3) {
        io::println("FAIL: SimResource capacity not set");
    } else if (r.available != 3) {
        io::println("FAIL: SimResource available should equal capacity at init");
    } else {
        io::println("PASS: SimResource init works");
    }
}

public fn test_resource_request_success(): void {
    let r: SimResource = new SimResource("server", 2);
    let ok: bool = r.request(1);
    if (!ok) {
        io::println("FAIL: SimResource request should succeed when available");
    } else if (r.available != 1) {
        io::println("FAIL: SimResource available should decrement after request");
    } else if (r.totalRequested != 1) {
        io::println("FAIL: SimResource totalRequested should increment");
    } else {
        io::println("PASS: SimResource request success works");
    }
}

public fn test_resource_request_when_full(): void {
    let r: SimResource = new SimResource("server", 1);
    r.request(1);
    let ok: bool = r.request(2);
    if (ok) {
        io::println("FAIL: SimResource request should fail when full");
    } else if (r.queueLength() != 1) {
        io::println("FAIL: SimResource queue should have 1 waiting process");
    } else {
        io::println("PASS: SimResource request when full queues the process");
    }
}

public fn test_resource_release_with_waiters(): void {
    let r: SimResource = new SimResource("server", 1);
    r.request(1);
    r.request(2);  // gets queued
    let nextId: int = r.release();
    if (nextId != 2) {
        io::println("FAIL: SimResource release should return next waiting id 2, got " + Integer.toString(nextId));
    } else if (r.totalReleased != 1) {
        io::println("FAIL: SimResource totalReleased should increment");
    } else {
        io::println("PASS: SimResource release with waiters dequeues");
    }
}

public fn test_resource_release_no_waiters(): void {
    let r: SimResource = new SimResource("server", 2);
    r.request(1);
    let nextId: int = r.release();
    if (nextId != -1) {
        io::println("FAIL: SimResource release no waiters should return -1");
    } else if (r.available != 2) {
        io::println("FAIL: SimResource available should restore to 2");
    } else {
        io::println("PASS: SimResource release no waiters returns -1");
    }
}

public fn test_resource_utilization(): void {
    let r: SimResource = new SimResource("server", 4);
    r.request(1);
    r.request(2);
    let u: double = r.utilization();
    if (Math.abs(u - 0.5) > 1e-9) {
        io::println("FAIL: SimResource utilization = " + Double.toString(u) + " expected 0.5");
    } else {
        io::println("PASS: SimResource utilization works");
    }
}

public fn test_resource_utilization_zero_capacity(): void {
    let r: SimResource = new SimResource("server", 0);
    let u: double = r.utilization();
    if (u != 0.0) {
        io::println("FAIL: SimResource utilization with capacity=0 should be 0");
    } else {
        io::println("PASS: SimResource utilization with capacity=0 returns 0");
    }
}

public fn test_resource_utilization_full(): void {
    let r: SimResource = new SimResource("server", 2);
    r.request(1);
    r.request(2);
    let u: double = r.utilization();
    if (Math.abs(u - 1.0) > 1e-9) {
        io::println("FAIL: SimResource utilization full = " + Double.toString(u));
    } else {
        io::println("PASS: SimResource utilization full returns 1.0");
    }
}

public fn test_resource_queueLength(): void {
    let r: SimResource = new SimResource("server", 1);
    r.request(1);
    r.request(2);
    r.request(3);
    if (r.queueLength() != 2) {
        io::println("FAIL: SimResource queueLength = " + Integer.toString(r.queueLength()));
    } else {
        io::println("PASS: SimResource queueLength works");
    }
}

public fn test_resource_multiple_release(): void {
    let r: SimResource = new SimResource("server", 1);
    r.request(1);
    r.request(2);
    r.request(3);
    let n1: int = r.release();
    let n2: int = r.release();
    if (n1 != 2 || n2 != 3) {
        io::println("FAIL: SimResource multiple release order wrong");
    } else {
        io::println("PASS: SimResource multiple release dequeues in order");
    }
}

public fn run_all_resource_tests(): void {
    io::println("=== Resource.tr Tests ===");
    test_resource_init();
    test_resource_request_success();
    test_resource_request_when_full();
    test_resource_release_with_waiters();
    test_resource_release_no_waiters();
    test_resource_utilization();
    test_resource_utilization_zero_capacity();
    test_resource_utilization_full();
    test_resource_queueLength();
    test_resource_multiple_release();
}
