// Test file for json/JsonSchema.tr
// Exercises the public API: ValidationError, ValidationReport, JsonSchema.
import tt::json::JsonSchema;
import tt::json::JsonValue;
import tt::util::ArrayList;
import tt::util::HashMap;
import tt::lang::Integer;
import tt::lang::Boolean;

public fn test_validationerror_init(): void {
    let e: ValidationError = new ValidationError();
    if (e.path != "" || e.message != "" || e.schemaLocation != "") {
        io::println("FAIL: ValidationError.init defaults wrong");
    } else {
        io::println("PASS: ValidationError.init works");
    }
}

public fn test_validationreport_init(): void {
    let r: ValidationReport = new ValidationReport();
    if (!r.valid) {
        io::println("FAIL: ValidationReport.valid should default true");
    } else if (r.errors == null) {
        io::println("FAIL: ValidationReport.errors is null");
    } else if (r.errors.size() != 0) {
        io::println("FAIL: ValidationReport.errors should be empty");
    } else {
        io::println("PASS: ValidationReport.init works");
    }
}

public fn test_validationreport_addError(): void {
    let r: ValidationReport = new ValidationReport();
    r.addError("/a", "msg", "/schema/a");
    if (r.valid) {
        io::println("FAIL: ValidationReport.valid should be false after addError");
    } else if (r.errors.size() != 1) {
        io::println("FAIL: ValidationReport.errors size=" + Integer.toString(r.errors.size()));
    } else {
        io::println("PASS: ValidationReport.addError works");
    }
}

public fn test_jsonschema_init(): void {
    let s: JsonSchema = new JsonSchema();
    if (s == null) {
        io::println("FAIL: JsonSchema.init returned null");
    } else {
        io::println("PASS: JsonSchema.init works");
    }
}

public fn test_jsonschema_load(): void {
    let s: JsonSchema = new JsonSchema();
    let schema: HashMap<string, JsonValue> = new HashMap<string, JsonValue>();
    schema.put("type", JsonValue.ofStr("string"));
    s.load(JsonValue.ofObject(schema));
    io::println("PASS: JsonSchema.load works");
}

public fn test_jsonschema_validate_type_string_pass(): void {
    let s: JsonSchema = new JsonSchema();
    let schema: HashMap<string, JsonValue> = new HashMap<string, JsonValue>();
    schema.put("type", JsonValue.ofStr("string"));
    s.load(JsonValue.ofObject(schema));
    let report: ValidationReport = s.validate(JsonValue.ofStr("hello"));
    if (!report.valid) {
        io::println("FAIL: JsonSchema.validate string should pass for string");
    } else {
        io::println("PASS: JsonSchema.validate type string pass works");
    }
}

public fn test_jsonschema_validate_type_string_fail(): void {
    let s: JsonSchema = new JsonSchema();
    let schema: HashMap<string, JsonValue> = new HashMap<string, JsonValue>();
    schema.put("type", JsonValue.ofStr("string"));
    s.load(JsonValue.ofObject(schema));
    let report: ValidationReport = s.validate(JsonValue.ofNum(42.0));
    if (report.valid) {
        io::println("FAIL: JsonSchema.validate string should fail for number");
    } else {
        io::println("PASS: JsonSchema.validate type string fail works");
    }
}

