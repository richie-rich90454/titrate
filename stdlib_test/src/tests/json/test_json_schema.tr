public fn run_all_json_schema_tests(): void {
    io::println("=== JsonSchema.tr Tests ===");
    test_validationerror_init();
    test_validationreport_init();
    test_validationreport_addError();
    test_jsonschema_init();
    test_jsonschema_load();
    test_jsonschema_validate_type_string_pass();
    test_jsonschema_validate_type_string_fail();
    test_jsonschema_validate_type_number_pass();
    test_jsonschema_validate_minimum_pass();
    test_jsonschema_validate_minimum_fail();
    test_jsonschema_validate_maximum_pass();
    test_jsonschema_validate_maximum_fail();
    test_jsonschema_validate_minLength_pass();
    test_jsonschema_validate_minLength_fail();
    test_jsonschema_validate_maxLength_pass();
    test_jsonschema_validate_maxLength_fail();
    test_jsonschema_validate_enum_pass();
    test_jsonschema_validate_enum_fail();
    test_jsonschema_validate_const_pass();
    test_jsonschema_validate_const_fail();
    test_jsonschema_validate_required_pass();
    test_jsonschema_validate_required_fail();
    test_jsonschema_validate_minItems_fail();
    test_jsonschema_compile();
    test_jsonschema_validate_empty_schema();
}
