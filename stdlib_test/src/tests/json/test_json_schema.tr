public fn test_jsonschema_validate_required_pass(): void {
    let s: JsonSchema = new JsonSchema();
    let schema: HashMap<string, JsonValue> = new HashMap<string, JsonValue>();
    schema.put("type", JsonValue.ofStr("object"));
    let reqArr: ArrayList<JsonValue> = new ArrayList<JsonValue>();
    reqArr.add(JsonValue.ofStr("a"));
    schema.put("required", JsonValue.ofArray(reqArr));
    s.load(JsonValue.ofObject(schema));
    let data: HashMap<string, JsonValue> = new HashMap<string, JsonValue>();
    data.put("a", JsonValue.ofNum(1.0));
    let report: ValidationReport = s.validate(JsonValue.ofObject(data));
    if (!report.valid) {
        io::println("FAIL: JsonSchema.validate required should pass when key present");
    } else {
        io::println("PASS: JsonSchema.validate required pass works");
    }
}

public fn test_jsonschema_validate_required_fail(): void {
    let s: JsonSchema = new JsonSchema();
