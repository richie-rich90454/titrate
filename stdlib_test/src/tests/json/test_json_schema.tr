public fn test_jsonschema_validate_enum_pass(): void {
    let s: JsonSchema = new JsonSchema();
    let schema: HashMap<string, JsonValue> = new HashMap<string, JsonValue>();
    let enumArr: ArrayList<JsonValue> = new ArrayList<JsonValue>();
    enumArr.add(JsonValue.ofStr("a"));
    enumArr.add(JsonValue.ofStr("b"));
    enumArr.add(JsonValue.ofStr("c"));
    schema.put("enum", JsonValue.ofArray(enumArr));
    s.load(JsonValue.ofObject(schema));
    let report: ValidationReport = s.validate(JsonValue.ofStr("b"));
    if (!report.valid) {
        io::println("FAIL: JsonSchema.validate enum should pass for b");
    } else {
        io::println("PASS: JsonSchema.validate enum pass works");
    }
}

