public fn test_jsonschema_validate_minimum_pass(): void {
    let s: JsonSchema = new JsonSchema();
    let schema: HashMap<string, JsonValue> = new HashMap<string, JsonValue>();
    schema.put("type", JsonValue.ofStr("number"));
    schema.put("minimum", JsonValue.ofNum(10.0));
    s.load(JsonValue.ofObject(schema));
    let report: ValidationReport = s.validate(JsonValue.ofNum(15.0));
    if (!report.valid) {
        io::println("FAIL: JsonSchema.validate minimum should pass for 15 >= 10");
    } else {
        io::println("PASS: JsonSchema.validate minimum pass works");
    }
}

