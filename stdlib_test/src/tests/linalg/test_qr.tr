public fn test_rank_revealing_qr(): void {
    let a: ArrayList<ArrayList<double>> = new ArrayList<ArrayList<double>>();
    let row0: ArrayList<double> = new ArrayList<double>();
    row0.add(1.0);
    row0.add(2.0);
    let row1: ArrayList<double> = new ArrayList<double>();
    row1.add(2.0);
    row1.add(4.0);
    a.add(row0);
    a.add(row1);
    let result: Pair<ArrayList<ArrayList<double>>, ArrayList<ArrayList<double>>> = Qr.rankRevealingQr(a, 2, 2, 1e-9);
    if (result.first.size() != 2 || result.second.size() != 2) {
        io::println("FAIL: rankRevealingQr result sizes");
        return;
    }
    io::println("PASS: rankRevealingQr returns proper structure");
}

public fn run_all_qr_tests(): void {
    io::println("=== Qr.tr Tests ===");
    test_qr_householder();
    test_qr_givens();
    test_qr_pivoted();
    test_qr_column_pivoting();
    test_rank_revealing_qr();
}
