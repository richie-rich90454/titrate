// Test file for Qr.tr
// Exercises the public API for QR decomposition variants.
// Matrices are stored as flat ArrayList<double> in row-major order.
import tt::util::ArrayList;
import tt::util::HashMap;
import tt::linalg::Qr;
import tt::lang::Integer;
import tt::lang::Double;
import tt::math::Math;

public fn test_qr_householder(): void {
    // 2x2 matrix [[1, 2], [3, 4]] stored flat: [1, 2, 3, 4]
    let a: ArrayList<double> = new ArrayList<double>();
    a.add(1.0);
    a.add(2.0);
    a.add(3.0);
    a.add(4.0);
    let result: HashMap<string, ArrayList<double>> = Qr.qrHouseholder(a, 2, 2);
    let q: ArrayList<double> = result.get("Q");
    let r: ArrayList<double> = result.get("R");
    if (q.size() != 4 || r.size() != 4) {
        io::println("FAIL: qrHouseholder sizes q=" + Integer.toString(q.size()) + " r=" + Integer.toString(r.size()));
        return;
    }
    // R should be upper triangular: R[1][0] (=index 2) should be ~0
    if (Math.abs(r.get(2)) > 1e-9) {
        io::println("FAIL: qrHouseholder R not upper triangular");
    } else {
        io::println("PASS: qrHouseholder produces upper triangular R");
    }
}

public fn test_qr_givens(): void {
    let a: ArrayList<double> = new ArrayList<double>();
    a.add(1.0);
    a.add(2.0);
    a.add(3.0);
    a.add(4.0);
    let result: HashMap<string, ArrayList<double>> = Qr.qrGivens(a, 2, 2);
    let q: ArrayList<double> = result.get("Q");
    let r: ArrayList<double> = result.get("R");
    if (q.size() != 4 || r.size() != 4) {
        io::println("FAIL: qrGivens sizes q=" + Integer.toString(q.size()) + " r=" + Integer.toString(r.size()));
        return;
    }
    if (Math.abs(r.get(2)) > 1e-9) {
        io::println("FAIL: qrGivens R not upper triangular");
    } else {
        io::println("PASS: qrGivens produces upper triangular R");
    }
}

public fn test_qr_pivoted(): void {
    let a: ArrayList<double> = new ArrayList<double>();
    a.add(1.0);
    a.add(2.0);
    a.add(3.0);
    a.add(4.0);
    let result: HashMap<string, ArrayList<double>> = Qr.qrPivoted(a, 2, 2);
    if (result.get("Q").size() != 4 || result.get("R").size() != 4) {
        io::println("FAIL: qrPivoted result sizes");
        return;
    }
    io::println("PASS: qrPivoted returns proper structure");
}

public fn test_qr_column_pivoting(): void {
    let a: ArrayList<double> = new ArrayList<double>();
    a.add(1.0);
    a.add(2.0);
    a.add(3.0);
    a.add(4.0);
    let result: HashMap<string, ArrayList<double>> = Qr.qrColumnPivoting(a, 2, 2);
    if (result.get("Q").size() != 4 || result.get("R").size() != 4) {
        io::println("FAIL: qrColumnPivoting result sizes");
        return;
    }
    io::println("PASS: qrColumnPivoting returns proper structure");
}

public fn test_rank_revealing_qr(): void {
    let a: ArrayList<double> = new ArrayList<double>();
    a.add(1.0);
    a.add(2.0);
    a.add(2.0);
    a.add(4.0);
    let result: HashMap<string, double> = Qr.rankRevealingQr(a, 2, 2, 1e-9);
    let rank: double = result.get("rank");
    // [[1,2],[2,4]] is rank 1 (row 2 = 2 * row 1)
    if (Math.abs(rank - 1.0) > 1e-9) {
        io::println("FAIL: rankRevealingQr rank = " + Double.toString(rank) + " expected 1.0");
    } else {
        io::println("PASS: rankRevealingQr returns proper rank");
    }
}

public fn run_all_qr_tests(): void {
    io::println("=== Qr.tr Tests ===");
    test_qr_householder();
    test_qr_givens();
    test_qr_pivoted();
    test_qr_column_pivoting();
    test_rank_revealing_qr();
}
