// Test file for Eigen.tr
// Exercises the public API for eigenvalue/eigenvector computations.
// Matrices are stored as flat ArrayList<double> in row-major order.
import tt::util::ArrayList;
import tt::util::Pair;
import tt::linalg::Eigen;
import tt::lang::Integer;
import tt::lang::Double;
import tt::math::Math;
import tt::math::MathAdvanced;

public fn test_eigenvalues_2x2(): void {
    // Diagonal matrix [[5, 0], [0, 3]] stored flat: [5, 0, 0, 3]
    // has eigenvalues 5 and 3
    let a: ArrayList<double> = new ArrayList<double>();
    a.add(5.0);
    a.add(0.0);
    a.add(0.0);
    a.add(3.0);
    let eigs: ArrayList<double> = Eigen.eigenvalues(a, 2);
    if (eigs.size() != 2) {
        io::println("FAIL: eigenvalues size = " + Integer.toString(eigs.size()));
        return;
    }
    // Check both eigenvalues are present (order may vary)
    let has5: bool = Math.abs(eigs.get(0) - 5.0) < 1e-6 || Math.abs(eigs.get(1) - 5.0) < 1e-6;
    let has3: bool = Math.abs(eigs.get(0) - 3.0) < 1e-6 || Math.abs(eigs.get(1) - 3.0) < 1e-6;
    if (!has5 || !has3) {
        io::println("FAIL: eigenvalues = " + Double.toString(eigs.get(0)) + ", " + Double.toString(eigs.get(1)));
    } else {
        io::println("PASS: eigenvalues for diagonal matrix works");
    }
}

public fn test_eigenvectors_2x2(): void {
    // [[5, 0], [0, 3]] has eigenvectors [1,0] and [0,1]
    let a: ArrayList<double> = new ArrayList<double>();
    a.add(5.0);
    a.add(0.0);
    a.add(0.0);
    a.add(3.0);
    let result: Pair<ArrayList<double>, ArrayList<double>> = Eigen.eigenvectors(a, 2);
    let eigs: ArrayList<double> = result.first;
    let vecs: ArrayList<double> = result.second;
    if (eigs.size() != 2 || vecs.size() != 4) {
        io::println("FAIL: eigenvectors sizes eigs=" + Integer.toString(eigs.size()) + " vecs=" + Integer.toString(vecs.size()));
        return;
    }
    io::println("PASS: eigenvectors returns proper structure");
}

public fn test_power_iteration(): void {
    // For diagonal matrix with largest eigenvalue 5
    let a: ArrayList<double> = new ArrayList<double>();
    a.add(5.0);
    a.add(0.0);
    a.add(0.0);
    a.add(3.0);
    let result: Pair<double, ArrayList<double>> = Eigen.powerIteration(a, 2, 100);
    let eigenvalue: double = result.first;
    let v: ArrayList<double> = result.second;
    if (v.size() != 2) {
        io::println("FAIL: powerIteration result size = " + Integer.toString(v.size()));
        return;
    }
    // Vector should be normalized (magnitude ~1)
    let mag: double = MathAdvanced.sqrt(v.get(0) * v.get(0) + v.get(1) * v.get(1));
    if (Math.abs(mag - 1.0) > 1e-6) {
        io::println("FAIL: powerIteration vector magnitude = " + Double.toString(mag));
    } else {
        io::println("PASS: powerIteration eigenvalue=" + Double.toString(eigenvalue) + " (expected ~5.0)");
    }
}

public fn test_inverse_iteration(): void {
    let a: ArrayList<double> = new ArrayList<double>();
    a.add(5.0);
    a.add(0.0);
    a.add(0.0);
    a.add(3.0);
    let result: Pair<double, ArrayList<double>> = Eigen.inverseIteration(a, 2, 3.0, 100);
    let eigenvalue: double = result.first;
    let v: ArrayList<double> = result.second;
    if (v.size() != 2) {
        io::println("FAIL: inverseIteration result size = " + Integer.toString(v.size()));
        return;
    }
    io::println("PASS: inverseIteration eigenvalue=" + Double.toString(eigenvalue));
}

public fn test_rayleigh_quotient(): void {
    // For [[5,0],[0,3]] and v=[1,0], rayleigh quotient = 5
    let a: ArrayList<double> = new ArrayList<double>();
    a.add(5.0);
    a.add(0.0);
    a.add(0.0);
    a.add(3.0);
    let v: ArrayList<double> = new ArrayList<double>();
    v.add(1.0);
    v.add(0.0);
    let q: double = Eigen.rayleighQuotient(a, 2, v);
    if (Math.abs(q - 5.0) > 1e-6) {
        io::println("FAIL: rayleighQuotient = " + Double.toString(q) + " expected 5.0");
    } else {
        io::println("PASS: rayleighQuotient works");
    }
}

public fn run_all_eigen_tests(): void {
    io::println("=== Eigen.tr Tests ===");
    test_eigenvalues_2x2();
    test_eigenvectors_2x2();
    test_power_iteration();
    test_inverse_iteration();
    test_rayleigh_quotient();
}
