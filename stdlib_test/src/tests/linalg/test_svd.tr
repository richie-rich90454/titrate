// Test file for Svd.tr
// Exercises the public API for SVD decomposition and related operations.
// Matrices are stored as flat ArrayList<double> in row-major order.
import tt::util::ArrayList;
import tt::util::HashMap;
import tt::linalg::Svd;
import tt::lang::Integer;
import tt::lang::Double;
import tt::math::Math;

public fn test_svd_basic(): void {
    // 2x2 matrix [[1, 2], [3, 4]] stored flat: [1, 2, 3, 4]
    let a: ArrayList<double> = new ArrayList<double>();
    a.add(1.0);
    a.add(2.0);
    a.add(3.0);
    a.add(4.0);
    let result: HashMap<string, ArrayList<double>> = Svd.svd(a, 2, 2);
    let u: ArrayList<double> = result.get("U");
    let s: ArrayList<double> = result.get("S");
    let vt: ArrayList<double> = result.get("Vt");
    if (u.size() != 4 || s.size() != 2 || vt.size() != 4) {
        io::println("FAIL: svd result sizes U=" + Integer.toString(u.size()) + " S=" + Integer.toString(s.size()) + " Vt=" + Integer.toString(vt.size()));
        return;
    }
    // Singular values should be positive and ordered descending
    if (s.get(0) < s.get(1)) {
        io::println("FAIL: svd singular values not descending");
    } else {
        io::println("PASS: svd returns properly structured result");
    }
}

public fn test_thin_svd(): void {
    let a: ArrayList<double> = new ArrayList<double>();
    a.add(1.0);
    a.add(2.0);
    a.add(3.0);
    a.add(4.0);
    let result: HashMap<string, ArrayList<double>> = Svd.thinSvd(a, 2, 2);
    let s: ArrayList<double> = result.get("S");
    if (s.size() != 2) {
        io::println("FAIL: thinSvd S size = " + Integer.toString(s.size()));
        return;
    }
    io::println("PASS: thinSvd works");
}

public fn test_truncated_svd(): void {
    let a: ArrayList<double> = new ArrayList<double>();
    a.add(1.0);
    a.add(2.0);
    a.add(3.0);
    a.add(4.0);
    let result: HashMap<string, ArrayList<double>> = Svd.truncatedSvd(a, 2, 2, 1);
    let s: ArrayList<double> = result.get("S");
    if (s.size() != 1) {
        io::println("FAIL: truncatedSvd S size = " + Integer.toString(s.size()) + " expected 1");
        return;
    }
    io::println("PASS: truncatedSvd returns k=1 singular values");
}

public fn test_condition_number(): void {
    // Identity matrix has condition number 1
    let a: ArrayList<double> = new ArrayList<double>();
    a.add(1.0);
    a.add(0.0);
    a.add(0.0);
    a.add(1.0);
    let cond: double = Svd.conditionNumber(a, 2, 2);
    if (Math.abs(cond - 1.0) > 1e-6) {
        io::println("FAIL: conditionNumber for identity = " + Double.toString(cond) + " expected 1.0");
    } else {
        io::println("PASS: conditionNumber for identity is 1.0");
    }
}

public fn test_pseudoinverse(): void {
    // Pseudoinverse of identity is identity (flat 2x2)
    let a: ArrayList<double> = new ArrayList<double>();
    a.add(1.0);
    a.add(0.0);
    a.add(0.0);
    a.add(1.0);
    let pinv: ArrayList<double> = Svd.pseudoinverse(a, 2, 2);
    if (pinv.size() != 4) {
        io::println("FAIL: pseudoinverse size = " + Integer.toString(pinv.size()));
        return;
    }
    if (Math.abs(pinv.get(0) - 1.0) > 1e-6 || Math.abs(pinv.get(3) - 1.0) > 1e-6) {
        io::println("FAIL: pseudoinverse of identity not identity");
    } else {
        io::println("PASS: pseudoinverse of identity works");
    }
}

public fn test_low_rank_approximation(): void {
    let a: ArrayList<double> = new ArrayList<double>();
    a.add(1.0);
    a.add(2.0);
    a.add(3.0);
    a.add(4.0);
    let approx: ArrayList<double> = Svd.lowRankApproximation(a, 2, 2, 1);
    if (approx.size() != 4) {
        io::println("FAIL: lowRankApproximation size = " + Integer.toString(approx.size()));
        return;
    }
    io::println("PASS: lowRankApproximation returns proper matrix");
}

public fn run_all_svd_tests(): void {
    io::println("=== Svd.tr Tests ===");
    test_svd_basic();
    test_thin_svd();
    test_truncated_svd();
    test_condition_number();
    test_pseudoinverse();
    test_low_rank_approximation();
}
