// Test file for chem/RHFDiag.tr
// Exercises Jacobi diagonalization and S^{-1/2} symmetric orthogonalization.
import tt::chem::RHF;
import tt::chem::Molecule;
import tt::chem::Atom;
import tt::chem::RHFDiag;
import tt::chem::RHFMatrix;
import tt::math::linalg::Matrix;
import tt::math::Math;
import tt::math::MathAdvanced;
import tt::util::ArrayList;
import tt::lang::Integer;

fn absDiff(a: double, b: double): double {
    let d: double = a - b;
    if (d < 0.0) { return -d; }
    return d;
}

// Helper: build an H2 RHF object (basis=2, two H atoms at 1.4 A)
fn _makeH2Rhf(): RHF {
    let mol: Molecule = new Molecule("H2");
    let h1: Atom = new Atom("H", 1, 1.008);
    let h2: Atom = new Atom("H", 1, 1.008);
    h1.setPosition(0.0, 0.0, 0.0);
    h2.setPosition(1.4, 0.0, 0.0);
    mol.addAtom(h1);
    mol.addAtom(h2);
    let rhf: RHF = new RHF(mol, 2);
    return rhf;
}

// ---- jacobiDiagonalize tests ----

public fn test_jacobi_identity_matrix(): void {
    let rhf: RHF = _makeH2Rhf();
    let A: Matrix = Matrix.identity(3);
    let (V, eigenvals): (Matrix, ArrayList<double>) = jacobiDiagonalize(rhf, A);
    // Eigenvalues of identity are all 1
    let n: int = eigenvals.size();
    if (n != 3) {
        io::println("FAIL: jacobi identity size = " + Integer.toString(n));
    } else {
        io::println("PASS: jacobi identity size = 3");
    }
    var ok: bool = true;
    var i: int = 0;
    while (i < 3) {
        if (absDiff(eigenvals.get(i), 1.0) > 1e-9) { ok = false; }
        i = i + 1;
    }
    if (ok) {
        io::println("PASS: jacobi identity eigenvalues = 1");
    } else {
        io::println("FAIL: jacobi identity eigenvalues not all 1");
    }
}

public fn test_jacobi_diagonal_matrix(): void {
    let rhf: RHF = _makeH2Rhf();
    let A: Matrix = new Matrix(3, 3);
    A.set(0, 0, 5.0);
    A.set(1, 1, 2.0);
    A.set(2, 2, 8.0);
    let (V, eigenvals): (Matrix, ArrayList<double>) = jacobiDiagonalize(rhf, A);
    // Eigenvalues should be sorted ascending: 2, 5, 8
    if (absDiff(eigenvals.get(0), 2.0) < 1e-9 &&
        absDiff(eigenvals.get(1), 5.0) < 1e-9 &&
        absDiff(eigenvals.get(2), 8.0) < 1e-9) {
        io::println("PASS: jacobi diagonal eigenvalues sorted ascending");
    } else {
        io::println("FAIL: jacobi diagonal eigenvalues not sorted");
    }
}

public fn test_jacobi_2x2_symmetric(): void {
    let rhf: RHF = _makeH2Rhf();
    let A: Matrix = new Matrix(2, 2);
    A.set(0, 0, 2.0);
    A.set(1, 1, 4.0);
    A.set(0, 1, 1.0);
    A.set(1, 0, 1.0);
    let (V, eigenvals): (Matrix, ArrayList<double>) = jacobiDiagonalize(rhf, A);
    // For [[2,1],[1,4]]: eigenvalues = 3 - sqrt(2), 3 + sqrt(2)
    let e1: double = 3.0 - MathAdvanced.sqrt(2.0);
    let e2: double = 3.0 + MathAdvanced.sqrt(2.0);
    if (absDiff(eigenvals.get(0), e1) < 1e-9 && absDiff(eigenvals.get(1), e2) < 1e-9) {
        io::println("PASS: jacobi 2x2 symmetric eigenvalues");
    } else {
        io::println("FAIL: jacobi 2x2 symmetric eigenvalues wrong");
    }
}

public fn test_jacobi_returns_eigenvector_matrix(): void {
    let rhf: RHF = _makeH2Rhf();
    let A: Matrix = new Matrix(2, 2);
    A.set(0, 0, 2.0);
    A.set(1, 1, 4.0);
    A.set(0, 1, 1.0);
    A.set(1, 0, 1.0);
    let (V, eigenvals): (Matrix, ArrayList<double>) = jacobiDiagonalize(rhf, A);
    // V should be 2x2
    if (V.rows() == 2 && V.cols() == 2) {
        io::println("PASS: jacobi eigenvector matrix dimensions 2x2");
    } else {
        io::println("FAIL: jacobi eigenvector matrix dimensions");
    }
}

public fn test_jacobi_orthonormal_eigenvectors(): void {
    let rhf: RHF = _makeH2Rhf();
    let A: Matrix = new Matrix(2, 2);
    A.set(0, 0, 2.0);
    A.set(1, 1, 4.0);
    A.set(0, 1, 1.0);
    A.set(1, 0, 1.0);
    let (V, eigenvals): (Matrix, ArrayList<double>) = jacobiDiagonalize(rhf, A);
    // Columns of V should be orthonormal: V^T * V = I
    // Column 0 norm:
    let c0x: double = V.get(0, 0);
    let c0y: double = V.get(1, 0);
    let norm0: double = MathAdvanced.sqrt(c0x * c0x + c0y * c0y);
    // Column 1 norm:
    let c1x: double = V.get(0, 1);
    let c1y: double = V.get(1, 1);
    let norm1: double = MathAdvanced.sqrt(c1x * c1x + c1y * c1y);
    // Dot product of column 0 and column 1:
    let dot: double = c0x * c1x + c0y * c1y;
    if (absDiff(norm0, 1.0) < 1e-9 && absDiff(norm1, 1.0) < 1e-9 && absDiff(dot, 0.0) < 1e-9) {
        io::println("PASS: jacobi eigenvectors orthonormal");
    } else {
        io::println("FAIL: jacobi eigenvectors not orthonormal");
    }
}

public fn test_jacobi_reconstruction(): void {
    let rhf: RHF = _makeH2Rhf();
    // For symmetric A: A = V * diag(eigenvals) * V^T
    let A: Matrix = new Matrix(2, 2);
    A.set(0, 0, 2.0);
    A.set(1, 1, 4.0);
    A.set(0, 1, 1.0);
    A.set(1, 0, 1.0);
    let (V, eigenvals): (Matrix, ArrayList<double>) = jacobiDiagonalize(rhf, A);
    // Build diag(eigenvals)
    let D: Matrix = new Matrix(2, 2);
    D.set(0, 0, eigenvals.get(0));
    D.set(1, 1, eigenvals.get(1));
    // Reconstruct: V * D * V^T
    let VT: Matrix = V.transpose();
    let recon: Matrix = V.mul(D).mul(VT);
    let ok: bool = absDiff(recon.get(0, 0), 2.0) < 1e-9 &&
                   absDiff(recon.get(1, 1), 4.0) < 1e-9 &&
                   absDiff(recon.get(0, 1), 1.0) < 1e-9 &&
                   absDiff(recon.get(1, 0), 1.0) < 1e-9;
    if (ok) {
        io::println("PASS: jacobi reconstruction V*D*V^T = A");
    } else {
        io::println("FAIL: jacobi reconstruction mismatch");
    }
}

public fn test_jacobi_eigenvalues_sorted_ascending(): void {
    let rhf: RHF = _makeH2Rhf();
    let A: Matrix = new Matrix(3, 3);
    A.set(0, 0, 10.0);
    A.set(1, 1, 1.0);
    A.set(2, 2, 5.0);
    A.set(0, 1, 0.5);
    A.set(1, 0, 0.5);
    A.set(0, 2, 0.3);
    A.set(2, 0, 0.3);
    A.set(1, 2, 0.2);
    A.set(2, 1, 0.2);
    let (V, eigenvals): (Matrix, ArrayList<double>) = jacobiDiagonalize(rhf, A);
    var sorted: bool = true;
    var i: int = 0;
    while (i < eigenvals.size() - 1) {
        if (eigenvals.get(i) > eigenvals.get(i + 1)) { sorted = false; }
        i = i + 1;
    }
    if (sorted) {
        io::println("PASS: jacobi eigenvalues sorted ascending");
    } else {
        io::println("FAIL: jacobi eigenvalues not sorted");
    }
}

public fn test_jacobi_1x1_matrix(): void {
    let rhf: RHF = _makeH2Rhf();
    let A: Matrix = new Matrix(1, 1);
    A.set(0, 0, 7.5);
    let (V, eigenvals): (Matrix, ArrayList<double>) = jacobiDiagonalize(rhf, A);
    if (eigenvals.size() == 1 && absDiff(eigenvals.get(0), 7.5) < 1e-9) {
        io::println("PASS: jacobi 1x1 matrix");
    } else {
        io::println("FAIL: jacobi 1x1 matrix");
    }
}

// ---- computeSInverseHalf tests ----

public fn test_sinv_half_returns_matrix(): void {
    let rhf: RHF = _makeH2Rhf();
    let sinvHalf: Matrix = computeSInverseHalf(rhf);
    if (sinvHalf.rows() == 2 && sinvHalf.cols() == 2) {
        io::println("PASS: computeSInverseHalf returns 2x2 matrix");
    } else {
        io::println("FAIL: computeSInverseHalf dimensions");
    }
}

public fn test_sinv_half_finite_values(): void {
    let rhf: RHF = _makeH2Rhf();
    let sinvHalf: Matrix = computeSInverseHalf(rhf);
    var allFinite: bool = true;
    var i: int = 0;
    while (i < 2) {
        var j: int = 0;
        while (j < 2) {
            let v: double = sinvHalf.get(i, j);
            if (v != v) { allFinite = false; }  // NaN check
            if (v == Math.INF()) { allFinite = false; }
            j = j + 1;
        }
        i = i + 1;
    }
    if (allFinite) {
        io::println("PASS: computeSInverseHalf values finite");
    } else {
        io::println("FAIL: computeSInverseHalf has non-finite values");
    }
}

public fn test_sinv_half_symmetric(): void {
    let rhf: RHF = _makeH2Rhf();
    let sinvHalf: Matrix = computeSInverseHalf(rhf);
    // S^{-1/2} should be symmetric: M = M^T
    if (absDiff(sinvHalf.get(0, 1), sinvHalf.get(1, 0)) < 1e-9) {
        io::println("PASS: computeSInverseHalf symmetric");
    } else {
        io::println("FAIL: computeSInverseHalf not symmetric");
    }
}

public fn test_sinv_half_orthogonalization_property(): void {
    let rhf: RHF = _makeH2Rhf();
    // Property: S^{-1/2} * S * S^{-1/2} = I
    let sinvHalf: Matrix = computeSInverseHalf(rhf);
    let S: Matrix = toMatrix(rhf, rhf.overlapMatrix);
    let product: Matrix = sinvHalf.mul(S).mul(sinvHalf);
    // Check that product is approximately identity
    let i00: double = absDiff(product.get(0, 0), 1.0);
    let i11: double = absDiff(product.get(1, 1), 1.0);
    let off01: double = absDiff(product.get(0, 1), 0.0);
    let off10: double = absDiff(product.get(1, 0), 0.0);
    if (i00 < 1e-6 && i11 < 1e-6 && off01 < 1e-6 && off10 < 1e-6) {
        io::println("PASS: S^{-1/2} * S * S^{-1/2} = I");
    } else {
        io::println("FAIL: S^{-1/2} orthogonalization property");
    }
}

public fn test_sinv_half_diagonal_positive(): void {
    let rhf: RHF = _makeH2Rhf();
    let sinvHalf: Matrix = computeSInverseHalf(rhf);
    // For an overlap matrix, diagonal of S is 1, so diagonal of S^{-1/2} should be positive
    if (sinvHalf.get(0, 0) > 0.0 && sinvHalf.get(1, 1) > 0.0) {
        io::println("PASS: computeSInverseHalf diagonal positive");
    } else {
        io::println("FAIL: computeSInverseHalf diagonal not positive");
    }
}

public fn run_all_rhf_diag_tests(): void {
    io::println("=== RHFDiag.tr Tests ===");
    test_jacobi_identity_matrix();
    test_jacobi_diagonal_matrix();
    test_jacobi_2x2_symmetric();
    test_jacobi_returns_eigenvector_matrix();
    test_jacobi_orthonormal_eigenvectors();
    test_jacobi_reconstruction();
    test_jacobi_eigenvalues_sorted_ascending();
    test_jacobi_1x1_matrix();
    test_sinv_half_returns_matrix();
    test_sinv_half_finite_values();
    test_sinv_half_symmetric();
    test_sinv_half_orthogonalization_property();
    test_sinv_half_diagonal_positive();
}
