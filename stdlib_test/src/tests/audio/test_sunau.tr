    let data: ArrayList<int> = new ArrayList<int>();
    data.add(0x00); data.add(0x10);
    w.writeframes(data);
    if (w.getnframes() != 1) {
        io::println("FAIL: SunAuWriter writeframes nframes wrong");
    } else {
        io::println("PASS: SunAuWriter writeframes works");
    }
}

public fn test_sunaureader_getparams(): void {
    let au: SunauAudio = new SunauAudio();
    au.encoding = 3;
    au.sampleRate = 8000;
    au.channels = 1;
    let r: SunAuReader = new SunAuReader(au, "dummy");
    let p: AudioParams = r.getparams();
    if (p.nchannels != 1) {
        io::println("FAIL: SunAuReader.getparams nchannels wrong");
    } else if (p.sampwidth != 2) {
        io::println("FAIL: SunAuReader.getparams sampwidth wrong");
    } else if (p.framerate != 8000) {
        io::println("FAIL: SunAuReader.getparams framerate wrong");
    } else {
        io::println("PASS: SunAuReader.getparams works");
    }
}

public fn test_sunaureader_markers(): void {
    let au: SunauAudio = new SunauAudio();
    let r: SunAuReader = new SunAuReader(au, "dummy");
    let m: Variant = r.getmarkers();
    if (m != null) {
        io::println("FAIL: SunAuReader.getmarkers should be null");
    } else {
        let g: Variant = r.getmark(0);
        if (g != null) {
            io::println("FAIL: SunAuReader.getmark should be null");
        } else {
            io::println("PASS: SunAuReader markers work");
        }
    }
}

public fn test_sunaureader_rewind_setpos(): void {
    let au: SunauAudio = new SunauAudio();
    au.encoding = 3;
    au.channels = 1;
    au.dataSize = 4;
    var i: int = 0;
    while (i < 4) { au.samples.add(0); i = i + 1; }
    let r: SunAuReader = new SunAuReader(au, "dummy");
    r.readframes(2);
    if (r.tell() != 2) {
        io::println("FAIL: SunAuReader tell wrong after read");
        return;
    }
    r.rewind();
    if (r.tell() != 0) {
        io::println("FAIL: SunAuReader rewind wrong");
        return;
    }
    // nframes=2 (dataSize=4, sampwidth=2, channels=1) so setpos(3) clamps to 2.
    r.setpos(3);
    if (r.tell() != 2) {
        io::println("FAIL: SunAuReader setpos wrong");
        return;
    }
    r.setpos(-5);
    if (r.tell() != 0) {
        io::println("FAIL: SunAuReader setpos negative wrong");
        return;
    }
    r.setpos(1000);
    if (r.tell() != 2) {
        io::println("FAIL: SunAuReader setpos large wrong");
        return;
    }
    io::println("PASS: SunAuReader rewind/setpos work");
}

public fn test_sunaureader_readframes(): void {
    let au: SunauAudio = new SunauAudio();
    au.encoding = 3;
    au.channels = 1;
    au.dataSize = 8;
    var i: int = 0;
    while (i < 8) { au.samples.add(i); i = i + 1; }
    let r: SunAuReader = new SunAuReader(au, "dummy");
    let bytes: ArrayList<int> = r.readframes(2);
    if (bytes.size() != 4) {
        io::println("FAIL: SunAuReader readframes size wrong=" + Integer.toString(bytes.size()));
    } else if (bytes.get(0) != 0 || bytes.get(3) != 3) {
        io::println("FAIL: SunAuReader readframes values wrong");
    } else {
        io::println("PASS: SunAuReader readframes works");
    }
}

public fn test_sunaureader_close(): void {
    let au: SunauAudio = new SunauAudio();
    let r: SunAuReader = new SunAuReader(au, "dummy");
    r.close();
    let bytes: ArrayList<int> = r.readframes(10);
    if (bytes.size() != 0) {
        io::println("FAIL: SunAuReader after close readframes should be empty");
    } else {
        io::println("PASS: SunAuReader close works");
    }
}

public fn run_all_sunau_tests(): void {
    io::println("=== Sunau.tr Tests ===");
    test_sunauaudio_defaults();
    test_sampwidth_all_encodings();
    test_comptype_ulaw();
    test_comptype_float();
    test_comptype_double();
    test_comptype_none();
    test_nframes_known_size();
    test_nframes_unknown_size();
    test_nframes_stereo();
    test_read_missing_file();
    test_open_write_mode();
    test_open_read_missing_file();
    test_open_unknown_mode();
    test_write_and_read_roundtrip();
    test_writeAudioBuffer_creates_file();
    test_readAudioBuffer_missing_file();
    test_audioparams_init();
    test_sunauwriter_defaults();
    test_sunauwriter_setsampwidth();
    test_sunauwriter_setcomptype();
    test_sunauwriter_writeframesraw();
    test_sunauwriter_writeframes();
    test_sunaureader_getparams();
    test_sunaureader_markers();
    test_sunaureader_rewind_setpos();
    test_sunaureader_readframes();
    test_sunaureader_close();
}
