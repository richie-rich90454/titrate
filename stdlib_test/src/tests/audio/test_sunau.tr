// Test file for audio/Sunau.tr
// Exercises the public API: SunauAudio class, AudioParams, SunAuReader,
// SunAuWriter, read/write, open(), readAudioBuffer, writeAudioBuffer.
// Note: Uses literal encoding values (1=ULAW,2=L8,3=L16,4=L24,5=L32,6=F32,7=F64)
// because public const exports from Sunau.tr are not visible to importers.
import tt::audio::Sunau;
import tt::audio::AudioBuffer;
import tt::util::ArrayList;
import tt::lang::Integer;

public fn test_sunauaudio_defaults(): void {
    let au: SunauAudio = new SunauAudio();
    if (au.dataOffset != 24) {
        io::println("FAIL: SunauAudio.dataOffset default wrong");
    } else if (au.dataSize != -1) {
        io::println("FAIL: SunauAudio.dataSize default wrong");
    } else if (au.encoding != 3) {
        io::println("FAIL: SunauAudio.encoding default wrong");
    } else if (au.sampleRate != 8000) {
        io::println("FAIL: SunauAudio.sampleRate default wrong");
    } else if (au.channels != 1) {
        io::println("FAIL: SunauAudio.channels default wrong");
    } else if (au.info != "") {
        io::println("FAIL: SunauAudio.info default wrong");
    } else if (au.samples.size() != 0) {
        io::println("FAIL: SunauAudio.samples default wrong");
    } else {
        io::println("PASS: SunauAudio defaults work");
    }
}

public fn test_sampwidth_all_encodings(): void {
    let au: SunauAudio = new SunauAudio();
    au.encoding = 1; // ULAW
    if (au.sampwidth() != 1) {
        io::println("FAIL: sampwidth ulaw should be 1");
        return;
    }
    au.encoding = 2; // LINEAR_8
    if (au.sampwidth() != 1) {
        io::println("FAIL: sampwidth linear8 should be 1");
        return;
    }
    au.encoding = 3; // LINEAR_16
    if (au.sampwidth() != 2) {
        io::println("FAIL: sampwidth linear16 should be 2");
        return;
    }
    au.encoding = 4; // LINEAR_24
    if (au.sampwidth() != 3) {
        io::println("FAIL: sampwidth linear24 should be 3");
        return;
    }
    au.encoding = 5; // LINEAR_32
    if (au.sampwidth() != 4) {
        io::println("FAIL: sampwidth linear32 should be 4");
        return;
    }
    au.encoding = 6; // FLOAT_32
    if (au.sampwidth() != 4) {
        io::println("FAIL: sampwidth float32 should be 4");
        return;
    }
    au.encoding = 7; // FLOAT_64
    if (au.sampwidth() != 8) {
        io::println("FAIL: sampwidth float64 should be 8");
        return;
    }
    io::println("PASS: sampwidth all encodings work");
}

public fn test_comptype_ulaw(): void {
    let au: SunauAudio = new SunauAudio();
    au.encoding = 1;
    if (au.comptype() != "ULAW") {
        io::println("FAIL: comptype ULAW wrong");
    } else if (au.compname() != "CCITT G.711 mulaw") {
        io::println("FAIL: compname ULAW wrong");
    } else {
        io::println("PASS: comptype/compname ULAW work");
    }
}

