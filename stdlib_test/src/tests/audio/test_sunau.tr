public fn test_write_and_read_roundtrip(): void {
    let au: SunauAudio = new SunauAudio();
    au.encoding = 3;
    au.sampleRate = 8000;
    au.channels = 1;
    au.info = "test";
    au.samples.add(0x00);
    au.samples.add(0x00);
    au.samples.add(0x00);
    au.samples.add(0x10);
    let path: string = "test_sunau_roundtrip.au";
    write(path, au);
    let reread: SunauAudio = read(path);
    if (reread.channels != 1) {
        io::println("FAIL: roundtrip channels wrong");
    } else if (reread.sampleRate != 8000) {
        io::println("FAIL: roundtrip sampleRate wrong");
    } else if (reread.encoding != 3) {
        io::println("FAIL: roundtrip encoding wrong");
    } else if (reread.info != "test") {
        io::println("FAIL: roundtrip info wrong");
    } else if (reread.samples.size() != 4) {
        io::println("FAIL: roundtrip samples size wrong");
    } else {
        io::println("PASS: write+read roundtrip works");
    }
}

public fn test_writeAudioBuffer_creates_file(): void {
    let buf: AudioBuffer = new AudioBuffer(8000, 1);
    var i: int = 0;
    while (i < 50) {
        let frame: ArrayList<double> = new ArrayList<double>();
        frame.add(0.0);
        buf.addFrame(frame);
        i = i + 1;
    }
    let path: string = "test_sunau_write_buffer.au";
    writeAudioBuffer(path, buf);
    let au: SunauAudio = read(path);
    if (au.channels != 1) {
        io::println("FAIL: writeAudioBuffer channels wrong");
    } else if (au.sampleRate != 8000) {
        io::println("FAIL: writeAudioBuffer sampleRate wrong");
    } else if (au.encoding != 3) {
        io::println("FAIL: writeAudioBuffer encoding wrong");
    } else if (au.nframes() != 50) {
        io::println("FAIL: writeAudioBuffer nframes wrong=" + Integer.toString(au.nframes()));
    } else {
        io::println("PASS: writeAudioBuffer creates file works");
    }
}

public fn test_readAudioBuffer_missing_file(): void {
    let buf: AudioBuffer = readAudioBuffer("nonexistent_sunau_readbuf_test.au");
    if (buf == null) {
        io::println("FAIL: readAudioBuffer missing file returns null");
    } else if (buf.numFrames() != 0) {
        io::println("FAIL: readAudioBuffer missing file should be empty");
    } else {
        io::println("PASS: readAudioBuffer missing file works");
    }
}

public fn test_audioparams_init(): void {
    let p: AudioParams = new AudioParams(2, 2, 44100, 100, "NONE", "not compressed");
    if (p.nchannels != 2) {
        io::println("FAIL: AudioParams.nchannels wrong");
    } else if (p.sampwidth != 2) {
        io::println("FAIL: AudioParams.sampwidth wrong");
    } else if (p.framerate != 44100) {
        io::println("FAIL: AudioParams.framerate wrong");
    } else if (p.nframes != 100) {
        io::println("FAIL: AudioParams.nframes wrong");
    } else if (p.comptype != "NONE") {
        io::println("FAIL: AudioParams.comptype wrong");
    } else if (p.compname != "not compressed") {
        io::println("FAIL: AudioParams.compname wrong");
    } else {
        io::println("PASS: AudioParams.init works");
    }
}

public fn test_sunauwriter_defaults(): void {
    let w: SunAuWriter = new SunAuWriter("dummy_sunau_writer_test.au");
