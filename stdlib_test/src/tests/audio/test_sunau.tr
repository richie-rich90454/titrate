        io::println("PASS: SunAuWriter defaults work");
    }
}

public fn test_sunauwriter_setsampwidth(): void {
    let w: SunAuWriter = new SunAuWriter("dummy_sunau_writer_sw.au");
    w.setsampwidth(1);
    if (w.getsampwidth() != 1) {
        io::println("FAIL: SunAuWriter setsampwidth 1 wrong");
        return;
    }
    w.setsampwidth(3);
    if (w.getsampwidth() != 3) {
        io::println("FAIL: SunAuWriter setsampwidth 3 wrong");
        return;
    }
    w.setsampwidth(4);
    if (w.getsampwidth() != 4) {
        io::println("FAIL: SunAuWriter setsampwidth 4 wrong");
        return;
    }
    io::println("PASS: SunAuWriter setsampwidth works");
}

public fn test_sunauwriter_setcomptype(): void {
    let w: SunAuWriter = new SunAuWriter("dummy_sunau_writer_ct.au");
    w.setcomptype("ULAW", "");
    if (w.getcomptype() != "ULAW") {
        io::println("FAIL: SunAuWriter setcomptype ULAW wrong");
        return;
    }
    w.setcomptype("FLOAT", "");
    if (w.getcomptype() != "FLOAT") {
        io::println("FAIL: SunAuWriter setcomptype FLOAT wrong");
        return;
    }
    w.setcomptype("DOUBLE", "");
    if (w.getcomptype() != "DOUBLE") {
        io::println("FAIL: SunAuWriter setcomptype DOUBLE wrong");
        return;
    }
    w.setcomptype("NONE", "");
    if (w.getcomptype() != "NONE") {
        io::println("FAIL: SunAuWriter setcomptype NONE wrong");
        return;
    }
    io::println("PASS: SunAuWriter setcomptype works");
}

public fn test_sunauwriter_writeframesraw(): void {
    let w: SunAuWriter = new SunAuWriter("test_sunau_writer_raw.au");
    w.setnchannels(1);
    w.setsampwidth(2);
    w.setframerate(8000);
    let data: ArrayList<int> = new ArrayList<int>();
    data.add(0x00); data.add(0x10);
    data.add(0x00); data.add(0x20);
    w.writeframesraw(data);
    if (w.tell() != 2) {
        io::println("FAIL: SunAuWriter writeframesraw tell wrong");
        return;
    }
    w.close();
    let au: SunauAudio = read("test_sunau_writer_raw.au");
    if (au.nframes() != 2) {
        io::println("FAIL: SunAuWriter writeframesraw nframes wrong");
    } else {
        io::println("PASS: SunAuWriter writeframesraw works");
    }
}

public fn test_sunauwriter_writeframes(): void {
    let w: SunAuWriter = new SunAuWriter("test_sunau_writer_frames.au");
    w.setnchannels(1);
