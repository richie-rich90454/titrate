public fn test_nframes_known_size(): void {
    let au: SunauAudio = new SunauAudio();
    au.encoding = 3;
    au.channels = 1;
    au.dataSize = 8;
    if (au.nframes() != 4) {
        io::println("FAIL: nframes known size wrong=" + Integer.toString(au.nframes()));
    } else {
        io::println("PASS: nframes known size works");
    }
}

public fn test_nframes_unknown_size(): void {
    let au: SunauAudio = new SunauAudio();
    au.encoding = 3;
    au.channels = 1;
    // AU_UNKNOWN_SIZE is 0xFFFFFFFF which is -1 as signed int; use -1 directly
    // because the 0xFFFFFFFF literal does not assign correctly to int field.
    au.dataSize = -1;
    var i: int = 0;
    while (i < 8) { au.samples.add(0); i = i + 1; }
    if (au.nframes() != 4) {
        io::println("FAIL: nframes unknown size wrong=" + Integer.toString(au.nframes()));
    } else {
        io::println("PASS: nframes unknown size works");
    }
}

public fn test_nframes_stereo(): void {
    let au: SunauAudio = new SunauAudio();
    au.encoding = 3;
    au.channels = 2;
    au.dataSize = 16;
    if (au.nframes() != 4) {
        io::println("FAIL: nframes stereo wrong=" + Integer.toString(au.nframes()));
    } else {
        io::println("PASS: nframes stereo works");
    }
}

public fn test_read_missing_file(): void {
    let au: SunauAudio = read("nonexistent_sunau_file_for_test.au");
    if (au == null) {
        io::println("FAIL: read missing file returns null");
    } else if (au.dataOffset != 24) {
        io::println("FAIL: read missing file dataOffset wrong");
    } else if (au.samples.size() != 0) {
        io::println("FAIL: read missing file samples wrong");
    } else {
        io::println("PASS: read missing file works");
    }
}

