// Test file for audio/Aifc.tr
// Exercises the public API: AifcAudio class, read, write, open, writeAudioBuffer, readAudioBuffer.
import tt::audio::Aifc;
import tt::audio::AudioBuffer;
import tt::util::ArrayList;
import tt::lang::Integer;

public fn test_aifcaudio_defaults(): void {
    let a: AifcAudio = new AifcAudio();
    if (a.formType != "AIFF") {
        io::println("FAIL: AifcAudio.formType default wrong");
    } else if (a.channels != 1) {
        io::println("FAIL: AifcAudio.channels default wrong");
    } else if (a.numFrames != 0) {
        io::println("FAIL: AifcAudio.numFrames default wrong");
    } else if (a.sampleSize != 16) {
        io::println("FAIL: AifcAudio.sampleSize default wrong");
    } else if (a.sampleRate != 44100.0) {
        io::println("FAIL: AifcAudio.sampleRate default wrong");
    } else if (a.compType != "NONE") {
        io::println("FAIL: AifcAudio.compType default wrong");
    } else if (a.compName != "") {
        io::println("FAIL: AifcAudio.compName default wrong");
    } else if (a.ssndOffset != 0) {
        io::println("FAIL: AifcAudio.ssndOffset default wrong");
    } else if (a.ssndBlockSize != 0) {
        io::println("FAIL: AifcAudio.ssndBlockSize default wrong");
    } else if (a.samples.size() != 0) {
        io::println("FAIL: AifcAudio.samples default wrong");
    } else {
        io::println("PASS: AifcAudio defaults work");
    }
}

public fn test_sampwidth_16bit(): void {
    let a: AifcAudio = new AifcAudio();
    a.sampleSize = 16;
    if (a.sampwidth() != 2) {
        io::println("FAIL: sampwidth 16bit should be 2 bytes");
    } else {
        io::println("PASS: sampwidth 16bit works");
    }
}

