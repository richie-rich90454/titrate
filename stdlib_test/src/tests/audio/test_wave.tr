}

public fn test_write_and_read_roundtrip(): void {
    let w: Wave_write = new Wave_write("test_wave_roundtrip.wav");
    w.setnchannels(1);
    w.setsampwidth(2);
    w.setframerate(8000);
    let data: ArrayList<int> = new ArrayList<int>();
    data.add(0x00); data.add(0x10);
    data.add(0x00); data.add(0x20);
    data.add(0x00); data.add(0x30);
    data.add(0x00); data.add(0x40);
    w.writeframes(data);
    w.close();
    let r: Wave_read = new Wave_read("test_wave_roundtrip.wav");
    if (r.getnchannels() != 1) {
        io::println("FAIL: roundtrip nchannels wrong");
    } else if (r.getsampwidth() != 2) {
        io::println("FAIL: roundtrip sampwidth wrong");
    } else if (r.getframerate() != 8000) {
        io::println("FAIL: roundtrip framerate wrong");
    } else if (r.getnframes() != 4) {
        io::println("FAIL: roundtrip nframes wrong=" + Integer.toString(r.getnframes()));
    } else if (r.getcomptype() != "NONE") {
        io::println("FAIL: roundtrip comptype wrong");
    } else {
        io::println("PASS: write+read roundtrip works");
    }
}

public fn test_readframes_partial(): void {
    let w: Wave_write = new Wave_write("test_wave_readframes.wav");
    w.setnchannels(1);
    w.setsampwidth(2);
    w.setframerate(8000);
    let data: ArrayList<int> = new ArrayList<int>();
    var i: int = 0;
    while (i < 8) { data.add(i); i = i + 1; }
    w.writeframes(data);
    w.close();
    let r: Wave_read = new Wave_read("test_wave_readframes.wav");
    let bytes: ArrayList<int> = r.readframes(2);
    if (bytes.size() != 4) {
        io::println("FAIL: readframes partial size wrong=" + Integer.toString(bytes.size()));
    } else if (bytes.get(0) != 0 || bytes.get(3) != 3) {
        io::println("FAIL: readframes partial values wrong");
    } else if (r.tell() != 2) {
        io::println("FAIL: readframes partial tell wrong");
    } else {
        io::println("PASS: readframes partial works");
    }
}

public fn test_readframes_beyond_end(): void {
    let w: Wave_write = new Wave_write("test_wave_readframes_end.wav");
    w.setnchannels(1);
    w.setsampwidth(2);
    w.setframerate(8000);
    let data: ArrayList<int> = new ArrayList<int>();
    data.add(0x00); data.add(0x10);
    data.add(0x00); data.add(0x20);
    w.writeframes(data);
    w.close();
    let r: Wave_read = new Wave_read("test_wave_readframes_end.wav");
    let bytes: ArrayList<int> = r.readframes(100);
    if (bytes.size() != 4) {
        io::println("FAIL: readframes beyond end size wrong=" + Integer.toString(bytes.size()));
    } else {
        io::println("PASS: readframes beyond end works");
    }
}

public fn test_readframes_after_rewind(): void {
    let w: Wave_write = new Wave_write("test_wave_rewind.wav");
    w.setnchannels(1);
    w.setsampwidth(2);
    w.setframerate(8000);
    let data: ArrayList<int> = new ArrayList<int>();
    data.add(0x00); data.add(0x10);
    data.add(0x00); data.add(0x20);
    w.writeframes(data);
    w.close();
    let r: Wave_read = new Wave_read("test_wave_rewind.wav");
    r.readframes(2);
    if (r.tell() != 2) {
        io::println("FAIL: readframes after rewind tell pre wrong");
        return;
    }
    r.rewind();
    if (r.tell() != 0) {
        io::println("FAIL: readframes after rewind tell wrong");
        return;
    }
    let bytes: ArrayList<int> = r.readframes(1);
    if (bytes.size() != 2) {
        io::println("FAIL: readframes after rewind size wrong");
    } else {
        io::println("PASS: readframes after rewind works");
    }
}

public fn test_setpos_and_read(): void {
    let w: Wave_write = new Wave_write("test_wave_setpos.wav");
    w.setnchannels(1);
    w.setsampwidth(2);
    w.setframerate(8000);
    let data: ArrayList<int> = new ArrayList<int>();
    var i: int = 0;
    while (i < 8) { data.add(i * 2); i = i + 1; }
    w.writeframes(data);
    w.close();
    let r: Wave_read = new Wave_read("test_wave_setpos.wav");
    r.setpos(2);
    if (r.tell() != 2) {
        io::println("FAIL: setpos tell wrong");
        return;
    }
    let bytes: ArrayList<int> = r.readframes(1);
    if (bytes.size() != 2) {
        io::println("FAIL: setpos read size wrong");
    } else if (bytes.get(0) != 8 || bytes.get(1) != 10) {
        io::println("FAIL: setpos read values wrong");
    } else {
        io::println("PASS: setpos and read works");
    }
}

public fn test_getparams(): void {
    let w: Wave_write = new Wave_write("test_wave_getparams.wav");
    w.setnchannels(2);
    w.setsampwidth(2);
    w.setframerate(44100);
    let data: ArrayList<int> = new ArrayList<int>();
    data.add(0x00); data.add(0x10);
    data.add(0x00); data.add(0x20);
    data.add(0x00); data.add(0x30);
    data.add(0x00); data.add(0x40);
    w.writeframes(data);
    w.close();
    let r: Wave_read = new Wave_read("test_wave_getparams.wav");
    let p: ArrayList<Variant> = r.getparams();
    if (p.size() != 6) {
        io::println("FAIL: getparams size wrong");
    } else if (p.get(0) as int != 2) {
        io::println("FAIL: getparams nchannels wrong");
    } else if (p.get(1) as int != 2) {
        io::println("FAIL: getparams sampwidth wrong");
    } else if (p.get(2) as int != 44100) {
        io::println("FAIL: getparams framerate wrong");
    } else if (p.get(4) as string != "NONE") {
        io::println("FAIL: getparams comptype wrong");
    } else {
        io::println("PASS: getparams works");
    }
}

public fn test_write_audio_buffer(): void {
    let buf: AudioBuffer = new AudioBuffer(8000, 1);
    var i: int = 0;
    while (i < 50) {
        let frame: ArrayList<double> = new ArrayList<double>();
        frame.add(0.0);
        buf.addFrame(frame);
        i = i + 1;
    }
    let path: string = "test_wave_write_buffer.wav";
    writeAudioBuffer(path, buf);
    let r: Wave_read = new Wave_read(path);
    if (r.getnchannels() != 1) {
        io::println("FAIL: writeAudioBuffer nchannels wrong");
    } else if (r.getsampwidth() != 2) {
        io::println("FAIL: writeAudioBuffer sampwidth wrong");
    } else if (r.getframerate() != 8000) {
        io::println("FAIL: writeAudioBuffer framerate wrong");
    } else if (r.getnframes() != 50) {
        io::println("FAIL: writeAudioBuffer nframes wrong=" + Integer.toString(r.getnframes()));
    } else {
        io::println("PASS: writeAudioBuffer works");
    }
}

public fn test_read_audio_buffer_missing_file(): void {
    let buf: AudioBuffer = readAudioBuffer("nonexistent_wave_readbuf_test.wav");
    if (buf == null) {
        io::println("FAIL: readAudioBuffer missing file returns null");
    } else if (buf.numFrames() != 0) {
        io::println("FAIL: readAudioBuffer missing file should be empty");
    } else {
        io::println("PASS: readAudioBuffer missing file works");
    }
}

public fn test_read_audio_buffer_roundtrip(): void {
    let buf: AudioBuffer = new AudioBuffer(8000, 1);
    var i: int = 0;
    while (i < 10) {
        let frame: ArrayList<double> = new ArrayList<double>();
        frame.add(0.5);
        buf.addFrame(frame);
        i = i + 1;
    }
    let path: string = "test_wave_readbuf_roundtrip.wav";
    writeAudioBuffer(path, buf);
    let reread: AudioBuffer = readAudioBuffer(path);
    if (reread.numFrames() != 10) {
        io::println("FAIL: readAudioBuffer roundtrip frames wrong=" + Integer.toString(reread.numFrames()));
    } else if (reread.sampleRate != 8000) {
        io::println("FAIL: readAudioBuffer roundtrip sampleRate wrong");
    } else if (reread.channels != 1) {
        io::println("FAIL: readAudioBuffer roundtrip channels wrong");
    } else {
        io::println("PASS: readAudioBuffer roundtrip works");
    }
}

public fn test_setcomptype_float(): void {
    let w: Wave_write = new Wave_write("test_wave_comptype_float.wav");
    w.setnchannels(1);
    w.setsampwidth(4);
    w.setframerate(8000);
    w.setcomptype("FLOAT", "");
    let data: ArrayList<int> = new ArrayList<int>();
    data.add(0x00); data.add(0x00); data.add(0x80); data.add(0x3F);
    data.add(0x00); data.add(0x00); data.add(0x80); data.add(0xBF);
    w.writeframes(data);
    w.close();
    let r: Wave_read = new Wave_read("test_wave_comptype_float.wav");
    if (r.getcomptype() != "FLOAT") {
        io::println("FAIL: setcomptype FLOAT comptype wrong");
    } else if (r.getcompname() != "IEEE float") {
        io::println("FAIL: setcomptype FLOAT compname wrong");
    } else {
        io::println("PASS: setcomptype FLOAT works");
    }
}

public fn test_setcomptype_alaw(): void {
    let w: Wave_write = new Wave_write("test_wave_comptype_alaw.wav");
    w.setnchannels(1);
    w.setsampwidth(1);
    w.setframerate(8000);
    w.setcomptype("ALAW", "");
    let data: ArrayList<int> = new ArrayList<int>();
    data.add(0xD5);
    data.add(0x55);
    w.writeframes(data);
    w.close();
    let r: Wave_read = new Wave_read("test_wave_comptype_alaw.wav");
    if (r.getcomptype() != "ALAW") {
        io::println("FAIL: setcomptype ALAW comptype wrong");
    } else if (r.getcompname() != "CCITT G.711 a-law") {
        io::println("FAIL: setcomptype ALAW compname wrong");
    } else {
        io::println("PASS: setcomptype ALAW works");
    }
}

