// Test file for audio/Wave.tr
// Exercises the public API: Wave_read, Wave_write, open, readAudioBuffer,
// writeAudioBuffer. Uses literal format codes (1=PCM,3=IEEE_FLOAT,6=ALAW,7=MULAW)
// because public const exports from Wave.tr are not visible to importers.
import tt::audio::Wave;
import tt::audio::AudioBuffer;
import tt::util::ArrayList;
import tt::lang::Integer;

public fn test_wave_read_missing_file(): void {
    let r: Wave_read = new Wave_read("nonexistent_wave_file_for_test.wav");
    if (r.getnchannels() != 0) {
        io::println("FAIL: Wave_read missing file nchannels wrong");
    } else if (r.getsampwidth() != 0) {
        io::println("FAIL: Wave_read missing file sampwidth wrong");
    } else if (r.getframerate() != 0) {
        io::println("FAIL: Wave_read missing file framerate wrong");
    } else if (r.getnframes() != 0) {
        io::println("FAIL: Wave_read missing file nframes wrong");
    } else if (r.getcomptype() != "NONE") {
        io::println("FAIL: Wave_read missing file comptype wrong");
    } else if (r.getcompname() != "not compressed") {
        io::println("FAIL: Wave_read missing file compname wrong");
    } else {
        io::println("PASS: Wave_read missing file works");
    }
}

public fn test_wave_read_markers(): void {
    let r: Wave_read = new Wave_read("nonexistent_wave_markers_test.wav");
    let m: Variant = r.getmarkers();
    if (m != null) {
        io::println("FAIL: Wave_read.getmarkers should be null");
    } else {
        let g: Variant = r.getmark(0);
        if (g != null) {
            io::println("FAIL: Wave_read.getmark should be null");
        } else {
            io::println("PASS: Wave_read markers work");
        }
    }
}

public fn test_wave_read_close(): void {
    let r: Wave_read = new Wave_read("nonexistent_wave_close_test.wav");
    r.close();
    let bytes: ArrayList<int> = r.readframes(10);
    if (bytes.size() != 0) {
        io::println("FAIL: Wave_read after close readframes should be empty");
    } else {
        io::println("PASS: Wave_read close works");
    }
}

public fn test_wave_read_rawbytes_empty(): void {
    let r: Wave_read = new Wave_read("nonexistent_wave_rawbytes_test.wav");
    let raw: ArrayList<int> = r.rawBytes();
    if (raw.size() != 0) {
        io::println("FAIL: Wave_read rawBytes should be empty for missing file");
    } else {
        io::println("PASS: Wave_read rawBytes empty works");
    }
}

public fn test_wave_read_rewind_setpos_tell(): void {
    let r: Wave_read = new Wave_read("nonexistent_wave_seek_test.wav");
    if (r.tell() != 0) {
        io::println("FAIL: Wave_read tell initial wrong");
        return;
    }
    r.rewind();
    if (r.tell() != 0) {
        io::println("FAIL: Wave_read rewind wrong");
        return;
    }
    r.setpos(100);
    if (r.tell() != 0) {
        io::println("FAIL: Wave_read setpos beyond nframes should stay 0");
        return;
    }
    r.setpos(-5);
    if (r.tell() != 0) {
        io::println("FAIL: Wave_read setpos negative wrong");
        return;
    }
    io::println("PASS: Wave_read rewind/setpos/tell work");
}

public fn test_wave_write_defaults(): void {
    let w: Wave_write = new Wave_write("dummy_wave_write_test.wav");
    if (w.isClosed()) {
        io::println("FAIL: Wave_write should not be closed by default");
    } else {
        io::println("PASS: Wave_write defaults work");
    }
}

public fn test_wave_write_close(): void {
    let w: Wave_write = new Wave_write("dummy_wave_close_test.wav");
    w.close();
    if (!w.isClosed()) {
        io::println("FAIL: Wave_write should be closed after close");
    } else {
        w.close();
        io::println("PASS: Wave_write close works");
    }
}

