    let w: Wave_write = new Wave_write("test_wave_comptype_ulaw.wav");
    w.setnchannels(1);
    w.setsampwidth(1);
    w.setframerate(8000);
    w.setcomptype("ULAW", "");
    let data: ArrayList<int> = new ArrayList<int>();
    data.add(0xFF);
    data.add(0x7F);
    w.writeframes(data);
    w.close();
    let r: Wave_read = new Wave_read("test_wave_comptype_ulaw.wav");
    if (r.getcomptype() != "ULAW") {
        io::println("FAIL: setcomptype ULAW comptype wrong");
    } else if (r.getcompname() != "CCITT G.711 mu-law") {
        io::println("FAIL: setcomptype ULAW compname wrong");
    } else {
        io::println("PASS: setcomptype ULAW works");
    }
}

public fn test_stereo_roundtrip(): void {
    let w: Wave_write = new Wave_write("test_wave_stereo.wav");
    w.setnchannels(2);
    w.setsampwidth(2);
    w.setframerate(44100);
    let data: ArrayList<int> = new ArrayList<int>();
    data.add(0x00); data.add(0x10);
    data.add(0x00); data.add(0x20);
    data.add(0x00); data.add(0x30);
    data.add(0x00); data.add(0x40);
    w.writeframes(data);
    w.close();
    let r: Wave_read = new Wave_read("test_wave_stereo.wav");
    if (r.getnchannels() != 2) {
        io::println("FAIL: stereo nchannels wrong");
    } else if (r.getnframes() != 2) {
        io::println("FAIL: stereo nframes wrong=" + Integer.toString(r.getnframes()));
    } else {
        let bytes: ArrayList<int> = r.readframes(1);
        if (bytes.size() != 4) {
            io::println("FAIL: stereo readframes size wrong=" + Integer.toString(bytes.size()));
        } else {
            io::println("PASS: stereo roundtrip works");
        }
    }
}

public fn test_setparams(): void {
    let w: Wave_write = new Wave_write("test_wave_setparams.wav");
    let params: ArrayList<Variant> = new ArrayList<Variant>();
    params.add(2 as Variant);
    params.add(2 as Variant);
    params.add(44100 as Variant);
    params.add(100 as Variant);
    params.add("NONE" as Variant);
    params.add("not compressed" as Variant);
    w.setparams(params);
    let data: ArrayList<int> = new ArrayList<int>();
    data.add(0x00); data.add(0x10);
    data.add(0x00); data.add(0x20);
    w.writeframes(data);
    w.close();
    let r: Wave_read = new Wave_read("test_wave_setparams.wav");
    if (r.getnchannels() != 2) {
        io::println("FAIL: setparams nchannels wrong");
    } else if (r.getframerate() != 44100) {
        io::println("FAIL: setparams framerate wrong");
    } else {
        io::println("PASS: setparams works");
    }
}

public fn run_all_wave_tests(): void {
    io::println("=== Wave.tr Tests ===");
    test_wave_read_missing_file();
    test_wave_read_markers();
    test_wave_read_close();
    test_wave_read_rawbytes_empty();
    test_wave_read_rewind_setpos_tell();
    test_wave_write_defaults();
    test_wave_write_close();
    test_wave_write_tell_empty();
    test_wave_write_writeframesraw_tell();
    test_open_write_mode();
    test_open_read_mode();
    test_open_rb_wb_modes();
    test_open_unknown_mode();
    test_write_and_read_roundtrip();
    test_readframes_partial();
    test_readframes_beyond_end();
    test_readframes_after_rewind();
    test_setpos_and_read();
    test_getparams();
    test_write_audio_buffer();
    test_read_audio_buffer_missing_file();
    test_read_audio_buffer_roundtrip();
    test_setcomptype_float();
    test_setcomptype_alaw();
    test_setcomptype_ulaw();
    test_stereo_roundtrip();
    test_setparams();
}
