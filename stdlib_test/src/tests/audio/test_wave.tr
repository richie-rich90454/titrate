    let w: Wave_write = new Wave_write("dummy_wave_tell_test.wav");
    if (w.tell() != 0) {
        io::println("FAIL: Wave_write tell should be 0 for empty");
    } else {
        io::println("PASS: Wave_write tell empty works");
    }
}

public fn test_wave_write_writeframesraw_tell(): void {
    let w: Wave_write = new Wave_write("dummy_wave_raw_test.wav");
    w.setnchannels(1);
    w.setsampwidth(2);
    let data: ArrayList<int> = new ArrayList<int>();
    data.add(0x00); data.add(0x10);
    data.add(0x00); data.add(0x20);
    w.writeframesraw(data);
    if (w.tell() != 2) {
        io::println("FAIL: Wave_write writeframesraw tell wrong");
    } else {
        io::println("PASS: Wave_write writeframesraw tell works");
    }
}

