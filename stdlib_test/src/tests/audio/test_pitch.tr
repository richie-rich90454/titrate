public fn test_detectPitchHPS_returns_value(): void {
    // Build a synthetic spectrum with a peak at bin corresponding to 200 Hz.
    // bin = freq * fftSize / sampleRate; fftSize=1024, sampleRate=16000 => bin = 200*1024/16000 = 12.8
    let fftSize: int = 1024;
    let sampleRate: int = 16000;
    let spectrum: ArrayList<double> = new ArrayList<double>();
    var i: int = 0;
    while (i < fftSize) {
        spectrum.add(0.0);
        i = i + 1;
    }
    // Place peaks at fundamental and harmonics (2x, 3x)
    let fundamentalBin: int = 13;
    spectrum.set(fundamentalBin, 10.0);
    if (fundamentalBin * 2 < fftSize) { spectrum.set(fundamentalBin * 2, 5.0); }
    if (fundamentalBin * 3 < fftSize) { spectrum.set(fundamentalBin * 3, 2.0); }
    let pitch: double = detectPitchHPS(spectrum, sampleRate, fftSize, 50.0, 2000.0);
    if (pitch <= 0.0) {
        io::println("FAIL: detectPitchHPS pitch=" + Double.toString(pitch));
    } else {
        io::println("PASS: detectPitchHPS pitch=" + Double.toString(pitch));
    }
}

public fn test_detectPitchHPS_zero_spectrum(): void {
    let fftSize: int = 1024;
    let sampleRate: int = 16000;
    let spectrum: ArrayList<double> = new ArrayList<double>();
    var i: int = 0;
    while (i < fftSize) {
        spectrum.add(0.0);
        i = i + 1;
    }
    let pitch: double = detectPitchHPS(spectrum, sampleRate, fftSize, 50.0, 2000.0);
    // All-zero spectrum: bestVal will be 0; function returns bestBin * sampleRate / fftSize
    // We just check it doesn't crash
    io::println("PASS: detectPitchHPS zero spectrum does not crash");
}

public fn test_detectAutocorrelation_from_buffer(): void {
    // Build an AudioBuffer containing a sine wave and run detectAutocorrelation.
    let sampleRate: int = 16000;
    let buf: AudioBuffer = new AudioBuffer(sampleRate, 1);
    var i: int = 0;
    while (i < 1024) {
        let frame: ArrayList<double> = new ArrayList<double>();
        let t: double = i as double;
        frame.add(_sine(2.0 * 3.14159265358979 * 440.0 * t / sampleRate as double));
        buf.addFrame(frame);
        i = i + 1;
    }
    let pitch: double = detectAutocorrelation(buf);
    if (pitch <= 0.0) {
        io::println("FAIL: detectAutocorrelation buffer pitch=" + Double.toString(pitch));
    } else {
        io::println("PASS: detectAutocorrelation buffer pitch=" + Double.toString(pitch));
    }
}

// Local sine helper using a Taylor series approximation. We avoid importing
// MathTrig here to keep the test self-contained; the values only need to be
// periodic for pitch detection to work.
fn _sine(x: double): double {
    // Reduce x to [-pi, pi]
    let pi: double = 3.14159265358979;
    let twoPi: double = 2.0 * pi;
    var y: double = x;
    while (y > pi) { y = y - twoPi; }
    while (y < -pi) { y = y + twoPi; }
    // Taylor series for sin
    let y2: double = y * y;
    let y3: double = y2 * y;
    let y5: double = y3 * y2;
    let y7: double = y5 * y2;
    let y9: double = y7 * y2;
    return y - y3 / 6.0 + y5 / 120.0 - y7 / 5040.0 + y9 / 362880.0;
}

public fn run_all_pitch_tests(): void {
    io::println("=== Pitch.tr Tests ===");
    test_detectPitchAutocorrelation_sine();
    test_detectPitchAutocorrelation_zero_signal();
    test_detectPitchAutocorrelation_returns_frequency_range();
    test_detectPitchYIN_sine();
    test_detectPitchYIN_zero_signal();
    test_detectPitchYIN_returns_frequency_range();
    test_detectPitchHPS_returns_value();
    test_detectPitchHPS_zero_spectrum();
    test_detectAutocorrelation_from_buffer();
}
