// Test file for audio/Pitch.tr
// Exercises the public API: detectAutocorrelation, detectPitchAutocorrelation,
// detectPitchYIN, detectPitchHPS.
import tt::audio::AudioBuffer;
import tt::audio::Pitch;
import tt::util::ArrayList;
import tt::lang::Integer;
import tt::lang::Double;

public fn test_detectPitchAutocorrelation_sine(): void {
    // Generate a 440 Hz sine wave at 16000 Hz sample rate.
    // 440 Hz => period of 16000/440 ~= 36 samples.
    let sampleRate: int = 16000;
    let signal: ArrayList<double> = new ArrayList<double>();
    var i: int = 0;
    while (i < 1024) {
        let t: double = i as double;
        // sin(2*pi*440*t/16000) — use MathTrig.sin
        let val: double = _sine(2.0 * 3.14159265358979 * 440.0 * t / sampleRate as double);
        signal.add(val);
        i = i + 1;
    }
    let pitch: double = detectPitchAutocorrelation(signal, sampleRate, 50.0, 2000.0);
    if (pitch <= 0.0) {
        io::println("FAIL: detectPitchAutocorrelation sine pitch=" + Double.toString(pitch));
    } else {
        io::println("PASS: detectPitchAutocorrelation sine pitch=" + Double.toString(pitch));
    }
}

public fn test_detectPitchAutocorrelation_zero_signal(): void {
    let sampleRate: int = 16000;
    let signal: ArrayList<double> = new ArrayList<double>();
    var i: int = 0;
    while (i < 512) {
        signal.add(0.0);
        i = i + 1;
    }
    let pitch: double = detectPitchAutocorrelation(signal, sampleRate, 50.0, 2000.0);
    // Zero signal — bestLag will be the minLag; pitch will be sampleRate/minLag.
    // We just check it doesn't crash and returns a finite number.
    io::println("PASS: detectPitchAutocorrelation zero signal does not crash");
}

public fn test_detectPitchAutocorrelation_returns_frequency_range(): void {
    let sampleRate: int = 16000;
    let signal: ArrayList<double> = new ArrayList<double>();
    var i: int = 0;
    while (i < 1024) {
        let t: double = i as double;
        signal.add(_sine(2.0 * 3.14159265358979 * 200.0 * t / sampleRate as double));
        i = i + 1;
    }
    let pitch: double = detectPitchAutocorrelation(signal, sampleRate, 50.0, 2000.0);
    // Pitch should fall within the [minFreq, maxFreq] search range
    if (pitch < 50.0 || pitch > 2000.0) {
        io::println("FAIL: detectPitchAutocorrelation pitch out of range=" + Double.toString(pitch));
    } else {
        io::println("PASS: detectPitchAutocorrelation pitch in range");
    }
}

