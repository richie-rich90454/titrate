// Test file for algorithms/Algorithms.tr
// Exercises the public API: sort, stableSort, find, findIf, binarySearch,
// lowerBound, upperBound, count, countIf, transform, replace, remove, unique,
// reverse, rotate, shuffle, partition, minElement, maxElement, accumulate,
// gcd, lcm, clamp, merge, anyOf, allOf, noneOf, forEach, fill, iota, isSorted, equal.
import tt::algorithms::Algorithms;
import tt::util::ArrayList;
import tt::lang::Integer;

public fn test_sort_basic(): void {
    let data: ArrayList<int> = new ArrayList<int>();
    data.add(3); data.add(1); data.add(4); data.add(1); data.add(5);
    let result: ArrayList<int> = sort<int>(data);
    if (result.get(0) != 1 || result.get(4) != 5) {
        io::println("FAIL: sort basic");
    } else {
        io::println("PASS: sort basic");
    }
}

public fn test_sort_empty(): void {
    let data: ArrayList<int> = new ArrayList<int>();
    let result: ArrayList<int> = sort<int>(data);
    if (result.size() != 0) {
        io::println("FAIL: sort empty");
    } else {
        io::println("PASS: sort empty");
    }
}

public fn test_stableSort_basic(): void {
    let data: ArrayList<int> = new ArrayList<int>();
    data.add(3); data.add(1); data.add(4); data.add(1); data.add(5);
    let result: ArrayList<int> = stableSort<int>(data);
    if (result.get(0) != 1 || result.get(4) != 5) {
        io::println("FAIL: stableSort basic");
    } else {
        io::println("PASS: stableSort basic");
    }
}

public fn test_find_found(): void {
    let data: ArrayList<int> = new ArrayList<int>();
    data.add(3); data.add(1); data.add(4); data.add(1); data.add(5);
    let idx: int = find<int>(data, 4);
    if (idx != 2) {
        io::println("FAIL: find found idx=" + Integer.toString(idx));
    } else {
        io::println("PASS: find found");
    }
}

public fn test_find_notFound(): void {
    let data: ArrayList<int> = new ArrayList<int>();
    data.add(3); data.add(1); data.add(4);
    let idx: int = find<int>(data, 99);
    if (idx != -1) {
        io::println("FAIL: find notFound");
    } else {
        io::println("PASS: find notFound");
    }
}

public fn test_findIf_basic(): void {
    let data: ArrayList<int> = new ArrayList<int>();
    data.add(1); data.add(3); data.add(5); data.add(7);
    let idx: int = findIf<int>(data, fn(x: int): bool { return x > 4; });
    if (idx != 2) {
        io::println("FAIL: findIf basic idx=" + Integer.toString(idx));
    } else {
        io::println("PASS: findIf basic");
    }
}

public fn test_binarySearch_found(): void {
    let data: ArrayList<int> = new ArrayList<int>();
    data.add(1); data.add(3); data.add(5); data.add(7); data.add(9);
    let idx: int = binarySearch<int>(data, 5);
    if (idx != 2) {
        io::println("FAIL: binarySearch found idx=" + Integer.toString(idx));
    } else {
        io::println("PASS: binarySearch found");
    }
}

public fn test_binarySearch_notFound(): void {
    let data: ArrayList<int> = new ArrayList<int>();
    data.add(1); data.add(3); data.add(5); data.add(7); data.add(9);
    let idx: int = binarySearch<int>(data, 6);
    if (idx != -1) {
        io::println("FAIL: binarySearch notFound");
    } else {
        io::println("PASS: binarySearch notFound");
    }
}

