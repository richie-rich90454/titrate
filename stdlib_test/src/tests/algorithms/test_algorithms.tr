    let data: ArrayList<int> = new ArrayList<int>();
    data.add(1); data.add(3); data.add(3); data.add(5); data.add(7);
    let idx: int = lowerBound<int>(data, 3);
    if (idx != 1) {
        io::println("FAIL: lowerBound basic idx=" + Integer.toString(idx));
    } else {
        io::println("PASS: lowerBound basic");
    }
}

