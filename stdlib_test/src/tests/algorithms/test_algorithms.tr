    let data: ArrayList<int> = new ArrayList<int>();
    data.add(1); data.add(3); data.add(3); data.add(5); data.add(7);
    let idx: int = upperBound<int>(data, 3);
    if (idx != 3) {
        io::println("FAIL: upperBound basic idx=" + Integer.toString(idx));
    } else {
        io::println("PASS: upperBound basic");
    }
}

public fn test_count_basic(): void {
    let data: ArrayList<int> = new ArrayList<int>();
    data.add(1); data.add(3); data.add(3); data.add(5); data.add(3);
    let c: int = count<int>(data, 3);
    if (c != 3) {
        io::println("FAIL: count basic c=" + Integer.toString(c));
    } else {
        io::println("PASS: count basic");
    }
}

public fn test_countIf_basic(): void {
    let data: ArrayList<int> = new ArrayList<int>();
    data.add(1); data.add(2); data.add(3); data.add(4); data.add(5);
    let c: int = countIf<int>(data, fn(x: int): bool { return x % 2 == 0; });
    if (c != 2) {
        io::println("FAIL: countIf basic c=" + Integer.toString(c));
    } else {
        io::println("PASS: countIf basic");
    }
}

public fn test_transform_basic(): void {
    let data: ArrayList<int> = new ArrayList<int>();
    data.add(1); data.add(2); data.add(3);
    let result: ArrayList<int> = transform<int, int>(data, fn(x: int): int { return x * 2; });
    if (result.get(0) != 2 || result.get(2) != 6) {
        io::println("FAIL: transform basic");
    } else {
        io::println("PASS: transform basic");
    }
}

public fn test_replace_basic(): void {
    let data: ArrayList<int> = new ArrayList<int>();
    data.add(1); data.add(2); data.add(1); data.add(3);
    replace<int>(data, 1, 9);
    if (data.get(0) != 9 || data.get(2) != 9) {
        io::println("FAIL: replace basic");
    } else {
        io::println("PASS: replace basic");
    }
}

public fn test_remove_basic(): void {
    let data: ArrayList<int> = new ArrayList<int>();
    data.add(1); data.add(2); data.add(1); data.add(3);
    let result: ArrayList<int> = remove<int>(data, 1);
    if (result.size() != 2 || result.get(0) != 2) {
        io::println("FAIL: remove basic");
    } else {
        io::println("PASS: remove basic");
    }
}

public fn test_unique_basic(): void {
    let data: ArrayList<int> = new ArrayList<int>();
    data.add(1); data.add(1); data.add(2); data.add(2); data.add(3);
    let result: ArrayList<int> = unique<int>(data);
    if (result.size() != 3) {
        io::println("FAIL: unique basic size=" + Integer.toString(result.size()));
    } else {
        io::println("PASS: unique basic");
    }
}

public fn test_reverse_basic(): void {
    let data: ArrayList<int> = new ArrayList<int>();
    data.add(1); data.add(2); data.add(3); data.add(4);
    let result: ArrayList<int> = reverse<int>(data);
    if (result.get(0) != 4 || result.get(3) != 1) {
        io::println("FAIL: reverse basic");
    } else {
        io::println("PASS: reverse basic");
    }
}

public fn test_rotate_basic(): void {
    let data: ArrayList<int> = new ArrayList<int>();
    data.add(1); data.add(2); data.add(3); data.add(4); data.add(5);
    let result: ArrayList<int> = rotate<int>(data, 2);
    if (result.get(0) != 3 || result.get(4) != 2) {
        io::println("FAIL: rotate basic");
    } else {
        io::println("PASS: rotate basic");
    }
}

public fn test_shuffle_basic(): void {
    let data: ArrayList<int> = new ArrayList<int>();
    data.add(1); data.add(2); data.add(3); data.add(4); data.add(5);
    let result: ArrayList<int> = shuffle<int>(data);
    if (result.size() != 5) {
        io::println("FAIL: shuffle basic size");
    } else {
        io::println("PASS: shuffle basic");
    }
}

public fn test_partition_basic(): void {
    let data: ArrayList<int> = new ArrayList<int>();
    data.add(1); data.add(2); data.add(3); data.add(4); data.add(5);
    let parts: ArrayList<ArrayList<int>> = partition<int>(data, fn(x: int): bool { return x % 2 == 0; });
    if (parts.get(0).size() != 2 || parts.get(1).size() != 3) {
        io::println("FAIL: partition basic");
    } else {
        io::println("PASS: partition basic");
    }
}

public fn test_minElement_basic(): void {
    let data: ArrayList<int> = new ArrayList<int>();
    data.add(5); data.add(2); data.add(8); data.add(1); data.add(9);
    let m: int = minElement<int>(data);
    if (m != 1) {
        io::println("FAIL: minElement basic m=" + Integer.toString(m));
    } else {
        io::println("PASS: minElement basic");
    }
}

