public fn test_accumulate_basic(): void {
    let data: ArrayList<int> = new ArrayList<int>();
    data.add(1); data.add(2); data.add(3); data.add(4);
    let sum: int = accumulate<int>(data, 0, fn(a: int, b: int): int { return a + b; });
    if (sum != 10) {
        io::println("FAIL: accumulate basic sum=" + Integer.toString(sum));
    } else {
        io::println("PASS: accumulate basic");
    }
}

public fn test_gcd_basic(): void {
    let g: int = gcd(12, 18);
    if (g != 6) {
        io::println("FAIL: gcd basic g=" + Integer.toString(g));
    } else {
        io::println("PASS: gcd basic");
    }
}

public fn test_lcm_basic(): void {
    let l: int = lcm(4, 6);
    if (l != 12) {
        io::println("FAIL: lcm basic l=" + Integer.toString(l));
    } else {
        io::println("PASS: lcm basic");
    }
}

public fn test_clamp_basic(): void {
    let v: int = clamp<int>(15, 0, 10);
    if (v != 10) {
        io::println("FAIL: clamp basic v=" + Integer.toString(v));
    } else {
        io::println("PASS: clamp basic");
    }
}

public fn test_clamp_within(): void {
    let v: int = clamp<int>(5, 0, 10);
    if (v != 5) {
        io::println("FAIL: clamp within v=" + Integer.toString(v));
    } else {
        io::println("PASS: clamp within");
    }
}

public fn test_merge_basic(): void {
    let a: ArrayList<int> = new ArrayList<int>();
    a.add(1); a.add(3); a.add(5);
    let b: ArrayList<int> = new ArrayList<int>();
    b.add(2); b.add(4); b.add(6);
    let result: ArrayList<int> = merge<int>(a, b);
    if (result.size() != 6 || result.get(0) != 1 || result.get(5) != 6) {
        io::println("FAIL: merge basic");
    } else {
        io::println("PASS: merge basic");
    }
}

public fn test_anyOf_basic(): void {
    let data: ArrayList<int> = new ArrayList<int>();
    data.add(1); data.add(2); data.add(3);
    let r: bool = anyOf<int>(data, fn(x: int): bool { return x > 2; });
    if (!r) {
        io::println("FAIL: anyOf basic");
    } else {
        io::println("PASS: anyOf basic");
    }
}

public fn test_allOf_basic(): void {
    let data: ArrayList<int> = new ArrayList<int>();
    data.add(1); data.add(2); data.add(3);
    let r: bool = allOf<int>(data, fn(x: int): bool { return x > 0; });
    if (!r) {
        io::println("FAIL: allOf basic");
    } else {
        io::println("PASS: allOf basic");
    }
}

public fn test_noneOf_basic(): void {
    let data: ArrayList<int> = new ArrayList<int>();
    data.add(1); data.add(2); data.add(3);
    let r: bool = noneOf<int>(data, fn(x: int): bool { return x > 10; });
    if (!r) {
        io::println("FAIL: noneOf basic");
    } else {
        io::println("PASS: noneOf basic");
    }
}

public fn test_fill_basic(): void {
    let data: ArrayList<int> = new ArrayList<int>();
    data.add(0); data.add(0); data.add(0);
    fill<int>(data, 7);
    if (data.get(0) != 7 || data.get(2) != 7) {
        io::println("FAIL: fill basic");
    } else {
        io::println("PASS: fill basic");
    }
}

public fn test_iota_basic(): void {
    let result: ArrayList<int> = iota(5, 3);
    if (result.size() != 3 || result.get(0) != 5 || result.get(2) != 7) {
        io::println("FAIL: iota basic");
    } else {
        io::println("PASS: iota basic");
    }
}

public fn test_isSorted_true(): void {
    let data: ArrayList<int> = new ArrayList<int>();
    data.add(1); data.add(2); data.add(3); data.add(4);
    if (!isSorted<int>(data)) {
        io::println("FAIL: isSorted true");
    } else {
        io::println("PASS: isSorted true");
    }
}

public fn test_isSorted_false(): void {
    let data: ArrayList<int> = new ArrayList<int>();
    data.add(1); data.add(3); data.add(2); data.add(4);
    if (isSorted<int>(data)) {
        io::println("FAIL: isSorted false");
    } else {
        io::println("PASS: isSorted false");
    }
}

public fn test_equal_true(): void {
    let a: ArrayList<int> = new ArrayList<int>();
    a.add(1); a.add(2); a.add(3);
    let b: ArrayList<int> = new ArrayList<int>();
    b.add(1); b.add(2); b.add(3);
    if (!equal<int>(a, b)) {
        io::println("FAIL: equal true");
    } else {
        io::println("PASS: equal true");
    }
}

public fn test_equal_false(): void {
    let a: ArrayList<int> = new ArrayList<int>();
    a.add(1); a.add(2); a.add(3);
    let b: ArrayList<int> = new ArrayList<int>();
    b.add(1); b.add(2); b.add(4);
    if (equal<int>(a, b)) {
        io::println("FAIL: equal false");
    } else {
        io::println("PASS: equal false");
    }
}

public fn run_all_algorithms_tests(): void {
    test_sort_basic();
    test_sort_empty();
    test_stableSort_basic();
    test_find_found();
    test_find_notFound();
    test_findIf_basic();
    test_binarySearch_found();
    test_binarySearch_notFound();
    test_lowerBound_basic();
    test_upperBound_basic();
    test_count_basic();
    test_countIf_basic();
    test_transform_basic();
    test_replace_basic();
    test_remove_basic();
    test_unique_basic();
    test_reverse_basic();
    test_rotate_basic();
    test_shuffle_basic();
    test_partition_basic();
    test_minElement_basic();
    test_maxElement_basic();
    test_accumulate_basic();
    test_gcd_basic();
    test_lcm_basic();
    test_clamp_basic();
    test_clamp_within();
    test_merge_basic();
    test_anyOf_basic();
    test_allOf_basic();
    test_noneOf_basic();
    test_fill_basic();
    test_iota_basic();
    test_isSorted_true();
    test_isSorted_false();
    test_equal_true();
    test_equal_false();
}
