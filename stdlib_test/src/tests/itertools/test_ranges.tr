// Test file for itertools/Ranges.tr
// Exercises C++20 ranges parity functions: iota, iotaInclusive, keys, values,
// elements, adjacent, pairwise, join, joinWith, split, lazySplit, stride,
// chunk, slide, common, reverse, single, emptyRange, repeat, sort,
// sortWithProjection, copy, copyProjection, transform, transformWithProjection,
// to, toTransform, and range concept predicates.
import tt::itertools::Ranges;
import tt::util::ArrayList;
import tt::util::Pair;
import tt::lang::Integer;

// ==================== views::iota ====================

public fn test_iota_basic(): void {
    let out: ArrayList<int> = iota(0, 5);
    if (out.size() == 5 && out.get(0) == 0 && out.get(4) == 4) {
        io::println("PASS: iota(0, 5) works");
    } else {
        io::println("FAIL: iota(0, 5) size=" + Integer.toString(out.size()));
    }
}

public fn test_iota_start_offset(): void {
    let out: ArrayList<int> = iota(10, 3);
    if (out.size() == 3 && out.get(0) == 10 && out.get(2) == 12) {
        io::println("PASS: iota(10, 3) works");
    } else {
        io::println("FAIL: iota(10, 3)");
    }
}

public fn test_iota_zero_count(): void {
    let out: ArrayList<int> = iota(0, 0);
    if (out.size() == 0) {
        io::println("PASS: iota zero count returns empty");
    } else {
        io::println("FAIL: iota zero count");
    }
}

public fn test_iota_negative_count(): void {
    let out: ArrayList<int> = iota(5, -3);
    if (out.size() == 0) {
        io::println("PASS: iota negative count returns empty");
    } else {
        io::println("FAIL: iota negative count");
    }
}

