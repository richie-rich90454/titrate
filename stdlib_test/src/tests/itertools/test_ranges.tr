// ==================== ranges::sort ====================

public fn test_sort_basic(): void {
    let list: ArrayList<int> = new ArrayList<int>();
    list.add(3); list.add(1); list.add(2);
    let out: ArrayList<int> = sort<int>(list);
    if (out.size() == 3 && out.get(0) == 1 && out.get(1) == 2 && out.get(2) == 3) {
        io::println("PASS: sort works");
    } else {
        io::println("FAIL: sort size=" + Integer.toString(out.size()));
    }
}

public fn test_sort_empty(): void {
    let list: ArrayList<int> = new ArrayList<int>();
    let out: ArrayList<int> = sort<int>(list);
    if (out.size() == 0) {
        io::println("PASS: sort empty returns empty");
    } else {
        io::println("FAIL: sort empty");
    }
}

public fn test_sort_single(): void {
    let list: ArrayList<int> = new ArrayList<int>();
    list.add(42);
    let out: ArrayList<int> = sort<int>(list);
    if (out.size() == 1 && out.get(0) == 42) {
        io::println("PASS: sort single works");
    } else {
        io::println("FAIL: sort single");
    }
}

public fn test_sort_already_sorted(): void {
    let list: ArrayList<int> = new ArrayList<int>();
    list.add(1); list.add(2); list.add(3); list.add(4); list.add(5);
    let out: ArrayList<int> = sort<int>(list);
    if (out.size() == 5 && out.get(0) == 1 && out.get(4) == 5) {
        io::println("PASS: sort already sorted works");
    } else {
        io::println("FAIL: sort already sorted");
    }
}

public fn test_sort_does_not_mutate(): void {
    let list: ArrayList<int> = new ArrayList<int>();
    list.add(3); list.add(1); list.add(2);
    let out: ArrayList<int> = sort<int>(list);
    if (list.get(0) == 3 && list.get(1) == 1 && list.get(2) == 2 && out.get(0) == 1) {
        io::println("PASS: sort does not mutate input");
    } else {
        io::println("FAIL: sort mutates input");
    }
}

public fn test_sort_strings(): void {
    let list: ArrayList<string> = new ArrayList<string>();
    list.add("banana"); list.add("apple"); list.add("cherry");
    let out: ArrayList<string> = sort<string>(list);
    if (out.size() == 3 && out.get(0) == "apple" && out.get(1) == "banana" && out.get(2) == "cherry") {
        io::println("PASS: sort strings works");
    } else {
        io::println("FAIL: sort strings");
    }
}

// ==================== ranges::sortWithProjection ====================

public fn test_sortWithProjection_basic(): void {
    let list: ArrayList<int> = new ArrayList<int>();
    list.add(3); list.add(1); list.add(2);
    let proj: fn(int): int = fn(x: int): int { return x; };
    let out: ArrayList<int> = sortWithProjection<int, int>(list, proj);
    if (out.size() == 3 && out.get(0) == 1 && out.get(1) == 2 && out.get(2) == 3) {
        io::println("PASS: sortWithProjection works");
    } else {
        io::println("FAIL: sortWithProjection");
    }
}

public fn test_sortWithProjection_empty(): void {
    let list: ArrayList<int> = new ArrayList<int>();
    let proj: fn(int): int = fn(x: int): int { return x; };
    let out: ArrayList<int> = sortWithProjection<int, int>(list, proj);
    if (out.size() == 0) {
        io::println("PASS: sortWithProjection empty returns empty");
    } else {
        io::println("FAIL: sortWithProjection empty");
    }
}

// ==================== ranges::copy ====================

public fn test_copy_basic(): void {
    let list: ArrayList<int> = new ArrayList<int>();
    list.add(1); list.add(2); list.add(3);
    let out: ArrayList<int> = copy<int>(list);
    if (out.size() == 3 && out.get(0) == 1 && out.get(2) == 3) {
        io::println("PASS: copy works");
    } else {
        io::println("FAIL: copy");
    }
}

public fn test_copy_independent(): void {
    let list: ArrayList<int> = new ArrayList<int>();
    list.add(1); list.add(2);
    let out: ArrayList<int> = copy<int>(list);
    out.set(0, 99);
    if (list.get(0) == 1 && out.get(0) == 99) {
        io::println("PASS: copy is independent");
    } else {
        io::println("FAIL: copy not independent");
    }
}

// ==================== ranges::copyProjection ====================

public fn test_copyProjection_basic(): void {
    let list: ArrayList<int> = new ArrayList<int>();
    list.add(1); list.add(2); list.add(3);
    let proj: fn(int): int = fn(x: int): int { return x * 10; };
    let out: ArrayList<int> = copyProjection<int, int>(list, proj);
    if (out.size() == 3 && out.get(0) == 10 && out.get(1) == 20 && out.get(2) == 30) {
        io::println("PASS: copyProjection works");
    } else {
        io::println("FAIL: copyProjection");
    }
}

// ==================== ranges::transform ====================

public fn test_transform_basic(): void {
    let list: ArrayList<int> = new ArrayList<int>();
    list.add(1); list.add(2); list.add(3);
    let f: fn(int): int = fn(x: int): int { return x * x; };
    let out: ArrayList<int> = transform<int, int>(list, f);
    if (out.size() == 3 && out.get(0) == 1 && out.get(1) == 4 && out.get(2) == 9) {
        io::println("PASS: transform works");
    } else {
        io::println("FAIL: transform");
    }
}

public fn test_transform_empty(): void {
    let list: ArrayList<int> = new ArrayList<int>();
    let f: fn(int): int = fn(x: int): int { return x; };
    let out: ArrayList<int> = transform<int, int>(list, f);
    if (out.size() == 0) {
        io::println("PASS: transform empty returns empty");
    } else {
        io::println("FAIL: transform empty");
    }
}

public fn test_transform_type_change(): void {
    let list: ArrayList<int> = new ArrayList<int>();
    list.add(1); list.add(2); list.add(3);
    let f: fn(int): string = fn(x: int): string { return Integer.toString(x); };
    let out: ArrayList<string> = transform<int, string>(list, f);
    if (out.size() == 3 && out.get(0) == "1" && out.get(1) == "2" && out.get(2) == "3") {
        io::println("PASS: transform type change works");
    } else {
        io::println("FAIL: transform type change");
    }
}

// ==================== ranges::transformWithProjection ====================

public fn test_transformWithProjection_basic(): void {
    let list: ArrayList<int> = new ArrayList<int>();
    list.add(1); list.add(2); list.add(3);
    let proj: fn(int): int = fn(x: int): int { return x * 2; };
    let f: fn(int): int = fn(x: int): int { return x + 1; };
    let out: ArrayList<int> = transformWithProjection<int, int, int>(list, proj, f);
    if (out.size() == 3 && out.get(0) == 3 && out.get(1) == 5 && out.get(2) == 7) {
        io::println("PASS: transformWithProjection works");
    } else {
        io::println("FAIL: transformWithProjection");
    }
}

