// ==================== views::keys / values ====================

public fn test_keys(): void {
    let pairs: ArrayList<Pair<int, string>> = new ArrayList<Pair<int, string>>();
    pairs.add(new Pair<int, string>(1, "a"));
    pairs.add(new Pair<int, string>(2, "b"));
    pairs.add(new Pair<int, string>(3, "c"));
    let out: ArrayList<int> = keys<int, string>(pairs);
    if (out.size() == 3 && out.get(0) == 1 && out.get(1) == 2 && out.get(2) == 3) {
        io::println("PASS: keys works");
    } else {
        io::println("FAIL: keys size=" + Integer.toString(out.size()));
    }
}

public fn test_keys_empty(): void {
    let pairs: ArrayList<Pair<int, string>> = new ArrayList<Pair<int, string>>();
    let out: ArrayList<int> = keys<int, string>(pairs);
    if (out.size() == 0) {
        io::println("PASS: keys empty returns empty");
    } else {
        io::println("FAIL: keys empty");
    }
}

public fn test_values(): void {
    let pairs: ArrayList<Pair<int, string>> = new ArrayList<Pair<int, string>>();
    pairs.add(new Pair<int, string>(1, "a"));
    pairs.add(new Pair<int, string>(2, "b"));
    pairs.add(new Pair<int, string>(3, "c"));
    let out: ArrayList<string> = values<int, string>(pairs);
    if (out.size() == 3 && out.get(0) == "a" && out.get(1) == "b" && out.get(2) == "c") {
        io::println("PASS: values works");
    } else {
        io::println("FAIL: values size=" + Integer.toString(out.size()));
    }
}

public fn test_values_empty(): void {
    let pairs: ArrayList<Pair<int, string>> = new ArrayList<Pair<int, string>>();
    let out: ArrayList<string> = values<int, string>(pairs);
    if (out.size() == 0) {
        io::println("PASS: values empty returns empty");
    } else {
        io::println("FAIL: values empty");
    }
}

// ==================== views::elements ====================

public fn test_elements_first(): void {
    let tuples: ArrayList<ArrayList<Variant>> = new ArrayList<ArrayList<Variant>>();
    let t1: ArrayList<Variant> = new ArrayList<Variant>();
    t1.add(1); t1.add("a");
    let t2: ArrayList<Variant> = new ArrayList<Variant>();
    t2.add(2); t2.add("b");
    tuples.add(t1); tuples.add(t2);
    let out: ArrayList<Variant> = elements(tuples, 0);
    if (out.size() == 2 && (out.get(0) as int) == 1 && (out.get(1) as int) == 2) {
        io::println("PASS: elements index 0 works");
    } else {
        io::println("FAIL: elements index 0 size=" + Integer.toString(out.size()));
    }
}

public fn test_elements_second(): void {
    let tuples: ArrayList<ArrayList<Variant>> = new ArrayList<ArrayList<Variant>>();
    let t1: ArrayList<Variant> = new ArrayList<Variant>();
    t1.add(1); t1.add("a");
    let t2: ArrayList<Variant> = new ArrayList<Variant>();
    t2.add(2); t2.add("b");
    tuples.add(t1); tuples.add(t2);
    let out: ArrayList<Variant> = elements(tuples, 1);
    if (out.size() == 2 && (out.get(0) as string) == "a" && (out.get(1) as string) == "b") {
        io::println("PASS: elements index 1 works");
    } else {
        io::println("FAIL: elements index 1");
    }
}

public fn test_elements_out_of_range(): void {
    let tuples: ArrayList<ArrayList<Variant>> = new ArrayList<ArrayList<Variant>>();
    let t1: ArrayList<Variant> = new ArrayList<Variant>();
    t1.add(1);
    tuples.add(t1);
    let out: ArrayList<Variant> = elements(tuples, 5);
    if (out.size() == 0) {
        io::println("PASS: elements out of range returns empty");
    } else {
        io::println("FAIL: elements out of range");
    }
}

public fn test_elements_empty(): void {
    let tuples: ArrayList<ArrayList<Variant>> = new ArrayList<ArrayList<Variant>>();
    let out: ArrayList<Variant> = elements(tuples, 0);
    if (out.size() == 0) {
        io::println("PASS: elements empty returns empty");
    } else {
        io::println("FAIL: elements empty");
    }
}

// ==================== views::adjacent ====================

public fn test_adjacent_basic(): void {
    let list: ArrayList<int> = new ArrayList<int>();
    list.add(1); list.add(2); list.add(3); list.add(4);
    let out: ArrayList<ArrayList<int>> = adjacent<int>(list, 2);
    if (out.size() == 3) {
        if (out.get(0).get(0) == 1 && out.get(0).get(1) == 2 && out.get(2).get(0) == 3 && out.get(2).get(1) == 4) {
            io::println("PASS: adjacent n=2 works");
        } else {
            io::println("FAIL: adjacent n=2 content");
        }
    } else {
        io::println("FAIL: adjacent n=2 size=" + Integer.toString(out.size()));
    }
}

public fn test_adjacent_n3(): void {
    let list: ArrayList<int> = new ArrayList<int>();
    list.add(1); list.add(2); list.add(3); list.add(4); list.add(5);
    let out: ArrayList<ArrayList<int>> = adjacent<int>(list, 3);
    if (out.size() == 3 && out.get(0).size() == 3 && out.get(2).get(2) == 5) {
        io::println("PASS: adjacent n=3 works");
    } else {
        io::println("FAIL: adjacent n=3 size=" + Integer.toString(out.size()));
    }
}

public fn test_adjacent_n_too_large(): void {
    let list: ArrayList<int> = new ArrayList<int>();
    list.add(1); list.add(2);
    let out: ArrayList<ArrayList<int>> = adjacent<int>(list, 5);
    if (out.size() == 0) {
        io::println("PASS: adjacent n too large returns empty");
    } else {
        io::println("FAIL: adjacent n too large");
    }
}

public fn test_adjacent_n_zero(): void {
    let list: ArrayList<int> = new ArrayList<int>();
    list.add(1); list.add(2);
    let out: ArrayList<ArrayList<int>> = adjacent<int>(list, 0);
    if (out.size() == 0) {
