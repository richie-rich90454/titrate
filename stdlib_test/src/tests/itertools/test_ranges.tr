// ==================== views::join ====================

public fn test_join_basic(): void {
    let lists: ArrayList<ArrayList<int>> = new ArrayList<ArrayList<int>>();
    let a: ArrayList<int> = new ArrayList<int>();
    a.add(1); a.add(2);
    let b: ArrayList<int> = new ArrayList<int>();
    b.add(3); b.add(4);
    lists.add(a); lists.add(b);
    let out: ArrayList<int> = join<int>(lists);
    if (out.size() == 4 && out.get(0) == 1 && out.get(3) == 4) {
        io::println("PASS: join works");
    } else {
        io::println("FAIL: join size=" + Integer.toString(out.size()));
    }
}

public fn test_join_empty(): void {
    let lists: ArrayList<ArrayList<int>> = new ArrayList<ArrayList<int>>();
    let out: ArrayList<int> = join<int>(lists);
    if (out.size() == 0) {
        io::println("PASS: join empty returns empty");
    } else {
        io::println("FAIL: join empty");
    }
}

public fn test_join_with_empty_inner(): void {
    let lists: ArrayList<ArrayList<int>> = new ArrayList<ArrayList<int>>();
    let a: ArrayList<int> = new ArrayList<int>();
    let b: ArrayList<int> = new ArrayList<int>();
    b.add(1);
    lists.add(a); lists.add(b);
    let out: ArrayList<int> = join<int>(lists);
    if (out.size() == 1 && out.get(0) == 1) {
        io::println("PASS: join with empty inner works");
    } else {
        io::println("FAIL: join with empty inner");
    }
}

// ==================== views::joinWith ====================

public fn test_joinWith_basic(): void {
    let lists: ArrayList<ArrayList<int>> = new ArrayList<ArrayList<int>>();
    let a: ArrayList<int> = new ArrayList<int>();
    a.add(1); a.add(2);
    let b: ArrayList<int> = new ArrayList<int>();
    b.add(3);
    lists.add(a); lists.add(b);
    let out: ArrayList<int> = joinWith<int>(lists, 0);
    if (out.size() == 4 && out.get(0) == 1 && out.get(2) == 0 && out.get(3) == 3) {
        io::println("PASS: joinWith works");
    } else {
        io::println("FAIL: joinWith size=" + Integer.toString(out.size()));
    }
}

public fn test_joinWith_single(): void {
    let lists: ArrayList<ArrayList<int>> = new ArrayList<ArrayList<int>>();
    let a: ArrayList<int> = new ArrayList<int>();
    a.add(1); a.add(2);
    lists.add(a);
    let out: ArrayList<int> = joinWith<int>(lists, 0);
    if (out.size() == 2 && out.get(0) == 1 && out.get(1) == 2) {
        io::println("PASS: joinWith single list no separator");
    } else {
        io::println("FAIL: joinWith single");
    }
}

public fn test_joinWith_empty(): void {
    let lists: ArrayList<ArrayList<int>> = new ArrayList<ArrayList<int>>();
    let out: ArrayList<int> = joinWith<int>(lists, 0);
    if (out.size() == 0) {
        io::println("PASS: joinWith empty returns empty");
    } else {
        io::println("FAIL: joinWith empty");
    }
}

// ==================== views::split / lazySplit ====================

public fn test_split_basic(): void {
    let list: ArrayList<int> = new ArrayList<int>();
    list.add(1); list.add(0); list.add(2); list.add(0); list.add(3);
    let out: ArrayList<ArrayList<int>> = split<int>(list, 0);
    if (out.size() == 3 && out.get(0).get(0) == 1 && out.get(1).get(0) == 2 && out.get(2).get(0) == 3) {
        io::println("PASS: split works");
    } else {
        io::println("FAIL: split size=" + Integer.toString(out.size()));
    }
}

public fn test_split_no_delimiter(): void {
    let list: ArrayList<int> = new ArrayList<int>();
    list.add(1); list.add(2); list.add(3);
    let out: ArrayList<ArrayList<int>> = split<int>(list, 0);
    if (out.size() == 1 && out.get(0).size() == 3) {
        io::println("PASS: split no delimiter works");
    } else {
        io::println("FAIL: split no delimiter");
    }
}

public fn test_split_consecutive_delimiters(): void {
    let list: ArrayList<int> = new ArrayList<int>();
    list.add(0); list.add(0); list.add(1);
    let out: ArrayList<ArrayList<int>> = split<int>(list, 0);
    if (out.size() == 3 && out.get(0).size() == 0 && out.get(1).size() == 0 && out.get(2).size() == 1) {
        io::println("PASS: split consecutive delimiters works");
    } else {
        io::println("FAIL: split consecutive delimiters size=" + Integer.toString(out.size()));
    }
}

public fn test_lazySplit_basic(): void {
    let list: ArrayList<int> = new ArrayList<int>();
    list.add(1); list.add(0); list.add(2);
    let out: ArrayList<ArrayList<int>> = lazySplit<int>(list, 0);
    if (out.size() == 2 && out.get(0).get(0) == 1 && out.get(1).get(0) == 2) {
        io::println("PASS: lazySplit works");
    } else {
        io::println("FAIL: lazySplit");
    }
}

