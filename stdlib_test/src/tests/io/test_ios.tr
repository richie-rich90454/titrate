// Test file for io/Ios.tr
// Exercises fmtflags, iostate, openmode, seekdir constants, IosBase, BasicIos,
// Ios, Wios, throwIfBad, stateName, flagsName.
import tt::io::Ios;
import tt::io::Iomanip;
import tt::io::StreamBuf;
import tt::lang::String;

public fn test_fmtflags_constants(): void {
    if (Ios.FMT_DEC != 1) {
        io::println("FAIL: FMT_DEC constant wrong");
    } else if (Ios.FMT_HEX != 2) {
        io::println("FAIL: FMT_HEX constant wrong");
    } else if (Ios.FMT_OCT != 4) {
        io::println("FAIL: FMT_OCT constant wrong");
    } else {
        io::println("PASS: fmtflags constants work");
    }
}

public fn test_iostate_constants(): void {
    if (Ios.GOOD_STATE != 0) {
        io::println("FAIL: GOOD_STATE constant wrong");
    } else if (Ios.EOF_STATE != 1) {
        io::println("FAIL: EOF_STATE constant wrong");
    } else if (Ios.FAIL_STATE != 2) {
        io::println("FAIL: FAIL_STATE constant wrong");
    } else if (Ios.BAD_STATE != 4) {
        io::println("FAIL: BAD_STATE constant wrong");
    } else {
        io::println("PASS: iostate constants work");
    }
}

public fn test_openmode_constants(): void {
    if (Ios.APP != 1 || Ios.IN != 8 || Ios.OUT != 16) {
        io::println("FAIL: openmode constants wrong");
    } else {
        io::println("PASS: openmode constants work");
    }
}

public fn test_seekdir_constants(): void {
    if (Ios.BEG != 0 || Ios.CUR != 1 || Ios.END != 2) {
        io::println("FAIL: seekdir constants wrong");
    } else {
        io::println("PASS: seekdir constants work");
    }
}

public fn test_ios_base_init(): void {
    let base: IosBase = new IosBase();
    if (!base.good()) {
        io::println("FAIL: IosBase should be good initially");
    } else if (base.fail()) {
        io::println("FAIL: IosBase should not fail initially");
    } else if (base.eof()) {
        io::println("FAIL: IosBase should not be eof initially");
    } else if (base.bad()) {
        io::println("FAIL: IosBase should not be bad initially");
    } else if (base.precision != 6) {
        io::println("FAIL: IosBase precision wrong");
    } else if (base.width != 0) {
        io::println("FAIL: IosBase width wrong");
    } else {
        io::println("PASS: IosBase init works");
    }
}

public fn test_ios_base_setf(): void {
    let base: IosBase = new IosBase();
    let old: int = base.setf(Ios.FMT_HEX);
    if (!base.isHex()) {
        io::println("FAIL: setf did not set hex flag");
    } else {
        io::println("PASS: IosBase setf works");
    }
}

public fn test_ios_base_unsetf(): void {
    let base: IosBase = new IosBase();
    base.setf(Ios.FMT_HEX);
    base.unsetf(Ios.FMT_HEX);
    if (base.isHex()) {
        io::println("FAIL: unsetf should clear hex flag");
    } else {
        io::println("PASS: IosBase unsetf works");
    }
}

public fn test_ios_base_flags(): void {
    let base: IosBase = new IosBase();
    let old: int = base.flags();
    if ((old & Ios.FMT_DEC) == 0) {
        io::println("FAIL: default flags should include DEC");
    } else {
        io::println("PASS: IosBase flags works");
    }
}

public fn test_ios_base_set_precision(): void {
    let base: IosBase = new IosBase();
    let old: int = base.setPrecision(12);
    if (base.precision != 12) {
        io::println("FAIL: setPrecision = " + base.precision);
    } else {
        io::println("PASS: IosBase setPrecision works");
    }
}

public fn test_ios_base_set_width(): void {
    let base: IosBase = new IosBase();
    let old: int = base.setWidth(25);
    if (base.width != 25) {
        io::println("FAIL: setWidth = " + base.width);
    } else {
        io::println("PASS: IosBase setWidth works");
    }
}

public fn test_ios_base_set_fill(): void {
    let base: IosBase = new IosBase();
    let old: string = base.setFill("*");
    if (base.fillChar != "*") {
        io::println("FAIL: setFill wrong");
    } else {
        io::println("PASS: IosBase setFill works");
    }
}

public fn test_ios_base_state_management(): void {
    let base: IosBase = new IosBase();
    base.setState(Ios.EOF_STATE);
    if (!base.eof()) {
        io::println("FAIL: should be eof");
    } else {
        io::println("PASS: IosBase setState works");
    }
    base.clear();
    if (!base.good()) {
        io::println("FAIL: should be good after clear");
    } else {
        io::println("PASS: IosBase clear works");
    }
}

public fn test_ios_base_bool_value(): void {
    let base: IosBase = new IosBase();
    if (!base.boolValue()) {
        io::println("FAIL: good stream should be true");
    } else {
        io::println("PASS: IosBase boolValue works");
    }
    base.setState(Ios.BAD_STATE);
    if (base.boolValue()) {
        io::println("FAIL: bad stream should be false");
    } else {
        io::println("PASS: IosBase boolValue with bad works");
    }
}

public fn test_basic_ios_init(): void {
    let ios: BasicIos = new BasicIos();
    if (ios.rdbuf() != null) {
        io::println("FAIL: BasicIos buf should be null initially");
    } else {
        io::println("PASS: BasicIos init works");
    }
}

public fn test_basic_ios_rdbuf(): void {
    let buf: StreamBuf = new StringBuf();
    let ios: BasicIos = new BasicIos();
    ios.initWithBuf(buf);
    if (ios.rdbuf() != buf) {
        io::println("FAIL: rdbuf mismatch");
    } else {
        io::println("PASS: BasicIos rdbuf works");
    }
}

public fn test_basic_ios_set_rdbuf(): void {
    let buf1: StreamBuf = new StringBuf();
    let buf2: StreamBuf = new StringBuf();
    let ios: BasicIos = new BasicIos();
    ios.initWithBuf(buf1);
    let old: StreamBuf = ios.setRdbuf(buf2);
    if (ios.rdbuf() != buf2) {
        io::println("FAIL: setRdbuf not reflected");
    } else if (old != buf1) {
        io::println("FAIL: setRdbuf old buf wrong");
    } else {
        io::println("PASS: BasicIos setRdbuf works");
    }
}

public fn test_basic_ios_tie(): void {
    let ios: BasicIos = new BasicIos();
    if (ios.tie() != null) {
        io::println("FAIL: tied stream should be null initially");
    } else {
        io::println("PASS: BasicIos tie works");
    }
}

public fn test_basic_ios_set_tie(): void {
    let ios1: BasicIos = new BasicIos();
    let ios2: BasicIos = new BasicIos();
    let old: IosBase = ios1.setTie(ios2);
    if (ios1.tie() != ios2) {
        io::println("FAIL: setTie not reflected");
    } else {
        io::println("PASS: BasicIos setTie works");
    }
}

public fn test_basic_ios_set_bad(): void {
    let ios: BasicIos = new BasicIos();
    ios.setBad();
    if (!ios.bad()) {
        io::println("FAIL: should be bad after setBad");
    } else {
        io::println("PASS: BasicIos setBad works");
    }
}

public fn test_basic_ios_set_fail(): void {
    let ios: BasicIos = new BasicIos();
    ios.setFail();
    if (!ios.fail()) {
        io::println("FAIL: should be fail after setFail");
    } else {
        io::println("PASS: BasicIos setFail works");
    }
}

public fn test_basic_ios_set_eof(): void {
    let ios: BasicIos = new BasicIos();
    ios.setEof();
    if (!ios.eof()) {
        io::println("FAIL: should be eof after setEof");
    } else {
        io::println("PASS: BasicIos setEof works");
    }
}

public fn test_basic_ios_get_without_buffer(): void {
    let ios: BasicIos = new BasicIos();
    let c: int = ios.get();
    if (c != -1 || !ios.bad()) {
        io::println("FAIL: get without buffer should return -1 and set bad");
    } else {
        io::println("PASS: BasicIos get without buffer works");
    }
}

public fn test_basic_ios_put_without_buffer(): void {
    let ios: BasicIos = new BasicIos();
    let r: int = ios.put(65);
    if (r != -1 || !ios.bad()) {
        io::println("FAIL: put without buffer should return -1 and set bad");
    } else {
        io::println("PASS: BasicIos put without buffer works");
    }
}

public fn test_ios_factory(): void {
    let ios: BasicIos = Ios.Ios();
    if (ios == null) {
        io::println("FAIL: Ios() factory returned null");
    } else if (ios.fillChar != " ") {
        io::println("FAIL: Ios() fillChar wrong");
    } else {
        io::println("PASS: Ios() factory works");
    }
}

public fn test_wios_factory(): void {
    let wios: BasicIos = Ios.Wios();
    if (wios == null) {
        io::println("FAIL: Wios() factory returned null");
    } else {
        io::println("PASS: Wios() factory works");
    }
}

public fn test_throw_if_bad_no_mask(): void {
    let ios: BasicIos = new BasicIos();
    // Should not throw for good stream
    Ios.throwIfBad(ios, Ios.BAD_STATE);
    io::println("PASS: throwIfBad on good stream works");
}

public fn test_throw_if_bad_with_badbit(): void {
    let ios: BasicIos = new BasicIos();
    ios.setBad();
    var caught: bool = false;
    try {
        Ios.throwIfBad(ios, Ios.BAD_STATE);
    } catch (e: string) {
        caught = true;
    }
    if (!caught) {
        io::println("FAIL: throwIfBad should throw when badbit set");
    } else {
        io::println("PASS: throwIfBad with badbit throws");
    }
}

public fn test_state_name_good(): void {
    if (Ios.stateName(Ios.GOOD_STATE) != "good") {
        io::println("FAIL: stateName good = " + Ios.stateName(Ios.GOOD_STATE));
    } else {
        io::println("PASS: stateName good works");
    }
}

public fn test_state_name_bad(): void {
    let name: string = Ios.stateName(Ios.BAD_STATE);
    if (String.contains(name, "bad")) {
        io::println("PASS: stateName bad works");
    } else {
        io::println("FAIL: stateName bad = " + name);
    }
}

public fn test_flags_name_hex(): void {
    let name: string = Ios.flagsName(Ios.FMT_HEX);
    if (String.contains(name, "hex")) {
        io::println("PASS: flagsName hex works");
    } else {
        io::println("FAIL: flagsName hex = " + name);
    }
}

public fn test_flags_name_default(): void {
    if (Ios.flagsName(0) != "default") {
        io::println("FAIL: flagsName default wrong");
    } else {
        io::println("PASS: flagsName default works");
    }
}

public fn test_ios_base_setf_masked(): void {
    let base: IosBase = new IosBase();
    base.setfMasked(Ios.FMT_HEX, Ios.FMT_BASEFIELD);
    if (!base.isHex()) {
        io::println("FAIL: setfMasked hex failed");
    } else {
        io::println("PASS: IosBase setfMasked works");
    }
}

public fn test_ios_base_to_format_state(): void {
    let base: IosBase = new IosBase();
    base.setf(Ios.FMT_HEX);
    base.setf(Ios.FMT_BOOLALPHA);
    let fs: FormatState = base.toFormatState();
    if (fs.base != 16) {
        io::println("FAIL: toFormatState base = " + fs.base);
    } else if (!fs.boolAlpha) {
        io::println("FAIL: toFormatState boolAlpha");
    } else {
        io::println("PASS: IosBase toFormatState works");
    }
}

public fn test_ios_base_flag_checkers(): void {
    let base: IosBase = new IosBase();
    if (!base.isDec()) {
        io::println("FAIL: default should be dec");
    } else if (base.isLeft() || base.isRight()) {
        io::println("FAIL: default should not be left/right");
    } else {
        io::println("PASS: IosBase flag checkers work");
    }
}

public fn run_all_ios_tests(): void {
    io::println("=== Ios.tr Tests ===");
    test_fmtflags_constants();
    test_iostate_constants();
    test_openmode_constants();
    test_seekdir_constants();
    test_ios_base_init();
    test_ios_base_setf();
    test_ios_base_unsetf();
    test_ios_base_flags();
    test_ios_base_set_precision();
    test_ios_base_set_width();
    test_ios_base_set_fill();
    test_ios_base_state_management();
    test_ios_base_bool_value();
    test_basic_ios_init();
    test_basic_ios_rdbuf();
    test_basic_ios_set_rdbuf();
    test_basic_ios_tie();
    test_basic_ios_set_tie();
    test_basic_ios_set_bad();
    test_basic_ios_set_fail();
    test_basic_ios_set_eof();
    test_basic_ios_get_without_buffer();
    test_basic_ios_put_without_buffer();
    test_ios_factory();
    test_wios_factory();
    test_throw_if_bad_no_mask();
    test_throw_if_bad_with_badbit();
    test_state_name_good();
    test_state_name_bad();
    test_flags_name_hex();
    test_flags_name_default();
    test_ios_base_setf_masked();
    test_ios_base_to_format_state();
    test_ios_base_flag_checkers();
}
