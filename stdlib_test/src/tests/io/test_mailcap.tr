// Test file for io/Mailcap.tr
// Exercises getcaps, readmailcapfile, findmatch.
import tt::io::Mailcap;
import tt::util::ArrayList;
import tt::util::HashMap;
import tt::lang::String;
import tt::io::File;

public fn test_read_mailcap_missing_file(): void {
    // Should not crash on missing file
    Mailcap.readmailcapfile("nonexistent_mailcap_file.txt");
    io::println("PASS: readmailcapfile missing file works");
}

public fn test_getcaps(): void {
    let caps: HashMap<string, ArrayList<HashMap<string, string>>> = Mailcap.getcaps();
    if (caps == null) {
        io::println("FAIL: getcaps returned null");
    } else {
        io::println("PASS: getcaps works (" + caps.size() + " entries)");
    }
}

public fn test_read_mailcap_file(): void {
    let path: string = "test_mailcap.txt";
    File_writeFile(path, "text/plain; cat %s; description=Plain Text\n");
    Mailcap.readmailcapfile(path);
    let caps: HashMap<string, ArrayList<HashMap<string, string>>> = Mailcap.getcaps();
    if (!caps.containsKey("text/plain")) {
        io::println("FAIL: text/plain should be in caps after reading");
    } else {
        io::println("PASS: readmailcapfile works");
    }
    Fs_deleteFile(path);
}

public fn test_findmatch_missing_type(): void {
    let caps: HashMap<string, ArrayList<HashMap<string, string>>> = Mailcap.getcaps();
    let (cmd: string, entry: HashMap<string, string>) = Mailcap.findmatch(caps, "application/x-nonexistent", "view", "");
    if (String.length(cmd) != 0) {
        io::println("FAIL: findmatch on missing type should return empty");
    } else {
        io::println("PASS: findmatch missing type works");
    }
}

public fn test_findmatch_empty_caps(): void {
    let caps: HashMap<string, ArrayList<HashMap<string, string>>> = new HashMap<string, ArrayList<HashMap<string, string>>>();
    let (cmd: string, entry: HashMap<string, string>) = Mailcap.findmatch(caps, "text/plain", "view", "");
    if (String.length(cmd) != 0) {
        io::println("FAIL: findmatch empty caps should return empty");
    } else {
        io::println("PASS: findmatch empty caps works");
    }
}

public fn test_findmatch_substitute(): void {
    let caps: HashMap<string, ArrayList<HashMap<string, string>>> = new HashMap<string, ArrayList<HashMap<string, string>>>();
    let entries: ArrayList<HashMap<string, string>> = new ArrayList<HashMap<string, string>>();
    let entry: HashMap<string, string> = new HashMap<string, string>();
    entry.put("view", "cat %s");
    entries.add(entry);
    caps.put("text/plain", entries);
    let (cmd: string, found: HashMap<string, string>) = Mailcap.findmatch(caps, "text/plain", "view", "myfile.txt");
    if (cmd != "cat myfile.txt") {
        io::println("FAIL: findmatch substitute = " + cmd);
    } else {
        io::println("PASS: findmatch substitute works");
    }
}

public fn test_read_mailcap_empty_file(): void {
    let path: string = "test_mailcap_empty.txt";
    File_writeFile(path, "");
    Mailcap.readmailcapfile(path);
    io::println("PASS: readmailcapfile empty file works");
    Fs_deleteFile(path);
}

public fn test_read_mailcap_comment(): void {
    let path: string = "test_mailcap_comment.txt";
    File_writeFile(path, "# this is a comment\n");
    Mailcap.readmailcapfile(path);
    io::println("PASS: readmailcapfile with comment works");
    Fs_deleteFile(path);
}

public fn run_all_mailcap_tests(): void {
    io::println("=== Mailcap.tr Tests ===");
    test_read_mailcap_missing_file();
    test_getcaps();
    test_read_mailcap_file();
    test_findmatch_missing_type();
    test_findmatch_empty_caps();
    test_findmatch_substitute();
    test_read_mailcap_empty_file();
    test_read_mailcap_comment();
}
