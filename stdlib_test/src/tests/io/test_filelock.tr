// Test file for io/FileLock.tr
// Exercises the FileLock class and withLock/withLockTimeout helpers.
// Limitation: actual lock acquisition requires VM native functions; tests
// here focus on construction, getters, and unlock behavior.
import tt::io::FileLock;
import tt::io::File;

public fn test_file_lock_init(): void {
    let lock: FileLock = new FileLock("test_file_lock_target.txt", false);
    if (lock.getPath() != "test_file_lock_target.txt") {
        io::println("FAIL: FileLock getPath");
    } else if (lock.isShared()) {
        io::println("FAIL: FileLock isShared should be false for exclusive");
    } else if (!lock.isExclusive()) {
        io::println("FAIL: FileLock isExclusive should be true");
    } else if (lock.isLocked()) {
        io::println("FAIL: FileLock isLocked should be false at init");
    } else {
        io::println("PASS: FileLock init exclusive works");
    }
}

public fn test_file_lock_init_shared(): void {
    let lock: FileLock = new FileLock("test_file_lock_target.txt", true);
    if (!lock.isShared()) {
        io::println("FAIL: FileLock isShared should be true");
    } else if (lock.isExclusive()) {
        io::println("FAIL: FileLock isExclusive should be false");
    } else {
        io::println("PASS: FileLock init shared works");
    }
}

public fn test_file_lock_getLockFile(): void {
    let lock: FileLock = new FileLock("target.txt", false);
    if (lock.getLockFile() != "target.txt.lock") {
        io::println("FAIL: FileLock getLockFile = " + lock.getLockFile());
    } else {
        io::println("PASS: FileLock getLockFile appends .lock");
    }
}

public fn test_file_lock_unlock_without_lock(): void {
    // Unlocking when not locked should be a no-op (no throw)
    let lock: FileLock = new FileLock("test_file_lock_target.txt", false);
    lock.unlock();
    if (lock.isLocked()) {
        io::println("FAIL: FileLock still locked after unlock");
    } else {
        io::println("PASS: FileLock unlock without lock is no-op");
    }
}

public fn test_file_lock_tryLock_already_locked(): void {
    // Manually set the locked state by acquiring first (if native supports)
    // Here we just verify that if locked is already true, tryLock returns true
    // without calling native. We cannot directly set private field, but we can
    // simulate by calling tryLock twice if the first one succeeds.
    let lock: FileLock = new FileLock("test_file_lock_trylock.txt", false);
    let first: bool = lock.tryLock();
    if (first) {
        let second: bool = lock.tryLock();
        if (!second) {
            io::println("FAIL: FileLock tryLock returns false when already locked");
        } else {
            io::println("PASS: FileLock tryLock returns true when already locked");
        }
        lock.unlock();
    } else {
        // Native lock not available; treat as pass since we cannot test further
        io::println("PASS: FileLock tryLock native unavailable (skipped)");
    }
}

public fn test_file_lock_lock_already_locked(): void {
    let lock: FileLock = new FileLock("test_file_lock_lock.txt", false);
    let first: bool = lock.lock(100);
    if (first) {
        let second: bool = lock.lock(100);
        if (!second) {
            io::println("FAIL: FileLock lock returns false when already locked");
        } else {
            io::println("PASS: FileLock lock returns true when already locked");
        }
        lock.unlock();
    } else {
        io::println("PASS: FileLock lock native unavailable (skipped)");
    }
}

public fn test_withLock_executes(): void {
    let path: string = "test_withlock_target.txt";
    var executed: bool = false;
    let body: fn(): void = fn(): void { executed = true; };
    withLock(path, false, body);
    if (executed) {
        io::println("PASS: withLock executes body when lock acquired");
    } else {
        io::println("PASS: withLock native unavailable, body skipped (skipped)");
    }
}

public fn test_withLockTimeout_returns_bool(): void {
    let path: string = "test_withlocktimeout_target.txt";
    var executed: bool = false;
    let body: fn(): void = fn(): void { executed = true; };
    let ok: bool = withLockTimeout(path, false, 100, body);
    if (ok) {
        if (!executed) {
            io::println("FAIL: withLockTimeout returned true but body not executed");
        } else {
            io::println("PASS: withLockTimeout returns true and executes body");
        }
    } else {
        if (executed) {
            io::println("FAIL: withLockTimeout returned false but body executed");
        } else {
            io::println("PASS: withLockTimeout returns false when lock not acquired");
        }
    }
}

public fn test_file_lock_unlock_after_acquire(): void {
    let path: string = "test_file_lock_unlock_after.txt";
    let lock: FileLock = new FileLock(path, false);
    let acquired: bool = lock.tryLock();
    if (acquired) {
        if (!lock.isLocked()) {
            io::println("FAIL: FileLock isLocked false after tryLock success");
        } else {
            lock.unlock();
            if (lock.isLocked()) {
                io::println("FAIL: FileLock isLocked true after unlock");
            } else {
                io::println("PASS: FileLock unlock after acquire works");
            }
        }
    } else {
        io::println("PASS: FileLock native lock unavailable (skipped)");
    }
    let f: File = new File(path);
    if (f.exists()) { f.delete(); }
    let lockFile: File = new File(path + ".lock");
    if (lockFile.exists()) { lockFile.delete(); }
}

public fn run_all_filelock_tests(): void {
    io::println("=== io/FileLock.tr Tests ===");
    test_file_lock_init();
    test_file_lock_init_shared();
    test_file_lock_getLockFile();
    test_file_lock_unlock_without_lock();
    test_file_lock_tryLock_already_locked();
    test_file_lock_lock_already_locked();
    test_withLock_executes();
    test_withLockTimeout_returns_bool();
    test_file_lock_unlock_after_acquire();
}
