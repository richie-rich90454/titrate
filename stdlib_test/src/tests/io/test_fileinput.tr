// Test for FileInput — basic construction
import tt::io::FileInput;

public fn test_fileinput_init(): void {
    let fi = new FileInput(null, "r");
    if (fi.lineno() == 0) {
        io::println("PASS: FileInput init works");
    } else {
        io::println("FAIL: FileInput init lineno wrong");
    }
}

public fn run_all_fileinput_tests(): void {
    io::println("=== FileInput.tr Tests ===");
    test_fileinput_init();
}
