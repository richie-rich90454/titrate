// Test file for io/FileInput.tr
// Exercises FileInput class, input, filename, lineno, filelineno, isfirstline,
// isstdin, nextfile, close, readline.
import tt::io::FileInput;
import tt::util::ArrayList;
import tt::lang::String;
import tt::lang::Integer;
import tt::io::File;

public fn test_fileinput_init(): void {
    let fi: FileInput = new FileInput(null, "r");
    if (fi.lineno() != 0) {
        io::println("FAIL: FileInput init lineno wrong");
    } else if (fi.filename() != "") {
        io::println("FAIL: FileInput init filename wrong");
    } else if (fi.isstdin()) {
        io::println("FAIL: FileInput init isstdin wrong");
    } else {
        io::println("PASS: FileInput init works");
    }
}

public fn test_fileinput_init_with_files(): void {
    let files: ArrayList<string> = new ArrayList<string>();
    files.add("test_fi_a.txt");
    files.add("test_fi_b.txt");
    let fi: FileInput = new FileInput(files, "r");
    if (fi.isfirstline()) {
        io::println("FAIL: FileInput init isfirstline wrong");
    } else {
        io::println("PASS: FileInput init with files works");
    }
}

public fn test_fileinput_module_input(): void {
    let fi: FileInput = FileInput.input(null, "r");
    if (fi == null) {
        io::println("FAIL: input returned null");
    } else {
        io::println("PASS: FileInput input works");
    }
}

public fn test_fileinput_module_filename(): void {
    FileInput.input(null, "r");
    let name: string = FileInput.filename();
    if (name != "") {
        io::println("FAIL: filename wrong = " + name);
    } else {
        io::println("PASS: FileInput filename works");
    }
}

public fn test_fileinput_module_lineno(): void {
    FileInput.input(null, "r");
    if (FileInput.lineno() != 0) {
        io::println("FAIL: lineno wrong");
    } else {
        io::println("PASS: FileInput lineno works");
    }
}

public fn test_fileinput_module_filelineno(): void {
    FileInput.input(null, "r");
    if (FileInput.filelineno() != 0) {
        io::println("FAIL: filelineno wrong");
    } else {
        io::println("PASS: FileInput filelineno works");
    }
}

public fn test_fileinput_module_isfirstline(): void {
    FileInput.input(null, "r");
    if (FileInput.isfirstline()) {
        io::println("FAIL: isfirstline should be false");
    } else {
        io::println("PASS: FileInput isfirstline works");
    }
}

public fn test_fileinput_module_isstdin(): void {
    FileInput.input(null, "r");
    if (FileInput.isstdin()) {
        io::println("FAIL: isstdin should be false");
    } else {
        io::println("PASS: FileInput isstdin works");
    }
}

public fn test_fileinput_module_close(): void {
    FileInput.input(null, "r");
    FileInput.close();
    io::println("PASS: FileInput close works");
}

public fn test_fileinput_module_readline(): void {
    FileInput.input(null, "r");
    let line: string = FileInput.readline();
    // No stdin input available, should return null
    if (line != null) {
        io::println("FAIL: readline should be null with no input");
    } else {
        io::println("PASS: FileInput readline returns null with no stdin");
    }
}

public fn test_fileinput_nextfile(): void {
    let files: ArrayList<string> = new ArrayList<string>();
    let fi: FileInput = new FileInput(files, "r");
    if (!fi.nextfile()) {
        io::println("FAIL: nextfile should return false with empty list");
    } else {
        io::println("PASS: FileInput nextfile works");
    }
}

public fn test_fileinput_close_method(): void {
    let fi: FileInput = new FileInput(null, "r");
    fi.close();
    let line: string = fi.nextLine();
    if (line != null) {
        io::println("FAIL: nextLine after close should return null");
    } else {
        io::println("PASS: FileInput close method works");
    }
}

public fn test_fileinput_read_with_file(): void {
    let path: string = "test_fi_read.txt";
    File_writeFile(path, "line1\nline2\nline3\n");
    let files: ArrayList<string> = new ArrayList<string>();
    files.add(path);
    let fi: FileInput = new FileInput(files, "r");
    let l1: string = fi.nextLine();
    if (l1 != "line1") {
        io::println("FAIL: first line = " + (l1 == null ? "null" : l1));
    } else {
        io::println("PASS: FileInput read file works");
    }
    fi.close();
    Fs_deleteFile(path);
}

public fn run_all_fileinput_tests(): void {
    io::println("=== FileInput.tr Tests ===");
    test_fileinput_init();
    test_fileinput_init_with_files();
    test_fileinput_module_input();
    test_fileinput_module_filename();
    test_fileinput_module_lineno();
    test_fileinput_module_filelineno();
    test_fileinput_module_isfirstline();
    test_fileinput_module_isstdin();
    test_fileinput_module_close();
    test_fileinput_module_readline();
    test_fileinput_nextfile();
    test_fileinput_close_method();
    test_fileinput_read_with_file();
}
