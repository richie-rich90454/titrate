// Test for FileCmp — basic construction
import tt::io::FileCmp;

public fn test_cmp_missing(): void {
    let result = FileCmp.cmp("nonexistent_a.txt", "nonexistent_b.txt", true);
    if (result) {
        io::println("FAIL: cmp missing files should return false");
    } else {
        io::println("PASS: cmp on missing files returns false");
    }
}

public fn run_all_filecmp_tests(): void {
    io::println("=== FileCmp.tr Tests ===");
    test_cmp_missing();
}
