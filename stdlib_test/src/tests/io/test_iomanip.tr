// Test file for io/Iomanip.tr
// Exercises FormatState, Manipulator, setw, setprecision, setfill, setbase,
// hex, dec, oct, fixed, scientific, boolalpha, noboolalpha, showpoint,
// noshowpoint, put_money, get_money, put_time, get_time, quoted, applyAll.
import tt::io::Iomanip;
import tt::util::ArrayList;
import tt::lang::String;
import tt::lang::Integer;

public fn test_format_state_init(): void {
    let fs: FormatState = new FormatState();
    if (fs.width != 0) {
        io::println("FAIL: FormatState initial width wrong");
    } else if (fs.precision != 6) {
        io::println("FAIL: FormatState initial precision wrong");
    } else if (fs.base != 10) {
        io::println("FAIL: FormatState initial base wrong");
    } else if (fs.fillChar != " ") {
        io::println("FAIL: FormatState initial fillChar wrong");
    } else {
        io::println("PASS: FormatState init works");
    }
}

public fn test_format_state_copy(): void {
    let fs: FormatState = new FormatState();
    fs.width = 10;
    let copy: FormatState = fs.copy();
    if (copy.width != 10) {
        io::println("FAIL: FormatState copy width wrong");
    } else {
        io::println("PASS: FormatState copy works");
    }
    // Verify independence
    fs.width = 20;
    if (copy.width != 10) {
        io::println("FAIL: FormatState copy should be independent");
    } else {
        io::println("PASS: FormatState copy independent");
    }
}

public fn test_setw(): void {
    let m: SetWManip = Iomanip.setw(15);
    if (m.name != "setw") {
        io::println("FAIL: setw name wrong");
    } else {
        io::println("PASS: setw created");
    }
    let fs: FormatState = new FormatState();
    m.apply(fs);
    if (fs.width != 15) {
        io::println("FAIL: setw apply width = " + fs.width);
    } else {
        io::println("PASS: setw apply works");
    }
}

public fn test_setprecision(): void {
    let m: SetPrecisionManip = Iomanip.setprecision(3);
    let fs: FormatState = new FormatState();
    m.apply(fs);
    if (fs.precision != 3) {
        io::println("FAIL: setprecision = " + fs.precision);
    } else {
        io::println("PASS: setprecision works");
    }
}

public fn test_setfill(): void {
    let m: SetFillManip = Iomanip.setfill("*");
    let fs: FormatState = new FormatState();
    m.apply(fs);
    if (fs.fillChar != "*") {
        io::println("FAIL: setfill wrong");
    } else {
        io::println("PASS: setfill works");
    }
}

public fn test_setfill_empty(): void {
    let m: SetFillManip = Iomanip.setfill("");
    let fs: FormatState = new FormatState();
    m.apply(fs);
    if (fs.fillChar != " ") {
        io::println("FAIL: setfill empty should not change");
    } else {
        io::println("PASS: setfill empty does nothing");
    }
}

public fn test_setbase(): void {
    let m16: SetBaseManip = Iomanip.setbase(16);
    let m8: SetBaseManip = Iomanip.setbase(8);
    let fs: FormatState = new FormatState();
    m16.apply(fs);
    if (fs.base != 16) {
        io::println("FAIL: setbase 16 = " + fs.base);
    } else {
        io::println("PASS: setbase 16 works");
    }
    m8.apply(fs);
    if (fs.base != 8) {
        io::println("FAIL: setbase 8 = " + fs.base);
    } else {
        io::println("PASS: setbase 8 works");
    }
}

public fn test_setbase_invalid(): void {
    let m: SetBaseManip = Iomanip.setbase(7);
    let fs: FormatState = new FormatState();
    m.apply(fs);
    if (fs.base != 10) {
        io::println("FAIL: setbase invalid should keep default");
    } else {
        io::println("PASS: setbase invalid ignored");
    }
}

