}

public fn test_get_money_parse(): void {
    let gm: GetMoneyManip = Iomanip.get_money("$123.45", false);
    if (!gm.parse()) {
        io::println("FAIL: get_money parse returned false");
    } else if (gm.cents != 12345) {
        io::println("FAIL: get_money cents = " + gm.cents);
    } else {
        io::println("PASS: get_money parse works");
    }
}

public fn test_get_money_parse_international(): void {
    let gm: GetMoneyManip = Iomanip.get_money("678.90 XXX", true);
    if (!gm.parse()) {
        io::println("FAIL: get_money intl parse returned false");
    } else if (gm.cents != 67890) {
        io::println("FAIL: get_money intl cents = " + gm.cents);
    } else {
        io::println("PASS: get_money international parse works");
    }
}

public fn test_get_money_parse_negative(): void {
    let gm: GetMoneyManip = Iomanip.get_money("-$5.00", false);
    if (!gm.parse()) {
        io::println("FAIL: get_money negative parse returned false");
    } else if (gm.cents != -500) {
        io::println("FAIL: get_money negative cents = " + gm.cents);
    } else {
        io::println("PASS: get_money negative parse works");
    }
}

public fn test_get_money_parse_null(): void {
    let gm: GetMoneyManip = Iomanip.get_money(null, false);
    if (gm.parse()) {
        io::println("FAIL: get_money null should not parse");
    } else {
        io::println("PASS: get_money null parse returns false");
    }
}

public fn test_put_time(): void {
    let pt: PutTimeManip = Iomanip.put_time(0, "%Y-%m-%d");
    let formatted: string = pt.format();
    if (String.length(formatted) == 0) {
        io::println("FAIL: put_time returned empty");
    } else {
        io::println("PASS: put_time works (" + formatted + ")");
    }
}

public fn test_get_time(): void {
    let gt: GetTimeManip = Iomanip.get_time("2025-01-15", "%Y-%m-%d");
    if (!gt.parse()) {
        io::println("FAIL: get_time parse returned false");
    } else {
        io::println("PASS: get_time parse works");
    }
}

public fn test_get_time_null(): void {
    let gt: GetTimeManip = Iomanip.get_time(null, "%Y");
    if (gt.parse()) {
        io::println("FAIL: get_time null should not parse");
    } else {
        io::println("PASS: get_time null parse returns false");
    }
}

public fn test_quoted_default(): void {
    let q: QuotedManip = Iomanip.quoted("hello");
    let formatted: string = q.format();
    if (formatted != "\"hello\"") {
        io::println("FAIL: quoted default = " + formatted);
    } else {
        io::println("PASS: quoted default works");
    }
}

public fn test_quoted_with_embedded_quote(): void {
    let q: QuotedManip = Iomanip.quoted("say \"hi\"", "\"", "\\");
    let formatted: string = q.format();
    if (formatted != "\"say \\\"hi\\\"\"") {
        io::println("FAIL: quoted with embedded quote = " + formatted);
    } else {
        io::println("PASS: quoted with embedded quote works");
    }
}

public fn test_quoted_custom_delimiter(): void {
    let q: QuotedManip = Iomanip.quoted("test", "'", "\\");
    let formatted: string = q.format();
    if (formatted != "'test'") {
        io::println("FAIL: quoted custom delimiter = " + formatted);
    } else {
        io::println("PASS: quoted custom delimiter works");
    }
}

public fn test_quoted_null(): void {
    let q: QuotedManip = Iomanip.quoted(null);
    let formatted: string = q.format();
    if (formatted != "\"\"") {
        io::println("FAIL: quoted null = " + formatted);
    } else {
        io::println("PASS: quoted null works");
    }
}

public fn test_apply_all(): void {
    let fs: FormatState = new FormatState();
    let manips: ArrayList<Manipulator> = new ArrayList<Manipulator>();
    manips.add(Iomanip.setw(20));
    manips.add(Iomanip.setprecision(4));
    manips.add(Iomanip.setfill("0"));
    manips.add(Iomanip.hex());
    Iomanip.applyAll(fs, manips);
    if (fs.width != 20 || fs.precision != 4) {
        io::println("FAIL: applyAll width/precision");
    } else if (fs.fillChar != "0") {
        io::println("FAIL: applyAll fillChar");
    } else if (fs.base != 16) {
        io::println("FAIL: applyAll base = " + fs.base);
    } else {
        io::println("PASS: applyAll works");
    }
}

public fn test_apply_all_null_manip(): void {
    let fs: FormatState = new FormatState();
    let manips: ArrayList<Manipulator> = new ArrayList<Manipulator>();
    manips.add(null);
    // Should not crash with null entry
    Iomanip.applyAll(fs, manips);
    io::println("PASS: applyAll with null manip works");
}

public fn test_manipulator_to_string(): void {
    let m: Manipulator = Iomanip.hex();
    let s: string = m.toString();
    if (String.contains(s, "hex")) {
        io::println("PASS: Manipulator toString works");
    } else {
        io::println("FAIL: Manipulator toString = " + s);
    }
}

public fn run_all_iomanip_tests(): void {
    io::println("=== Iomanip.tr Tests ===");
    test_format_state_init();
    test_format_state_copy();
    test_setw();
    test_setprecision();
    test_setfill();
    test_setfill_empty();
    test_setbase();
    test_setbase_invalid();
    test_hex_manip();
    test_dec_manip();
    test_oct_manip();
    test_fixed_manip();
    test_scientific_manip();
    test_boolalpha_manip();
    test_noboolalpha_manip();
    test_showpoint_manip();
    test_noshowpoint_manip();
    test_put_money_domestic();
    test_put_money_international();
    test_put_money_negative();
    test_put_money_default_intl();
    test_get_money_parse();
    test_get_money_parse_international();
    test_get_money_parse_negative();
    test_get_money_parse_null();
    test_put_time();
    test_get_time();
    test_get_time_null();
    test_quoted_default();
    test_quoted_with_embedded_quote();
    test_quoted_custom_delimiter();
    test_quoted_null();
    test_apply_all();
    test_apply_all_null_manip();
    test_manipulator_to_string();
}
