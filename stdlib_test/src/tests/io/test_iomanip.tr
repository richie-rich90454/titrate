public fn test_put_money_domestic(): void {
    let pm: PutMoneyManip = Iomanip.put_money(12345, false);
    let formatted: string = pm.format();
    if (formatted != "$123.45") {
        io::println("FAIL: put_money domestic = " + formatted);
    } else {
        io::println("PASS: put_money domestic works");
    }
}

public fn test_put_money_international(): void {
    let pm: PutMoneyManip = Iomanip.put_money(67890, true);
    let formatted: string = pm.format();
    if (formatted != "678.90 XXX") {
        io::println("FAIL: put_money intl = " + formatted);
    } else {
        io::println("PASS: put_money international works");
    }
}

public fn test_put_money_negative(): void {
    let pm: PutMoneyManip = Iomanip.put_money(-500, false);
    let formatted: string = pm.format();
    if (formatted != "-$5.00") {
        io::println("FAIL: put_money negative = " + formatted);
    } else {
        io::println("PASS: put_money negative works");
    }
}

public fn test_put_money_default_intl(): void {
    let pm: PutMoneyManip = Iomanip.put_money(999);
    let formatted: string = pm.format();
    if (formatted != "$9.99") {
        io::println("FAIL: put_money default = " + formatted);
    } else {
        io::println("PASS: put_money default works");
