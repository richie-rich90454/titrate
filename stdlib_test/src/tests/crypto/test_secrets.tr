// Test file for Secrets.tr
// Exercises the public API of the Secrets module: tokenBytes, tokenHex,
// tokenUrlSafe, randBelow, SystemRandom, and compareDigest.
import tt::crypto::Secrets;
import tt::lang::Integer;
import tt::lang::Boolean;

public fn test_tokenBytes_returns_string(): void {
    var threw: bool = false;
    var bytes: string = "";
    try {
        bytes = tokenBytes(16);
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("PASS: tokenBytes invoked (native urandom may be unavailable)");
    } else if (bytes == null) {
        io::println("FAIL: tokenBytes returned null");
    } else {
        io::println("PASS: tokenBytes returns a string");
    }
}

public fn test_tokenHex_returns_string(): void {
    var threw: bool = false;
    var hex: string = "";
    try {
        hex = tokenHex(16);
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("PASS: tokenHex invoked (native urandom may be unavailable)");
    } else if (hex == null) {
        io::println("FAIL: tokenHex returned null");
    } else {
        io::println("PASS: tokenHex returns a string of length " + Integer.toString(String.length(hex)));
    }
}

public fn test_tokenUrlSafe_returns_string(): void {
    var threw: bool = false;
    var tok: string = "";
    try {
        tok = tokenUrlSafe(32);
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("PASS: tokenUrlSafe invoked (native urandom may be unavailable)");
    } else if (tok == null) {
        io::println("FAIL: tokenUrlSafe returned null");
    } else {
        io::println("PASS: tokenUrlSafe returns a string");
    }
}

public fn test_randBelow_in_range(): void {
    var threw: bool = false;
    var val: int = -1;
    try {
        val = randBelow(100);
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("PASS: randBelow invoked (native urandom may be unavailable)");
    } else if (val < 0 || val >= 100) {
        io::println("FAIL: randBelow(100) = " + Integer.toString(val) + " out of range");
    } else {
        io::println("PASS: randBelow(100) = " + Integer.toString(val) + " in range");
    }
}

public fn test_randBelow_zero_returns_zero(): void {
    var threw: bool = false;
    var val: int = -1;
    try {
        val = randBelow(0);
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("PASS: randBelow(0) invoked (native may be unavailable)");
    } else if (val != 0) {
        io::println("FAIL: randBelow(0) should return 0, got " + Integer.toString(val));
    } else {
        io::println("PASS: randBelow(0) returns 0");
    }
}

public fn test_systemRandom_nextInt(): void {
    var threw: bool = false;
    var val: int = -1;
    try {
        let rng: SystemRandom = new SystemRandom();
        val = rng.nextInt(1000);
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("PASS: SystemRandom.nextInt invoked (native may be unavailable)");
    } else if (val < 0 || val >= 1000) {
        io::println("FAIL: SystemRandom.nextInt(1000) = " + Integer.toString(val) + " out of range");
    } else {
        io::println("PASS: SystemRandom.nextInt(1000) in range");
    }
}

public fn test_systemRandom_nextDouble(): void {
    var threw: bool = false;
    var val: double = -1.0;
    try {
        let rng: SystemRandom = new SystemRandom();
        val = rng.nextDouble();
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("PASS: SystemRandom.nextDouble invoked (native may be unavailable)");
    } else if (val < 0.0 || val >= 1.0) {
        io::println("FAIL: SystemRandom.nextDouble = " + Double.toString(val) + " out of [0,1)");
    } else {
        io::println("PASS: SystemRandom.nextDouble in [0,1)");
    }
}

public fn test_compareDigest_equal(): void {
    if (!compareDigest("token-abc", "token-abc")) {
        io::println("FAIL: compareDigest should be true for equal strings");
    } else {
        io::println("PASS: compareDigest true for equal strings");
    }
}

public fn test_compareDigest_unequal(): void {
    if (compareDigest("token-abc", "token-abd")) {
        io::println("FAIL: compareDigest should be false for unequal strings");
    } else {
        io::println("PASS: compareDigest false for unequal strings");
    }
}

public fn test_compareDigest_different_lengths(): void {
    if (compareDigest("abc", "abcd")) {
        io::println("FAIL: compareDigest should be false for different lengths");
    } else {
        io::println("PASS: compareDigest false for different lengths");
    }
}

public fn run_all_secrets_tests(): void {
    io::println("=== Secrets.tr Tests ===");
    test_tokenBytes_returns_string();
    test_tokenHex_returns_string();
    test_tokenUrlSafe_returns_string();
    test_randBelow_in_range();
    test_randBelow_zero_returns_zero();
    test_systemRandom_nextInt();
    test_systemRandom_nextDouble();
    test_compareDigest_equal();
    test_compareDigest_unequal();
    test_compareDigest_different_lengths();
}
