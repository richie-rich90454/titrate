// Test file for Hmac.tr
// Exercises the public API of the Hmac module: sha256, sha512, md5, sha1,
// sha384, sha3_256, compareDigest, and the *Bytes variants.
import tt::crypto::Hmac;
import tt::lang::Integer;
import tt::lang::Boolean;

public fn test_sha256_deterministic(): void {
    let h1: string = sha256("secret-key", "message");
    let h2: string = sha256("secret-key", "message");
    if (h1 != h2) {
        io::println("FAIL: Hmac.sha256 not deterministic");
    } else {
        io::println("PASS: Hmac.sha256 deterministic");
    }
}

public fn test_sha256_different_keys_differ(): void {
    let h1: string = sha256("key1", "message");
    let h2: string = sha256("key2", "message");
    if (h1 == h2) {
        io::println("FAIL: Hmac.sha256 should differ for different keys");
    } else {
        io::println("PASS: Hmac.sha256 differs for different keys");
    }
}

public fn test_sha256_different_messages_differ(): void {
    let h1: string = sha256("key", "msg1");
    let h2: string = sha256("key", "msg2");
    if (h1 == h2) {
        io::println("FAIL: Hmac.sha256 should differ for different messages");
    } else {
        io::println("PASS: Hmac.sha256 differs for different messages");
    }
}

public fn test_sha512_deterministic(): void {
    let h1: string = sha512("k", "m");
    let h2: string = sha512("k", "m");
    if (h1 != h2) {
        io::println("FAIL: Hmac.sha512 not deterministic");
    } else {
        io::println("PASS: Hmac.sha512 deterministic");
    }
}

public fn test_md5_deterministic(): void {
    let h1: string = md5("k", "m");
    let h2: string = md5("k", "m");
    if (h1 != h2) {
        io::println("FAIL: Hmac.md5 not deterministic");
    } else {
        io::println("PASS: Hmac.md5 deterministic");
    }
}

public fn test_sha1_deterministic(): void {
    let h1: string = sha1("k", "m");
    let h2: string = sha1("k", "m");
    if (h1 != h2) {
        io::println("FAIL: Hmac.sha1 not deterministic");
    } else {
        io::println("PASS: Hmac.sha1 deterministic");
    }
}

public fn test_sha384_deterministic(): void {
    let h1: string = sha384("k", "m");
    let h2: string = sha384("k", "m");
    if (h1 != h2) {
        io::println("FAIL: Hmac.sha384 not deterministic");
    } else {
        io::println("PASS: Hmac.sha384 deterministic");
    }
}

public fn test_sha3_256_deterministic(): void {
    let h1: string = sha3_256("k", "m");
    let h2: string = sha3_256("k", "m");
    if (h1 != h2) {
        io::println("FAIL: Hmac.sha3_256 not deterministic");
    } else {
        io::println("PASS: Hmac.sha3_256 deterministic");
    }
}

public fn test_compareDigest_equal(): void {
    if (!compareDigest("abc", "abc")) {
        io::println("FAIL: compareDigest should be true for equal strings");
    } else {
        io::println("PASS: compareDigest true for equal strings");
    }
}

public fn test_compareDigest_unequal(): void {
    if (compareDigest("abc", "abd")) {
        io::println("FAIL: compareDigest should be false for unequal strings");
    } else {
        io::println("PASS: compareDigest false for unequal strings");
    }
}

public fn test_compareDigest_different_lengths(): void {
    if (compareDigest("abc", "abcd")) {
        io::println("FAIL: compareDigest should be false for different lengths");
    } else {
        io::println("PASS: compareDigest false for different lengths");
    }
}

public fn test_sha256Bytes_returns_string(): void {
    let bytes: string = sha256Bytes("key", "msg");
    if (bytes == null) {
        io::println("FAIL: sha256Bytes returned null");
    } else {
        // Raw bytes should be shorter than the hex digest (32 vs 64 chars)
        io::println("PASS: sha256Bytes returns a string of length " + Integer.toString(String.length(bytes)));
    }
}

public fn test_sha512Bytes_returns_string(): void {
    let bytes: string = sha512Bytes("key", "msg");
    if (bytes == null) {
        io::println("FAIL: sha512Bytes returned null");
    } else {
        io::println("PASS: sha512Bytes returns a string of length " + Integer.toString(String.length(bytes)));
    }
}

public fn test_long_key_hashed(): void {
    // Keys longer than the block size (64 for sha256) should be hashed first.
    let longKey: string = "this is a very long key that exceeds the block size of 64 bytes for sure yes indeed it does";
    let h1: string = sha256(longKey, "msg");
    let h2: string = sha256(longKey, "msg");
    if (h1 != h2) {
        io::println("FAIL: Hmac.sha256 not deterministic for long key");
    } else {
        io::println("PASS: Hmac.sha256 handles long keys");
    }
}

public fn run_all_hmac_tests(): void {
    io::println("=== Hmac.tr Tests ===");
    test_sha256_deterministic();
    test_sha256_different_keys_differ();
    test_sha256_different_messages_differ();
    test_sha512_deterministic();
    test_md5_deterministic();
    test_sha1_deterministic();
    test_sha384_deterministic();
    test_sha3_256_deterministic();
    test_compareDigest_equal();
    test_compareDigest_unequal();
    test_compareDigest_different_lengths();
    test_sha256Bytes_returns_string();
    test_sha512Bytes_returns_string();
    test_long_key_hashed();
}
