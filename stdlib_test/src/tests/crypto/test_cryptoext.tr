        io::println("FAIL: chacha20Poly1305Decrypt returned null");
    } else {
        io::println("PASS: chacha20Poly1305Decrypt returns a string");
    }
}

public fn test_hkdfExtract_callable(): void {
    var threw: bool = false;
    var prk: string = "";
    try {
        prk = hkdfExtract("salt", "input-keying-material");
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("PASS: hkdfExtract invoked (native may be unavailable)");
    } else if (prk == null) {
        io::println("FAIL: hkdfExtract returned null");
    } else {
        io::println("PASS: hkdfExtract returns a string");
    }
}

public fn test_hkdfExpand_callable(): void {
    var threw: bool = false;
    var okm: string = "";
    try {
        okm = hkdfExpand("prk", "info", 32);
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("PASS: hkdfExpand invoked (native may be unavailable)");
    } else if (okm == null) {
        io::println("FAIL: hkdfExpand returned null");
    } else {
        io::println("PASS: hkdfExpand returns a string");
    }
}

public fn run_all_cryptoext_tests(): void {
    io::println("=== CryptoExt.tr Tests ===");
    test_constantTimeEquals_equal();
    test_constantTimeEquals_unequal();
    test_constantTimeEquals_different_lengths();
    test_constantTimeCompare_equal();
    test_constantTimeCompare_unequal();
    test_ed25519Sign_callable();
    test_ed25519Verify_callable();
    test_curve25519KeyExchange_callable();
    test_chacha20Poly1305Encrypt_callable();
    test_chacha20Poly1305Decrypt_callable();
    test_hkdfExtract_callable();
    test_hkdfExpand_callable();
}
