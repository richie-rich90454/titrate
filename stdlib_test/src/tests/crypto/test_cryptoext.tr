// Test file for CryptoExt.tr
// Exercises the public API of the CryptoExt module: Ed25519 sign/verify,
// Curve25519 key exchange, ChaCha20-Poly1305 encrypt/decrypt, HKDF, and
// constant-time comparison functions.
import tt::crypto::CryptoExt;
import tt::lang::Boolean;

public fn test_constantTimeEquals_equal(): void {
    if (!constantTimeEquals("abcdef", "abcdef")) {
        io::println("FAIL: constantTimeEquals should be true for equal strings");
    } else {
        io::println("PASS: constantTimeEquals true for equal strings");
    }
}

public fn test_constantTimeEquals_unequal(): void {
    if (constantTimeEquals("abcdef", "abcdez")) {
        io::println("FAIL: constantTimeEquals should be false for unequal strings");
    } else {
        io::println("PASS: constantTimeEquals false for unequal strings");
    }
}

public fn test_constantTimeEquals_different_lengths(): void {
    if (constantTimeEquals("abc", "abcd")) {
        io::println("FAIL: constantTimeEquals should be false for different lengths");
    } else {
        io::println("PASS: constantTimeEquals false for different lengths");
    }
}

public fn test_constantTimeCompare_equal(): void {
    if (!constantTimeCompare("secret", "secret")) {
        io::println("FAIL: constantTimeCompare should be true for equal strings");
    } else {
        io::println("PASS: constantTimeCompare true for equal strings");
    }
}

public fn test_constantTimeCompare_unequal(): void {
    if (constantTimeCompare("secret", "secreu")) {
        io::println("FAIL: constantTimeCompare should be false for unequal strings");
    } else {
        io::println("PASS: constantTimeCompare false for unequal strings");
    }
}

public fn test_ed25519Sign_callable(): void {
    var threw: bool = false;
    var sig: string = "";
    try {
        sig = ed25519Sign("private-key-data", "message to sign");
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("PASS: ed25519Sign invoked (native may be unavailable)");
    } else if (sig == null) {
        io::println("FAIL: ed25519Sign returned null");
    } else {
        io::println("PASS: ed25519Sign returns a string");
    }
}

public fn test_ed25519Verify_callable(): void {
    var threw: bool = false;
    var result: bool = false;
    try {
        result = ed25519Verify("public-key", "message", "signature");
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("PASS: ed25519Verify invoked (native may be unavailable)");
    } else {
        io::println("PASS: ed25519Verify returns " + Boolean.toString(result));
    }
}

public fn test_curve25519KeyExchange_callable(): void {
    var threw: bool = false;
    var secret: string = "";
    try {
        secret = curve25519KeyExchange("priv", "pub");
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("PASS: curve25519KeyExchange invoked (native may be unavailable)");
    } else if (secret == null) {
        io::println("FAIL: curve25519KeyExchange returned null");
    } else {
        io::println("PASS: curve25519KeyExchange returns a string");
    }
}

public fn test_chacha20Poly1305Encrypt_callable(): void {
    var threw: bool = false;
    var ct: string = "";
    try {
        ct = chacha20Poly1305Encrypt("32-byte-key-32-byte-key-32-byte", "12byte-nonce!", "plaintext");
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("PASS: chacha20Poly1305Encrypt invoked (native may be unavailable)");
    } else if (ct == null) {
        io::println("FAIL: chacha20Poly1305Encrypt returned null");
    } else {
        io::println("PASS: chacha20Poly1305Encrypt returns a string");
    }
}

public fn test_chacha20Poly1305Decrypt_callable(): void {
    var threw: bool = false;
    var pt: string = "";
    try {
        pt = chacha20Poly1305Decrypt("32-byte-key-32-byte-key-32-byte", "12byte-nonce!", "ciphertext");
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("PASS: chacha20Poly1305Decrypt invoked (native may be unavailable)");
