    let opt: RMSProp = new RMSProp(0.01);
    if (absDiff(opt.learningRate, 0.01) > 1e-9) {
        io::println("FAIL: RMSProp learningRate");
    } else {
        io::println("PASS: RMSProp learningRate = 0.01");
    }
    let weights: ArrayList<ArrayList<double>> = makeWeights(1, 2, 1.0);
    let grads: ArrayList<ArrayList<double>> = makeWeights(1, 2, 0.1);
    opt.step(weights, grads);
    if (weights.get(0).get(0) >= 1.0) {
        io::println("FAIL: RMSProp step should decrease weight");
    } else {
        io::println("PASS: RMSProp step decreased weight");
    }
}

public fn test_adagrad(): void {
    let opt: AdaGrad = new AdaGrad(0.1);
    if (absDiff(opt.learningRate, 0.1) > 1e-9) {
        io::println("FAIL: AdaGrad learningRate");
    } else {
        io::println("PASS: AdaGrad learningRate = 0.1");
    }
    let weights: ArrayList<ArrayList<double>> = makeWeights(1, 2, 1.0);
    let grads: ArrayList<ArrayList<double>> = makeWeights(1, 2, 0.1);
    opt.step(weights, grads);
    if (weights.get(0).get(0) >= 1.0) {
        io::println("FAIL: AdaGrad step should decrease weight");
    } else {
        io::println("PASS: AdaGrad step decreased weight");
    }
}

public fn run_all_optimizer_tests(): void {
    io::println("=== ml/Optimizer.tr Tests ===");
    test_sgd_optimizer();
    test_sgd_nesterov();
    test_adam_optimizer();
    test_step_function();
    test_step_lr();
    test_cosine_lr();
    test_warmup_lr();
    test_adamw();
    test_rmsprop();
    test_adagrad();
}
