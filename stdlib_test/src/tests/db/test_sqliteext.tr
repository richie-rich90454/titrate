// Test file for SqliteExt.tr
// Exercises the public API of PreparedStatement, TransactionController,
// BlobReader, and the module-level prepare/walMode/writeBlob/backup functions.
import tt::db::SqliteExt;
import tt::util::ArrayList;
import tt::util::HashMap;
import tt::lang::Variant;
import tt::lang::Integer;

public fn test_prepare_returns_statement(): void {
    let stmt: PreparedStatement = prepare("main", "SELECT 1");
    if (stmt == null) {
        io::println("FAIL: prepare returned null");
    } else if (stmt.sql != "SELECT 1") {
        io::println("FAIL: PreparedStatement.sql = " + stmt.sql);
    } else {
        io::println("PASS: prepare returns PreparedStatement with sql");
    }
}

public fn test_preparedstatement_init_empty_params(): void {
    let stmt: PreparedStatement = new PreparedStatement("INSERT INTO t VALUES (?)");
    if (stmt.params.size() != 0) {
        io::println("FAIL: PreparedStatement.params should be empty on init");
    } else {
        io::println("PASS: PreparedStatement.params empty on init");
    }
}

public fn test_preparedstatement_bindInt(): void {
    let stmt: PreparedStatement = new PreparedStatement("INSERT INTO t VALUES (?)");
    stmt.bindInt(1, 42);
    if (stmt.params.size() != 1) {
        io::println("FAIL: PreparedStatement.params size after bindInt = " + Integer.toString(stmt.params.size()));
    } else {
        io::println("PASS: PreparedStatement.bindInt adds a param");
    }
}

public fn test_preparedstatement_bindString(): void {
    let stmt: PreparedStatement = new PreparedStatement("INSERT INTO t VALUES (?)");
    stmt.bindString(1, "hello");
    if (stmt.params.size() != 1) {
        io::println("FAIL: PreparedStatement.params size after bindString = " + Integer.toString(stmt.params.size()));
    } else {
        io::println("PASS: PreparedStatement.bindString adds a param");
    }
}

public fn test_preparedstatement_bindDouble(): void {
    let stmt: PreparedStatement = new PreparedStatement("INSERT INTO t VALUES (?)");
    stmt.bindDouble(1, 3.14);
    if (stmt.params.size() != 1) {
        io::println("FAIL: PreparedStatement.params size after bindDouble = " + Integer.toString(stmt.params.size()));
    } else {
        io::println("PASS: PreparedStatement.bindDouble adds a param");
    }
}

public fn test_preparedstatement_bindNull(): void {
    let stmt: PreparedStatement = new PreparedStatement("INSERT INTO t VALUES (?, ?)");
    stmt.bindNull(1);
    stmt.bindNull(2);
    if (stmt.params.size() != 2) {
        io::println("FAIL: PreparedStatement.params size after bindNull = " + Integer.toString(stmt.params.size()));
    } else {
        io::println("PASS: PreparedStatement.bindNull adds params");
    }
}

public fn test_preparedstatement_bind_out_of_order(): void {
    // Binding index 3 first should expand the list to size 3
    let stmt: PreparedStatement = new PreparedStatement("INSERT INTO t VALUES (?, ?, ?)");
    stmt.bindInt(3, 30);
    if (stmt.params.size() != 3) {
        io::println("FAIL: PreparedStatement.params size = " + Integer.toString(stmt.params.size()) + " expected 3");
    } else {
        io::println("PASS: PreparedStatement.bind expands params list");
    }
}

public fn test_transactioncontroller_init_state(): void {
    let tc: TransactionController = new TransactionController(":memory:");
    if (tc.isInTransaction()) {
        io::println("FAIL: TransactionController.isInTransaction should be false on init");
    } else {
        io::println("PASS: TransactionController.isInTransaction false on init");
    }
    if (tc.dbPath != ":memory:") {
        io::println("FAIL: TransactionController.dbPath = " + tc.dbPath);
    } else {
        io::println("PASS: TransactionController.dbPath works");
    }
}

public fn test_transactioncontroller_commit_without_begin_throws(): void {
    let tc: TransactionController = new TransactionController(":memory:");
    var threw: bool = false;
    try {
        tc.commit();
    } catch (e: string) {
        threw = true;
        if (String.indexOf(e, "no active transaction") < 0) {
            io::println("FAIL: commit error message = " + e);
        }
    }
    if (!threw) {
        io::println("FAIL: TransactionController.commit should throw when not in transaction");
    } else {
        io::println("PASS: TransactionController.commit throws when not in transaction");
    }
}

public fn test_transactioncontroller_rollback_without_begin_throws(): void {
    let tc: TransactionController = new TransactionController(":memory:");
    var threw: bool = false;
    try {
        tc.rollback();
    } catch (e: string) {
        threw = true;
    }
    if (!threw) {
        io::println("FAIL: TransactionController.rollback should throw when not in transaction");
    } else {
        io::println("PASS: TransactionController.rollback throws when not in transaction");
    }
}

public fn test_transactioncontroller_begin_twice_throws(): void {
    let tc: TransactionController = new TransactionController(":memory:");
    // First begin calls native Sqlite_execute which may fail; we set the flag
    // manually to test the guard. Use try/catch around the first begin in case
    // native fails.
    try {
        tc.begin();
    } catch (e: string) {
        // Native may fail; ignore - we test the inTransaction guard below.
    }
    // Force the in-transaction state to test the double-begin guard
    tc.inTransaction = true;
    var threw: bool = false;
    try {
        tc.begin();
    } catch (e: string) {
        threw = true;
        if (String.indexOf(e, "already in transaction") < 0) {
            io::println("FAIL: double-begin error = " + e);
        }
    }
    if (!threw) {
        io::println("FAIL: TransactionController.begin should throw when already in transaction");
    } else {
        io::println("PASS: TransactionController.begin throws when already in transaction");
    }
}

public fn test_walMode_callable(): void {
    // Native-backed; we verify the function is callable without throwing
    // on a memory database. Wrapped in try/catch in case native is unavailable.
    var threw: bool = false;
    try {
        walMode(":memory:", true);
        walMode(":memory:", false);
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("PASS: walMode invoked (native may have thrown, acceptable)");
    } else {
        io::println("PASS: walMode executes without throwing");
    }
}

public fn test_backup_callable(): void {
    var threw: bool = false;
    try {
        backup(":memory:", "backup_target.db");
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("PASS: backup invoked (native may have thrown, acceptable)");
    } else {
        io::println("PASS: backup executes without throwing");
    }
}

public fn run_all_sqliteext_tests(): void {
    io::println("=== SqliteExt.tr Tests ===");
    test_prepare_returns_statement();
    test_preparedstatement_init_empty_params();
    test_preparedstatement_bindInt();
    test_preparedstatement_bindString();
    test_preparedstatement_bindDouble();
    test_preparedstatement_bindNull();
    test_preparedstatement_bind_out_of_order();
    test_transactioncontroller_init_state();
    test_transactioncontroller_commit_without_begin_throws();
    test_transactioncontroller_rollback_without_begin_throws();
    test_transactioncontroller_begin_twice_throws();
    test_walMode_callable();
    test_backup_callable();
}
