// Test file for finance/FactorModel.tr
// Exercises the public API: capm, famaFrench3, famaFrench5, factorExposure, alphaEstimate.
import tt::finance::FactorModel;
import tt::util::ArrayList;
import tt::util::HashMap;
import tt::lang::Double;
import tt::lang::Integer;

public fn test_capm_basic(): void {
    let result: HashMap<string, double> = capm(0.10, 0.08, 0.02);
    if (!result.containsKey("alpha") || !result.containsKey("beta")) {
        io::println("FAIL: capm missing keys");
    } else {
        io::println("PASS: capm returns alpha and beta");
    }
}

public fn test_capm_beta_calculation(): void {
    // excessStock = 0.10 - 0.02 = 0.08; excessMarket = 0.08 - 0.02 = 0.06
    // beta = 0.08 / 0.06 = 1.333...
    let result: HashMap<string, double> = capm(0.10, 0.08, 0.02);
    let beta: double = result.get("beta");
    if (beta < 1.30 || beta > 1.36) {
        io::println("FAIL: capm beta expected ~1.333, got " + Double.toString(beta));
    } else {
        io::println("PASS: capm beta calculation correct");
    }
}

public fn test_capm_zero_market_excess(): void {
    // When market excess return is zero, beta defaults to 1.0
    let result: HashMap<string, double> = capm(0.05, 0.02, 0.02);
    let beta: double = result.get("beta");
    if (beta != 1.0) {
        io::println("FAIL: capm beta should default to 1.0, got " + Double.toString(beta));
    } else {
        io::println("PASS: capm beta defaults to 1.0");
    }
}

public fn test_famaFrench3_keys(): void {
    let returns: ArrayList<double> = new ArrayList<double>();
    let market: ArrayList<double> = new ArrayList<double>();
    let smb: ArrayList<double> = new ArrayList<double>();
    let hml: ArrayList<double> = new ArrayList<double>();
    var i: int = 0;
    while (i < 10) {
        returns.add(0.01 * (i as double));
        market.add(0.008 * (i as double));
        smb.add(0.002 * (i as double));
        hml.add(-0.001 * (i as double));
        i = i + 1;
    }
    let result: HashMap<string, double> = famaFrench3(returns, market, smb, hml);
    if (result.containsKey("alpha") && result.containsKey("marketBeta") && result.containsKey("smbBeta") && result.containsKey("hmlBeta") && result.containsKey("residual")) {
        io::println("PASS: famaFrench3 returns all expected keys");
    } else {
        io::println("FAIL: famaFrench3 missing keys");
    }
}

public fn test_famaFrench3_insufficient_data(): void {
    // Fewer than 4 observations should return zero betas
    let returns: ArrayList<double> = new ArrayList<double>();
    let market: ArrayList<double> = new ArrayList<double>();
    let smb: ArrayList<double> = new ArrayList<double>();
    let hml: ArrayList<double> = new ArrayList<double>();
    returns.add(0.01); market.add(0.01); smb.add(0.01); hml.add(0.01);
    let result: HashMap<string, double> = famaFrench3(returns, market, smb, hml);
    let alpha: double = result.get("alpha");
    if (alpha != 0.0) {
        io::println("FAIL: famaFrench3 insufficient data should return alpha=0");
    } else {
        io::println("PASS: famaFrench3 insufficient data handled");
    }
}

public fn test_famaFrench5_keys(): void {
    let returns: ArrayList<double> = new ArrayList<double>();
    let market: ArrayList<double> = new ArrayList<double>();
    let smb: ArrayList<double> = new ArrayList<double>();
    let hml: ArrayList<double> = new ArrayList<double>();
    let rmw: ArrayList<double> = new ArrayList<double>();
    let cma: ArrayList<double> = new ArrayList<double>();
    var i: int = 0;
    while (i < 10) {
        returns.add(0.01 * (i as double));
        market.add(0.008 * (i as double));
        smb.add(0.002 * (i as double));
        hml.add(-0.001 * (i as double));
        rmw.add(0.001 * (i as double));
        cma.add(-0.0005 * (i as double));
        i = i + 1;
    }
    let result: HashMap<string, double> = famaFrench5(returns, market, smb, hml, rmw, cma);
    if (result.containsKey("alpha") && result.containsKey("marketBeta") && result.containsKey("smbBeta") && result.containsKey("hmlBeta") && result.containsKey("rmwBeta") && result.containsKey("cmaBeta") && result.containsKey("residual")) {
        io::println("PASS: famaFrench5 returns all expected keys");
    } else {
        io::println("FAIL: famaFrench5 missing keys");
    }
}

public fn test_famaFrench5_insufficient_data(): void {
    let returns: ArrayList<double> = new ArrayList<double>();
    let market: ArrayList<double> = new ArrayList<double>();
    let smb: ArrayList<double> = new ArrayList<double>();
    let hml: ArrayList<double> = new ArrayList<double>();
    let rmw: ArrayList<double> = new ArrayList<double>();
    let cma: ArrayList<double> = new ArrayList<double>();
    var i: int = 0;
    while (i < 5) {
        returns.add(0.01); market.add(0.01); smb.add(0.01); hml.add(0.01); rmw.add(0.01); cma.add(0.01);
        i = i + 1;
    }
    let result: HashMap<string, double> = famaFrench5(returns, market, smb, hml, rmw, cma);
    let alpha: double = result.get("alpha");
    if (alpha != 0.0) {
        io::println("FAIL: famaFrench5 insufficient data should return alpha=0");
    } else {
        io::println("PASS: famaFrench5 insufficient data handled");
    }
}

public fn test_factorExposure_returns_coefficients(): void {
    let returns: ArrayList<double> = new ArrayList<double>();
    let factors: ArrayList<ArrayList<double>> = new ArrayList<ArrayList<double>>();
    let factor1: ArrayList<double> = new ArrayList<double>();
    var i: int = 0;
    while (i < 10) {
        returns.add((i as double) * 0.01);
        factor1.add((i as double) * 0.005);
        i = i + 1;
    }
    factors.add(factor1);
    let coeffs: ArrayList<double> = factorExposure(returns, factors);
    // Should return 2 coefficients (intercept + 1 factor)
    if (coeffs.size() != 2) {
        io::println("FAIL: factorExposure should return 2 coefficients, got " + Integer.toString(coeffs.size()));
    } else {
        io::println("PASS: factorExposure returns correct number of coefficients");
    }
}

public fn test_factorExposure_empty(): void {
    let returns: ArrayList<double> = new ArrayList<double>();
    let factors: ArrayList<ArrayList<double>> = new ArrayList<ArrayList<double>>();
    let coeffs: ArrayList<double> = factorExposure(returns, factors);
    if (coeffs.size() != 0) {
        io::println("FAIL: factorExposure empty should return 0 coefficients");
    } else {
        io::println("PASS: factorExposure empty handled");
    }
}

public fn test_alphaEstimate_basic(): void {
    let returns: ArrayList<double> = new ArrayList<double>();
    let benchmark: ArrayList<double> = new ArrayList<double>();
    var i: int = 0;
    while (i < 10) {
        returns.add(0.01 + 0.001 * (i as double));
        benchmark.add(0.008 + 0.0005 * (i as double));
        i = i + 1;
    }
    let alpha: double = alphaEstimate(returns, benchmark, 0.02);
    // Alpha should be a finite number (not NaN)
    if (alpha != alpha) {
        io::println("FAIL: alphaEstimate returned NaN");
    } else {
        io::println("PASS: alphaEstimate returns finite value");
    }
}

public fn test_alphaEstimate_insufficient(): void {
    let returns: ArrayList<double> = new ArrayList<double>();
    let benchmark: ArrayList<double> = new ArrayList<double>();
    returns.add(0.01);
    benchmark.add(0.01);
    let alpha: double = alphaEstimate(returns, benchmark, 0.02);
    if (alpha != 0.0) {
        io::println("FAIL: alphaEstimate insufficient should return 0");
    } else {
        io::println("PASS: alphaEstimate insufficient handled");
    }
}

public fn run_all_factormodel_tests(): void {
    io::println("=== FactorModel.tr Tests ===");
    test_capm_basic();
    test_capm_beta_calculation();
    test_capm_zero_market_excess();
    test_famaFrench3_keys();
    test_famaFrench3_insufficient_data();
    test_famaFrench5_keys();
    test_famaFrench5_insufficient_data();
    test_factorExposure_returns_coefficients();
    test_factorExposure_empty();
    test_alphaEstimate_basic();
    test_alphaEstimate_insufficient();
}
