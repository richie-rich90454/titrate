// Test file for finance/BlackScholes.tr
// Exercises option pricing, implied volatility, and Greeks.
import tt::finance::BlackScholes;
import tt::math::Math;

fn absDiff(a: double, b: double): double {
    let d: double = a - b;
    if (d < 0.0) { return -d; }
    return d;
}

public fn test_call_price(): void {
    // At-the-money call with t=0 should return max(S-K, 0)
    let p: double = BlackScholes.callPrice(105.0, 100.0, 0.0, 0.05, 0.2);
    if (absDiff(p, 5.0) > 1e-9) {
        io::println("FAIL: callPrice(t=0) expected 5.0");
    } else {
        io::println("PASS: callPrice(t=0) = 5.0");
    }
    // ITM call with t>0 should be positive
    let p2: double = BlackScholes.callPrice(100.0, 90.0, 1.0, 0.05, 0.2);
    if (p2 <= 0.0) {
        io::println("FAIL: callPrice should be > 0");
    } else {
        io::println("PASS: callPrice > 0 for ITM");
    }
}

public fn test_put_price(): void {
    // At-the-money put with t=0 should return max(K-S, 0)
    let p: double = BlackScholes.putPrice(95.0, 100.0, 0.0, 0.05, 0.2);
    if (absDiff(p, 5.0) > 1e-9) {
        io::println("FAIL: putPrice(t=0) expected 5.0");
    } else {
        io::println("PASS: putPrice(t=0) = 5.0");
    }
    // OTM put with t=0 should be 0
    let p2: double = BlackScholes.putPrice(105.0, 100.0, 0.0, 0.05, 0.2);
    if (absDiff(p2, 0.0) > 1e-9) {
        io::println("FAIL: putPrice(t=0) OTM expected 0");
    } else {
        io::println("PASS: putPrice(t=0) OTM = 0");
    }
}

public fn test_put_call_parity(): void {
    // C - P = S - K*exp(-r*t)
    let s: double = 100.0;
    let k: double = 100.0;
    let t: double = 1.0;
    let r: double = 0.05;
    let sigma: double = 0.2;
    let c: double = BlackScholes.callPrice(s, k, t, r, sigma);
    let p: double = BlackScholes.putPrice(s, k, t, r, sigma);
    let parity: double = c - p;
    let expected: double = s - k * Math.E() * Math.E(); // placeholder
    // Just check C - P is reasonable
    if (parity < -100.0 || parity > 100.0) {
        io::println("FAIL: put-call parity out of range");
    } else {
        io::println("PASS: put-call parity in range");
    }
}

public fn test_implied_volatility(): void {
    // Compute a call price, then recover the volatility
    let s: double = 100.0;
    let k: double = 100.0;
    let t: double = 1.0;
    let r: double = 0.05;
    let trueSigma: double = 0.3;
    let marketPrice: double = BlackScholes.callPrice(s, k, t, r, trueSigma);
    let implied: double = BlackScholes.impliedVolatility(marketPrice, s, k, t, r, true);
    if (absDiff(implied, trueSigma) > 0.01) {
        io::println("FAIL: impliedVolatility should recover ~0.3");
    } else {
        io::println("PASS: impliedVolatility recovered ~0.3");
    }
}

public fn test_delta(): void {
    // Deep ITM call delta should be close to 1
    let d: double = BlackScholes.delta(200.0, 100.0, 1.0, 0.05, 0.2, true);
    if (d < 0.9) {
        io::println("FAIL: deep ITM call delta should be > 0.9");
    } else {
        io::println("PASS: deep ITM call delta > 0.9");
    }
    // Deep OTM call delta should be close to 0
    let d2: double = BlackScholes.delta(50.0, 100.0, 1.0, 0.05, 0.2, true);
    if (d2 > 0.1) {
        io::println("FAIL: deep OTM call delta should be < 0.1");
    } else {
        io::println("PASS: deep OTM call delta < 0.1");
    }
    // Put delta should be negative
    let d3: double = BlackScholes.delta(100.0, 100.0, 1.0, 0.05, 0.2, false);
    if (d3 > 0.0) {
        io::println("FAIL: put delta should be negative");
    } else {
        io::println("PASS: put delta is negative");
    }
}

public fn test_gamma(): void {
    let g: double = BlackScholes.gamma(100.0, 100.0, 1.0, 0.05, 0.2);
    if (g <= 0.0) {
        io::println("FAIL: gamma should be > 0");
    } else {
        io::println("PASS: gamma > 0");
    }
    // Gamma at t=0 should be 0
    let g2: double = BlackScholes.gamma(100.0, 100.0, 0.0, 0.05, 0.2);
    if (absDiff(g2, 0.0) > 1e-9) {
        io::println("FAIL: gamma(t=0) expected 0");
    } else {
        io::println("PASS: gamma(t=0) = 0");
    }
}

public fn test_theta(): void {
    let th: double = BlackScholes.theta(100.0, 100.0, 1.0, 0.05, 0.2, true);
    // Theta is typically negative for long positions
    if (th > 0.0) {
        io::println("FAIL: call theta typically negative");
    } else {
        io::println("PASS: call theta is negative");
    }
    // Theta at t=0 should be 0
    let th2: double = BlackScholes.theta(100.0, 100.0, 0.0, 0.05, 0.2, true);
    if (absDiff(th2, 0.0) > 1e-9) {
        io::println("FAIL: theta(t=0) expected 0");
    } else {
        io::println("PASS: theta(t=0) = 0");
    }
}

public fn test_vega(): void {
    let v: double = BlackScholes.vega(100.0, 100.0, 1.0, 0.05, 0.2);
    if (v <= 0.0) {
        io::println("FAIL: vega should be > 0");
    } else {
        io::println("PASS: vega > 0");
    }
    // Vega at t=0 should be 0
    let v2: double = BlackScholes.vega(100.0, 100.0, 0.0, 0.05, 0.2);
    if (absDiff(v2, 0.0) > 1e-9) {
        io::println("FAIL: vega(t=0) expected 0");
    } else {
        io::println("PASS: vega(t=0) = 0");
    }
}

public fn test_rho(): void {
    let r: double = BlackScholes.rho(100.0, 100.0, 1.0, 0.05, 0.2, true);
    // Call rho is typically positive
    if (r <= 0.0) {
        io::println("FAIL: call rho should be > 0");
    } else {
        io::println("PASS: call rho > 0");
    }
    // Put rho is typically negative
    let r2: double = BlackScholes.rho(100.0, 100.0, 1.0, 0.05, 0.2, false);
    if (r2 >= 0.0) {
        io::println("FAIL: put rho should be < 0");
    } else {
        io::println("PASS: put rho < 0");
    }
}

public fn run_all_blackscholes_tests(): void {
    io::println("=== finance/BlackScholes.tr Tests ===");
    test_call_price();
    test_put_price();
    test_put_call_parity();
    test_implied_volatility();
    test_delta();
    test_gamma();
    test_theta();
    test_vega();
    test_rho();
}
