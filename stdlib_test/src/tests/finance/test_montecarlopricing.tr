public fn test_antitheticVariateCall_nonnegative(): void {
    let price: double = antitheticVariateCall(100.0, 100.0, 1.0, 0.05, 0.2, 100);
    if (price < 0.0) {
        io::println("FAIL: antitheticVariateCall should be non-negative");
    } else {
        io::println("PASS: antitheticVariateCall non-negative");
    }
}

public fn test_antitheticVariateCall_itm(): void {
    let itm: double = antitheticVariateCall(150.0, 100.0, 1.0, 0.05, 0.2, 100);
    let otm: double = antitheticVariateCall(50.0, 100.0, 1.0, 0.05, 0.2, 100);
    if (itm <= otm) {
        io::println("FAIL: antithetic ITM call should be > OTM");
    } else {
        io::println("PASS: antithetic ITM call > OTM call");
    }
}

public fn test_controlVariateCall_nonnegative(): void {
    let price: double = controlVariateCall(100.0, 100.0, 1.0, 0.05, 0.2, 100);
    if (price < 0.0) {
        io::println("FAIL: controlVariateCall should be non-negative");
    } else {
        io::println("PASS: controlVariateCall non-negative");
    }
}

public fn test_controlVariateCall_itm(): void {
    let itm: double = controlVariateCall(150.0, 100.0, 1.0, 0.05, 0.2, 100);
    let otm: double = controlVariateCall(50.0, 100.0, 1.0, 0.05, 0.2, 100);
    if (itm <= otm) {
        io::println("FAIL: control variate ITM call should be > OTM");
    } else {
        io::println("PASS: control variate ITM call > OTM call");
    }
