public fn run_all_montecarlopricing_tests(): void {
    io::println("=== MonteCarloPricing.tr Tests ===");
    test_gbmPath_length();
    test_gbmPath_initial();
    test_gbmPath_positive();
    test_monteCarloCall_nonnegative();
    test_monteCarloCall_itm_gt_otm();
    test_monteCarloPut_nonnegative();
    test_monteCarloPut_itm_gt_otm();
    test_monteCarloAsian_nonnegative();
    test_antitheticVariateCall_nonnegative();
    test_antitheticVariateCall_itm();
    test_controlVariateCall_nonnegative();
    test_controlVariateCall_itm();
}
