// Test file for calculus/Calculus.tr
// Exercises the public API: derivative, secondDerivative, riemannSum,
// trapezoidRule, simpsonsRule, integrate, newtonsMethod, bisection, findMin,
// findMax, averageValue, linearApprox, eulerMethod, rungeKutta4, taylorCoefficients.
import tt::calculus::Calculus;
import tt::math::MathAdvanced;
import tt::util::ArrayList;

public fn test_derivative_basic(): void {
    let f: fn(double): double = fn(x: double): double { return x * x; };
    let d: double = derivative(f, 3.0, 1e-6);
    if (d < 5.9 || d > 6.1) {
        io::println("FAIL: derivative basic d=" + Double.toString(d));
    } else {
        io::println("PASS: derivative basic");
    }
}

public fn test_derivative_default_h(): void {
    let f: fn(double): double = fn(x: double): double { return 2.0 * x; };
    let d: double = derivative(f, 5.0);
    if (d < 1.9 || d > 2.1) {
        io::println("FAIL: derivative default h");
    } else {
        io::println("PASS: derivative default h");
    }
}

public fn test_derivative_constant(): void {
    let f: fn(double): double = fn(x: double): double { return 5.0; };
    let d: double = derivative(f, 3.0, 1e-6);
    if (d < -0.1 || d > 0.1) {
        io::println("FAIL: derivative constant");
    } else {
        io::println("PASS: derivative constant");
    }
}

public fn test_secondDerivative_basic(): void {
    let f: fn(double): double = fn(x: double): double { return x * x; };
    let d: double = secondDerivative(f, 3.0, 1e-4);
    if (d < 1.9 || d > 2.1) {
        io::println("FAIL: secondDerivative basic");
    } else {
        io::println("PASS: secondDerivative basic");
    }
}

public fn test_riemannSum_left(): void {
    let f: fn(double): double = fn(x: double): double { return x; };
    let s: double = riemannSum(f, 0.0, 10.0, 100, "left");
    if (s < 45.0 || s > 55.0) {
        io::println("FAIL: riemannSum left");
    } else {
        io::println("PASS: riemannSum left");
    }
}

public fn test_riemannSum_right(): void {
    let f: fn(double): double = fn(x: double): double { return x; };
    let s: double = riemannSum(f, 0.0, 10.0, 100, "right");
    if (s < 45.0 || s > 55.0) {
        io::println("FAIL: riemannSum right");
    } else {
        io::println("PASS: riemannSum right");
    }
}

public fn test_riemannSum_midpoint(): void {
    let f: fn(double): double = fn(x: double): double { return x; };
    let s: double = riemannSum(f, 0.0, 10.0, 100, "midpoint");
    if (s < 45.0 || s > 55.0) {
        io::println("FAIL: riemannSum midpoint");
