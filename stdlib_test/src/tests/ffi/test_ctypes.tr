// Test for Ctypes — basic construction
import tt::ffi::Ctypes::Pointer;

public fn test_pointer_init(): void {
    let p = new Pointer();
    if (p == null) {
        io::println("FAIL: Pointer constructor returned null");
    } else {
        io::println("PASS: Pointer construction works");
    }
}

public fn run_all_ctypes_tests(): void {
    io::println("=== Ctypes.tr Tests ===");
    test_pointer_init();
}
