public fn test_get_ready_auto_prepare(): void {
    let sorter: TopologicalSorter<string> = new TopologicalSorter<string>();
    let preds: ArrayList<string> = new ArrayList<string>();
    sorter.addNode("a", preds);
    // get_ready without calling prepare() first should auto-prepare
    let ready: ArrayList<string> = sorter.get_ready();
    if (ready.size() != 1) {
        io::println("FAIL: get_ready auto-prepare size wrong");
    } else if (ready.get(0) != "a") {
        io::println("FAIL: get_ready auto-prepare value wrong");
    } else {
        io::println("PASS: get_ready auto-prepare works");
    }
}

public fn test_integer_nodes(): void {
    let sorter: TopologicalSorter<int> = new TopologicalSorter<int>();
    sorter.addNodeOne(3, 1);
    sorter.addNodeOne(2, 1);
    sorter.addNodeOne(4, 2);
    sorter.addNodeOne(4, 3);
    let preds1: ArrayList<int> = new ArrayList<int>();
    sorter.addNode(1, preds1);
    let order: ArrayList<int> = sorter.static_order();
    if (order.size() != 4) {
        io::println("FAIL: integer nodes order size wrong");
        return;
    }
    // 1 must come before 2 and 3, and both 2 and 3 before 4
    var pos1: int = -1;
    var pos4: int = -1;
    var i: int = 0;
    while (i < order.size()) {
        if (order.get(i) == 1) { pos1 = i; }
        if (order.get(i) == 4) { pos4 = i; }
        i = i + 1;
    }
    if (pos1 < pos4) {
        io::println("PASS: integer nodes work");
    } else {
        io::println("FAIL: integer nodes order invalid");
    }
}

public fn test_null_predecessors(): void {
    let sorter: TopologicalSorter<string> = new TopologicalSorter<string>();
    sorter.addNode("a", null);
    if (sorter.nodeCount() != 1) {
        io::println("FAIL: null predecessors nodeCount wrong");
    } else {
        let order: ArrayList<string> = sorter.static_order();
        if (order.size() != 1) {
            io::println("FAIL: null predecessors order wrong");
        } else {
            io::println("PASS: null predecessors works");
        }
    }
}

public fn test_static_order_idempotent(): void {
    let sorter: TopologicalSorter<string> = new TopologicalSorter<string>();
    sorter.addNodeOne("b", "a");
    let predsA: ArrayList<string> = new ArrayList<string>();
    sorter.addNode("a", predsA);
    let order1: ArrayList<string> = sorter.static_order();
    let order2: ArrayList<string> = sorter.static_order();
    if (order1.size() != 2) {
        io::println("FAIL: static_order idempotent first size wrong");
    } else if (order2.size() != 0) {
        io::println("FAIL: static_order second call should be empty");
    } else {
        io::println("PASS: static_order idempotent works");
    }
}

public fn run_all_topologicalsorter_tests(): void {
    io::println("=== TopologicalSorter.tr Tests ===");
    test_empty_sorter();
    test_single_node();
    test_linear_chain();
    test_diamond_dependency();
    test_addNodeOne();
    test_get_ready_and_done();
    test_predecessors_and_successors();
    test_multiple_independent_nodes();
    test_factory_topologicalSorter();
    test_factory_fromEdges();
    test_addNode_after_prepare_throws();
    test_done_unknown_node_throws();
    test_done_non_ready_node_throws();
    test_get_ready_auto_prepare();
    test_integer_nodes();
    test_null_predecessors();
    test_static_order_idempotent();
}
