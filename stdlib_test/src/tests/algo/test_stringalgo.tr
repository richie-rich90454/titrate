// Test file for algo/StringAlgo.tr
// Exercises the public API: kmpSearch, kmp, rabinKarp, boyerMoore, suffixArray, lcpArray, zAlgorithm, ahoCorasick.
import tt::algo::StringAlgo;
import tt::util::ArrayList;
import tt::util::HashMap;
import tt::lang::Integer;

public fn test_kmpSearch_match(): void {
    let result: ArrayList<int> = kmpSearch("hello world", "world");
    if (result.size() != 1) {
        io::println("FAIL: kmpSearch match size=" + Integer.toString(result.size()));
    } else if (result.get(0) != 6) {
        io::println("FAIL: kmpSearch match index=" + Integer.toString(result.get(0)));
    } else {
        io::println("PASS: kmpSearch match works");
    }
}

public fn test_kmpSearch_no_match(): void {
    let result: ArrayList<int> = kmpSearch("hello world", "xyz");
    if (result.size() != 0) {
        io::println("FAIL: kmpSearch no match size=" + Integer.toString(result.size()));
    } else {
        io::println("PASS: kmpSearch no match works");
    }
}

public fn test_kmpSearch_multiple_matches(): void {
    let result: ArrayList<int> = kmpSearch("ababab", "ab");
    if (result.size() != 3) {
        io::println("FAIL: kmpSearch multiple size=" + Integer.toString(result.size()));
    } else {
        io::println("PASS: kmpSearch multiple matches works");
    }
}

public fn test_kmpSearch_empty_pattern(): void {
    let result: ArrayList<int> = kmpSearch("hello", "");
    if (result.size() != 0) {
        io::println("FAIL: kmpSearch empty pattern should return empty");
    } else {
        io::println("PASS: kmpSearch empty pattern works");
    }
}

public fn test_kmp_alias(): void {
    let result: ArrayList<int> = kmp("hello world", "world");
    if (result.size() != 1) {
        io::println("FAIL: kmp alias size wrong");
    } else {
        io::println("PASS: kmp alias works");
    }
}

