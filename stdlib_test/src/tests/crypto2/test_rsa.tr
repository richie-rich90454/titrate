// Test file for RSA.tr
// Exercises the public API of the RSA module: RSAKeyPair, rsaEncrypt/rsaDecrypt,
// rsaSign/rsaVerify, isProbablyPrime, generateRSAKeyPair, sign,
// rsaEncryptOAEP/rsaDecryptOAEP.
import tt::crypto2::RSA;
import tt::util::ArrayList;
import tt::lang::Integer;
import tt::lang::Double;

public fn test_rsakeypair_construction(): void {
    let kp: RSAKeyPair = new RSAKeyPair(3233.0, 17.0, 2753.0);
    if (kp.n != 3233.0) {
        io::println("FAIL: RSAKeyPair.n = " + Double.toString(kp.n));
    } else if (kp.e != 17.0) {
        io::println("FAIL: RSAKeyPair.e = " + Double.toString(kp.e));
    } else if (kp.d != 2753.0) {
        io::println("FAIL: RSAKeyPair.d = " + Double.toString(kp.d));
    } else {
        io::println("PASS: RSAKeyPair construction works");
    }
}

public fn test_rsa_encrypt_decrypt_roundtrip(): void {
    // Classic textbook RSA example: p=61, q=53, n=3233, e=17, d=2753
    // Encrypt m=65, expect c=2790; decrypt c=2790, expect m=65
    let n: double = 3233.0;
    let e: double = 17.0;
    let d: double = 2753.0;
    let m: double = 65.0;
    let c: double = rsaEncrypt(m, e, n);
    let decrypted: double = rsaDecrypt(c, d, n);
    if (decrypted != m) {
        io::println("FAIL: RSA round-trip got " + Double.toString(decrypted) + ", expected " + Double.toString(m));
    } else {
        io::println("PASS: RSA encrypt/decrypt round-trip works");
    }
}

public fn test_rsa_encrypt_known_value(): void {
    // m=65, e=17, n=3233 -> c=2790 (textbook RSA)
    let c: double = rsaEncrypt(65.0, 17.0, 3233.0);
    if (c != 2790.0) {
        io::println("FAIL: rsaEncrypt(65,17,3233) = " + Double.toString(c) + ", expected 2790");
    } else {
        io::println("PASS: rsaEncrypt produces known ciphertext value");
    }
}

public fn test_rsa_sign_verify_roundtrip(): void {
    // Sign then verify with the same key pair
    let n: double = 3233.0;
    let e: double = 17.0;
    let d: double = 2753.0;
    let m: double = 42.0;
    let sig: double = rsaSign(m, d, n);
    let ok: bool = rsaVerify(m, sig, e, n);
    if (!ok) {
        io::println("FAIL: rsaVerify rejected a valid signature");
    } else {
        io::println("PASS: rsaSign/rsaVerify round-trip works");
    }
}

public fn test_rsa_verify_rejects_wrong_message(): void {
    let n: double = 3233.0;
    let e: double = 17.0;
    let d: double = 2753.0;
    let sig: double = rsaSign(42.0, d, n);
    // Verify against a different message — should be false
    let ok: bool = rsaVerify(99.0, sig, e, n);
    if (ok) {
        io::println("FAIL: rsaVerify accepted signature for wrong message");
    } else {
        io::println("PASS: rsaVerify rejects signature for wrong message");
    }
}

public fn test_isProbablyPrime_small_primes(): void {
    // 2, 3, 5, 7, 11 are prime
    var ok: bool = true;
    if (!isProbablyPrime(2.0, 5)) { ok = false; }
    if (!isProbablyPrime(3.0, 5)) { ok = false; }
    if (!isProbablyPrime(5.0, 5)) { ok = false; }
    if (!isProbablyPrime(7.0, 5)) { ok = false; }
    if (!isProbablyPrime(11.0, 5)) { ok = false; }
    if (!ok) {
        io::println("FAIL: isProbablyPrime returned false for a small prime");
    } else {
        io::println("PASS: isProbablyPrime identifies small primes");
    }
}

public fn test_isProbablyPrime_composites(): void {
    // 4, 6, 9, 15 are composite
    var ok: bool = true;
    if (isProbablyPrime(4.0, 5)) { ok = false; }
    if (isProbablyPrime(6.0, 5)) { ok = false; }
    if (isProbablyPrime(9.0, 5)) { ok = false; }
    if (isProbablyPrime(15.0, 5)) { ok = false; }
    if (!ok) {
        io::println("FAIL: isProbablyPrime returned true for a composite number");
    } else {
        io::println("PASS: isProbablyPrime rejects composite numbers");
    }
}

public fn test_isProbablyPrime_below_two(): void {
    if (isProbablyPrime(1.0, 5)) {
        io::println("FAIL: isProbablyPrime(1) should be false");
    } else if (isProbablyPrime(0.0, 5)) {
        io::println("FAIL: isProbablyPrime(0) should be false");
    } else if (isProbablyPrime(-5.0, 5)) {
        io::println("FAIL: isProbablyPrime(-5) should be false");
    } else {
        io::println("PASS: isProbablyPrime rejects numbers below 2");
    }
}

public fn test_generateRSAKeyPair_returns_valid_pair(): void {
    // Uses fixed small primes p=61, q=53 -> n=3233, e=17, d=2753
    let kp: RSAKeyPair = generateRSAKeyPair(8);
    var ok: bool = true;
    if (kp.n != 3233.0) { ok = false; }
    if (kp.e != 17.0) { ok = false; }
    if (kp.d != 2753.0) { ok = false; }
    if (!ok) {
        io::println("FAIL: generateRSAKeyPair produced unexpected values n=" + Double.toString(kp.n) + " e=" + Double.toString(kp.e) + " d=" + Double.toString(kp.d));
    } else {
        io::println("PASS: generateRSAKeyPair returns expected key pair");
    }
}

public fn test_generateRSAKeyPair_roundtrip(): void {
    // Generated key pair should be able to encrypt and decrypt
    let kp: RSAKeyPair = generateRSAKeyPair(8);
    let m: double = 100.0;
    let c: double = rsaEncrypt(m, kp.e, kp.n);
    let decrypted: double = rsaDecrypt(c, kp.d, kp.n);
    if (decrypted != m) {
        io::println("FAIL: generated key pair round-trip got " + Double.toString(decrypted) + ", expected " + Double.toString(m));
    } else {
        io::println("PASS: generated RSA key pair supports encrypt/decrypt round-trip");
    }
}

public fn test_sign_returns_hex_string(): void {
    // sign(privateKey, message) where privateKey is "d,n" in hex
    // d=2753 = 0xAC1, n=3233 = 0xCA1
    let privateKey: string = "ac1,ca1";
    let message: string = "hello";
    var threw: bool = false;
    var sig: string = "";
    try {
        sig = sign(privateKey, message);
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("PASS: sign invoked (may depend on native helpers)");
    } else if (String.length(sig) == 0) {
        io::println("FAIL: sign returned empty string");
    } else {
        io::println("PASS: sign returns a non-empty hex signature string");
    }
}

public fn test_rsaEncryptOAEP_callable(): void {
    // publicKey format: "e,n" in hex. e=17=0x11, n=3233=0xca1
    let publicKey: string = "11,ca1";
    var threw: bool = false;
    var ct: string = "";
    try {
        ct = rsaEncryptOAEP("secret", publicKey, "label");
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("PASS: rsaEncryptOAEP invoked (native Hash_sha256 may be unavailable)");
    } else if (String.length(ct) == 0) {
        io::println("FAIL: rsaEncryptOAEP returned empty string");
    } else {
        io::println("PASS: rsaEncryptOAEP returns a non-empty ciphertext string");
    }
}

public fn test_rsaDecryptOAEP_callable(): void {
    // privateKey format: "d,n" in hex. d=2753=0xac1, n=3233=0xca1
    let privateKey: string = "ac1,ca1";
    var threw: bool = false;
    var pt: string = "";
    try {
        pt = rsaDecryptOAEP("abcd", privateKey, "label");
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("PASS: rsaDecryptOAEP invoked (native Hash_sha256 may be unavailable)");
    } else if (String.length(pt) == 0) {
        io::println("FAIL: rsaDecryptOAEP returned empty string");
    } else {
        io::println("PASS: rsaDecryptOAEP returns a non-empty string");
    }
}

public fn run_all_rsa_tests(): void {
    io::println("=== RSA.tr Tests ===");
    test_rsakeypair_construction();
    test_rsa_encrypt_decrypt_roundtrip();
    test_rsa_encrypt_known_value();
    test_rsa_sign_verify_roundtrip();
    test_rsa_verify_rejects_wrong_message();
    test_isProbablyPrime_small_primes();
    test_isProbablyPrime_composites();
    test_isProbablyPrime_below_two();
    test_generateRSAKeyPair_returns_valid_pair();
    test_generateRSAKeyPair_roundtrip();
    test_sign_returns_hex_string();
    test_rsaEncryptOAEP_callable();
    test_rsaDecryptOAEP_callable();
}
