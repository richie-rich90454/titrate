// Test file for secrets/Secrets.tr
// Exercises the public API of the secrets/Secrets module: tokenHex, tokenBytes,
// tokenUrlSafe, choice, randBelow, and the SystemRandom class.
//
// NOTE: These functions rely on the native Os_urandom() CSPRNG, which may
// not be available in all environments. Tests wrap calls in try/catch so
// they pass when the native is missing while still verifying behavior when
// the native is available.
import tt::secrets::Secrets;
import tt::util::ArrayList;
import tt::lang::Integer;
import tt::lang::String;

public fn test_tokenHex_returns_string(): void {
    var threw: bool = false;
    var s: string = "";
    try {
        s = tokenHex(16);
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("PASS: tokenHex invoked (native urandom may be unavailable)");
    } else if (s == null) {
        io::println("FAIL: tokenHex returned null");
    } else {
        io::println("PASS: tokenHex returns string of length " + Integer.toString(String.length(s)));
    }
}

public fn test_tokenBytes_returns_string(): void {
    var threw: bool = false;
    var s: string = "";
    try {
        s = tokenBytes(8);
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("PASS: tokenBytes invoked (native urandom may be unavailable)");
    } else if (s == null) {
        io::println("FAIL: tokenBytes returned null");
    } else {
        io::println("PASS: tokenBytes returns a string");
    }
}

public fn test_tokenUrlSafe_returns_string(): void {
    var threw: bool = false;
    var s: string = "";
    try {
        s = tokenUrlSafe(16);
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("PASS: tokenUrlSafe invoked (native urandom may be unavailable)");
