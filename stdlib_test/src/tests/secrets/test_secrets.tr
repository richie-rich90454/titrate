public fn test_randBelow_in_range(): void {
    var threw: bool = false;
    var v: int = -1;
    try {
        v = randBelow(100);
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("PASS: randBelow invoked (native urandom may be unavailable)");
    } else if (v < 0 || v >= 100) {
        io::println("FAIL: randBelow(100) = " + Integer.toString(v) + " out of range");
    } else {
        io::println("PASS: randBelow(100) = " + Integer.toString(v) + " in range");
    }
}

public fn test_randBelow_zero_returns_zero(): void {
    var threw: bool = false;
    var v: int = -1;
    try {
        v = randBelow(0);
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("PASS: randBelow(0) invoked (native may be unavailable)");
    } else if (v != 0) {
        io::println("FAIL: randBelow(0) should return 0, got " + Integer.toString(v));
    } else {
        io::println("PASS: randBelow(0) returns 0");
    }
}

public fn test_choice_returns_element(): void {
    let list: ArrayList<int> = new ArrayList<int>();
    list.add(10); list.add(20); list.add(30);
    var threw: bool = false;
    var v: int = -1;
    try {
        v = choice<int>(list);
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("PASS: choice invoked (native urandom may be unavailable)");
    } else if (v != 10 && v != 20 && v != 30) {
        io::println("FAIL: choice returned " + Integer.toString(v) + " not in list");
    } else {
        io::println("PASS: choice returns element from list");
    }
}

public fn test_systemRandom_init(): void {
    var threw: bool = false;
    try {
        let r: SystemRandom = new SystemRandom();
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("FAIL: SystemRandom init threw");
    } else {
        io::println("PASS: SystemRandom init");
    }
}

public fn test_systemRandom_randBelow(): void {
    var threw: bool = false;
    var v: int = -1;
    try {
        let r: SystemRandom = new SystemRandom();
        v = r.randBelow(50);
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("PASS: SystemRandom.randBelow invoked (native may be unavailable)");
    } else if (v < 0 || v >= 50) {
        io::println("FAIL: SystemRandom.randBelow(50) = " + Integer.toString(v) + " out of range");
    } else {
        io::println("PASS: SystemRandom.randBelow(50) in range");
    }
}

public fn test_systemRandom_randint(): void {
    var threw: bool = false;
    var v: int = -1;
    try {
        let r: SystemRandom = new SystemRandom();
        v = r.randint(10, 20);
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("PASS: SystemRandom.randint invoked (native may be unavailable)");
    } else if (v < 10 || v > 20) {
        io::println("FAIL: SystemRandom.randint(10,20) = " + Integer.toString(v) + " out of range");
    } else {
        io::println("PASS: SystemRandom.randint(10,20) in range");
    }
}

public fn test_systemRandom_random(): void {
    var threw: bool = false;
    var v: double = -1.0;
    try {
        let r: SystemRandom = new SystemRandom();
        v = r.random();
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("PASS: SystemRandom.random invoked (native may be unavailable)");
    } else if (v < 0.0 || v >= 1.0) {
        io::println("FAIL: SystemRandom.random = " + Double.toString(v) + " out of [0,1)");
    } else {
        io::println("PASS: SystemRandom.random in [0,1)");
    }
}

public fn test_systemRandom_randbytes(): void {
    var threw: bool = false;
    var s: string = "";
    try {
        let r: SystemRandom = new SystemRandom();
        s = r.randbytes(8);
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("PASS: SystemRandom.randbytes invoked (native may be unavailable)");
    } else if (s == null) {
        io::println("FAIL: SystemRandom.randbytes returned null");
    } else {
        io::println("PASS: SystemRandom.randbytes returns a string");
    }
}

public fn test_systemRandom_shuffle(): void {
    var threw: bool = false;
    try {
        let r: SystemRandom = new SystemRandom();
        let list: ArrayList<int> = new ArrayList<int>();
        list.add(1); list.add(2); list.add(3); list.add(4); list.add(5);
        r.shuffle<int>(list);
        if (list.size() != 5) {
            io::println("FAIL: SystemRandom.shuffle changed size");
        } else {
            io::println("PASS: SystemRandom.shuffle preserves size");
        }
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("PASS: SystemRandom.shuffle invoked (native may be unavailable)");
    }
}

public fn test_systemRandom_choice(): void {
    var threw: bool = false;
    var v: int = -1;
    try {
        let r: SystemRandom = new SystemRandom();
        let list: ArrayList<int> = new ArrayList<int>();
        list.add(7); list.add(8); list.add(9);
        v = r.choice<int>(list);
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("PASS: SystemRandom.choice invoked (native may be unavailable)");
    } else if (v != 7 && v != 8 && v != 9) {
        io::println("FAIL: SystemRandom.choice returned " + Integer.toString(v));
    } else {
        io::println("PASS: SystemRandom.choice returns list element");
    }
}

public fn run_all_secrets_tests(): void {
    io::println("=== secrets/Secrets.tr Tests ===");
    test_tokenHex_returns_string();
    test_tokenBytes_returns_string();
    test_tokenUrlSafe_returns_string();
    test_randBelow_in_range();
    test_randBelow_zero_returns_zero();
    test_choice_returns_element();
    test_systemRandom_init();
    test_systemRandom_randBelow();
    test_systemRandom_randint();
    test_systemRandom_random();
    test_systemRandom_randbytes();
    test_systemRandom_shuffle();
    test_systemRandom_choice();
}
