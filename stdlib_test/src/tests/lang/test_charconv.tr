// Test file for CharConv.tr
// Exercises the public API of the CharConv module.
import tt::lang::CharConv;
import tt::lang::String;

public fn test_toChars_int(): void {
    let r: CharsResult = CharConv.toChars(42);
    if (r.ptr != "42" || !r.ok()) {
        io::println("FAIL: toChars int");
    } else {
        io::println("PASS: toChars int");
    }
}

public fn test_toChars_negative(): void {
    let r: CharsResult = CharConv.toChars(-42);
    if (r.ptr != "-42" || !r.ok()) {
        io::println("FAIL: toChars negative");
    } else {
        io::println("PASS: toChars negative");
    }
}

public fn test_toChars_zero(): void {
    let r: CharsResult = CharConv.toChars(0);
    if (r.ptr != "0" || !r.ok()) {
        io::println("FAIL: toChars zero");
    } else {
        io::println("PASS: toChars zero");
    }
}

public fn test_toCharsBase_hex(): void {
    let r: CharsResult = CharConv.toCharsBase(255, 16);
    if (r.ptr == "ff" || r.ptr == "FF") {
        io::println("PASS: toCharsBase hex");
    } else {
        io::println("FAIL: toCharsBase hex got " + r.ptr);
    }
}

public fn test_toCharsBase_binary(): void {
    let r: CharsResult = CharConv.toCharsBase(42, 2);
    if (r.ptr == "101010") {
        io::println("PASS: toCharsBase binary");
    } else {
        io::println("FAIL: toCharsBase binary got " + r.ptr);
    }
}

public fn test_toCharsBase_octal(): void {
    let r: CharsResult = CharConv.toCharsBase(42, 8);
    if (r.ptr == "52") {
        io::println("PASS: toCharsBase octal");
    } else {
        io::println("FAIL: toCharsBase octal got " + r.ptr);
    }
}

public fn test_toCharsBase_invalid_base(): void {
    let r: CharsResult = CharConv.toCharsBase(42, 3);
    if (r.ec == CharConv.ERRC_INVALID_ARGUMENT) {
        io::println("PASS: toCharsBase invalid base");
    } else {
        io::println("FAIL: toCharsBase invalid base");
    }
}

public fn test_toCharsLong(): void {
    let r: CharsResult = CharConv.toCharsLong(1000000000000 as long);
    if (r.ptr == "1000000000000") {
        io::println("PASS: toCharsLong");
    } else {
        io::println("FAIL: toCharsLong got " + r.ptr);
    }
}

public fn test_toCharsLong_zero(): void {
    let r: CharsResult = CharConv.toCharsLong(0 as long);
    if (r.ptr == "0") {
        io::println("PASS: toCharsLong zero");
    } else {
        io::println("FAIL: toCharsLong zero");
    }
}

public fn test_toCharsDouble(): void {
    let r: CharsResult = CharConv.toCharsDouble(3.14);
    if (r.ok() && String.length(r.ptr) > 0) {
        io::println("PASS: toCharsDouble");
    } else {
        io::println("FAIL: toCharsDouble");
    }
}

public fn test_toCharsDouble_nan(): void {
    let r: CharsResult = CharConv.toCharsDouble(0.0 / 0.0);
    if (r.ptr == "nan") {
        io::println("PASS: toCharsDouble NaN");
    } else {
        io::println("FAIL: toCharsDouble NaN got " + r.ptr);
    }
}

public fn test_toCharsDouble_inf(): void {
    let r: CharsResult = CharConv.toCharsDouble(1.0 / 0.0);
    if (r.ptr == "inf") {
        io::println("PASS: toCharsDouble inf");
    } else {
        io::println("FAIL: toCharsDouble inf got " + r.ptr);
    }
}

public fn test_toCharsDouble_neg_inf(): void {
    let r: CharsResult = CharConv.toCharsDouble(-1.0 / 0.0);
    if (r.ptr == "-inf") {
        io::println("PASS: toCharsDouble -inf");
    } else {
        io::println("FAIL: toCharsDouble -inf got " + r.ptr);
    }
}

public fn test_fromCharsInt(): void {
    let r: CharsResult = CharConv.fromCharsInt("42");
    if (r.ok() && r.intValue == 42 && r.consumed == 2) {
        io::println("PASS: fromCharsInt");
    } else {
        io::println("FAIL: fromCharsInt");
    }
}

public fn test_fromCharsInt_negative(): void {
    let r: CharsResult = CharConv.fromCharsInt("-42");
    if (r.ok() && r.intValue == -42) {
        io::println("PASS: fromCharsInt negative");
    } else {
        io::println("FAIL: fromCharsInt negative");
    }
}

public fn test_fromCharsInt_empty(): void {
    let r: CharsResult = CharConv.fromCharsInt("");
    if (!r.ok() && r.ec == CharConv.ERRC_INVALID_ARGUMENT) {
        io::println("PASS: fromCharsInt empty");
    } else {
        io::println("FAIL: fromCharsInt empty");
    }
}

public fn test_fromCharsInt_null(): void {
    let r: CharsResult = CharConv.fromCharsInt(null);
    if (!r.ok() && r.ec == CharConv.ERRC_INVALID_ARGUMENT) {
        io::println("PASS: fromCharsInt null");
    } else {
        io::println("FAIL: fromCharsInt null");
    }
}

public fn test_fromCharsIntBase_hex(): void {
    let r: CharsResult = CharConv.fromCharsIntBase("ff", 16);
    if (r.ok() && r.intValue == 255) {
        io::println("PASS: fromCharsIntBase hex");
    } else {
        io::println("FAIL: fromCharsIntBase hex");
    }
}

public fn test_fromCharsIntBase_binary(): void {
    let r: CharsResult = CharConv.fromCharsIntBase("101010", 2);
    if (r.ok() && r.intValue == 42) {
        io::println("PASS: fromCharsIntBase binary");
    } else {
        io::println("FAIL: fromCharsIntBase binary");
    }
}

public fn test_fromCharsLong(): void {
    let r: CharsResult = CharConv.fromCharsLong("9999999999999");
    if (r.ok() && r.intValue == 9999999999999 as long) {
        io::println("PASS: fromCharsLong");
    } else {
        io::println("FAIL: fromCharsLong");
    }
}

public fn test_fromCharsDouble(): void {
    let r: CharsResult = CharConv.fromCharsDouble("3.14");
    if (r.ok() && r.doubleValue > 3.13 && r.doubleValue < 3.15) {
        io::println("PASS: fromCharsDouble");
    } else {
        io::println("FAIL: fromCharsDouble");
    }
}

public fn test_fromCharsDouble_inf(): void {
    let r: CharsResult = CharConv.fromCharsDouble("inf");
    if (r.ok() && Double.isInfinite(r.doubleValue)) {
        io::println("PASS: fromCharsDouble inf");
    } else {
        io::println("FAIL: fromCharsDouble inf");
    }
}

public fn test_fromCharsDouble_nan(): void {
    let r: CharsResult = CharConv.fromCharsDouble("nan");
    if (r.ok() && Double.isNaN(r.doubleValue)) {
        io::println("PASS: fromCharsDouble nan");
    } else {
        io::println("FAIL: fromCharsDouble nan");
    }
}

public fn test_roundTripDouble(): void {
    let ok: bool = CharConv.roundTripDouble(3.14159265358979);
    if (ok) {
        io::println("PASS: roundTripDouble");
    } else {
        io::println("FAIL: roundTripDouble");
    }
}

public fn test_roundTripInt(): void {
    let ok: bool = CharConv.roundTripInt(12345);
    if (ok) {
        io::println("PASS: roundTripInt");
    } else {
        io::println("FAIL: roundTripInt");
    }
}

public fn test_roundTripLong(): void {
    let ok: bool = CharConv.roundTripLong(9876543210 as long);
    if (ok) {
        io::println("PASS: roundTripLong");
    } else {
        io::println("FAIL: roundTripLong");
    }
}

public fn test_charsResult_toString(): void {
    let r: CharsResult = CharConv.toChars(42);
    let s: string = r.toString();
    if (String.length(s) > 0) {
        io::println("PASS: CharsResult.toString");
    } else {
        io::println("FAIL: CharsResult.toString");
    }
}

public fn test_charsResult_ok(): void {
    let r: CharsResult = CharConv.toChars(42);
    if (r.ok()) {
        io::println("PASS: CharsResult.ok success");
    } else {
        io::println("FAIL: CharsResult.ok success");
    }
}

public fn test_constants(): void {
    if (CharConv.SCIENTIFIC == 1 && CharConv.FIXED == 2 && CharConv.HEX == 4 && CharConv.GENERAL == 3) {
        io::println("PASS: chars_format constants");
    } else {
        io::println("FAIL: chars_format constants");
    }
    if (CharConv.ERRC_SUCCESS == 0 && CharConv.ERRC_INVALID_ARGUMENT == 1 && CharConv.ERRC_RESULT_OUT_OF_RANGE == 2) {
        io::println("PASS: errc constants");
    } else {
        io::println("FAIL: errc constants");
    }
}

public fn test_toCharsDoubleFmt_scientific(): void {
    let r: CharsResult = CharConv.toCharsDoubleFmt(3.14, CharConv.SCIENTIFIC);
    if (r.ok() && String.length(r.ptr) > 0) {
        io::println("PASS: toCharsDoubleFmt scientific");
    } else {
        io::println("FAIL: toCharsDoubleFmt scientific");
    }
}

public fn test_toCharsDoublePrec(): void {
    let r: CharsResult = CharConv.toCharsDoublePrec(3.14159, CharConv.FIXED, 3);
    if (r.ok() && String.length(r.ptr) > 0) {
        io::println("PASS: toCharsDoublePrec");
    } else {
        io::println("FAIL: toCharsDoublePrec");
    }
}

public fn test_fromCharsDoubleFmt(): void {
    let r: CharsResult = CharConv.fromCharsDoubleFmt("1.5e2", CharConv.SCIENTIFIC);
    if (r.ok() && r.doubleValue > 149.9 && r.doubleValue < 150.1) {
        io::println("PASS: fromCharsDoubleFmt");
    } else {
        io::println("FAIL: fromCharsDoubleFmt");
    }
}

public fn run_all_charconv_tests(): void {
    io::println("=== CharConv.tr Tests ===");
    test_toChars_int();
    test_toChars_negative();
    test_toChars_zero();
    test_toCharsBase_hex();
    test_toCharsBase_binary();
    test_toCharsBase_octal();
    test_toCharsBase_invalid_base();
    test_toCharsLong();
    test_toCharsLong_zero();
    test_toCharsDouble();
    test_toCharsDouble_nan();
    test_toCharsDouble_inf();
    test_toCharsDouble_neg_inf();
    test_fromCharsInt();
    test_fromCharsInt_negative();
    test_fromCharsInt_empty();
    test_fromCharsInt_null();
    test_fromCharsIntBase_hex();
    test_fromCharsIntBase_binary();
    test_fromCharsLong();
    test_fromCharsDouble();
    test_fromCharsDouble_inf();
    test_fromCharsDouble_nan();
    test_roundTripDouble();
    test_roundTripInt();
    test_roundTripLong();
    test_charsResult_toString();
    test_charsResult_ok();
    test_constants();
    test_toCharsDoubleFmt_scientific();
    test_toCharsDoublePrec();
    test_fromCharsDoubleFmt();
}
