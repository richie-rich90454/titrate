// Test for CharConv — basic function call
import tt::lang::CharConv;
import tt::lang::String;

public fn test_toChars_int(): void {
    let r = CharConv.toChars(42);
    if (r.ptr == "42" && r.ok()) {
        io::println("PASS: toChars int works");
    } else {
        io::println("FAIL: toChars int");
    }
}

public fn run_all_charconv_tests(): void {
    io::println("=== CharConv.tr Tests ===");
    test_toChars_int();
}
