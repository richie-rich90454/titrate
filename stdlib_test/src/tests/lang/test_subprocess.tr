// Test file for Subprocess.tr (lang)
// Exercises the public API of the Subprocess module (in lang).
import tt::lang::Subprocess;
import tt::util::ArrayList;

public fn test_subprocessResult(): void {
    let result: SubprocessResult = new SubprocessResult("out", "err", 0, 12345);
    if (result.stdout == "out" && result.stderr == "err" && result.returnCode == 0 && result.pid == 12345) {
        io::println("PASS: SubprocessResult init");
    } else {
        io::println("FAIL: SubprocessResult init");
    }
}

public fn test_subprocessResult_defaults(): void {
    let result: SubprocessResult = new SubprocessResult("", "", -1, 0);
    if (result.stdout == "" && result.stderr == "" && result.returnCode == -1) {
        io::println("PASS: SubprocessResult defaults");
    } else {
        io::println("FAIL: SubprocessResult defaults");
    }
}

public fn run_all_subprocess_lang_tests(): void {
    io::println("=== Subprocess.tr (lang) Tests ===");
    test_subprocessResult();
    test_subprocessResult_defaults();
}
