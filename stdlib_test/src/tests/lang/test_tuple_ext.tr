// Test file for lang/TupleExt.tr
// Exercises Tuple3, Tuple4, and Tuple5 classes.
import tt::lang::TupleExt;
import tt::lang::Variant;

public fn test_tuple3_construct(): void {
    let t: Tuple3 = new Tuple3(Variant.of("a", 1 as Variant), Variant.of("b", 2 as Variant), Variant.of("c", 3 as Variant));
    if (t == null) {
        io::println("FAIL: Tuple3 null");
    } else {
        io::println("PASS: Tuple3 construction works");
    }
}

public fn test_tuple3_getters(): void {
    let t: Tuple3 = new Tuple3(Variant.of("a", 1 as Variant), Variant.of("b", 2 as Variant), Variant.of("c", 3 as Variant));
    if (t.getFirst() == null || t.getSecond() == null || t.getThird() == null) {
        io::println("FAIL: Tuple3 getters null");
    } else if (!t.getFirst().hasTag("a") || !t.getSecond().hasTag("b") || !t.getThird().hasTag("c")) {
        io::println("FAIL: Tuple3 getters tags wrong");
    } else {
        io::println("PASS: Tuple3 getters works");
    }
}

public fn test_tuple3_fields(): void {
    let t: Tuple3 = new Tuple3(Variant.of("a", 1 as Variant), Variant.of("b", 2 as Variant), Variant.of("c", 3 as Variant));
    if (t.first == null || t.second == null || t.third == null) {
        io::println("FAIL: Tuple3 fields null");
    } else {
        io::println("PASS: Tuple3 fields works");
    }
}

public fn test_tuple3_toString(): void {
    let t: Tuple3 = new Tuple3(Variant.of("a", 1 as Variant), Variant.of("b", 2 as Variant), Variant.of("c", 3 as Variant));
    let s: string = t.toString();
    if (String.length(s) == 0) {
        io::println("FAIL: Tuple3 toString empty");
    } else if (String.indexOf(s, "(") < 0 || String.indexOf(s, ")") < 0) {
        io::println("FAIL: Tuple3 toString missing parens = " + s);
    } else {
        io::println("PASS: Tuple3 toString works");
    }
}

