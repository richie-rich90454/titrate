// Test file for Itertools.tr (lang)
// Exercises the public API of the Itertools module (in lang).
import tt::lang::Itertools;
import tt::util::ArrayList;
import tt::util::Pair;
import tt::lang::Variant;

public fn test_accumulate_double(): void {
    let data: ArrayList<double> = new ArrayList<double>();
    data.add(1.0);
    data.add(2.0);
    data.add(3.0);
    let adder: fn(double, double): double = fn(a: double, b: double): double { return a + b; };
    let result: ArrayList<double> = Itertools.accumulate(data, adder);
    if (result.size() == 3 && result.get(0) == 1.0 && result.get(2) == 6.0) {
        io::println("PASS: accumulate double");
    } else {
        io::println("FAIL: accumulate double");
    }
}

public fn test_accumulate_empty(): void {
    let data: ArrayList<double> = new ArrayList<double>();
    let adder: fn(double, double): double = fn(a: double, b: double): double { return a + b; };
    let result: ArrayList<double> = Itertools.accumulate(data, adder);
    if (result.size() == 0) {
        io::println("PASS: accumulate empty");
    } else {
        io::println("FAIL: accumulate empty");
    }
}

public fn test_accumulateVariant(): void {
    let data: ArrayList<Variant> = new ArrayList<Variant>();
    data.add(Variant.of("int", Variant.of("string", "1")));
    data.add(Variant.of("int", Variant.of("string", "2")));
    let f: fn(Variant, Variant): Variant = fn(a: Variant, b: Variant): Variant { return a; };
    let result: ArrayList<Variant> = Itertools.accumulateVariant(data, f);
    if (result.size() == 2) {
        io::println("PASS: accumulateVariant");
    } else {
        io::println("FAIL: accumulateVariant");
    }
}

public fn test_compress(): void {
    let data: ArrayList<Variant> = new ArrayList<Variant>();
    data.add(Variant.of("string", "a"));
    data.add(Variant.of("string", "b"));
    data.add(Variant.of("string", "c"));
    let selectors: ArrayList<bool> = new ArrayList<bool>();
    selectors.add(true);
    selectors.add(false);
    selectors.add(true);
    let result: ArrayList<Variant> = Itertools.compress(data, selectors);
    if (result.size() == 2) {
        io::println("PASS: compress");
    } else {
        io::println("FAIL: compress");
    }
}

public fn test_dropwhile(): void {
    let data: ArrayList<Variant> = new ArrayList<Variant>();
    data.add(Variant.of("int", Variant.of("string", "1")));
    data.add(Variant.of("int", Variant.of("string", "2")));
    data.add(Variant.of("int", Variant.of("string", "3")));
    let pred: fn(Variant): bool = fn(v: Variant): bool { return true; };
    let result: ArrayList<Variant> = Itertools.dropwhile(data, pred);
    if (result.size() == 0) {
        io::println("PASS: dropwhile all");
    } else {
        io::println("FAIL: dropwhile all");
    }
}

public fn test_filterfalse(): void {
    let data: ArrayList<Variant> = new ArrayList<Variant>();
    data.add(Variant.of("int", Variant.of("string", "1")));
    data.add(Variant.of("int", Variant.of("string", "2")));
    let pred: fn(Variant): bool = fn(v: Variant): bool { return true; };
    let result: ArrayList<Variant> = Itertools.filterfalse(data, pred);
    if (result.size() == 0) {
        io::println("PASS: filterfalse all");
    } else {
        io::println("FAIL: filterfalse all");
    }
}

public fn test_groupby(): void {
    let data: ArrayList<Variant> = new ArrayList<Variant>();
    data.add(Variant.of("string", "apple"));
    data.add(Variant.of("string", "banana"));
    data.add(Variant.of("string", "avocado"));
    let keyFn: fn(Variant): string = fn(v: Variant): string {
        return String.substring(v.toString(), 0, 1);
    };
    let groups: HashMap<string, ArrayList<Variant>> = Itertools.groupby(data, keyFn);
    if (groups.size() > 0) {
        io::println("PASS: groupby");
    } else {
        io::println("FAIL: groupby");
    }
}

public fn test_islice(): void {
    let data: ArrayList<Variant> = new ArrayList<Variant>();
    data.add(Variant.of("int", Variant.of("string", "0")));
    data.add(Variant.of("int", Variant.of("string", "1")));
    data.add(Variant.of("int", Variant.of("string", "2")));
    data.add(Variant.of("int", Variant.of("string", "3")));
    let result: ArrayList<Variant> = Itertools.islice(data, 1, 3, 1);
    if (result.size() == 2) {
        io::println("PASS: islice");
    } else {
        io::println("FAIL: islice");
    }
}

public fn test_islice_empty_step_zero(): void {
    let data: ArrayList<Variant> = new ArrayList<Variant>();
    data.add(Variant.of("int", Variant.of("string", "1")));
    let result: ArrayList<Variant> = Itertools.islice(data, 0, 1, 0);
    if (result.size() == 0) {
        io::println("PASS: islice step zero");
    } else {
        io::println("FAIL: islice step zero");
    }
}

public fn test_takewhile(): void {
    let data: ArrayList<Variant> = new ArrayList<Variant>();
    data.add(Variant.of("int", Variant.of("string", "1")));
    data.add(Variant.of("int", Variant.of("string", "2")));
    let pred: fn(Variant): bool = fn(v: Variant): bool { return true; };
    let result: ArrayList<Variant> = Itertools.takewhile(data, pred);
    if (result.size() == 2) {
        io::println("PASS: takewhile all");
    } else {
        io::println("FAIL: takewhile all");
    }
}

public fn test_zipLongest(): void {
    let a: ArrayList<Variant> = new ArrayList<Variant>();
    a.add(Variant.of("string", "a"));
    a.add(Variant.of("string", "b"));
    let b: ArrayList<Variant> = new ArrayList<Variant>();
    b.add(Variant.of("string", "1"));
    let fill: Variant = Variant.of("string", "FILL");
    let result: ArrayList<Pair<Variant, Variant>> = Itertools.zipLongest(a, b, fill);
    if (result.size() == 2) {
        io::println("PASS: zipLongest");
    } else {
        io::println("FAIL: zipLongest");
    }
}

public fn test_starmap(): void {
    let data: ArrayList<ArrayList<Variant>> = new ArrayList<ArrayList<Variant>>();
    let inner: ArrayList<Variant> = new ArrayList<Variant>();
    inner.add(Variant.of("int", Variant.of("string", "1")));
    data.add(inner);
    let f: fn(ArrayList<Variant>): Variant = fn(args: ArrayList<Variant>): Variant {
        return Variant.of("int", Variant.of("string", "0"));
    };
    let result: ArrayList<Variant> = Itertools.starmap(f, data);
    if (result.size() == 1) {
        io::println("PASS: starmap");
    } else {
        io::println("FAIL: starmap");
    }
}

public fn run_all_itertools_lang_tests(): void {
    io::println("=== Itertools.tr (lang) Tests ===");
    test_accumulate_double();
    test_accumulate_empty();
    test_accumulateVariant();
    test_compress();
    test_dropwhile();
    test_filterfalse();
    test_groupby();
    test_islice();
    test_islice_empty_step_zero();
    test_takewhile();
    test_zipLongest();
    test_starmap();
}
