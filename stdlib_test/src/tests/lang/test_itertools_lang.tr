public fn test_itertools_dropwhile(): void {
    let data: ArrayList<Variant> = new ArrayList<Variant>();
    data.add(Variant.of("int", 1 as Variant));
    data.add(Variant.of("int", 2 as Variant));
    data.add(Variant.of("int", 3 as Variant));
    data.add(Variant.of("int", 0 as Variant));
    data.add(Variant.of("int", 5 as Variant));
    // Drop while tag is "int" — once predicate false, keep rest
    let result: ArrayList<Variant> = Itertools.dropwhile(data, fn(v: Variant): bool { return v.hasTag("int"); });
    // Since all have "int" tag, predicate stays true; result empty
    if (result.size() != 0) {
        io::println("FAIL: Itertools.dropwhile size = " + Integer.toString(result.size()));
    } else {
        io::println("PASS: Itertools.dropwhile works");
    }
}

public fn test_itertools_dropwhile_partial(): void {
    let data: ArrayList<Variant> = new ArrayList<Variant>();
    data.add(Variant.of("drop", 1 as Variant));
    data.add(Variant.of("drop", 2 as Variant));
    data.add(Variant.of("keep", 3 as Variant));
    data.add(Variant.of("keep", 4 as Variant));
    // Drop while tag is "drop"; once "keep" found, stop dropping
    let result: ArrayList<Variant> = Itertools.dropwhile(data, fn(v: Variant): bool { return v.hasTag("drop"); });
    if (result.size() != 2) {
        io::println("FAIL: Itertools.dropwhile partial size = " + Integer.toString(result.size()));
    } else {
        io::println("PASS: Itertools.dropwhile partial works");
    }
}

public fn test_itertools_filterfalse(): void {
    let data: ArrayList<Variant> = new ArrayList<Variant>();
    data.add(Variant.of("even", 1 as Variant));
    data.add(Variant.of("odd", 2 as Variant));
    data.add(Variant.of("even", 3 as Variant));
    data.add(Variant.of("odd", 4 as Variant));
    // Keep elements where predicate is FALSE (i.e., not "even")
    let result: ArrayList<Variant> = Itertools.filterfalse(data, fn(v: Variant): bool { return v.hasTag("even"); });
    if (result.size() != 2) {
        io::println("FAIL: Itertools.filterfalse size = " + Integer.toString(result.size()));
    } else {
        io::println("PASS: Itertools.filterfalse works");
    }
}

public fn test_itertools_filterfalse_all_kept(): void {
    let data: ArrayList<Variant> = new ArrayList<Variant>();
    data.add(Variant.of("a", 1 as Variant));
    data.add(Variant.of("b", 2 as Variant));
    // Predicate always true, so filterfalse keeps nothing
    let result: ArrayList<Variant> = Itertools.filterfalse(data, fn(v: Variant): bool { return true; });
    if (result.size() != 0) {
        io::println("FAIL: Itertools.filterfalse all true size = " + Integer.toString(result.size()));
    } else {
        io::println("PASS: Itertools.filterfalse all true works");
    }
}

public fn test_itertools_groupby(): void {
    let data: ArrayList<Variant> = new ArrayList<Variant>();
    data.add(Variant.of("a", 1 as Variant));
    data.add(Variant.of("a", 2 as Variant));
    data.add(Variant.of("b", 3 as Variant));
    data.add(Variant.of("b", 4 as Variant));
    data.add(Variant.of("a", 5 as Variant));
    let result: HashMap<string, ArrayList<Variant>> = Itertools.groupby(data, fn(v: Variant): string { return v.typeTag(); });
    if (!result.containsKey("a") || !result.containsKey("b")) {
        io::println("FAIL: Itertools.groupby missing keys");
    } else if (result.get("a").size() != 3 || result.get("b").size() != 2) {
        io::println("FAIL: Itertools.groupby group sizes");
    } else {
        io::println("PASS: Itertools.groupby works");
    }
}

public fn test_itertools_groupby_empty(): void {
    let data: ArrayList<Variant> = new ArrayList<Variant>();
    let result: HashMap<string, ArrayList<Variant>> = Itertools.groupby(data, fn(v: Variant): string { return v.typeTag(); });
    if (result.size() != 0) {
        io::println("FAIL: Itertools.groupby empty size = " + Integer.toString(result.size()));
    } else {
        io::println("PASS: Itertools.groupby empty works");
    }
}

public fn test_itertools_islice(): void {
    let data: ArrayList<Variant> = new ArrayList<Variant>();
    data.add(Variant.of("int", 0 as Variant));
    data.add(Variant.of("int", 1 as Variant));
    data.add(Variant.of("int", 2 as Variant));
    data.add(Variant.of("int", 3 as Variant));
    data.add(Variant.of("int", 4 as Variant));
    let result: ArrayList<Variant> = Itertools.islice(data, 0, 5, 2);
    if (result.size() != 3) {
        io::println("FAIL: Itertools.islice size = " + Integer.toString(result.size()));
    } else {
        io::println("PASS: Itertools.islice works");
    }
}

public fn test_itertools_islice_step_zero(): void {
    let data: ArrayList<Variant> = new ArrayList<Variant>();
    data.add(Variant.of("int", 0 as Variant));
    let result: ArrayList<Variant> = Itertools.islice(data, 0, 5, 0);
    // step <= 0 returns empty
    if (result.size() != 0) {
        io::println("FAIL: Itertools.islice step zero size = " + Integer.toString(result.size()));
    } else {
        io::println("PASS: Itertools.islice step zero works");
    }
}

public fn test_itertools_islice_range(): void {
    let data: ArrayList<Variant> = new ArrayList<Variant>();
    var i: int = 0;
    while (i < 10) {
        data.add(Variant.of("int", i as Variant));
        i = i + 1;
    }
    let result: ArrayList<Variant> = Itertools.islice(data, 2, 8, 3);
    // indices 2, 5 -> 2 elements
    if (result.size() != 2) {
        io::println("FAIL: Itertools.islice range size = " + Integer.toString(result.size()));
    } else {
        io::println("PASS: Itertools.islice range works");
    }
}

public fn test_itertools_starmap(): void {
    let args1: ArrayList<Variant> = new ArrayList<Variant>();
    args1.add(Variant.of("int", 1 as Variant));
    args1.add(Variant.of("int", 2 as Variant));
    let args2: ArrayList<Variant> = new ArrayList<Variant>();
    args2.add(Variant.of("int", 3 as Variant));
    args2.add(Variant.of("int", 4 as Variant));
    let data: ArrayList<ArrayList<Variant>> = new ArrayList<ArrayList<Variant>>();
    data.add(args1); data.add(args2);
    let result: ArrayList<Variant> = Itertools.starmap(fn(args: ArrayList<Variant>): Variant { return args.get(0); }, data);
    if (result.size() != 2) {
        io::println("FAIL: Itertools.starmap size = " + Integer.toString(result.size()));
    } else {
        io::println("PASS: Itertools.starmap works");
    }
}

public fn test_itertools_starmap_empty(): void {
    let data: ArrayList<ArrayList<Variant>> = new ArrayList<ArrayList<Variant>>();
    let result: ArrayList<Variant> = Itertools.starmap(fn(args: ArrayList<Variant>): Variant { return args.get(0); }, data);
    if (result.size() != 0) {
        io::println("FAIL: Itertools.starmap empty size = " + Integer.toString(result.size()));
    } else {
        io::println("PASS: Itertools.starmap empty works");
    }
}

