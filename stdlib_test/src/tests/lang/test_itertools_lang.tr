public fn test_itertools_zipLongest_equal(): void {
    let a: ArrayList<Variant> = new ArrayList<Variant>();
    a.add(Variant.of("int", 1 as Variant));
    a.add(Variant.of("int", 2 as Variant));
    let b: ArrayList<Variant> = new ArrayList<Variant>();
    b.add(Variant.of("str", 10 as Variant));
    b.add(Variant.of("str", 20 as Variant));
    let fill: Variant = Variant.of("fill", 0 as Variant);
    let result: ArrayList<Pair<Variant, Variant>> = Itertools.zipLongest(a, b, fill);
    if (result.size() != 2) {
        io::println("FAIL: Itertools.zipLongest equal size = " + Integer.toString(result.size()));
    } else {
        io::println("PASS: Itertools.zipLongest equal works");
    }
}

public fn test_itertools_zipLongest_unequal(): void {
    let a: ArrayList<Variant> = new ArrayList<Variant>();
    a.add(Variant.of("int", 1 as Variant));
    a.add(Variant.of("int", 2 as Variant));
    a.add(Variant.of("int", 3 as Variant));
    let b: ArrayList<Variant> = new ArrayList<Variant>();
    b.add(Variant.of("str", 10 as Variant));
    let fill: Variant = Variant.of("fill", 0 as Variant);
    let result: ArrayList<Pair<Variant, Variant>> = Itertools.zipLongest(a, b, fill);
    if (result.size() != 3) {
        io::println("FAIL: Itertools.zipLongest unequal size = " + Integer.toString(result.size()));
    } else {
        // The last pair should use fillValue for b
        let lastPair: Pair<Variant, Variant> = result.get(2);
        if (lastPair.getSecond().hasTag("fill")) {
            io::println("PASS: Itertools.zipLongest unequal fill works");
        } else {
            io::println("FAIL: Itertools.zipLongest unequal fill not applied");
        }
    }
}

public fn test_itertools_zipLongest_empty(): void {
    let a: ArrayList<Variant> = new ArrayList<Variant>();
    let b: ArrayList<Variant> = new ArrayList<Variant>();
    let fill: Variant = Variant.of("fill", 0 as Variant);
    let result: ArrayList<Pair<Variant, Variant>> = Itertools.zipLongest(a, b, fill);
    if (result.size() != 0) {
        io::println("FAIL: Itertools.zipLongest empty size = " + Integer.toString(result.size()));
    } else {
        io::println("PASS: Itertools.zipLongest empty works");
    }
}

public fn run_all_itertools_lang_tests(): void {
    io::println("=== lang/Itertools.tr Tests ===");
    test_itertools_accumulate();
    test_itertools_accumulate_empty();
    test_itertools_accumulate_single();
    test_itertools_accumulateVariant();
    test_itertools_accumulateVariant_empty();
    test_itertools_compress();
    test_itertools_compress_all_true();
    test_itertools_compress_all_false();
    test_itertools_dropwhile();
    test_itertools_dropwhile_partial();
    test_itertools_filterfalse();
    test_itertools_filterfalse_all_kept();
    test_itertools_groupby();
    test_itertools_groupby_empty();
    test_itertools_islice();
    test_itertools_islice_step_zero();
    test_itertools_islice_range();
    test_itertools_starmap();
    test_itertools_starmap_empty();
    test_itertools_takewhile();
    test_itertools_takewhile_all();
    test_itertools_takewhile_none();
    test_itertools_zipLongest_equal();
    test_itertools_zipLongest_unequal();
    test_itertools_zipLongest_empty();
}
