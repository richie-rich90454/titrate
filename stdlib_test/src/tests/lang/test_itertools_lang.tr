// Test file for lang/Itertools.tr
// Exercises the Variant-based iterator utilities:
// accumulate, accumulateVariant, compress, dropwhile, filterfalse,
// groupby, islice, starmap, takewhile, zipLongest.
import tt::lang::Itertools;
import tt::util::ArrayList;
import tt::util::HashMap;
import tt::util::Pair;
import tt::lang::Variant;
import tt::lang::Integer;

public fn test_itertools_accumulate(): void {
    let data: ArrayList<double> = new ArrayList<double>();
    data.add(1.0); data.add(2.0); data.add(3.0); data.add(4.0);
    let result: ArrayList<double> = Itertools.accumulate(data, fn(a: double, b: double): double { return a + b; });
    if (result.size() != 4 || result.get(0) != 1.0 || result.get(1) != 3.0 || result.get(2) != 6.0 || result.get(3) != 10.0) {
        io::println("FAIL: Itertools.accumulate");
    } else {
        io::println("PASS: Itertools.accumulate works");
    }
}

public fn test_itertools_accumulate_empty(): void {
    let data: ArrayList<double> = new ArrayList<double>();
    let result: ArrayList<double> = Itertools.accumulate(data, fn(a: double, b: double): double { return a + b; });
    if (result.size() != 0) {
        io::println("FAIL: Itertools.accumulate empty size = " + Integer.toString(result.size()));
    } else {
        io::println("PASS: Itertools.accumulate empty works");
    }
}

public fn test_itertools_accumulate_single(): void {
    let data: ArrayList<double> = new ArrayList<double>();
    data.add(7.0);
    let result: ArrayList<double> = Itertools.accumulate(data, fn(a: double, b: double): double { return a * b; });
    if (result.size() != 1 || result.get(0) != 7.0) {
        io::println("FAIL: Itertools.accumulate single");
    } else {
        io::println("PASS: Itertools.accumulate single works");
    }
}

public fn test_itertools_accumulateVariant(): void {
    let data: ArrayList<Variant> = new ArrayList<Variant>();
    data.add(Variant.of("int", 1 as Variant));
    data.add(Variant.of("int", 2 as Variant));
    data.add(Variant.of("int", 3 as Variant));
    let result: ArrayList<Variant> = Itertools.accumulateVariant(data, fn(a: Variant, b: Variant): Variant { return a; });
    if (result.size() != 3) {
        io::println("FAIL: Itertools.accumulateVariant size = " + Integer.toString(result.size()));
    } else {
        io::println("PASS: Itertools.accumulateVariant works");
    }
}

