public fn test_itertools_compress(): void {
    let data: ArrayList<Variant> = new ArrayList<Variant>();
    data.add(Variant.of("int", 1 as Variant));
    data.add(Variant.of("int", 2 as Variant));
    data.add(Variant.of("int", 3 as Variant));
    data.add(Variant.of("int", 4 as Variant));
    let selectors: ArrayList<bool> = new ArrayList<bool>();
    selectors.add(true); selectors.add(false); selectors.add(true); selectors.add(false);
    let result: ArrayList<Variant> = Itertools.compress(data, selectors);
    if (result.size() != 2) {
        io::println("FAIL: Itertools.compress size = " + Integer.toString(result.size()));
    } else {
        io::println("PASS: Itertools.compress works");
    }
}

