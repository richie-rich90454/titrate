// Test file for AssertExt.tr
// Exercises the public API of the AssertExt module.
import tt::lang::AssertExt;
import tt::lang::Variant;
import tt::util::ArrayList;

public fn test_assertEqual_pass(): void {
    let threw: bool = false;
    try {
        AssertExt.assertEqual(5 as Variant, 5 as Variant, "should be equal");
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("FAIL: AssertExt.assertEqual pass threw");
    } else {
        io::println("PASS: AssertExt.assertEqual pass");
    }
}

public fn test_assertEqual_fail(): void {
    let threw: bool = false;
    try {
        AssertExt.assertEqual(5 as Variant, 6 as Variant, "should be equal");
    } catch (e: string) {
        threw = true;
    }
    if (!threw) {
        io::println("FAIL: AssertExt.assertEqual fail did not throw");
    } else {
        io::println("PASS: AssertExt.assertEqual fail throws");
    }
}

