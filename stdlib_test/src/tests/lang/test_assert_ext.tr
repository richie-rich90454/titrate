public fn test_assertIn_found(): void {
    let coll: ArrayList<Variant> = new ArrayList<Variant>();
    coll.add(1 as Variant);
    coll.add(2 as Variant);
    coll.add(3 as Variant);
    let threw: bool = false;
    try {
        AssertExt.assertIn(2 as Variant, coll, "should be in");
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("FAIL: AssertExt.assertIn found threw");
    } else {
        io::println("PASS: AssertExt.assertIn found");
    }
}

public fn test_assertIn_notFound(): void {
    let coll: ArrayList<Variant> = new ArrayList<Variant>();
    coll.add(1 as Variant);
    coll.add(2 as Variant);
    let threw: bool = false;
    try {
        AssertExt.assertIn(99 as Variant, coll, "should be in");
    } catch (e: string) {
        threw = true;
    }
    if (!threw) {
        io::println("FAIL: AssertExt.assertIn notFound did not throw");
    } else {
        io::println("PASS: AssertExt.assertIn notFound throws");
    }
}

public fn run_all_assert_ext_tests(): void {
    io::println("=== AssertExt.tr Tests ===");
    test_assertEqual_pass();
    test_assertEqual_fail();
    test_assertNotEqual_pass();
    test_assertNotEqual_fail();
    test_assertTrue_pass();
    test_assertTrue_fail();
    test_assertFalse_pass();
    test_assertFalse_fail();
    test_assertAlmostEqualTolerance_pass();
    test_assertAlmostEqualTolerance_fail();
    test_assertAlmostEqual_pass();
    test_assertGreater_pass();
    test_assertGreater_fail();
    test_assertLess_pass();
    test_assertLess_fail();
    test_assertIsNotNone();
    test_assertIsNone();
    test_assertIn_found();
    test_assertIn_notFound();
}
