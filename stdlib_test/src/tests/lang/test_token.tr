// Test file for Token.tr
// Exercises the public API of the Token module.
import tt::lang::Token;
import tt::lang::String;
import tt::util::ArrayList;
import tt::util::HashMap;

public fn test_tokName(): void {
    let names: HashMap<int, string> = Token.tokName();
    if (names != null && names.size() > 0) {
        io::println("PASS: tokName");
    } else {
        io::println("FAIL: tokName");
    }
}

public fn test_nameOf(): void {
    let name: string = Token.nameOf(1);
    if (name == "NAME") {
        io::println("PASS: nameOf NAME");
    } else {
        io::println("FAIL: nameOf NAME got " + name);
    }
}

public fn test_nameOf_unknown(): void {
    let name: string = Token.nameOf(-999);
    if (name == "<UNKNOWN>") {
        io::println("PASS: nameOf unknown");
    } else {
        io::println("FAIL: nameOf unknown");
    }
}

public fn test_valueOf(): void {
    let value: int = Token.valueOf("NAME");
    if (value == 1) {
        io::println("PASS: valueOf NAME");
    } else {
        io::println("FAIL: valueOf NAME");
    }
}

public fn test_valueOf_unknown(): void {
    let value: int = Token.valueOf("NONEXISTENT");
    if (value == -1) {
        io::println("PASS: valueOf unknown");
    } else {
        io::println("FAIL: valueOf unknown");
    }
}

public fn test_isToken(): void {
    if (Token.isToken(1) && !Token.isToken(-999)) {
        io::println("PASS: isToken");
    } else {
        io::println("FAIL: isToken");
    }
}

public fn test_tokList(): void {
    let list: ArrayList<string> = Token.tokList();
    if (list.size() > 0) {
        io::println("PASS: tokList");
    } else {
        io::println("FAIL: tokList");
    }
}

public fn test_tokenInfo(): void {
    let ti: TokenInfo = new TokenInfo(1, "hello");
    if (ti._type == 1 && ti.string == "hello" && ti.start == 0 && ti.end == 0 && ti.line == 0) {
        io::println("PASS: TokenInfo basic");
    } else {
        io::println("FAIL: TokenInfo basic");
    }
}

public fn test_tokenInfo_initWithPosition(): void {
    let ti: TokenInfo = new TokenInfo(1, "x");
    ti.initWithPosition(1, "x", 1, 2, 3);
    if (ti.start == 1 && ti.end == 2 && ti.line == 3) {
        io::println("PASS: TokenInfo initWithPosition");
    } else {
        io::println("FAIL: TokenInfo initWithPosition");
    }
}

public fn test_tokenInfo_typeName(): void {
    let ti: TokenInfo = new TokenInfo(2, "42");
    let name: string = ti.typeName();
    if (name == "NUMBER") {
        io::println("PASS: TokenInfo.typeName");
    } else {
        io::println("FAIL: TokenInfo.typeName");
    }
}

public fn test_tokenInfo_toString(): void {
    let ti: TokenInfo = new TokenInfo(1, "test");
    let s: string = ti.toString();
    if (String.length(s) > 0) {
        io::println("PASS: TokenInfo.toString");
    } else {
        io::println("FAIL: TokenInfo.toString");
    }
}

public fn test_tokenInfo_equals(): void {
    let a: TokenInfo = new TokenInfo(1, "x");
    let b: TokenInfo = new TokenInfo(1, "x");
    a.initWithPosition(1, "x", 0, 1, 1);
    b.initWithPosition(1, "x", 0, 1, 1);
    if (a.equals(b)) {
        io::println("PASS: TokenInfo.equals same");
    } else {
        io::println("FAIL: TokenInfo.equals same");
    }
}

public fn test_tokenInfo_equals_diff(): void {
    let a: TokenInfo = new TokenInfo(1, "x");
    let b: TokenInfo = new TokenInfo(2, "42");
    if (!a.equals(b)) {
        io::println("PASS: TokenInfo.equals different");
    } else {
        io::println("FAIL: TokenInfo.equals different");
    }
}

public fn run_all_token_tests(): void {
    io::println("=== Token.tr Tests ===");
    test_tokName();
    test_nameOf();
    test_nameOf_unknown();
    test_valueOf();
    test_valueOf_unknown();
    test_isToken();
    test_tokList();
    test_tokenInfo();
    test_tokenInfo_initWithPosition();
    test_tokenInfo_typeName();
    test_tokenInfo_toString();
    test_tokenInfo_equals();
    test_tokenInfo_equals_diff();
}
