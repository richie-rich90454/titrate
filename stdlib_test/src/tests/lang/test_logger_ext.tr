// Test file for lang/LoggerExt.tr
// Exercises JsonFormatter, SyslogHandler (construction only), RotatingHandler
// (construction + shouldRotate logic), EmailHandler (construction + setters),
// PerLevelLogger (handler management), and AsyncHandler (buffering).
//
// NOTE: SyslogHandler.send, RotatingHandler.write, and EmailHandler.send rely on
// native functions (Udp_send, File_append, SmtpClient) that require external
// resources. Those code paths are not exercised here; only construction and
// non-native logic are tested.
import tt::lang::LoggerExt;
import tt::util::ArrayList;
import tt::util::HashMap;
import tt::lang::Variant;
import tt::lang::Integer;

public fn test_logger_jsonFormatter_default(): void {
    let f: JsonFormatter = LoggerExt.jsonFormatter();
    if (f == null) {
        io::println("FAIL: jsonFormatter returned null");
    } else if (f.pretty) {
        io::println("FAIL: jsonFormatter pretty should be false");
    } else {
        io::println("PASS: jsonFormatter default works");
    }
}

public fn test_logger_jsonFormatter_construct(): void {
    let f: JsonFormatter = new JsonFormatter(true);
    if (!f.pretty) {
        io::println("FAIL: JsonFormatter(true) pretty should be true");
    } else {
        io::println("PASS: JsonFormatter(true) works");
    }
}

public fn test_logger_jsonFormatter_format_no_context(): void {
    let f: JsonFormatter = LoggerExt.jsonFormatter();
    let out: string = f.format("INFO", "hello", null);
    if (out != "{\"level\": \"INFO\", \"message\": \"hello\"}") {
        io::println("FAIL: JsonFormatter.format no context = " + out);
    } else {
        io::println("PASS: JsonFormatter.format no context works");
    }
}

public fn test_logger_jsonFormatter_format_with_context(): void {
    let f: JsonFormatter = LoggerExt.jsonFormatter();
    let ctx: HashMap<string, Variant> = new HashMap<string, Variant>();
    ctx.put("user", Variant.of("string", "alice" as Variant));
    let out: string = f.format("ERROR", "boom", ctx);
    // Should contain level, message, and user keys
    if (String.length(out) == 0 || out == null) {
        io::println("FAIL: JsonFormatter.format with context empty");
    } else {
        let hasLevel: bool = false;
        let hasMessage: bool = false;
        let hasUser: bool = false;
        // Simple substring checks via indexOf
        if (String.indexOf(out, "\"level\"") >= 0) { hasLevel = true; }
        if (String.indexOf(out, "\"message\"") >= 0) { hasMessage = true; }
        if (String.indexOf(out, "\"user\"") >= 0) { hasUser = true; }
        if (hasLevel && hasMessage && hasUser) {
            io::println("PASS: JsonFormatter.format with context works");
        } else {
            io::println("FAIL: JsonFormatter.format with context missing keys = " + out);
        }
    }
}

public fn test_logger_jsonFormatter_pretty(): void {
    let f: JsonFormatter = new JsonFormatter(true);
    let out: string = f.format("INFO", "hi", null);
    // Pretty output should contain a newline
    if (String.indexOf(out, "\n") < 0) {
        io::println("FAIL: JsonFormatter pretty should contain newline");
    } else {
        io::println("PASS: JsonFormatter pretty works");
    }
}

public fn test_logger_syslogHandler_construct(): void {
    let h: SyslogHandler = new SyslogHandler("localhost", 514);
    if (h == null) {
        io::println("FAIL: SyslogHandler null");
    } else if (h.host != "localhost" || h.port != 514 || h.facility != "user") {
        io::println("FAIL: SyslogHandler fields wrong");
    } else {
        io::println("PASS: SyslogHandler construction works");
    }
}

public fn test_logger_rotatingHandler_construct(): void {
    let h: RotatingHandler = new RotatingHandler("app.log", 1000L, 3);
    if (h == null) {
        io::println("FAIL: RotatingHandler null");
    } else if (h.filePath != "app.log" || h.maxSize != 1000L || h.backupCount != 3 || h.currentSize != 0L) {
        io::println("FAIL: RotatingHandler fields wrong");
    } else {
        io::println("PASS: RotatingHandler construction works");
    }
}

public fn test_logger_rotatingHandler_shouldRotate(): void {
    let h: RotatingHandler = new RotatingHandler("app.log", 100L, 3);
    // currentSize is 0, maxSize is 100 -> should not rotate
    if (h.shouldRotate()) {
        io::println("FAIL: RotatingHandler shouldRotate true at size 0");
    } else {
        io::println("PASS: RotatingHandler shouldRotate false works");
    }
}

public fn test_logger_emailHandler_construct(): void {
    let to: ArrayList<string> = new ArrayList<string>();
    to.add("ops@example.com");
    let h: EmailHandler = new EmailHandler("smtp.example.com", 25, "from@example.com", to);
    if (h == null) {
        io::println("FAIL: EmailHandler null");
    } else if (h.smtpHost != "smtp.example.com" || h.smtpPort != 25 || h.from != "from@example.com") {
        io::println("FAIL: EmailHandler fields wrong");
    } else if (h.subjectPrefix != "[Log]" || h.username != "" || h.password != "") {
        io::println("FAIL: EmailHandler defaults wrong");
    } else {
        io::println("PASS: EmailHandler construction works");
    }
}

public fn test_logger_emailHandler_setCredentials(): void {
    let to: ArrayList<string> = new ArrayList<string>();
    let h: EmailHandler = new EmailHandler("smtp.example.com", 25, "from@example.com", to);
    h.setCredentials("user", "pass");
    if (h.username != "user" || h.password != "pass") {
        io::println("FAIL: EmailHandler setCredentials");
    } else {
        io::println("PASS: EmailHandler setCredentials works");
    }
}

public fn test_logger_emailHandler_setSubjectPrefix(): void {
    let to: ArrayList<string> = new ArrayList<string>();
    let h: EmailHandler = new EmailHandler("smtp.example.com", 25, "from@example.com", to);
    h.setSubjectPrefix("[Alert]");
    if (h.subjectPrefix != "[Alert]") {
        io::println("FAIL: EmailHandler setSubjectPrefix");
    } else {
        io::println("PASS: EmailHandler setSubjectPrefix works");
    }
}

public fn test_logger_perLevelLogger_construct(): void {
    let pl: PerLevelLogger = new PerLevelLogger();
    if (pl == null) {
        io::println("FAIL: PerLevelLogger null");
    } else {
        io::println("PASS: PerLevelLogger construction works");
    }
}

public fn test_logger_perLevelLogger_addHandler(): void {
    let pl: PerLevelLogger = new PerLevelLogger();
    let h: RotatingHandler = new RotatingHandler("app.log", 1000L, 3);
    pl.addHandler("ERROR", h);
    // Logging at ERROR would call h.write which needs File_append (native).
    // Just verify the handler was registered by logging at a level with no handlers.
    pl.log("DEBUG", "no handlers here");
    io::println("PASS: PerLevelLogger addHandler works");
}

public fn test_logger_perLevelLogger_log_no_handlers(): void {
    let pl: PerLevelLogger = new PerLevelLogger();
    // No handlers registered; log should be a no-op
    pl.log("INFO", "ignored");
    io::println("PASS: PerLevelLogger log no handlers works");
}

public fn test_logger_asyncHandler_buffering(): void {
    // Wrap a null handler — AsyncHandler flush will fall through to io::println
    let ah: AsyncHandler = new AsyncHandler(null, 3);
    ah.log("INFO", "first");
    ah.log("INFO", "second");
    // Buffer should have 2 entries, not yet flushed
    if (ah.buffer.size() != 2) {
        io::println("FAIL: AsyncHandler buffer size = " + Integer.toString(ah.buffer.size()));
    } else {
        io::println("PASS: AsyncHandler buffering works");
    }
}

public fn test_logger_asyncHandler_auto_flush(): void {
    let ah: AsyncHandler = new AsyncHandler(null, 2);
    ah.log("INFO", "first");
    ah.log("INFO", "second");
    // After 2 entries (== bufferSize), auto-flush should clear buffer
    if (ah.buffer.size() != 0) {
        io::println("FAIL: AsyncHandler auto flush buffer size = " + Integer.toString(ah.buffer.size()));
    } else {
        io::println("PASS: AsyncHandler auto flush works");
    }
}

public fn test_logger_asyncHandler_manual_flush(): void {
    let ah: AsyncHandler = new AsyncHandler(null, 100);
    ah.log("INFO", "first");
    ah.log("INFO", "second");
    ah.flush();
    if (ah.buffer.size() != 0) {
        io::println("FAIL: AsyncHandler manual flush buffer size = " + Integer.toString(ah.buffer.size()));
    } else {
        io::println("PASS: AsyncHandler manual flush works");
    }
}

public fn run_all_logger_ext_tests(): void {
    io::println("=== lang/LoggerExt.tr Tests ===");
    test_logger_jsonFormatter_default();
    test_logger_jsonFormatter_construct();
    test_logger_jsonFormatter_format_no_context();
    test_logger_jsonFormatter_format_with_context();
    test_logger_jsonFormatter_pretty();
    test_logger_syslogHandler_construct();
    test_logger_rotatingHandler_construct();
    test_logger_rotatingHandler_shouldRotate();
    test_logger_emailHandler_construct();
    test_logger_emailHandler_setCredentials();
    test_logger_emailHandler_setSubjectPrefix();
    test_logger_perLevelLogger_construct();
    test_logger_perLevelLogger_addHandler();
    test_logger_perLevelLogger_log_no_handlers();
    test_logger_asyncHandler_buffering();
    test_logger_asyncHandler_auto_flush();
    test_logger_asyncHandler_manual_flush();
}
