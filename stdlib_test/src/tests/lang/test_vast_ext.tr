    let result: string = VastExt.vastGcd("12", "8");
    if (result != "4") {
        io::println("FAIL: VastExt.vastGcd = " + result);
    } else {
        io::println("PASS: VastExt.vastGcd works");
    }
}

public fn test_vastext_lcm(): void {
    let result: string = VastExt.vastLcm("4", "6");
    if (result != "12") {
        io::println("FAIL: VastExt.vastLcm = " + result);
    } else {
        io::println("PASS: VastExt.vastLcm works");
    }
