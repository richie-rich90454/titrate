// Test file for lang/VastExt.tr
// Exercises string-based arbitrary-precision integer arithmetic:
// vastAdd, vastSub, vastMul, vastDiv, vastMod, vastGcd, vastLcm,
// factorial, vastFactorial, vastIsProbablePrime, vastShiftLeft,
// vastShiftRight, vastBitLength, vastToByteArray.
import tt::lang::VastExt;
import tt::util::ArrayList;
import tt::lang::Integer;

public fn test_vastext_add(): void {
    let result: string = VastExt.vastAdd("123", "456");
    if (result != "579") {
        io::println("FAIL: VastExt.vastAdd = " + result);
    } else {
        io::println("PASS: VastExt.vastAdd works");
    }
}

public fn test_vastext_add_carry(): void {
    let result: string = VastExt.vastAdd("999", "1");
    if (result != "1000") {
        io::println("FAIL: VastExt.vastAdd carry = " + result);
    } else {
        io::println("PASS: VastExt.vastAdd carry works");
    }
}

public fn test_vastext_add_large(): void {
    // Numbers beyond long range
    let result: string = VastExt.vastAdd("99999999999999999999", "1");
    if (result != "100000000000000000000") {
        io::println("FAIL: VastExt.vastAdd large = " + result);
    } else {
        io::println("PASS: VastExt.vastAdd large works");
    }
}

public fn test_vastext_add_negative(): void {
    let result: string = VastExt.vastAdd("-10", "20");
    if (result != "10") {
        io::println("FAIL: VastExt.vastAdd negative = " + result);
    } else {
        io::println("PASS: VastExt.vastAdd negative works");
    }
}

public fn test_vastext_sub(): void {
    let result: string = VastExt.vastSub("579", "456");
    if (result != "123") {
        io::println("FAIL: VastExt.vastSub = " + result);
    } else {
        io::println("PASS: VastExt.vastSub works");
    }
}

public fn test_vastext_sub_negative_result(): void {
    let result: string = VastExt.vastSub("10", "20");
    if (result != "-10") {
        io::println("FAIL: VastExt.vastSub negative = " + result);
    } else {
        io::println("PASS: VastExt.vastSub negative works");
    }
}

public fn test_vastext_mul(): void {
    let result: string = VastExt.vastMul("12", "34");
    if (result != "408") {
        io::println("FAIL: VastExt.vastMul = " + result);
    } else {
        io::println("PASS: VastExt.vastMul works");
    }
}

public fn test_vastext_mul_large(): void {
    let result: string = VastExt.vastMul("9999999999", "9999999999");
    if (result != "99999999980000000001") {
        io::println("FAIL: VastExt.vastMul large = " + result);
    } else {
        io::println("PASS: VastExt.vastMul large works");
    }
}

public fn test_vastext_mul_zero(): void {
    let result: string = VastExt.vastMul("0", "123");
    if (result != "0") {
        io::println("FAIL: VastExt.vastMul zero = " + result);
    } else {
        io::println("PASS: VastExt.vastMul zero works");
    }
}

