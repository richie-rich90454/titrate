    if (ErrorCode.PERMISSION_DENIED != 1) {
        io::println("FAIL: ErrorCode.PERMISSION_DENIED = " + Integer.toString(ErrorCode.PERMISSION_DENIED));
    } else {
        io::println("PASS: ErrorCode.PERMISSION_DENIED = 1");
    }
}

