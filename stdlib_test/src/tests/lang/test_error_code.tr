    if (ErrorCode.TIMEOUT != 4) {
        io::println("FAIL: ErrorCode.TIMEOUT = " + Integer.toString(ErrorCode.TIMEOUT));
    } else {
        io::println("PASS: ErrorCode.TIMEOUT = 4");
    }
}

public fn test_OUT_OF_MEMORY_constant(): void {
    if (ErrorCode.OUT_OF_MEMORY != 7) {
        io::println("FAIL: ErrorCode.OUT_OF_MEMORY = " + Integer.toString(ErrorCode.OUT_OF_MEMORY));
    } else {
        io::println("PASS: ErrorCode.OUT_OF_MEMORY = 7");
    }
}

public fn test_INVALID_ARGUMENT_constant(): void {
    if (ErrorCode.INVALID_ARGUMENT != 8) {
        io::println("FAIL: ErrorCode.INVALID_ARGUMENT = " + Integer.toString(ErrorCode.INVALID_ARGUMENT));
    } else {
        io::println("PASS: ErrorCode.INVALID_ARGUMENT = 8");
    }
}

public fn test_NOT_SUPPORTED_constant(): void {
    if (ErrorCode.NOT_SUPPORTED != 14) {
        io::println("FAIL: ErrorCode.NOT_SUPPORTED = " + Integer.toString(ErrorCode.NOT_SUPPORTED));
    } else {
        io::println("PASS: ErrorCode.NOT_SUPPORTED = 14");
    }
}

public fn run_all_error_code_tests(): void {
    io::println("=== ErrorCode.tr Tests ===");
    test_errorcode_init();
    test_errorcode_value();
    test_errorcode_category();
    test_errorcode_message();
    test_errorcode_toString();
    test_errorcode_equals_same();
    test_errorcode_equals_diff_value();
    test_errorcode_equals_diff_category();
    test_genericError();
    test_systemError();
    test_ioError();
    test_networkError();
    test_databaseError();
    test_NO_ERROR_constant();
    test_PERMISSION_DENIED_constant();
    test_FILE_NOT_FOUND_constant();
    test_TIMEOUT_constant();
    test_OUT_OF_MEMORY_constant();
    test_INVALID_ARGUMENT_constant();
    test_NOT_SUPPORTED_constant();
}
