    if (ErrorCode.FILE_NOT_FOUND != 2) {
        io::println("FAIL: ErrorCode.FILE_NOT_FOUND = " + Integer.toString(ErrorCode.FILE_NOT_FOUND));
    } else {
        io::println("PASS: ErrorCode.FILE_NOT_FOUND = 2");
    }
}

