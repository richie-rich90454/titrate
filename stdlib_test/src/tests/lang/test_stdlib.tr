// Test for StdLib — basic function calls
import tt::lang::StdLib;

public fn test_exit_constants(): void {
    if (StdLib.EXIT_SUCCESS() == 0 && StdLib.EXIT_FAILURE() == 1) {
        io::println("PASS: exit constants");
    } else {
        io::println("FAIL: exit constants");
    }
}

public fn run_all_stdlib_tests(): void {
    io::println("=== StdLib.tr Tests ===");
    test_exit_constants();
}
