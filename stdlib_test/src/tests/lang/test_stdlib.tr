// Test file for StdLib.tr
// Exercises the public API of the StdLib module.
import tt::lang::StdLib;
import tt::util::ArrayList;

public fn test_malloc(): void {
    let block: MemoryBlock = StdLib.malloc(64);
    if (block != null && block.size() == 64 && !block.isFreed()) {
        io::println("PASS: malloc");
    } else {
        io::println("FAIL: malloc");
    }
}

public fn test_malloc_zero(): void {
    let block: MemoryBlock = StdLib.malloc(0);
    if (block != null && block.size() == 0) {
        io::println("PASS: malloc zero");
    } else {
        io::println("FAIL: malloc zero");
    }
}

public fn test_calloc(): void {
    let block: MemoryBlock = StdLib.calloc(10, 4);
    if (block != null && block.size() == 40 && !block.isFreed()) {
        io::println("PASS: calloc");
    } else {
        io::println("FAIL: calloc");
    }
}

public fn test_free(): void {
    let block: MemoryBlock = StdLib.malloc(16);
    StdLib.free(block);
    if (block.isFreed()) {
        io::println("PASS: free");
    } else {
        io::println("FAIL: free");
    }
}

public fn test_realloc_null(): void {
    let block: MemoryBlock = StdLib.realloc(null, 32);
    if (block != null && block.size() == 32) {
        io::println("PASS: realloc null (like malloc)");
    } else {
        io::println("FAIL: realloc null (like malloc)");
    }
}

public fn test_realloc_shrink(): void {
    let block: MemoryBlock = StdLib.malloc(64);
    let shrunk: MemoryBlock = StdLib.realloc(block, 32);
    if (shrunk != null && shrunk.size() == 32) {
        io::println("PASS: realloc shrink");
    } else {
        io::println("FAIL: realloc shrink");
    }
}

public fn test_realloc_grow(): void {
    let block: MemoryBlock = StdLib.malloc(16);
    let grown: MemoryBlock = StdLib.realloc(block, 64);
    if (grown != null && grown.size() == 64 && !grown.isFreed()) {
        io::println("PASS: realloc grow");
    } else {
        io::println("FAIL: realloc grow");
    }
}

public fn test_realloc_free(): void {
    let block: MemoryBlock = StdLib.malloc(16);
    let result: MemoryBlock = StdLib.realloc(block, 0);
    if (result == null) {
        io::println("PASS: realloc size 0 frees");
    } else {
        io::println("FAIL: realloc size 0 frees");
    }
}

public fn test_memoryBlock_get_set(): void {
    let block: MemoryBlock = StdLib.malloc(8);
    block.set(0, 65);
    let val: int = block.get(0);
    if (val == 65) {
        io::println("PASS: MemoryBlock get/set");
    } else {
        io::println("FAIL: MemoryBlock get/set");
    }
}

public fn test_memoryBlock_out_of_range(): void {
    let block: MemoryBlock = StdLib.malloc(4);
    let val: int = block.get(100);
    if (val == -1) {
        io::println("PASS: MemoryBlock.get out of range");
    } else {
        io::println("FAIL: MemoryBlock.get out of range");
    }
}

public fn test_memoryBlock_freed_get(): void {
    let block: MemoryBlock = StdLib.malloc(4);
    StdLib.free(block);
    let val: int = block.get(0);
    if (val == -1) {
        io::println("PASS: MemoryBlock.get after free");
    } else {
        io::println("FAIL: MemoryBlock.get after free");
    }
}

public fn test_memoryBlock_toString(): void {
    let block: MemoryBlock = StdLib.malloc(3);
    block.set(0, 65);
    block.set(1, 66);
    block.set(2, 67);
    let s: string = block.toString();
    if (s == "ABC") {
        io::println("PASS: MemoryBlock.toString");
    } else {
        io::println("FAIL: MemoryBlock.toString");
    }
}

public fn test_qsort(): void {
    let list: ArrayList<int> = new ArrayList<int>();
    list.add(3);
    list.add(1);
    list.add(2);
    let cmp: fn(int, int): int = fn(a: int, b: int): int { return a - b; };
    StdLib.qsort(list, cmp);
    if (list.get(0) == 1 && list.get(1) == 2 && list.get(2) == 3) {
        io::println("PASS: qsort");
    } else {
        io::println("FAIL: qsort");
    }
}

public fn test_qsort_empty(): void {
    let list: ArrayList<int> = new ArrayList<int>();
    let cmp: fn(int, int): int = fn(a: int, b: int): int { return a - b; };
    StdLib.qsort(list, cmp);
    if (list.size() == 0) {
        io::println("PASS: qsort empty");
    } else {
        io::println("FAIL: qsort empty");
    }
}

public fn test_bsearch(): void {
    let list: ArrayList<int> = new ArrayList<int>();
    list.add(1);
    list.add(2);
    list.add(3);
    let cmp: fn(int, int): int = fn(a: int, b: int): int { return a - b; };
    let idx: int = StdLib.bsearch(list, 2, cmp);
    if (idx == 1) {
        io::println("PASS: bsearch found");
    } else {
        io::println("FAIL: bsearch found");
    }
}

public fn test_bsearch_not_found(): void {
    let list: ArrayList<int> = new ArrayList<int>();
    list.add(1);
    list.add(3);
    let cmp: fn(int, int): int = fn(a: int, b: int): int { return a - b; };
    let idx: int = StdLib.bsearch(list, 2, cmp);
    if (idx == -1) {
        io::println("PASS: bsearch not found");
    } else {
        io::println("FAIL: bsearch not found");
    }
}

public fn test_atof(): void {
    let val: double = StdLib.atof("3.14");
    if (val > 3.13 && val < 3.15) {
        io::println("PASS: atof");
    } else {
        io::println("FAIL: atof");
    }
}

public fn test_atoi(): void {
    let val: int = StdLib.atoi("42");
    if (val == 42) {
        io::println("PASS: atoi");
    } else {
        io::println("FAIL: atoi");
    }
}

public fn test_atol(): void {
    let val: long = StdLib.atol("9999999999");
    if (val == 9999999999 as long) {
        io::println("PASS: atol");
    } else {
        io::println("FAIL: atol");
    }
}

public fn test_strtol(): void {
    let r: StrtolResult = StdLib.strtol("42", 0, 10);
    if (r.value == 42 && r.endIndex > 0) {
        io::println("PASS: strtol");
    } else {
        io::println("FAIL: strtol");
    }
}

public fn test_strtol_hex(): void {
    let r: StrtolResult = StdLib.strtol("FF", 0, 16);
    if (r.value == 255) {
        io::println("PASS: strtol hex");
    } else {
        io::println("FAIL: strtol hex");
    }
}

public fn test_strtoul(): void {
    let r: StrtolResult = StdLib.strtoul("42", 0, 10);
    if (r.value == 42 && r.endIndex > 0) {
        io::println("PASS: strtoul");
    } else {
        io::println("FAIL: strtoul");
    }
}

public fn test_strtod(): void {
    let r: StrtodResult = StdLib.strtod("3.14", 0);
    if (r.value > 3.13 && r.value < 3.15) {
        io::println("PASS: strtod");
    } else {
        io::println("FAIL: strtod");
    }
}

public fn test_atexit(): void {
    let handler: fn(): void = fn(): void { };
    let result: int = StdLib.atexit(handler);
    if (result == 0 && StdLib.atexitHandlerCount() > 0) {
        io::println("PASS: atexit");
    } else {
        io::println("FAIL: atexit");
    }
    StdLib.clearAtexitHandlers();
}

public fn test_clearAtexitHandlers(): void {
    StdLib.clearAtexitHandlers();
    if (StdLib.atexitHandlerCount() == 0) {
        io::println("PASS: clearAtexitHandlers");
    } else {
        io::println("FAIL: clearAtexitHandlers");
    }
}

public fn test_srand_rand(): void {
    StdLib.srand(42);
    let r1: int = StdLib.rand();
    StdLib.srand(42);
    let r2: int = StdLib.rand();
    if (r1 == r2) {
        io::println("PASS: srand determinism");
    } else {
        io::println("FAIL: srand determinism");
    }
}

public fn test_RAND_MAX(): void {
    if (StdLib.RAND_MAX() == 32767) {
        io::println("PASS: RAND_MAX");
    } else {
        io::println("FAIL: RAND_MAX");
    }
}

public fn test_exit_constants(): void {
    if (StdLib.EXIT_SUCCESS() == 0 && StdLib.EXIT_FAILURE() == 1) {
        io::println("PASS: exit constants");
    } else {
        io::println("FAIL: exit constants");
    }
}

public fn test_poolSize(): void {
    let size: int = StdLib.poolSize();
    if (size >= 0) {
        io::println("PASS: poolSize");
    } else {
        io::println("FAIL: poolSize");
    }
}

public fn test_clearPool(): void {
    StdLib.clearPool();
    if (StdLib.poolSize() == 0) {
        io::println("PASS: clearPool");
    } else {
        io::println("FAIL: clearPool");
    }
}

public fn run_all_stdlib_tests(): void {
    io::println("=== StdLib.tr Tests ===");
    test_malloc();
    test_malloc_zero();
    test_calloc();
    test_free();
    test_realloc_null();
    test_realloc_shrink();
    test_realloc_grow();
    test_realloc_free();
    test_memoryBlock_get_set();
    test_memoryBlock_out_of_range();
    test_memoryBlock_freed_get();
    test_memoryBlock_toString();
    test_qsort();
    test_qsort_empty();
    test_bsearch();
    test_bsearch_not_found();
    test_atof();
    test_atoi();
    test_atol();
    test_strtol();
    test_strtol_hex();
    test_strtoul();
    test_strtod();
    test_atexit();
    test_clearAtexitHandlers();
    test_srand_rand();
    test_RAND_MAX();
    test_exit_constants();
    test_poolSize();
    test_clearPool();
}
