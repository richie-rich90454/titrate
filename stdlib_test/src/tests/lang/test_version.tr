public fn run_all_version_tests(): void {
    io::println("=== Version.tr Tests ===");
    test_isSupported();
    test_isSupported_unknown();
    test_macroYear();
    test_cppName();
    test_allMacroNames();
    test_report();
    test_cppLibCoroutines();
    test_cppLibConcepts();
    test_cppLibFormat();
    test_cppLibRanges();
    test_cppLibOptional();
    test_cppLibVariant();
    test_cppLibSpan();
    test_cppLibCompare();
    test_cppLibMemoryResource();
    test_cppLibCharconv();
    test_TITRATE_VERSION();
    test_TITRATE_VERSION_STRING();
    test_cppLibFilesystem();
    test_cppLibChrono();
    test_cppLibThread();
    test_cppLibAtomic();
    test_cppLibStringView();
    test_cppLibNumbers();
}
