public fn test_TITRATE_VERSION(): void {
    if (Version.TITRATE_VERSION == 202403) {
        io::println("PASS: TITRATE_VERSION");
    } else {
        io::println("FAIL: TITRATE_VERSION");
    }
}

public fn test_TITRATE_VERSION_STRING(): void {
    if (Version.TITRATE_VERSION_STRING == "2024.03") {
        io::println("PASS: TITRATE_VERSION_STRING");
    } else {
        io::println("FAIL: TITRATE_VERSION_STRING");
    }
}

