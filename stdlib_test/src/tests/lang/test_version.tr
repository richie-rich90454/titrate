// Test file for Version.tr
// Exercises the public API of the Version module.
import tt::lang::Version;
import tt::util::ArrayList;

public fn test_isSupported(): void {
    if (Version.isSupported("cppLibParallelAlgorithms")) {
        io::println("PASS: isSupported true");
    } else {
        io::println("FAIL: isSupported true");
    }
}

public fn test_isSupported_unknown(): void {
    if (!Version.isSupported("nonexistent_feature")) {
        io::println("PASS: isSupported unknown");
    } else {
        io::println("FAIL: isSupported unknown");
    }
}

public fn test_macroYear(): void {
    let year: int = Version.macroYear("cppLibParallelAlgorithms");
    if (year > 0) {
        io::println("PASS: macroYear");
    } else {
        io::println("FAIL: macroYear");
    }
}

public fn test_cppName(): void {
    let name: string = Version.cppName("cppLibParallelAlgorithms");
    if (String.length(name) > 0) {
        io::println("PASS: cppName");
    } else {
        io::println("FAIL: cppName");
    }
}

public fn test_allMacroNames(): void {
    let names: ArrayList<string> = Version.allMacroNames();
    if (names.size() > 0) {
        io::println("PASS: allMacroNames");
    } else {
        io::println("FAIL: allMacroNames");
    }
}

public fn test_report(): void {
    let report: string = Version.report();
    if (String.length(report) > 0) {
        io::println("PASS: report");
    } else {
        io::println("FAIL: report");
    }
}

public fn test_cppLibCoroutines(): void {
    io::println("PASS: cppLibCoroutines = " + (Version.cppLibCoroutines() ? "true" : "false"));
}

