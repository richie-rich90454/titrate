// Test file for Compare.tr
// Exercises the public API of the Compare module.
import tt::lang::Compare;
import tt::util::ArrayList;

public fn test_partialLess(): void {
    let p: PartialOrdering = Compare.partialLess();
    if (p.isOrdered() && !p.isUnordered() && p.ord() < 0) {
        io::println("PASS: partialLess");
    } else {
        io::println("FAIL: partialLess");
    }
}

public fn test_partialEquivalent(): void {
    let p: PartialOrdering = Compare.partialEquivalent();
    if (p.isOrdered() && p.ord() == 0) {
        io::println("PASS: partialEquivalent");
    } else {
        io::println("FAIL: partialEquivalent");
    }
}

public fn test_partialGreater(): void {
    let p: PartialOrdering = Compare.partialGreater();
    if (p.isOrdered() && !p.isUnordered() && p.ord() > 0 && p.ord() != 2) {
        io::println("PASS: partialGreater");
    } else {
        io::println("FAIL: partialGreater");
    }
}

public fn test_partialUnordered(): void {
    let p: PartialOrdering = Compare.partialUnordered();
    if (!p.isOrdered() && p.isUnordered() && p.ord() == 2) {
        io::println("PASS: partialUnordered");
    } else {
        io::println("FAIL: partialUnordered");
    }
}

public fn test_weakLess(): void {
    let w: WeakOrdering = Compare.weakLess();
    if (w.ord() < 0) {
        io::println("PASS: weakLess");
    } else {
        io::println("FAIL: weakLess");
    }
}

public fn test_weakEquivalent(): void {
    let w: WeakOrdering = Compare.weakEquivalent();
    if (w.ord() == 0) {
        io::println("PASS: weakEquivalent");
    } else {
        io::println("FAIL: weakEquivalent");
    }
}

public fn test_weakGreater(): void {
    let w: WeakOrdering = Compare.weakGreater();
    if (w.ord() > 0) {
        io::println("PASS: weakGreater");
    } else {
        io::println("FAIL: weakGreater");
    }
}

