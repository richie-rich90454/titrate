// Test for StdExcept — basic construction
import tt::lang::StdExcept;

public fn test_exception(): void {
    let e = new Exception("test");
    if (e.what() == "test") {
        io::println("PASS: Exception works");
    } else {
        io::println("FAIL: Exception.what wrong");
    }
}

public fn run_all_stdexcept_tests(): void {
    io::println("=== StdExcept.tr Tests ===");
    test_exception();
}
