// Test file for StdExcept.tr
// Exercises the public API of the StdExcept module.
import tt::lang::StdExcept;

public fn test_exception(): void {
    let e: Exception = new Exception("test msg");
    if (e.what() == "test msg" && !e.hasNested()) {
        io::println("PASS: Exception");
    } else {
        io::println("FAIL: Exception");
    }
}

public fn test_logicError(): void {
    let e: LogicError = StdExcept.logicError("bad logic");
    if (e.what() == "LogicError: bad logic") {
        io::println("PASS: LogicError");
    } else {
        io::println("FAIL: LogicError");
    }
}

public fn test_runtimeError(): void {
    let e: RuntimeError = StdExcept.runtimeError("runtime issue");
    if (e.what() == "RuntimeError: runtime issue") {
        io::println("PASS: RuntimeError");
    } else {
        io::println("FAIL: RuntimeError");
    }
}

public fn test_domainError(): void {
    let e: DomainError = StdExcept.domainError("domain");
    if (e.what() == "DomainError: domain") {
        io::println("PASS: DomainError");
    } else {
        io::println("FAIL: DomainError");
    }
}

public fn test_invalidArgument(): void {
    let e: InvalidArgument = StdExcept.invalidArgument("bad arg");
    if (e.what() == "InvalidArgument: bad arg") {
        io::println("PASS: InvalidArgument");
    } else {
        io::println("FAIL: InvalidArgument");
    }
}

public fn test_lengthError(): void {
    let e: LengthError = StdExcept.lengthError("too long");
    if (e.what() == "LengthError: too long") {
        io::println("PASS: LengthError");
    } else {
        io::println("FAIL: LengthError");
    }
}

public fn test_outOfRange(): void {
    let e: OutOfRange = StdExcept.outOfRange("out of range");
    if (e.what() == "OutOfRange: out of range") {
        io::println("PASS: OutOfRange");
    } else {
        io::println("FAIL: OutOfRange");
    }
}

public fn test_rangeError(): void {
    let e: RangeError = StdExcept.rangeError("range");
    if (e.what() == "RangeError: range") {
        io::println("PASS: RangeError");
    } else {
        io::println("FAIL: RangeError");
    }
}

public fn test_overflowError(): void {
    let e: OverflowError = StdExcept.overflowError("overflow");
    if (e.what() == "OverflowError: overflow") {
        io::println("PASS: OverflowError");
    } else {
        io::println("FAIL: OverflowError");
    }
}

public fn test_underflowError(): void {
    let e: UnderflowError = StdExcept.underflowError("underflow");
    if (e.what() == "UnderflowError: underflow") {
        io::println("PASS: UnderflowError");
    } else {
        io::println("FAIL: UnderflowError");
    }
}

public fn test_nestedException(): void {
    let inner: Exception = new Exception("inner");
    let outer: NestedException = StdExcept.nestedException("outer", inner);
    if (outer.what() == "NestedException: outer" && outer.hasNested()) {
        io::println("PASS: NestedException");
    } else {
        io::println("FAIL: NestedException");
    }
}

public fn test_throwLogicError(): void {
    try {
        StdExcept.throwLogicError("test");
        io::println("FAIL: throwLogicError should have thrown");
    } catch (e: string) {
        if (String.length(e) > 0) {
            io::println("PASS: throwLogicError");
        } else {
            io::println("FAIL: throwLogicError empty msg");
        }
    }
}

public fn test_throwInvalidArgument(): void {
    try {
        StdExcept.throwInvalidArgument("bad");
        io::println("FAIL: throwInvalidArgument should have thrown");
    } catch (e: string) {
        io::println("PASS: throwInvalidArgument (caught)");
    }
}

public fn test_throwRuntimeError(): void {
    try {
        StdExcept.throwRuntimeError("fail");
        io::println("FAIL: throwRuntimeError should have thrown");
    } catch (e: string) {
        io::println("PASS: throwRuntimeError (caught)");
    }
}

public fn test_exception_toString(): void {
    let e: Exception = new Exception("msg");
    if (e.toString() == "msg") {
        io::println("PASS: Exception.toString");
    } else {
        io::println("FAIL: Exception.toString");
    }
}

public fn test_logicError_inheritance(): void {
    let e: LogicError = new LogicError("test");
    if (e is Exception) {
        io::println("PASS: LogicError is Exception");
    } else {
        io::println("FAIL: LogicError is Exception");
    }
}

public fn test_invalidArgument_inheritance(): void {
    let e: InvalidArgument = new InvalidArgument("test");
    if (e is LogicError && e is Exception) {
        io::println("PASS: InvalidArgument inheritance chain");
    } else {
        io::println("FAIL: InvalidArgument inheritance chain");
    }
}

public fn test_runtimeError_inheritance(): void {
    let e: RuntimeError = new RuntimeError("test");
    if (e is Exception) {
        io::println("PASS: RuntimeError is Exception");
    } else {
        io::println("FAIL: RuntimeError is Exception");
    }
}

public fn test_overflowError_inheritance(): void {
    let e: OverflowError = new OverflowError("test");
    if (e is RuntimeError && e is Exception) {
        io::println("PASS: OverflowError inheritance chain");
    } else {
        io::println("FAIL: OverflowError inheritance chain");
    }
}

public fn run_all_stdexcept_tests(): void {
    io::println("=== StdExcept.tr Tests ===");
    test_exception();
    test_logicError();
    test_runtimeError();
    test_domainError();
    test_invalidArgument();
    test_lengthError();
    test_outOfRange();
    test_rangeError();
    test_overflowError();
    test_underflowError();
    test_nestedException();
    test_throwLogicError();
    test_throwInvalidArgument();
    test_throwRuntimeError();
    test_exception_toString();
    test_logicError_inheritance();
    test_invalidArgument_inheritance();
    test_runtimeError_inheritance();
    test_overflowError_inheritance();
}
