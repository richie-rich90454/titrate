// Test file for Numbers.tr
// Exercises the public API of the Numbers module.
import tt::lang::Numbers;
import tt::lang::Variant;
import tt::util::ArrayList;

public fn test_wrapInt(): void {
    let w: IntWrapper = Numbers.wrapInt(42);
    if (w.value == 42) {
        io::println("PASS: wrapInt");
    } else {
        io::println("FAIL: wrapInt");
    }
}

public fn test_wrapLong(): void {
    let w: LongWrapper = Numbers.wrapLong(1000000000000 as long);
    if (w.value == 1000000000000 as long) {
        io::println("PASS: wrapLong");
    } else {
        io::println("FAIL: wrapLong");
    }
}

public fn test_wrapDouble(): void {
    let w: DoubleWrapper = Numbers.wrapDouble(3.14);
    if (w.value > 3.13 && w.value < 3.15) {
        io::println("PASS: wrapDouble");
    } else {
        io::println("FAIL: wrapDouble");
    }
}

public fn test_rational(): void {
    let r: RationalImpl = Numbers.rational(1 as long, 3 as long);
    if (r.numerator() == 1 && r.denominator() == 3) {
        io::println("PASS: rational 1/3");
    } else {
        io::println("FAIL: rational 1/3");
    }
}

public fn test_rational_reduce(): void {
    let r: RationalImpl = Numbers.rational(2 as long, 4 as long);
    if (r.numerator() == 1 && r.denominator() == 2) {
        io::println("PASS: rational reduces 2/4 to 1/2");
    } else {
        io::println("FAIL: rational reduces 2/4 to 1/2");
    }
}

public fn test_rational_negative_denom(): void {
    let r: RationalImpl = Numbers.rational(1 as long, -2 as long);
    if (r.numerator() == -1 && r.denominator() == 2) {
        io::println("PASS: rational negative denom");
    } else {
        io::println("FAIL: rational negative denom");
    }
}

public fn test_intWrapper_methods(): void {
    let w: IntWrapper = Numbers.wrapInt(42);
    if (w.toLong() == 42 && w.toDouble() > 41.9) {
        io::println("PASS: IntWrapper toLong/toDouble");
    } else {
        io::println("FAIL: IntWrapper toLong/toDouble");
    }
}

public fn test_longWrapper_methods(): void {
    let w: LongWrapper = Numbers.wrapLong(99 as long);
    if (w.toLong() == 99) {
        io::println("PASS: LongWrapper toLong");
    } else {
        io::println("FAIL: LongWrapper toLong");
    }
}

public fn test_doubleWrapper_methods(): void {
    let w: DoubleWrapper = Numbers.wrapDouble(3.14);
    if (w.toDouble() > 3.13 && w.toDouble() < 3.15) {
        io::println("PASS: DoubleWrapper toDouble");
    } else {
        io::println("FAIL: DoubleWrapper toDouble");
    }
}

public fn test_doubleWrapper_floor_ceil(): void {
    let w: DoubleWrapper = Numbers.wrapDouble(3.7);
    if (w.floor() == 3 && w.ceil() == 4) {
        io::println("PASS: DoubleWrapper floor/ceil");
    } else {
        io::println("FAIL: DoubleWrapper floor/ceil");
    }
}

public fn test_doubleWrapper_truncate(): void {
    let w: DoubleWrapper = Numbers.wrapDouble(3.7);
    if (w.truncate() == 3) {
        io::println("PASS: DoubleWrapper truncate");
    } else {
        io::println("FAIL: DoubleWrapper truncate");
    }
}

public fn test_rational_toString(): void {
    let r: RationalImpl = Numbers.rational(1 as long, 3 as long);
    let s: string = r.toString();
    if (s == "1/3") {
        io::println("PASS: RationalImpl.toString 1/3");
    } else {
        io::println("FAIL: RationalImpl.toString 1/3 got " + s);
    }
}

public fn test_rational_integer_toString(): void {
    let r: RationalImpl = Numbers.rational(5 as long, 1 as long);
    let s: string = r.toString();
    if (s == "5") {
        io::println("PASS: RationalImpl.toString 5");
    } else {
        io::println("FAIL: RationalImpl.toString 5 got " + s);
    }
}

public fn test_isNumber(): void {
    if (Numbers.isNumber(Variant.of("int", Variant.of("string", "1")))) {
        io::println("PASS: isNumber int");
    } else {
        io::println("FAIL: isNumber int");
    }
}

public fn test_isNumber_null(): void {
    if (!Numbers.isNumber(null)) {
        io::println("PASS: isNumber null");
    } else {
        io::println("FAIL: isNumber null");
    }
}

public fn test_isIntegral(): void {
    if (Numbers.isIntegral(Variant.of("int", Variant.of("string", "1")))) {
        io::println("PASS: isIntegral int");
    } else {
        io::println("FAIL: isIntegral int");
    }
}

public fn test_isReal(): void {
    if (Numbers.isReal(Variant.of("double", Variant.of("string", "1.5")))) {
        io::println("PASS: isReal double");
    } else {
        io::println("FAIL: isReal double");
    }
}

public fn test_registerNumber(): void {
    let factory: fn(Variant): Number = fn(v: Variant): Number { return Numbers.wrapInt(0); };
    Numbers.registerNumber("test", factory);
    if (Numbers.lookupNumber("test")) {
        io::println("PASS: registerNumber/lookupNumber");
    } else {
        io::println("FAIL: registerNumber/lookupNumber");
    }
}

public fn test_registeredNumberNames(): void {
    let names: ArrayList<string> = Numbers.registeredNumberNames();
    if (names.size() >= 0) {
        io::println("PASS: registeredNumberNames");
    } else {
        io::println("FAIL: registeredNumberNames");
    }
}

public fn run_all_numbers_tests(): void {
    io::println("=== Numbers.tr Tests ===");
    test_wrapInt();
    test_wrapLong();
    test_wrapDouble();
    test_rational();
    test_rational_reduce();
    test_rational_negative_denom();
    test_intWrapper_methods();
    test_longWrapper_methods();
    test_doubleWrapper_methods();
    test_doubleWrapper_floor_ceil();
    test_doubleWrapper_truncate();
    test_rational_toString();
    test_rational_integer_toString();
    test_isNumber();
    test_isNumber_null();
    test_isIntegral();
    test_isReal();
    test_registerNumber();
    test_registeredNumberNames();
}
