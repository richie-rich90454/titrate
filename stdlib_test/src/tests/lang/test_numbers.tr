// Test for Numbers — basic construction
import tt::lang::Numbers;

public fn test_wrapInt(): void {
    let w = Numbers.wrapInt(42);
    if (w.value == 42) {
        io::println("PASS: wrapInt works");
    } else {
        io::println("FAIL: wrapInt value wrong");
    }
}

public fn run_all_numbers_tests(): void {
    io::println("=== Numbers.tr Tests ===");
    test_wrapInt();
}
