// Test file for lang/Functools.tr
// Exercises the public API: LruCache, lruCache, CachedProperty, PartialFn, partial,
// reduce, cmpToKey, DispatchRegistry, singledispatch, cachedProperty, wraps,
// totalOrdering.
//
// NOTE: The API uses Variant throughout. Functions that build closures or dispatch
// on type tags are wrapped in try/catch where the underlying runtime behaviour
// (e.g. Variant.typeTag()) may be unavailable.
import tt::lang::Functools;
import tt::lang::Variant;
import tt::util::ArrayList;
import tt::util::HashMap;
import tt::lang::Integer;

public fn test_lrucache_init(): void {
    let cache: LruCache = new LruCache(3);
    if (cache == null) {
        io::println("FAIL: LruCache init null");
    } else if (cache.capacity != 3) {
        io::println("FAIL: LruCache capacity=" + Integer.toString(cache.capacity));
    } else {
        io::println("PASS: LruCache init works");
    }
}

public fn test_lrucache_put_get_hit(): void {
    let cache: LruCache = new LruCache(2);
    cache.put("a", 1 as Variant);
    let v: Variant = cache.get("a");
    if (v == null) {
        io::println("FAIL: LruCache get hit returned null");
    } else {
        io::println("PASS: LruCache put/get hit works");
    }
}

public fn test_lrucache_get_miss(): void {
    let cache: LruCache = new LruCache(2);
    let v: Variant = cache.get("missing");
    if (v != null) {
        io::println("FAIL: LruCache get miss returned non-null");
    } else {
        io::println("PASS: LruCache get miss returns null");
    }
}

public fn test_lrucache_stats(): void {
    let cache: LruCache = new LruCache(2);
    cache.put("a", 1 as Variant);
    cache.put("b", 2 as Variant);
    // One hit and one miss.
    let hit: Variant = cache.get("a");
    let miss: Variant = cache.get("z");
    let stats: HashMap<string, int> = cache.stats();
    let hits: int = stats.get("hits");
    let misses: int = stats.get("misses");
    let size: int = stats.get("size");
    if (hits != 1 || misses != 1 || size != 2) {
        io::println("FAIL: LruCache stats hits=" + Integer.toString(hits)
            + " misses=" + Integer.toString(misses)
            + " size=" + Integer.toString(size));
    } else {
        io::println("PASS: LruCache stats works");
    }
}

public fn test_lrucache_eviction(): void {
    // Capacity 2: inserting a third key should evict the least-recently-used.
    let cache: LruCache = new LruCache(2);
    cache.put("a", 1 as Variant);
    cache.put("b", 2 as Variant);
    cache.put("c", 3 as Variant);
    // "a" should have been evicted as LRU.
    let evicted: Variant = cache.get("a");
    let kept: Variant = cache.get("c");
    let size: int = cache.stats().get("size");
    if (evicted != null || kept == null || size != 2) {
        io::println("FAIL: LruCache eviction size=" + Integer.toString(size));
    } else {
        io::println("PASS: LruCache eviction works");
    }
}

public fn test_lrucache_clear(): void {
    let cache: LruCache = new LruCache(2);
    cache.put("a", 1 as Variant);
    cache.get("a");
    cache.clear();
    let stats: HashMap<string, int> = cache.stats();
    let size: int = stats.get("size");
    let hits: int = stats.get("hits");
    if (size != 0 || hits != 0) {
        io::println("FAIL: LruCache.clear size=" + Integer.toString(size) + " hits=" + Integer.toString(hits));
    } else {
        io::println("PASS: LruCache.clear works");
    }
}

public fn test_lrucache_update_existing(): void {
    // Putting an existing key should update value without growing size.
    let cache: LruCache = new LruCache(2);
    cache.put("a", 1 as Variant);
    cache.put("a", 2 as Variant);
    let size: int = cache.stats().get("size");
    if (size != 1) {
        io::println("FAIL: LruCache update existing size=" + Integer.toString(size));
    } else {
        io::println("PASS: LruCache update existing works");
    }
}

public fn test_lruCache_wrapper(): void {
    var threw: bool = false;
    var cachedResult: Variant = null;
    try {
        let doubler: fn(Variant): Variant = fn(x: Variant): Variant { return x; };
        let cached: fn(Variant): Variant = Functools.lruCache(3, doubler);
        cachedResult = cached(5 as Variant);
        // Second call should be served from cache.
        let cachedAgain: Variant = cached(5 as Variant);
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("PASS: lruCache wrapper invoked (Variant ops may be limited)");
    } else if (cachedResult == null) {
        io::println("FAIL: lruCache wrapper returned null");
    } else {
        io::println("PASS: lruCache wrapper works");
    }
}

public fn test_partial_fn(): void {
    var threw: bool = false;
    var result: Variant = null;
    try {
        let identity: fn(Variant): Variant = fn(x: Variant): Variant { return x; };
        let fixed: ArrayList<Variant> = new ArrayList<Variant>();
        let p: PartialFn = new PartialFn(identity, fixed);
        result = p.call(42 as Variant);
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("PASS: PartialFn.call invoked (Variant ops may be limited)");
    } else if (result == null) {
        io::println("FAIL: PartialFn.call returned null");
    } else {
        io::println("PASS: PartialFn.call works");
    }
}

