public fn test_totalOrdering_keys(): void {
    // totalOrdering should produce a HashMap with eq, lt, ne, gt, le, ge entries.
    var threw: bool = false;
    var result: HashMap<string, fn(Variant, Variant): bool> = null;
    try {
        let eq: fn(Variant, Variant): bool = fn(a: Variant, b: Variant): bool { return true; };
        let lt: fn(Variant, Variant): bool = fn(a: Variant, b: Variant): bool { return false; };
        result = Functools.totalOrdering(eq, lt);
    } catch (e: string) {
        threw = true;
    }
    if (threw || result == null) {
        io::println("FAIL: totalOrdering returned null");
    } else if (!result.containsKey("eq") || !result.containsKey("lt")
        || !result.containsKey("ne") || !result.containsKey("gt")
        || !result.containsKey("le") || !result.containsKey("ge")) {
        io::println("FAIL: totalOrdering missing derived comparison keys");
    } else {
        io::println("PASS: totalOrdering keys works");
    }
}

public fn run_all_functools_lang_tests(): void {
    io::println("=== lang/Functools.tr Tests ===");
    test_lrucache_init();
    test_lrucache_put_get_hit();
    test_lrucache_get_miss();
    test_lrucache_stats();
    test_lrucache_eviction();
    test_lrucache_clear();
    test_lrucache_update_existing();
    test_lruCache_wrapper();
    test_partial_fn();
    test_partial_top_level();
    test_reduce_sum();
    test_reduce_empty();
    test_cmpToKey();
    test_dispatch_registry_default();
    test_dispatch_registry_register();
    test_singledispatch();
    test_cached_property();
    test_cached_property_get_caches();
    test_wraps();
    test_totalOrdering_keys();
}
