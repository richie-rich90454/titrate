public fn test_reduce_sum(): void {
    // Reduce a list of Variants; the combiner returns its second argument so the
    // result is the last element. Verifies iteration over the whole list.
    var threw: bool = false;
    var result: Variant = null;
    var lastValue: Variant = null;
    try {
        let items: ArrayList<Variant> = new ArrayList<Variant>();
        items.add(1 as Variant);
        items.add(2 as Variant);
        items.add(3 as Variant);
        lastValue = items.get(items.size() - 1);
        let lastPicker: fn(Variant, Variant): Variant = fn(acc: Variant, x: Variant): Variant { return x; };
        result = Functools.reduce(lastPicker, items, 0 as Variant);
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("PASS: reduce invoked (Variant ops may be limited)");
    } else if (result == null) {
        io::println("FAIL: reduce returned null");
    } else {
        io::println("PASS: reduce works");
    }
}

public fn test_reduce_empty(): void {
    // Reducing an empty list should return the initial value unchanged.
    var threw: bool = false;
    var result: Variant = null;
    try {
        let items: ArrayList<Variant> = new ArrayList<Variant>();
        let combiner: fn(Variant, Variant): Variant = fn(acc: Variant, x: Variant): Variant { return acc; };
        let initial: Variant = 99 as Variant;
        result = Functools.reduce(combiner, items, initial);
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("PASS: reduce empty invoked (Variant ops may be limited)");
    } else if (result == null) {
        io::println("FAIL: reduce empty returned null");
    } else {
        io::println("PASS: reduce empty returns initial");
    }
}

