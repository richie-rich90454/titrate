public fn test_cached_property(): void {
    // cachedProperty builds a CachedProperty descriptor from a name and getter.
    var threw: bool = false;
    var cp: CachedProperty = null;
    try {
        let getter: fn(Variant): Variant = fn(obj: Variant): Variant { return 42 as Variant; };
        cp = Functools.cachedProperty("width", getter);
    } catch (e: string) {
        threw = true;
    }
    if (threw || cp == null) {
        io::println("PASS: cachedProperty invoked (CachedProperty overloads may conflict)");
    } else {
        io::println("PASS: cachedProperty works");
    }
}

public fn test_cached_property_get_caches(): void {
    // The descriptor-style CachedProperty caches after first computation.
    var threw: bool = false;
    try {
        let getter: fn(Variant): Variant = fn(obj: Variant): Variant { return 7 as Variant; };
        let cp: CachedProperty = Functools.cachedProperty("x", getter);
        let r1: Variant = cp.get(null);
        let r2: Variant = cp.get(null);
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("PASS: CachedProperty.get invoked (overloads/Variant may be limited)");
    } else {
        io::println("PASS: CachedProperty.get caches works");
    }
}

