// Test file for util/Graph.tr
// Exercises Graph<V>: addVertex, addEdge, removeVertex, removeEdge, neighbors,
// degree, hasVertex, hasEdge, vertices, edges, bfs, dfs, topologicalSort,
// shortestPath, dijkstra, isConnected, isCyclic, kruskalMST, primMST.
import tt::util::Graph;
import tt::util::ArrayList;
import tt::util::HashMap;
import tt::lang::String;
import tt::lang::Integer;

public fn test_graph_init_default(): void {
    let g: Graph<string> = new Graph<string>();
    if (g == null) {
        io::println("FAIL: Graph init returned null");
    } else {
        io::println("PASS: Graph init default works");
    }
}

public fn test_graph_init_directed(): void {
    let g: Graph<string> = new Graph<string>(true);
    if (g == null) {
        io::println("FAIL: Graph init directed returned null");
    } else {
        io::println("PASS: Graph init directed works");
    }
}

public fn test_graph_add_vertex(): void {
    let g: Graph<string> = new Graph<string>();
    g.addVertex("A");
    if (!g.hasVertex("A")) {
        io::println("FAIL: hasVertex after addVertex");
    } else {
        io::println("PASS: Graph addVertex works");
    }
}

public fn test_graph_add_vertex_duplicate(): void {
    let g: Graph<string> = new Graph<string>();
    g.addVertex("A");
    g.addVertex("A"); // Should not duplicate
    let verts: ArrayList<string> = g.vertices();
    if (verts.size() != 1) {
        io::println("FAIL: duplicate addVertex should not increase count");
    } else {
        io::println("PASS: Graph addVertex duplicate works");
    }
}

public fn test_graph_add_edge(): void {
    let g: Graph<string> = new Graph<string>(true);
    g.addEdge("A", "B");
    if (!g.hasEdge("A", "B")) {
        io::println("FAIL: hasEdge after addEdge");
    } else {
        io::println("PASS: Graph addEdge works");
    }
}

public fn test_graph_add_edge_with_weight(): void {
    let g: Graph<string> = new Graph<string>(true);
    g.addEdge("A", "B", 5.0);
    if (!g.hasEdge("A", "B")) {
        io::println("FAIL: hasEdge after addEdge weighted");
    } else {
        io::println("PASS: Graph addEdge with weight works");
    }
}

public fn test_graph_undirected_edge(): void {
    let g: Graph<string> = new Graph<string>(false);
    g.addEdge("A", "B");
    if (!g.hasEdge("A", "B") || !g.hasEdge("B", "A")) {
        io::println("FAIL: undirected edge should be bidirectional");
    } else {
        io::println("PASS: Graph undirected edge works");
    }
}

public fn test_graph_neighbors(): void {
    let g: Graph<string> = new Graph<string>(true);
    g.addEdge("A", "B");
    g.addEdge("A", "C");
    let nbrs: ArrayList<string> = g.neighbors("A");
    if (nbrs.size() != 2) {
        io::println("FAIL: neighbors count = " + nbrs.size());
    } else {
        io::println("PASS: Graph neighbors works");
    }
}

public fn test_graph_neighbors_missing_vertex(): void {
    let g: Graph<string> = new Graph<string>();
    let nbrs: ArrayList<string> = g.neighbors("Nonexistent");
    if (nbrs.size() != 0) {
        io::println("FAIL: neighbors for missing vertex should be empty");
    } else {
        io::println("PASS: Graph neighbors missing vertex works");
    }
}

public fn test_graph_degree(): void {
    let g: Graph<string> = new Graph<string>(true);
    g.addEdge("X", "Y");
    g.addEdge("X", "Z");
    if (g.degree("X") != 2) {
        io::println("FAIL: degree = " + g.degree("X"));
    } else {
        io::println("PASS: Graph degree works");
    }
}

public fn test_graph_degree_missing(): void {
    let g: Graph<string> = new Graph<string>();
    if (g.degree("Missing") != 0) {
        io::println("FAIL: degree of missing vertex should be 0");
    } else {
        io::println("PASS: Graph degree missing works");
    }
}

public fn test_graph_has_vertex(): void {
    let g: Graph<string> = new Graph<string>();
    g.addVertex("Only");
    if (!g.hasVertex("Only")) {
        io::println("FAIL: hasVertex true");
    } else if (g.hasVertex("Other")) {
        io::println("FAIL: hasVertex false positive");
    } else {
        io::println("PASS: Graph hasVertex works");
    }
}

public fn test_graph_has_edge(): void {
    let g: Graph<string> = new Graph<string>(true);
    g.addEdge("A", "B");
    if (!g.hasEdge("A", "B")) {
        io::println("FAIL: hasEdge true");
    } else if (g.hasEdge("B", "A")) {
        io::println("FAIL: hasEdge should be false for reverse directed");
    } else {
        io::println("PASS: Graph hasEdge works");
    }
}

public fn test_graph_remove_vertex(): void {
    let g: Graph<string> = new Graph<string>(true);
    g.addEdge("A", "B");
    g.removeVertex("A");
    if (g.hasVertex("A")) {
        io::println("FAIL: vertex should be removed");
    } else {
        io::println("PASS: Graph removeVertex works");
    }
}

public fn test_graph_remove_missing_vertex(): void {
    let g: Graph<string> = new Graph<string>();
    g.removeVertex("Nonexistent"); // Should not crash
    io::println("PASS: Graph removeVertex missing works");
}

public fn test_graph_remove_edge(): void {
    let g: Graph<string> = new Graph<string>(true);
    g.addEdge("A", "B");
    g.removeEdge("A", "B");
    if (g.hasEdge("A", "B")) {
        io::println("FAIL: edge should be removed");
    } else {
        io::println("PASS: Graph removeEdge works");
    }
}

public fn test_graph_vertices(): void {
    let g: Graph<string> = new Graph<string>();
    g.addVertex("A");
    g.addVertex("B");
    let verts: ArrayList<string> = g.vertices();
    if (verts.size() != 2) {
        io::println("FAIL: vertices count = " + verts.size());
    } else {
        io::println("PASS: Graph vertices works");
    }
}

public fn test_graph_edges(): void {
    let g: Graph<string> = new Graph<string>(true);
    g.addEdge("A", "B");
    g.addEdge("B", "C");
    let edgeList: ArrayList<(string, string)> = g.edges();
    if (edgeList.size() != 2) {
        io::println("FAIL: edges count = " + edgeList.size());
    } else {
        io::println("PASS: Graph edges works");
    }
}

public fn test_graph_bfs(): void {
    let g: Graph<string> = new Graph<string>(true);
    g.addEdge("A", "B");
    g.addEdge("A", "C");
    g.addEdge("B", "D");
    let order: ArrayList<string> = g.bfs("A");
    if (order.size() != 4) {
        io::println("FAIL: BFS order size = " + order.size());
    } else if (order.get(0) != "A") {
        io::println("FAIL: BFS first should be A");
    } else {
        io::println("PASS: Graph BFS works");
    }
}

public fn test_graph_bfs_missing_start(): void {
    let g: Graph<string> = new Graph<string>();
    let order: ArrayList<string> = g.bfs("Missing");
    if (order.size() != 0) {
        io::println("FAIL: BFS missing start should be empty");
    } else {
        io::println("PASS: Graph BFS missing start works");
    }
}

public fn test_graph_dfs(): void {
    let g: Graph<string> = new Graph<string>(true);
    g.addEdge("A", "B");
    g.addEdge("A", "C");
    g.addEdge("B", "D");
    let order: ArrayList<string> = g.dfs("A");
    if (order.size() != 4) {
        io::println("FAIL: DFS order size = " + order.size());
    } else {
        io::println("PASS: Graph DFS works");
    }
}

public fn test_graph_dfs_missing_start(): void {
    let g: Graph<string> = new Graph<string>();
    let order: ArrayList<string> = g.dfs("Missing");
