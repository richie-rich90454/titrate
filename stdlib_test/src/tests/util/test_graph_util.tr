// Test file for Graph.tr (the one in util/, not algo/)
// Exercises the public API of the Graph class (adjacency list graph).
import tt::util::Graph;
import tt::util::ArrayList;
import tt::lang::Integer;
import tt::lang::Double;

public fn test_graph_addVertex(): void {
    let g: Graph<string> = new Graph<string>();
    g.addVertex("A");
    g.addVertex("B");
    if (!g.hasVertex("A") || !g.hasVertex("B") || g.hasVertex("Z")) {
        io::println("FAIL: Graph addVertex/hasVertex");
    } else {
        io::println("PASS: Graph addVertex/hasVertex works");
    }
}

public fn test_graph_addEdge_undirected(): void {
    let g: Graph<string> = new Graph<string>();
    g.addEdge("A", "B");
    if (!g.hasEdge("A", "B") || !g.hasEdge("B", "A")) {
        io::println("FAIL: Graph addEdge undirected");
    } else {
        io::println("PASS: Graph addEdge undirected works");
    }
}

public fn test_graph_addEdge_directed(): void {
    let g: Graph<string> = new Graph<string>(true);
    g.addEdge("A", "B");
    if (!g.hasEdge("A", "B") || g.hasEdge("B", "A")) {
        io::println("FAIL: Graph addEdge directed");
    } else {
        io::println("PASS: Graph addEdge directed works");
    }
}

