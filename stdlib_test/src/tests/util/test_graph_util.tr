}

public fn test_graph_toString(): void {
    let g: Graph<string> = new Graph<string>();
    g.addEdge("A", "B");
    let s: string = g.toString();
    if (String.length(s) == 0) {
        io::println("FAIL: Graph toString empty");
    } else {
        io::println("PASS: Graph toString works");
    }
}

public fn run_all_graph_util_tests(): void {
    io::println("=== Graph.tr (util) Tests ===");
    test_graph_addVertex();
    test_graph_addEdge_undirected();
    test_graph_addEdge_directed();
    test_graph_neighbors();
    test_graph_degree();
    test_graph_vertices();
    test_graph_bfs();
    test_graph_dfs();
    test_graph_shortestPath();
    test_graph_topologicalSort();
    test_graph_isConnected();
    test_graph_isCyclic_directed();
    test_graph_dijkstra();
    test_graph_removeVertex();
    test_graph_removeEdge();
    test_graph_kruskalMST();
    test_graph_primMST();
    test_graph_edges();
    test_graph_toString();
}
