public fn test_graph_bfs(): void {
    let g: Graph<string> = new Graph<string>();
    g.addEdge("A", "B");
    g.addEdge("A", "C");
    g.addEdge("B", "D");
    let result: ArrayList<string> = g.bfs("A");
    if (result.size() != 4) {
        io::println("FAIL: Graph bfs size = " + Integer.toString(result.size()));
    } else {
        if (result.get(0) != "A") {
            io::println("FAIL: Graph bfs starts at A");
        } else {
            io::println("PASS: Graph bfs works");
        }
    }
}

public fn test_graph_dfs(): void {
    let g: Graph<string> = new Graph<string>();
    g.addEdge("A", "B");
    g.addEdge("A", "C");
    g.addEdge("B", "D");
    let result: ArrayList<string> = g.dfs("A");
