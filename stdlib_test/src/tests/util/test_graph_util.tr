public fn test_graph_shortestPath(): void {
    let g: Graph<string> = new Graph<string>();
    g.addEdge("A", "B");
    g.addEdge("B", "C");
    g.addEdge("C", "D");
    let path: ArrayList<string> = g.shortestPath("A", "D");
    if (path.size() != 4) {
        io::println("FAIL: Graph shortestPath size = " + Integer.toString(path.size()));
    } else {
        if (path.get(0) != "A" || path.get(3) != "D") {
            io::println("FAIL: Graph shortestPath endpoints");
        } else {
            io::println("PASS: Graph shortestPath works");
        }
    }
}

public fn test_graph_topologicalSort(): void {
    let g: Graph<string> = new Graph<string>(true);
    g.addEdge("A", "B");
    g.addEdge("B", "C");
    g.addEdge("A", "C");
    let result: ArrayList<string> = g.topologicalSort();
    if (result.size() != 3) {
        io::println("FAIL: Graph topologicalSort size = " + Integer.toString(result.size()));
    } else {
        // A should come before B, B before C
        let aIdx: int = _indexOf(result, "A");
        let bIdx: int = _indexOf(result, "B");
        let cIdx: int = _indexOf(result, "C");
        if (aIdx < bIdx && bIdx < cIdx) {
            io::println("PASS: Graph topologicalSort works");
        } else {
            io::println("FAIL: Graph topologicalSort order");
        }
    }
}

fn _indexOf(list: ArrayList<string>, target: string): int {
    let i: int = 0;
    while (i < list.size()) {
        if (list.get(i) == target) {
            return i;
        }
        i = i + 1;
    }
    return -1;
}

public fn test_graph_isConnected(): void {
    let g: Graph<string> = new Graph<string>();
    g.addEdge("A", "B");
    g.addEdge("B", "C");
    if (!g.isConnected()) {
        io::println("FAIL: Graph isConnected true case");
    } else {
        g.addVertex("Z");
        if (g.isConnected()) {
            io::println("FAIL: Graph isConnected false case");
        } else {
            io::println("PASS: Graph isConnected works");
        }
    }
}

public fn test_graph_isCyclic_directed(): void {
    let g: Graph<string> = new Graph<string>(true);
    g.addEdge("A", "B");
    g.addEdge("B", "C");
    g.addEdge("C", "A");
    if (!g.isCyclic()) {
        io::println("FAIL: Graph isCyclic true case");
    } else {
        let g2: Graph<string> = new Graph<string>(true);
        g2.addEdge("A", "B");
        g2.addEdge("B", "C");
        if (g2.isCyclic()) {
            io::println("FAIL: Graph isCyclic false case");
        } else {
            io::println("PASS: Graph isCyclic works");
        }
    }
}

public fn test_graph_dijkstra(): void {
    let g: Graph<string> = new Graph<string>();
    g.addEdge("A", "B", 1.0);
    g.addEdge("B", "C", 2.0);
    g.addEdge("A", "C", 10.0);
    let dist = g.dijkstra("A");
    // A=0, B=1, C=3 (via B, not direct)
    let distC: double = dist.get("C");
    if (distC != 3.0) {
        io::println("FAIL: Graph dijkstra C dist = " + Double.toString(distC));
    } else {
        io::println("PASS: Graph dijkstra works");
    }
}

public fn test_graph_removeVertex(): void {
    let g: Graph<string> = new Graph<string>();
    g.addEdge("A", "B");
    g.addEdge("A", "C");
    g.removeVertex("B");
    if (g.hasVertex("B") || g.hasEdge("A", "B")) {
        io::println("FAIL: Graph removeVertex");
    } else {
        io::println("PASS: Graph removeVertex works");
    }
}

public fn test_graph_removeEdge(): void {
    let g: Graph<string> = new Graph<string>();
    g.addEdge("A", "B");
    g.removeEdge("A", "B");
    if (g.hasEdge("A", "B")) {
        io::println("FAIL: Graph removeEdge");
    } else {
        io::println("PASS: Graph removeEdge works");
    }
}

public fn test_graph_kruskalMST(): void {
    let g: Graph<string> = new Graph<string>();
    g.addEdge("A", "B", 1.0);
    g.addEdge("B", "C", 2.0);
    g.addEdge("A", "C", 10.0);
    let (weight: double, mstEdges: ArrayList<(string, string)>) = g.kruskalMST();
    // MST should have 2 edges with total weight 3.0
    if (mstEdges.size() != 2) {
        io::println("FAIL: Graph kruskalMST edge count = " + Integer.toString(mstEdges.size()));
    } else {
        if (weight != 3.0) {
            io::println("FAIL: Graph kruskalMST weight = " + Double.toString(weight));
        } else {
            io::println("PASS: Graph kruskalMST works");
        }
    }
}

public fn test_graph_primMST(): void {
    let g: Graph<string> = new Graph<string>();
    g.addEdge("A", "B", 1.0);
    g.addEdge("B", "C", 2.0);
    g.addEdge("A", "C", 10.0);
    let (weight: double, mstEdges: ArrayList<(string, string)>) = g.primMST("A");
    if (mstEdges.size() != 2) {
        io::println("FAIL: Graph primMST edge count = " + Integer.toString(mstEdges.size()));
    } else {
        if (weight != 3.0) {
            io::println("FAIL: Graph primMST weight = " + Double.toString(weight));
        } else {
            io::println("PASS: Graph primMST works");
        }
    }
}

public fn test_graph_edges(): void {
    let g: Graph<string> = new Graph<string>();
    g.addEdge("A", "B");
