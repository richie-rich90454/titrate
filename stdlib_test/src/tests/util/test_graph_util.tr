    let g: Graph<string> = new Graph<string>();
    g.addEdge("A", "B");
    g.addEdge("A", "C");
    let nbrs: ArrayList<string> = g.neighbors("A");
    if (nbrs.size() != 2) {
        io::println("FAIL: Graph neighbors size = " + Integer.toString(nbrs.size()));
    } else {
        io::println("PASS: Graph neighbors works");
    }
}

public fn test_graph_degree(): void {
    let g: Graph<string> = new Graph<string>();
    g.addEdge("A", "B");
    g.addEdge("A", "C");
    g.addEdge("A", "D");
    if (g.degree("A") != 3) {
        io::println("FAIL: Graph degree = " + Integer.toString(g.degree("A")));
