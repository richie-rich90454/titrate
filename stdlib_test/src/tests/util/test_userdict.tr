// Test file for UserDict.tr
// Exercises the public API of the UserDict class (HashMap wrapper for subclassing).
import tt::util::UserDict;
import tt::util::ArrayList;
import tt::util::HashMap;
import tt::lang::Variant;
import tt::lang::Integer;

public fn test_userdict_init(): void {
    let ud: UserDict = new UserDict();
    if (!ud.isEmpty() || ud.size() != 0) {
        io::println("FAIL: UserDict init");
    } else {
        io::println("PASS: UserDict init empty");
    }
}

public fn test_userdict_set_get(): void {
    let ud: UserDict = new UserDict();
    ud.set("a", 1 as Variant);
    ud.set("b", 2 as Variant);
    let a: Variant = ud.get("a");
    let b: Variant = ud.get("b");
    if (a == null || b == null) {
        io::println("FAIL: UserDict set/get null");
    } else {
        io::println("PASS: UserDict set/get works");
    }
}

public fn test_userdict_get_missing(): void {
    let ud: UserDict = new UserDict();
    let v: Variant = ud.get("nonexistent");
    if (v != null) {
        io::println("FAIL: UserDict get missing should return null");
    } else {
        io::println("PASS: UserDict get missing returns null");
    }
}

public fn test_userdict_contains(): void {
    let ud: UserDict = new UserDict();
    ud.set("x", 10 as Variant);
    if (!ud.contains("x") || ud.contains("y")) {
        io::println("FAIL: UserDict contains");
    } else {
        io::println("PASS: UserDict contains works");
    }
}

public fn test_userdict_remove(): void {
    let ud: UserDict = new UserDict();
    ud.set("a", 1 as Variant);
    let removed: bool = ud.remove("a");
    if (!removed || ud.contains("a") || ud.size() != 0) {
        io::println("FAIL: UserDict remove");
    } else {
        io::println("PASS: UserDict remove works");
    }
}

public fn test_userdict_remove_missing(): void {
    let ud: UserDict = new UserDict();
    let removed: bool = ud.remove("z");
    if (removed) {
        io::println("FAIL: UserDict remove missing should return false");
    } else {
        io::println("PASS: UserDict remove missing returns false");
    }
}

public fn test_userdict_size(): void {
    let ud: UserDict = new UserDict();
    ud.set("a", 1 as Variant);
    ud.set("b", 2 as Variant);
    ud.set("c", 3 as Variant);
    if (ud.size() != 3) {
        io::println("FAIL: UserDict size = " + Integer.toString(ud.size()));
    } else {
        io::println("PASS: UserDict size works");
    }
}

public fn test_userdict_isEmpty(): void {
    let ud: UserDict = new UserDict();
    if (!ud.isEmpty()) {
        io::println("FAIL: UserDict isEmpty new");
    } else {
        ud.set("a", 1 as Variant);
        if (ud.isEmpty()) {
            io::println("FAIL: UserDict isEmpty after set");
        } else {
            io::println("PASS: UserDict isEmpty works");
        }
    }
}

public fn test_userdict_keys(): void {
    let ud: UserDict = new UserDict();
    ud.set("a", 1 as Variant);
    ud.set("b", 2 as Variant);
    let keys: ArrayList<string> = ud.keys();
    if (keys.size() != 2) {
        io::println("FAIL: UserDict keys size = " + Integer.toString(keys.size()));
    } else {
        io::println("PASS: UserDict keys works");
    }
}

public fn test_userdict_values(): void {
    let ud: UserDict = new UserDict();
    ud.set("a", 1 as Variant);
    ud.set("b", 2 as Variant);
    let vals: ArrayList<Variant> = ud.values();
    if (vals.size() != 2) {
        io::println("FAIL: UserDict values size = " + Integer.toString(vals.size()));
    } else {
        io::println("PASS: UserDict values works");
    }
}

public fn test_userdict_clear(): void {
    let ud: UserDict = new UserDict();
    ud.set("a", 1 as Variant);
    ud.set("b", 2 as Variant);
    ud.clear();
    if (!ud.isEmpty() || ud.size() != 0) {
        io::println("FAIL: UserDict clear");
    } else {
        io::println("PASS: UserDict clear works");
    }
}

public fn test_userdict_getOrDefault(): void {
    let ud: UserDict = new UserDict();
    ud.set("a", 1 as Variant);
    let found: Variant = ud.getOrDefault("a", 99 as Variant);
    let missing: Variant = ud.getOrDefault("z", 99 as Variant);
    if (found == null || missing == null) {
        io::println("FAIL: UserDict getOrDefault null");
    } else {
        io::println("PASS: UserDict getOrDefault works");
    }
}

public fn test_userdict_setDefault(): void {
    let ud: UserDict = new UserDict();
    ud.set("a", 1 as Variant);
    // Key exists, should return existing value
    let existing: Variant = ud.setDefault("a", 99 as Variant);
    // Key doesn't exist, should set and return default
    let added: Variant = ud.setDefault("b", 2 as Variant);
    if (existing == null || added == null) {
        io::println("FAIL: UserDict setDefault null");
    } else {
        if (!ud.contains("b")) {
            io::println("FAIL: UserDict setDefault did not add key");
        } else {
            io::println("PASS: UserDict setDefault works");
        }
    }
}

public fn test_userdict_update(): void {
    let ud1: UserDict = new UserDict();
    ud1.set("a", 1 as Variant);
    let ud2: UserDict = new UserDict();
    ud2.set("b", 2 as Variant);
    ud2.set("a", 99 as Variant);
    ud1.update(ud2);
    if (ud1.size() != 2 || !ud1.contains("b")) {
        io::println("FAIL: UserDict update");
    } else {
        io::println("PASS: UserDict update works");
    }
}

public fn test_userdict_copy(): void {
    let ud: UserDict = new UserDict();
    ud.set("a", 1 as Variant);
    ud.set("b", 2 as Variant);
    let copy: UserDict = ud.copy();
    if (copy.size() != 2 || !copy.contains("a") || !copy.contains("b")) {
        io::println("FAIL: UserDict copy");
    } else {
        // Verify independence
        copy.set("c", 3 as Variant);
        if (ud.size() != 2) {
            io::println("FAIL: UserDict copy not independent");
        } else {
            io::println("PASS: UserDict copy works");
        }
    }
}

public fn test_userdict_initFromMap(): void {
    let map: HashMap<string, Variant> = new HashMap<string, Variant>();
    map.put("x", 42 as Variant);
    let ud: UserDict = new UserDict();
    ud.initFromMap(map);
    if (ud.size() != 1 || !ud.contains("x")) {
        io::println("FAIL: UserDict initFromMap");
    } else {
        io::println("PASS: UserDict initFromMap works");
    }
}

public fn run_all_userdict_tests(): void {
    io::println("=== UserDict.tr Tests ===");
    test_userdict_init();
    test_userdict_set_get();
    test_userdict_get_missing();
    test_userdict_contains();
    test_userdict_remove();
    test_userdict_remove_missing();
    test_userdict_size();
    test_userdict_isEmpty();
    test_userdict_keys();
    test_userdict_values();
    test_userdict_clear();
    test_userdict_getOrDefault();
    test_userdict_setDefault();
    test_userdict_update();
    test_userdict_copy();
    test_userdict_initFromMap();
}
