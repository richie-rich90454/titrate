// Test file for Set.tr (the generic Set in util/, backed by ArrayList)
// Exercises the public API of the Set class.
import tt::util::Set;
import tt::util::ArrayList;
import tt::lang::Integer;
import tt::lang::String;

public fn test_set_init(): void {
    let s: Set<int> = new Set<int>();
    if (!s.isEmpty() || s.size() != 0) {
        io::println("FAIL: Set init");
    } else {
        io::println("PASS: Set init empty");
    }
}

public fn test_set_add(): void {
    let s: Set<int> = new Set<int>();
    s.add(1);
    s.add(2);
    s.add(3);
    if (s.size() != 3) {
        io::println("FAIL: Set add size = " + Integer.toString(s.size()));
    } else {
        io::println("PASS: Set add works");
    }
}

public fn test_set_add_duplicate(): void {
    let s: Set<int> = new Set<int>();
    s.add(1);
    s.add(1);
    s.add(1);
    if (s.size() != 1) {
        io::println("FAIL: Set add duplicate size = " + Integer.toString(s.size()));
    } else {
        io::println("PASS: Set add deduplicates");
    }
}

public fn test_set_contains(): void {
    let s: Set<int> = new Set<int>();
    s.add(1);
    s.add(2);
    if (!s.contains(1) || !s.contains(2) || s.contains(99)) {
        io::println("FAIL: Set contains");
    } else {
        io::println("PASS: Set contains works");
    }
}

public fn test_set_remove(): void {
    let s: Set<int> = new Set<int>();
    s.add(1);
    s.add(2);
    let removed: bool = s.remove(1);
    if (!removed || s.contains(1) || s.size() != 1) {
        io::println("FAIL: Set remove");
    } else {
        io::println("PASS: Set remove works");
    }
}

public fn test_set_remove_notFound(): void {
    let s: Set<int> = new Set<int>();
    s.add(1);
    let removed: bool = s.remove(99);
    if (removed) {
        io::println("FAIL: Set remove not found");
    } else {
        io::println("PASS: Set remove not found works");
    }
}

public fn test_set_indexOf(): void {
    let s: Set<int> = new Set<int>();
    s.add(10);
    s.add(20);
    s.add(30);
    if (s.indexOf(20) != 1 || s.indexOf(99) != -1) {
        io::println("FAIL: Set indexOf");
    } else {
        io::println("PASS: Set indexOf works");
    }
}

public fn test_set_union(): void {
    let s1: Set<int> = new Set<int>();
    s1.add(1);
    s1.add(2);
    let s2: Set<int> = new Set<int>();
    s2.add(2);
    s2.add(3);
    let result: Set<int> = s1.union(s2);
    if (result.size() != 3) {
        io::println("FAIL: Set union size = " + Integer.toString(result.size()));
    } else {
        io::println("PASS: Set union works");
    }
}

public fn test_set_intersection(): void {
    let s1: Set<int> = new Set<int>();
    s1.add(1);
    s1.add(2);
    s1.add(3);
    let s2: Set<int> = new Set<int>();
    s2.add(2);
    s2.add(3);
    s2.add(4);
    let result: Set<int> = s1.intersection(s2);
    if (result.size() != 2 || !result.contains(2) || !result.contains(3)) {
        io::println("FAIL: Set intersection");
    } else {
        io::println("PASS: Set intersection works");
    }
}

public fn test_set_difference(): void {
    let s1: Set<int> = new Set<int>();
    s1.add(1);
    s1.add(2);
    s1.add(3);
    let s2: Set<int> = new Set<int>();
    s2.add(2);
    let result: Set<int> = s1.difference(s2);
    if (result.size() != 2 || !result.contains(1) || !result.contains(3) || result.contains(2)) {
        io::println("FAIL: Set difference");
    } else {
        io::println("PASS: Set difference works");
    }
}

public fn test_set_symmetricDifference(): void {
    let s1: Set<int> = new Set<int>();
    s1.add(1);
    s1.add(2);
    let s2: Set<int> = new Set<int>();
    s2.add(2);
    s2.add(3);
    let result: Set<int> = s1.symmetricDifference(s2);
    if (result.size() != 2 || !result.contains(1) || !result.contains(3)) {
        io::println("FAIL: Set symmetricDifference");
    } else {
        io::println("PASS: Set symmetricDifference works");
    }
}

public fn test_set_isSubsetOf(): void {
    let s1: Set<int> = new Set<int>();
    s1.add(1);
    s1.add(2);
    let s2: Set<int> = new Set<int>();
    s2.add(1);
    s2.add(2);
    s2.add(3);
    if (!s1.isSubsetOf(s2)) {
        io::println("FAIL: Set isSubsetOf true case");
    } else {
        if (s2.isSubsetOf(s1)) {
            io::println("FAIL: Set isSubsetOf false case");
        } else {
            io::println("PASS: Set isSubsetOf works");
        }
    }
}

public fn test_set_isSupersetOf(): void {
    let s1: Set<int> = new Set<int>();
    s1.add(1);
    s1.add(2);
    s1.add(3);
    let s2: Set<int> = new Set<int>();
    s2.add(1);
    s2.add(2);
    if (!s1.isSupersetOf(s2)) {
        io::println("FAIL: Set isSupersetOf");
    } else {
        io::println("PASS: Set isSupersetOf works");
    }
}

public fn test_set_equals(): void {
    let s1: Set<int> = new Set<int>();
    s1.add(1);
    s1.add(2);
    let s2: Set<int> = new Set<int>();
    s2.add(2);
    s2.add(1);
    if (!s1.equals(s2)) {
        io::println("FAIL: Set equals same elements");
    } else {
        io::println("PASS: Set equals works");
    }
}

public fn test_set_clear(): void {
    let s: Set<int> = new Set<int>();
    s.add(1);
    s.add(2);
    s.clear();
    if (!s.isEmpty() || s.size() != 0) {
        io::println("FAIL: Set clear");
    } else {
        io::println("PASS: Set clear works");
    }
}

public fn test_set_toArray(): void {
    let s: Set<int> = new Set<int>();
    s.add(1);
    s.add(2);
    let arr: ArrayList<int> = s.toArray();
    if (arr.size() != 2) {
        io::println("FAIL: Set toArray");
    } else {
        io::println("PASS: Set toArray works");
    }
}

public fn test_set_map(): void {
    let s: Set<int> = new Set<int>();
    s.add(1);
    s.add(2);
    s.add(3);
    let result: Set<int> = s.map(fn(x: int): int => x * 10);
    if (result.size() != 3) {
        io::println("FAIL: Set map size = " + Integer.toString(result.size()));
    } else {
        if (!result.contains(10) || !result.contains(20) || !result.contains(30)) {
            io::println("FAIL: Set map content");
        } else {
            io::println("PASS: Set map works");
        }
    }
}

public fn test_set_filter(): void {
    let s: Set<int> = new Set<int>();
    s.add(1);
    s.add(5);
    s.add(10);
    s.add(15);
    let result: Set<int> = s.filter(fn(x: int): bool => x > 5);
    if (result.size() != 2 || !result.contains(10) || !result.contains(15)) {
        io::println("FAIL: Set filter");
    } else {
        io::println("PASS: Set filter works");
    }
}

public fn test_set_toString(): void {
    let s: Set<int> = new Set<int>();
    s.add(1);
    let str: string = s.toString();
    if (String.length(str) == 0) {
        io::println("FAIL: Set toString empty");
    } else {
        io::println("PASS: Set toString works");
    }
}

public fn test_set_with_strings(): void {
    let s: Set<string> = new Set<string>();
    s.add("hello");
    s.add("world");
    s.add("hello"); // duplicate
    if (s.size() != 2 || !s.contains("hello") || !s.contains("world")) {
        io::println("FAIL: Set with strings");
    } else {
        io::println("PASS: Set works with strings");
    }
}

public fn run_all_set_tests(): void {
    io::println("=== Set.tr Tests ===");
    test_set_init();
    test_set_add();
    test_set_add_duplicate();
    test_set_contains();
    test_set_remove();
    test_set_remove_notFound();
    test_set_indexOf();
    test_set_union();
    test_set_intersection();
    test_set_difference();
    test_set_symmetricDifference();
    test_set_isSubsetOf();
    test_set_isSupersetOf();
    test_set_equals();
    test_set_clear();
    test_set_toArray();
    test_set_map();
    test_set_filter();
    test_set_toString();
    test_set_with_strings();
}
