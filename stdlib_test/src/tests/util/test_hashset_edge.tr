// Edge case tests for HashSet.tr
// Tests boundary conditions, empty inputs, and error conditions.
import tt::util::HashSet;
import tt::lang::Integer;

// Test empty set operations: size, isEmpty, clear.
public fn test_hashset_edge_empty_operations(): void {
    let set: HashSet<string> = new HashSet<string>();
    if (set.size() != 0) {
        io::println("FAIL: HashSet empty size = " + Integer.toString(set.size()));
    } else if (!set.isEmpty()) {
        io::println("FAIL: HashSet empty not isEmpty");
    } else {
        io::println("PASS: HashSet empty size/isEmpty");
    }
    set.clear();
    if (set.size() != 0 || !set.isEmpty()) {
        io::println("FAIL: HashSet clear on empty");
    } else {
        io::println("PASS: HashSet clear on empty set");
    }
}

// Test add duplicate element returns false and does not grow size.
public fn test_hashset_edge_add_duplicate(): void {
    let set: HashSet<int> = new HashSet<int>();
    let r1: bool = set.add(1);
    let r2: bool = set.add(1);
    let r3: bool = set.add(1);
    if (!r1 || r2 || r3) {
        io::println("FAIL: HashSet add duplicate return values");
    } else if (set.size() != 1) {
        io::println("FAIL: HashSet add duplicate size = " + Integer.toString(set.size()));
    } else {
        io::println("PASS: HashSet add duplicate rejected");
    }
}

// Test contains on an empty set returns false.
public fn test_hashset_edge_contains_empty(): void {
    let set: HashSet<string> = new HashSet<string>();
    if (set.contains("anything")) {
        io::println("FAIL: HashSet contains empty returned true");
    } else {
        io::println("PASS: HashSet contains on empty set false");
    }
}

// Test remove on a missing element returns false and leaves set unchanged.
public fn test_hashset_edge_remove_missing(): void {
    let set: HashSet<int> = new HashSet<int>();
    set.add(1);
    set.add(2);
    let r: bool = set.remove(99);
    if (r) {
        io::println("FAIL: HashSet remove missing returned true");
    } else if (set.size() != 2) {
        io::println("FAIL: HashSet remove missing changed size");
    } else {
        io::println("PASS: HashSet remove missing safe");
    }
}

// Test size tracking after a sequence of duplicates and removes.
public fn test_hashset_edge_size_after_duplicates(): void {
    let set: HashSet<int> = new HashSet<int>();
    set.add(1);
    set.add(1);
    set.add(2);
    set.add(2);
    set.add(3);
    if (set.size() != 3) {
        io::println("FAIL: HashSet size after dups = " + Integer.toString(set.size()));
    } else {
        io::println("PASS: HashSet size after duplicates");
    }
    set.remove(2);
    set.remove(2);
    if (set.size() != 2) {
        io::println("FAIL: HashSet size after dup removes = " + Integer.toString(set.size()));
    } else {
        io::println("PASS: HashSet size after duplicate removes");
    }
}

public fn run_all_hashset_edge_tests(): void {
    io::println("=== HashSet.tr Edge Tests ===");
    test_hashset_edge_empty_operations();
    test_hashset_edge_add_duplicate();
    test_hashset_edge_contains_empty();
    test_hashset_edge_remove_missing();
    test_hashset_edge_size_after_duplicates();
}
