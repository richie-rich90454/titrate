// Test file for namedTuple.tr
// Exercises the public API of the namedTuple class (named tuple with field access by name).
import tt::util::namedTuple;
import tt::util::ArrayList;
import tt::util::HashMap;
import tt::lang::Variant;
import tt::lang::Integer;
import tt::lang::String;

fn _makeNames(): ArrayList<string> {
    let names: ArrayList<string> = new ArrayList<string>();
    names.add("x");
    names.add("y");
    names.add("z");
    return names;
}

fn _makeValues(): ArrayList<Variant> {
    let vals: ArrayList<Variant> = new ArrayList<Variant>();
    vals.add(1 as Variant);
    vals.add(2 as Variant);
    vals.add(3 as Variant);
    return vals;
}

public fn test_namedtuple_init(): void {
    let nt: namedTuple = new namedTuple(_makeNames(), _makeValues());
    if (nt.size() != 3) {
        io::println("FAIL: namedTuple init size = " + Integer.toString(nt.size()));
    } else {
        io::println("PASS: namedTuple init works");
    }
}

public fn test_namedtuple_get(): void {
    let nt: namedTuple = new namedTuple(_makeNames(), _makeValues());
    let x: Variant = nt.get("x");
    let y: Variant = nt.get("y");
    if (x == null || y == null) {
        io::println("FAIL: namedTuple get null");
    } else {
        io::println("PASS: namedTuple get works");
    }
}

public fn test_namedtuple_getByIndex(): void {
    let nt: namedTuple = new namedTuple(_makeNames(), _makeValues());
    let v0: Variant = nt.getByIndex(0);
    let v1: Variant = nt.getByIndex(1);
    if (v0 == null || v1 == null) {
        io::println("FAIL: namedTuple getByIndex null");
    } else {
        io::println("PASS: namedTuple getByIndex works");
    }
}

public fn test_namedtuple_set(): void {
    let nt: namedTuple = new namedTuple(_makeNames(), _makeValues());
    nt.set("x", 99 as Variant);
    let v: Variant = nt.get("x");
    if (v == null) {
        io::println("FAIL: namedTuple set null");
    } else {
        io::println("PASS: namedTuple set works");
    }
}

public fn test_namedtuple_setByIndex(): void {
    let nt: namedTuple = new namedTuple(_makeNames(), _makeValues());
    nt.setByIndex(2, 77 as Variant);
    let v: Variant = nt.getByIndex(2);
    if (v == null) {
        io::println("FAIL: namedTuple setByIndex null");
    } else {
        io::println("PASS: namedTuple setByIndex works");
    }
}

public fn test_namedtuple_fieldNames(): void {
    let nt: namedTuple = new namedTuple(_makeNames(), _makeValues());
    let names: ArrayList<string> = nt.fieldNames();
    if (names.size() != 3 || names.get(0) != "x" || names.get(1) != "y" || names.get(2) != "z") {
        io::println("FAIL: namedTuple fieldNames");
    } else {
        io::println("PASS: namedTuple fieldNames works");
    }
}

public fn test_namedtuple_values(): void {
    let nt: namedTuple = new namedTuple(_makeNames(), _makeValues());
    let vals: ArrayList<Variant> = nt.values();
    if (vals.size() != 3) {
        io::println("FAIL: namedTuple values size = " + Integer.toString(vals.size()));
    } else {
        io::println("PASS: namedTuple values works");
    }
}

public fn test_namedtuple_hasField(): void {
    let nt: namedTuple = new namedTuple(_makeNames(), _makeValues());
    if (!nt.hasField("x") || !nt.hasField("y") || !nt.hasField("z") || nt.hasField("w")) {
        io::println("FAIL: namedTuple hasField");
    } else {
        io::println("PASS: namedTuple hasField works");
    }
}

public fn test_namedtuple_size(): void {
    let nt: namedTuple = new namedTuple(_makeNames(), _makeValues());
    if (nt.size() != 3) {
        io::println("FAIL: namedTuple size = " + Integer.toString(nt.size()));
    } else {
        io::println("PASS: namedTuple size works");
    }
}

public fn test_namedtuple_equals(): void {
    let nt1: namedTuple = new namedTuple(_makeNames(), _makeValues());
    let nt2: namedTuple = new namedTuple(_makeNames(), _makeValues());
    if (!nt1.equals(nt2)) {
        io::println("FAIL: namedTuple equals same");
    } else {
        io::println("PASS: namedTuple equals works");
    }
}

public fn test_namedtuple_clone(): void {
    let nt: namedTuple = new namedTuple(_makeNames(), _makeValues());
    let copy: namedTuple = nt.clone();
    if (copy.size() != 3) {
        io::println("FAIL: namedTuple clone size = " + Integer.toString(copy.size()));
    } else {
        if (!nt.equals(copy)) {
            io::println("FAIL: namedTuple clone content");
        } else {
            io::println("PASS: namedTuple clone works");
        }
    }
}

public fn test_namedtuple_asMap(): void {
    let nt: namedTuple = new namedTuple(_makeNames(), _makeValues());
    let map: HashMap<string, Variant> = nt.asMap();
    if (map.size() != 3) {
        io::println("FAIL: namedTuple asMap size = " + Integer.toString(map.size()));
    } else {
        io::println("PASS: namedTuple asMap works");
    }
}

public fn test_namedtuple_asList(): void {
    let nt: namedTuple = new namedTuple(_makeNames(), _makeValues());
    let list: ArrayList<Variant> = nt.asList();
    if (list.size() != 3) {
        io::println("FAIL: namedTuple asList size = " + Integer.toString(list.size()));
    } else {
        io::println("PASS: namedTuple asList works");
    }
}

public fn test_namedtuple_replace(): void {
    let nt: namedTuple = new namedTuple(_makeNames(), _makeValues());
    let replaced: namedTuple = nt.replace("y", 99 as Variant);
    // Original should be unchanged
    let origY: Variant = nt.get("y");
    let newY: Variant = replaced.get("y");
    if (origY == null || newY == null) {
        io::println("FAIL: namedTuple replace null");
    } else {
        io::println("PASS: namedTuple replace works");
    }
}

public fn test_namedtuple_toString(): void {
    let nt: namedTuple = new namedTuple(_makeNames(), _makeValues());
    let s: string = nt.toString();
    if (String.length(s) == 0) {
        io::println("FAIL: namedTuple toString empty");
    } else {
        io::println("PASS: namedTuple toString works");
    }
}

public fn test_namedtuple_fewer_values(): void {
    // Test with fewer values than field names (missing values should be null)
    let names: ArrayList<string> = new ArrayList<string>();
    names.add("a");
    names.add("b");
    names.add("c");
    let vals: ArrayList<Variant> = new ArrayList<Variant>();
    vals.add(1 as Variant);
    // Only 1 value for 3 fields
    let nt: namedTuple = new namedTuple(names, vals);
    if (nt.size() != 3) {
        io::println("FAIL: namedTuple fewer values size = " + Integer.toString(nt.size()));
    } else {
        let b: Variant = nt.get("b");
        if (b != null) {
            io::println("FAIL: namedTuple missing field should be null");
        } else {
            io::println("PASS: namedTuple handles fewer values");
        }
    }
}

public fn run_all_namedtuple_tests(): void {
    io::println("=== namedTuple.tr Tests ===");
    test_namedtuple_init();
    test_namedtuple_get();
    test_namedtuple_getByIndex();
    test_namedtuple_set();
    test_namedtuple_setByIndex();
    test_namedtuple_fieldNames();
    test_namedtuple_values();
    test_namedtuple_hasField();
    test_namedtuple_size();
    test_namedtuple_equals();
    test_namedtuple_clone();
    test_namedtuple_asMap();
    test_namedtuple_asList();
    test_namedtuple_replace();
    test_namedtuple_toString();
    test_namedtuple_fewer_values();
}
