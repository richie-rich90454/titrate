// Test file for Deque.tr
// Exercises the public API of the Deque class (double-ended queue).
import tt::util::Deque;
import tt::util::ArrayList;
import tt::lang::Variant;
import tt::lang::Integer;

public fn test_deque_pushLeft_pushRight(): void {
    let d: Deque = new Deque();
    d.pushRight(1 as Variant);
    d.pushRight(2 as Variant);
    d.pushLeft(0 as Variant);
    if (d.size() != 3) {
        io::println("FAIL: Deque.size() = " + Integer.toString(d.size()));
    } else {
        io::println("PASS: Deque.pushLeft/pushRight works");
    }
}

public fn test_deque_popLeft_popRight(): void {
    let d: Deque = new Deque();
    d.pushRight(1 as Variant);
    d.pushRight(2 as Variant);
    d.pushRight(3 as Variant);
    let left: Variant = d.popLeft();
    let right: Variant = d.popRight();
    if (left != 1 || right != 3 || d.size() != 1) {
        io::println("FAIL: Deque.popLeft/popRight");
    } else {
        io::println("PASS: Deque.popLeft/popRight works");
    }
}

public fn test_deque_peekLeft_peekRight(): void {
    let d: Deque = new Deque();
    d.pushRight(10 as Variant);
    d.pushRight(20 as Variant);
    if (d.peekLeft() != 10 || d.peekRight() != 20) {
        io::println("FAIL: Deque.peekLeft/peekRight");
    } else if (d.size() != 2) {
        io::println("FAIL: Deque.peek modified size");
    } else {
        io::println("PASS: Deque.peekLeft/peekRight works");
    }
}

public fn test_deque_isEmpty(): void {
    let d: Deque = new Deque();
    if (!d.isEmpty()) {
        io::println("FAIL: Deque.isEmpty new");
    } else {
        io::println("PASS: Deque.isEmpty new");
    }
    d.pushRight(1 as Variant);
    if (d.isEmpty()) {
        io::println("FAIL: Deque.isEmpty after push");
    } else {
        io::println("PASS: Deque.isEmpty after push");
    }
}

public fn test_deque_clear(): void {
    let d: Deque = new Deque();
    d.pushRight(1 as Variant);
    d.pushRight(2 as Variant);
    d.clear();
    if (!d.isEmpty() || d.size() != 0) {
        io::println("FAIL: Deque.clear");
    } else {
        io::println("PASS: Deque.clear works");
    }
}

public fn test_deque_contains(): void {
    let d: Deque = new Deque();
    d.pushRight(1 as Variant);
    d.pushRight(2 as Variant);
    d.pushRight(3 as Variant);
    if (!d.contains(1 as Variant) || d.contains(99 as Variant)) {
        io::println("FAIL: Deque.contains");
    } else {
        io::println("PASS: Deque.contains works");
    }
}

public fn test_deque_indexOf(): void {
    let d: Deque = new Deque();
    d.pushRight(10 as Variant);
    d.pushRight(20 as Variant);
    d.pushRight(30 as Variant);
    if (d.indexOf(20 as Variant) != 1 || d.indexOf(99 as Variant) != -1) {
        io::println("FAIL: Deque.indexOf");
    } else {
        io::println("PASS: Deque.indexOf works");
    }
}

public fn test_deque_count(): void {
    let d: Deque = new Deque();
    d.pushRight(1 as Variant);
    d.pushRight(2 as Variant);
    d.pushRight(1 as Variant);
    if (d.count(1 as Variant) != 2) {
        io::println("FAIL: Deque.count");
    } else {
        io::println("PASS: Deque.count works");
    }
}

public fn test_deque_rotate(): void {
    let d: Deque = new Deque();
    d.pushRight(1 as Variant);
    d.pushRight(2 as Variant);
    d.pushRight(3 as Variant);
    d.rotate(1);
    // After rotate right by 1: [3, 1, 2]
    if (d.peekLeft() != 3 || d.peekRight() != 2) {
        io::println("FAIL: Deque.rotate");
    } else {
        io::println("PASS: Deque.rotate works");
    }
}

public fn test_deque_copy(): void {
    let d: Deque = new Deque();
    d.pushRight(1 as Variant);
    d.pushRight(2 as Variant);
    let c: Deque = d.copy();
    c.pushRight(3 as Variant);
    if (d.size() != 2 || c.size() != 3) {
        io::println("FAIL: Deque.copy independence");
    } else {
        io::println("PASS: Deque.copy works");
    }
}

public fn test_deque_reversed(): void {
    let d: Deque = new Deque();
    d.pushRight(1 as Variant);
    d.pushRight(2 as Variant);
    d.pushRight(3 as Variant);
    let r: Deque = d.reversed();
    if (r.peekLeft() != 3 || r.peekRight() != 1) {
        io::println("FAIL: Deque.reversed");
    } else {
        io::println("PASS: Deque.reversed works");
    }
}

public fn test_deque_insert(): void {
    let d: Deque = new Deque();
    d.pushRight(1 as Variant);
    d.pushRight(3 as Variant);
    d.insert(1, 2 as Variant);
    if (d.size() != 3 || d.popLeft() != 1 || d.popLeft() != 2 || d.popLeft() != 3) {
        io::println("FAIL: Deque.insert");
    } else {
        io::println("PASS: Deque.insert works");
    }
}

public fn test_deque_extendLeft(): void {
    let a: Deque = new Deque();
    a.pushRight(1 as Variant);
    a.pushRight(2 as Variant);
    let b: Deque = new Deque();
    b.pushRight(3 as Variant);
    b.pushRight(4 as Variant);
    a.extendLeft(b);
    // extendLeft prepends reversed: [4, 3, 1, 2]
    if (a.size() != 4 || a.peekLeft() != 4) {
        io::println("FAIL: Deque.extendLeft size=" + Integer.toString(a.size()));
    } else {
        io::println("PASS: Deque.extendLeft works");
    }
}

public fn test_deque_remove(): void {
    let d: Deque = new Deque();
    d.pushRight(1 as Variant);
    d.pushRight(2 as Variant);
    d.pushRight(3 as Variant);
    d.remove(2 as Variant);
    if (d.size() != 2 || d.contains(2 as Variant)) {
        io::println("FAIL: Deque.remove");
    } else {
        io::println("PASS: Deque.remove works");
    }
}

public fn test_deque_maxLen(): void {
    let d: Deque = new Deque();
    d.initWithMaxLen(2);
    d.pushRight(1 as Variant);
    d.pushRight(2 as Variant);
    d.pushRight(3 as Variant);
    // maxLen=2 trims from left, leaving [2, 3]
    if (d.size() != 2 || d.peekLeft() != 2) {
        io::println("FAIL: Deque.maxLen size=" + Integer.toString(d.size()));
    } else {
        io::println("PASS: Deque.maxLen works");
    }
}

public fn run_all_deque_tests(): void {
    io::println("=== Deque.tr Tests ===");
    test_deque_pushLeft_pushRight();
    test_deque_popLeft_popRight();
    test_deque_peekLeft_peekRight();
    test_deque_isEmpty();
    test_deque_clear();
    test_deque_contains();
    test_deque_indexOf();
    test_deque_count();
    test_deque_rotate();
    test_deque_copy();
    test_deque_reversed();
    test_deque_insert();
    test_deque_extendLeft();
    test_deque_remove();
    test_deque_maxLen();
}
