// Test file for PriorityQueueExt.tr
// Exercises the public API of the PriorityQueueExt class (priority queue with ID-based updates).
import tt::util::PriorityQueueExt;
import tt::util::Pair;
import tt::lang::Variant;
import tt::lang::Integer;
import tt::lang::Double;

public fn test_pqext_init(): void {
    let pq: PriorityQueueExt = new PriorityQueueExt();
    if (!pq.isEmpty() || pq.size() != 0) {
        io::println("FAIL: PriorityQueueExt init");
    } else {
        io::println("PASS: PriorityQueueExt init empty");
    }
}

public fn test_pqext_push_size(): void {
    let pq: PriorityQueueExt = new PriorityQueueExt();
    pq.push(3.0, 30 as Variant, "a");
    pq.push(1.0, 10 as Variant, "b");
    pq.push(2.0, 20 as Variant, "c");
    if (pq.size() != 3) {
        io::println("FAIL: PriorityQueueExt push size = " + Integer.toString(pq.size()));
    } else {
        io::println("PASS: PriorityQueueExt push/size works");
    }
}

public fn test_pqext_pop_order(): void {
    let pq: PriorityQueueExt = new PriorityQueueExt();
    pq.push(3.0, 30 as Variant, "a");
    pq.push(1.0, 10 as Variant, "b");
    pq.push(2.0, 20 as Variant, "c");
    // Should pop in priority order: 1.0, 2.0, 3.0
    let first: Pair<double, Variant> = pq.pop();
    let second: Pair<double, Variant> = pq.pop();
    let third: Pair<double, Variant> = pq.pop();
    if (first.first() != 1.0 || second.first() != 2.0 || third.first() != 3.0) {
        io::println("FAIL: PriorityQueueExt pop order");
    } else {
        io::println("PASS: PriorityQueueExt pop order works");
    }
}

public fn test_pqext_peek(): void {
    let pq: PriorityQueueExt = new PriorityQueueExt();
    pq.push(5.0, 50 as Variant, "a");
    pq.push(1.0, 10 as Variant, "b");
    let top: Pair<double, Variant> = pq.peek();
    if (top.first() != 1.0) {
        io::println("FAIL: PriorityQueueExt peek");
    } else {
        if (pq.size() != 2) {
            io::println("FAIL: PriorityQueueExt peek modified size");
        } else {
            io::println("PASS: PriorityQueueExt peek works");
        }
    }
}

public fn test_pqext_isEmpty(): void {
    let pq: PriorityQueueExt = new PriorityQueueExt();
    if (!pq.isEmpty()) {
        io::println("FAIL: PriorityQueueExt isEmpty new");
    } else {
        pq.push(1.0, 10 as Variant, "a");
        if (pq.isEmpty()) {
            io::println("FAIL: PriorityQueueExt isEmpty after push");
        } else {
            io::println("PASS: PriorityQueueExt isEmpty works");
        }
    }
}

public fn test_pqext_contains(): void {
    let pq: PriorityQueueExt = new PriorityQueueExt();
    pq.push(1.0, 10 as Variant, "a");
    pq.push(2.0, 20 as Variant, "b");
    if (!pq.contains("a") || pq.contains("z")) {
        io::println("FAIL: PriorityQueueExt contains");
    } else {
        io::println("PASS: PriorityQueueExt contains works");
    }
}

public fn test_pqext_updatePriority(): void {
    let pq: PriorityQueueExt = new PriorityQueueExt();
    pq.push(5.0, 50 as Variant, "a");
    pq.push(1.0, 10 as Variant, "b");
    // Update "a" from priority 5.0 to 0.5 (should now be top)
    let updated: bool = pq.updatePriority("a", 0.5);
    if (!updated) {
        io::println("FAIL: PriorityQueueExt updatePriority not found");
    } else {
        let top: Pair<double, Variant> = pq.peek();
        if (top.first() != 0.5) {
            io::println("FAIL: PriorityQueueExt updatePriority top = " + Double.toString(top.first()));
        } else {
            io::println("PASS: PriorityQueueExt updatePriority works");
        }
    }
}

public fn test_pqext_remove(): void {
    let pq: PriorityQueueExt = new PriorityQueueExt();
    pq.push(1.0, 10 as Variant, "a");
    pq.push(2.0, 20 as Variant, "b");
    pq.push(3.0, 30 as Variant, "c");
    let removed: bool = pq.remove("b");
    if (!removed || pq.contains("b") || pq.size() != 2) {
        io::println("FAIL: PriorityQueueExt remove");
    } else {
        io::println("PASS: PriorityQueueExt remove works");
    }
}

public fn test_pqext_drainTo(): void {
    let pq: PriorityQueueExt = new PriorityQueueExt();
    pq.push(3.0, 30 as Variant, "a");
    pq.push(1.0, 10 as Variant, "b");
    pq.push(2.0, 20 as Variant, "c");
    pq.push(4.0, 40 as Variant, "d");
    let drained: ArrayList<Pair<double, Variant>> = pq.drainTo(2);
    if (drained.size() != 2 || pq.size() != 2) {
        io::println("FAIL: PriorityQueueExt drainTo");
    } else {
        // First drained should be priority 1.0
        if (drained.get(0).first() != 1.0) {
            io::println("FAIL: PriorityQueueExt drainTo order");
        } else {
            io::println("PASS: PriorityQueueExt drainTo works");
        }
    }
}

public fn test_pqext_tryPut(): void {
    let pq: PriorityQueueExt = new PriorityQueueExt();
    let ok: bool = pq.tryPut(1.0, 10 as Variant, "a");
    if (!ok || pq.size() != 1) {
        io::println("FAIL: PriorityQueueExt tryPut");
    } else {
        io::println("PASS: PriorityQueueExt tryPut works");
    }
}

public fn test_pqext_tryGet(): void {
    let pq: PriorityQueueExt = new PriorityQueueExt();
    // Empty queue should return null
    let empty: Pair<double, Variant> = pq.tryGet();
    if (empty != null) {
        io::println("FAIL: PriorityQueueExt tryGet empty");
    } else {
        pq.push(1.0, 10 as Variant, "a");
        let item: Pair<double, Variant> = pq.tryGet();
        if (item == null || item.first() != 1.0 || pq.size() != 0) {
            io::println("FAIL: PriorityQueueExt tryGet non-empty");
        } else {
            io::println("PASS: PriorityQueueExt tryGet works");
        }
    }
}

public fn test_pqext_pop_empty_throws(): void {
    let pq: PriorityQueueExt = new PriorityQueueExt();
    try {
        pq.pop();
        io::println("FAIL: PriorityQueueExt pop empty should throw");
    } catch (e: string) {
        io::println("PASS: PriorityQueueExt pop empty throws");
    }
}

public fn test_pqext_updatePriority_notFound(): void {
    let pq: PriorityQueueExt = new PriorityQueueExt();
    pq.push(1.0, 10 as Variant, "a");
    let updated: bool = pq.updatePriority("z", 0.5);
    if (updated) {
        io::println("FAIL: PriorityQueueExt updatePriority not found");
    } else {
        io::println("PASS: PriorityQueueExt updatePriority not found works");
    }
}

public fn test_pqext_remove_notFound(): void {
    let pq: PriorityQueueExt = new PriorityQueueExt();
    pq.push(1.0, 10 as Variant, "a");
    let removed: bool = pq.remove("z");
    if (removed) {
        io::println("FAIL: PriorityQueueExt remove not found");
    } else {
        io::println("PASS: PriorityQueueExt remove not found works");
    }
}

public fn run_all_priorityqueue_ext_tests(): void {
    io::println("=== PriorityQueueExt.tr Tests ===");
    test_pqext_init();
    test_pqext_push_size();
    test_pqext_pop_order();
    test_pqext_peek();
    test_pqext_isEmpty();
    test_pqext_contains();
    test_pqext_updatePriority();
    test_pqext_remove();
    test_pqext_drainTo();
    test_pqext_tryPut();
    test_pqext_tryGet();
    test_pqext_pop_empty_throws();
    test_pqext_updatePriority_notFound();
    test_pqext_remove_notFound();
}
