// Edge case tests for LinkedList.tr
// Tests boundary conditions, empty inputs, and error conditions.
import tt::util::LinkedList;
import tt::lang::Integer;

// Test empty list operations: size, isEmpty, clear, getFirst/getLast.
public fn test_linkedlist_edge_empty_operations(): void {
    let list: LinkedList<int> = new LinkedList<int>();
    if (list.size() != 0) {
        io::println("FAIL: LinkedList empty size = " + Integer.toString(list.size()));
    } else if (!list.isEmpty()) {
        io::println("FAIL: LinkedList empty not isEmpty");
    } else if (list.getFirst() != null || list.getLast() != null) {
        io::println("FAIL: LinkedList empty getFirst/getLast not null");
    } else {
        io::println("PASS: LinkedList empty size/isEmpty/peek");
    }
    list.clear();
    if (list.size() != 0 || !list.isEmpty()) {
        io::println("FAIL: LinkedList clear on empty");
    } else {
        io::println("PASS: LinkedList clear on empty");
    }
}

// Test add/remove at head and tail updates boundaries correctly.
public fn test_linkedlist_edge_head_tail(): void {
    let list: LinkedList<int> = new LinkedList<int>();
    list.addFirst(2);
    list.addLast(3);
    list.addFirst(1);
    list.addLast(4);
    // Expected: [1, 2, 3, 4]
    if (list.getFirst() != 1 || list.getLast() != 4) {
        io::println("FAIL: LinkedList head/tail add");
    } else {
        io::println("PASS: LinkedList add at head/tail");
    }
    let h: int = list.removeFirst();
    let t: int = list.removeLast();
    if (h != 1 || t != 4 || list.size() != 2) {
        io::println("FAIL: LinkedList remove head/tail");
    } else {
        io::println("PASS: LinkedList remove at head/tail");
    }
}

// Test single element operations: add then remove leaves list empty.
public fn test_linkedlist_edge_single_element(): void {
    let list: LinkedList<int> = new LinkedList<int>();
    list.addFirst(99);
    if (list.getFirst() != 99 || list.getLast() != 99 || list.size() != 1) {
        io::println("FAIL: LinkedList single element head==tail");
    } else {
        io::println("PASS: LinkedList single element head==tail");
    }
    let v: int = list.removeLast();
    if (v != 99 || !list.isEmpty() || list.getFirst() != null) {
        io::println("FAIL: LinkedList single remove to empty");
    } else {
        io::println("PASS: LinkedList single element remove to empty");
    }
}

// Test remove on out-of-bounds index returns null safely.
public fn test_linkedlist_edge_remove_oob(): void {
    let list: LinkedList<int> = new LinkedList<int>();
    list.addLast(1);
    let r1: int = list.remove(-1);
    let r2: int = list.remove(5);
    if (r1 != null || r2 != null) {
        io::println("FAIL: LinkedList remove OOB not null");
    } else if (list.size() != 1) {
        io::println("FAIL: LinkedList remove OOB changed size");
    } else {
        io::println("PASS: LinkedList remove OOB safe");
    }
}

// Test size tracking through add/remove from both ends.
public fn test_linkedlist_edge_size_tracking(): void {
    let list: LinkedList<int> = new LinkedList<int>();
    list.addLast(1);
    list.addLast(2);
    list.removeFirst();
    list.addFirst(0);
    list.removeLast();
    if (list.size() != 1) {
        io::println("FAIL: LinkedList size tracking = " + Integer.toString(list.size()));
    } else {
        io::println("PASS: LinkedList size tracking through ops");
    }
    list.clear();
    if (list.size() != 0) {
        io::println("FAIL: LinkedList size after clear = " + Integer.toString(list.size()));
    } else {
        io::println("PASS: LinkedList size after clear");
    }
}

public fn run_all_linkedlist_edge_tests(): void {
    io::println("=== LinkedList.tr Edge Tests ===");
    test_linkedlist_edge_empty_operations();
    test_linkedlist_edge_head_tail();
    test_linkedlist_edge_single_element();
    test_linkedlist_edge_remove_oob();
    test_linkedlist_edge_size_tracking();
}
