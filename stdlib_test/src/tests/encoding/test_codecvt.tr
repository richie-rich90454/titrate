public fn test_wstringConvert_invalid_tag_defaults_utf8(): void {
    let wsc: Codecvt.WStringConvert = new Codecvt.WStringConvert("invalid");
    if (wsc._facetTag == "utf8") {
        io::println("PASS: WStringConvert invalid tag defaults to utf8");
    } else {
        io::println("FAIL: WStringConvert invalid tag");
    }
}

public fn test_wstringConvert_converted(): void {
    let wsc: Codecvt.WStringConvert = new Codecvt.WStringConvert("utf8");
    if (wsc.converted() == 0) {
        io::println("PASS: WStringConvert.converted returns 0");
    } else {
        io::println("FAIL: WStringConvert.converted");
    }
}

