// ==================== WBufferConvert ====================

public fn test_wbufferConvert_utf8(): void {
    let buf: StringBuilder = new StringBuilder();
    let wbc: Codecvt.WBufferConvert = Codecvt.wbufferConvertUtf8(buf);
    let wide: string = String.fromCharCode(0xE9);
    let n: int = wbc.sputn(wide);
    if (n > 0) {
        let read: string = wbc.rdbuf();
        if (read == wide) {
            io::println("PASS: WBufferConvert utf8 write/read round-trip");
        } else {
            io::println("FAIL: WBufferConvert utf8 read");
        }
    } else {
        io::println("FAIL: WBufferConvert utf8 write returned 0");
    }
}

public fn test_wbufferConvert_buffer_access(): void {
    let buf: StringBuilder = new StringBuilder();
    let wbc: Codecvt.WBufferConvert = Codecvt.wbufferConvertUtf8(buf);
    let accessible: StringBuilder = wbc.buffer();
    if (accessible == buf) {
        io::println("PASS: WBufferConvert.buffer returns underlying buffer");
    } else {
        io::println("FAIL: WBufferConvert.buffer");
    }
}

public fn test_wbufferConvertUtf16_factory(): void {
    let buf: StringBuilder = new StringBuilder();
    let wbc: Codecvt.WBufferConvert = Codecvt.wbufferConvertUtf16(buf, false);
    let wide: string = String.fromCharCode(0x41);
    let n: int = wbc.sputn(wide);
    if (n > 0) {
        let read: string = wbc.rdbuf();
        if (read == wide) {
            io::println("PASS: wbufferConvertUtf16 factory round-trip");
        } else {
            io::println("FAIL: wbufferConvertUtf16 read");
        }
    } else {
        io::println("FAIL: wbufferConvertUtf16 write returned 0");
    }
}

public fn test_wbufferConvertUtf8Utf16_factory(): void {
    let buf: StringBuilder = new StringBuilder();
    let wbc: Codecvt.WBufferConvert = Codecvt.wbufferConvertUtf8Utf16(buf);
    let utf16: string = String.fromCharCode(0x41);
    let n: int = wbc.sputn(utf16);
    if (n > 0) {
        let read: string = wbc.rdbuf();
        if (read == utf16) {
            io::println("PASS: wbufferConvertUtf8Utf16 factory round-trip");
        } else {
            io::println("FAIL: wbufferConvertUtf8Utf16 read");
        }
    } else {
        io::println("FAIL: wbufferConvertUtf8Utf16 write returned 0");
    }
}

// ==================== Aggregator ====================

public fn run_all_codecvt_tests(): void {
    io::println("=== Codecvt.tr Tests ===");
    // CodecvtUtf8
    test_utf8_fromBytes_ascii();
    test_utf8_fromBytes_2byte();
    test_utf8_fromBytes_3byte();
    test_utf8_fromBytes_4byte();
    test_utf8_fromBytes_empty();
    test_utf8_fromBytes_bom();
    test_utf8_toBytes_ascii();
    test_utf8_toBytes_2byte();
    test_utf8_toBytes_3byte();
