        io::println("PASS: Duration.ofHours works");
    }
}

public fn test_duration_ofDays(): void {
    let d: Duration = Duration.ofDays(2);
    if (d.toMillis() != 172800000) {
        io::println("FAIL: Duration.ofDays returned " + Long.toString(d.toMillis()));
    } else {
        io::println("PASS: Duration.ofDays works");
    }
}

public fn test_duration_ofNanos(): void {
    let d: Duration = Duration.ofNanos(2000000);
    if (d.toMillis() != 2) {
        io::println("FAIL: Duration.ofNanos returned " + Long.toString(d.toMillis()));
    } else {
        io::println("PASS: Duration.ofNanos works");
    }
}

public fn test_duration_ofMicros(): void {
    let d: Duration = Duration.ofMicros(3000);
    if (d.toMillis() != 3) {
        io::println("FAIL: Duration.ofMicros returned " + Long.toString(d.toMillis()));
    } else {
        io::println("PASS: Duration.ofMicros works");
    }
}

public fn run_all_duration_tests(): void {
    io::println("=== Duration.tr Tests ===");
    test_duration_init_toMillis();
    test_duration_toSeconds();
    test_duration_totalSeconds();
    test_duration_toMinutes();
    test_duration_toHours();
    test_duration_toDays();
    test_duration_toNanos();
    test_duration_toMicros();
    test_duration_initWithNanos();
    test_duration_plus();
    test_duration_minus();
    test_duration_isNegative();
    test_duration_isZero();
    test_duration_multipliedBy();
    test_duration_dividedBy();
    test_duration_negated();
    test_duration_abs();
    test_duration_toString();
    test_duration_public_field();
    test_duration_ofMillis();
    test_duration_ofSeconds();
    test_duration_ofMinutes();
    test_duration_ofHours();
    test_duration_ofDays();
    test_duration_ofNanos();
    test_duration_ofMicros();
}
