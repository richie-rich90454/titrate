// Test file for time/Chrono.tr
// Exercises Period, ChronoDuration, SystemClock, SteadyClock,
// HighResolutionClock, UtcClock, TaiClock, GpsClock, FileClock,
// isClock, isClockV, TimePoint, clockCast, clockFor, Year, Month, Day,
// Weekday, YearMonthDay, Tzdb, TimeZone, LeapSecond, getTzdb, reloadTzdb,
// timeZone, timeZoneNames.
import tt::time::Chrono;
import tt::util::ArrayList;
import tt::lang::String;
import tt::lang::Integer;

// ==================== Period ====================

public fn test_period_init(): void {
    let p: Period = new Period(1, 1000);
    if (p.num != 1 || p.den != 1000) {
        io::println("FAIL: Period init wrong");
    } else {
        io::println("PASS: Period init works");
    }
}

public fn test_period_multiply(): void {
    let a: Period = new Period(1, 1000);
    let b: Period = new Period(1, 1);
    let r: Period = a.multiply(b);
    if (r.num != 1 || r.den != 1000) {
        io::println("FAIL: Period multiply = " + r.num + "/" + r.den);
    } else {
        io::println("PASS: Period multiply works");
    }
}

public fn test_period_divide(): void {
    let a: Period = new Period(1, 1);
    let b: Period = new Period(1000, 1);
    let r: Period = a.divide(b);
    if (r.num != 1 || r.den != 1000) {
        io::println("FAIL: Period divide = " + r.num + "/" + r.den);
    } else {
        io::println("PASS: Period divide works");
    }
}

public fn test_period_equals(): void {
    let a: Period = new Period(1, 1000);
    let b: Period = new Period(1, 1000);
    let c: Period = new Period(1, 1);
    if (!a.equals(b)) {
        io::println("FAIL: equal periods should match");
    } else if (a.equals(c)) {
        io::println("FAIL: different periods should not match");
    } else {
        io::println("PASS: Period equals works");
    }
}

public fn test_period_equals_null(): void {
    let a: Period = new Period(1, 1);
    if (a.equals(null)) {
        io::println("FAIL: equals null should return false");
    } else {
        io::println("PASS: Period equals null works");
    }
}

public fn test_period_factories(): void {
    if (Chrono.nano().num != 1 || Chrono.nano().den != 1000000000) {
        io::println("FAIL: nano period wrong");
    } else if (Chrono.milli().num != 1 || Chrono.milli().den != 1000) {
        io::println("FAIL: milli period wrong");
    } else if (Chrono.seconds_().num != 1 || Chrono.seconds_().den != 1) {
        io::println("FAIL: seconds period wrong");
    } else if (Chrono.minutes_().num != 60) {
        io::println("FAIL: minutes period wrong");
    } else {
        io::println("PASS: Period factories work");
    }
}

// ==================== ChronoDuration ====================

public fn test_chrono_duration_init(): void {
    let d: ChronoDuration = new ChronoDuration(1000, Chrono.milli());
    if (d.count() != 1000) {
        io::println("FAIL: ChronoDuration count = " + d.count());
    } else {
        io::println("PASS: ChronoDuration init works");
    }
}

public fn test_chrono_duration_to_nanos(): void {
    let d: ChronoDuration = new ChronoDuration(1, Chrono.seconds_());
    if (d.toNanos() != 1000000000) {
        io::println("FAIL: 1 sec to nanos = " + d.toNanos());
    } else {
        io::println("PASS: ChronoDuration toNanos works");
    }
}

public fn test_chrono_duration_zero(): void {
    let d: ChronoDuration = new ChronoDuration(5, Chrono.milli());
    let z: ChronoDuration = d.zero();
    if (!z.isZero()) {
        io::println("FAIL: zero() should be zero");
    } else {
        io::println("PASS: ChronoDuration zero works");
    }
}

public fn test_chrono_duration_plus(): void {
    let a: ChronoDuration = new ChronoDuration(100, Chrono.milli());
    let b: ChronoDuration = new ChronoDuration(200, Chrono.milli());
    let sum: ChronoDuration = a.plus(b);
    if (sum.count() != 300) {
        io::println("FAIL: duration plus = " + sum.count());
    } else {
        io::println("PASS: ChronoDuration plus works");
    }
}

public fn test_chrono_duration_minus(): void {
    let a: ChronoDuration = new ChronoDuration(500, Chrono.milli());
    let b: ChronoDuration = new ChronoDuration(200, Chrono.milli());
    let diff: ChronoDuration = a.minus(b);
    if (diff.count() != 300) {
        io::println("FAIL: duration minus = " + diff.count());
    } else {
        io::println("PASS: ChronoDuration minus works");
    }
}

public fn test_chrono_duration_multiplied_by(): void {
    let d: ChronoDuration = new ChronoDuration(10, Chrono.seconds_());
    let m: ChronoDuration = d.multipliedBy(3);
    if (m.count() != 30) {
        io::println("FAIL: duration multipliedBy = " + m.count());
    } else {
        io::println("PASS: ChronoDuration multipliedBy works");
    }
}

public fn test_chrono_duration_divided_by(): void {
    let d: ChronoDuration = new ChronoDuration(100, Chrono.milli());
    let div: ChronoDuration = d.dividedBy(4);
    if (div.count() != 25) {
        io::println("FAIL: duration dividedBy = " + div.count());
    } else {
        io::println("PASS: ChronoDuration dividedBy works");
    }
}

public fn test_chrono_duration_negated(): void {
    let d: ChronoDuration = new ChronoDuration(42, Chrono.seconds_());
    let n: ChronoDuration = d.negated();
    if (n.count() != -42) {
        io::println("FAIL: duration negated = " + n.count());
    } else {
        io::println("PASS: ChronoDuration negated works");
    }
}

public fn test_chrono_duration_abs(): void {
    let d: ChronoDuration = new ChronoDuration(-50, Chrono.milli());
    let a: ChronoDuration = d.abs();
    if (a.count() != 50) {
        io::println("FAIL: duration abs = " + a.count());
    } else {
        io::println("PASS: ChronoDuration abs works");
    }
}

public fn test_chrono_duration_is_negative(): void {
    let pos: ChronoDuration = new ChronoDuration(5, Chrono.seconds_());
    let neg: ChronoDuration = new ChronoDuration(-3, Chrono.seconds_());
    if (pos.isNegative()) {
        io::println("FAIL: positive duration should not be negative");
    } else if (!neg.isNegative()) {
        io::println("FAIL: negative duration should be negative");
    } else {
        io::println("PASS: ChronoDuration isNegative works");
    }
}

public fn test_chrono_duration_equals(): void {
    let a: ChronoDuration = new ChronoDuration(1000, Chrono.milli());
    let b: ChronoDuration = new ChronoDuration(1, Chrono.seconds_());
    if (!a.equals(b)) {
        io::println("FAIL: 1000ms should equal 1s");
    } else {
        io::println("PASS: ChronoDuration equals works");
    }
}

public fn test_chrono_duration_compare_to(): void {
    let small: ChronoDuration = new ChronoDuration(1, Chrono.seconds_());
    let large: ChronoDuration = new ChronoDuration(2, Chrono.seconds_());
    if (small.compareTo(large) != -1) {
        io::println("FAIL: compareTo should be -1");
    } else if (large.compareTo(small) != 1) {
        io::println("FAIL: compareTo should be 1");
    } else if (small.compareTo(small) != 0) {
        io::println("FAIL: compareTo equal should be 0");
    } else {
        io::println("PASS: ChronoDuration compareTo works");
    }
}

