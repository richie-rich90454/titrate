}

public fn run_all_chrono_tests(): void {
    io::println("=== Chrono.tr Tests ===");
    test_period_init();
    test_period_multiply();
    test_period_divide();
    test_period_equals();
    test_period_equals_null();
    test_period_factories();
    test_chrono_duration_init();
    test_chrono_duration_to_nanos();
    test_chrono_duration_zero();
    test_chrono_duration_plus();
    test_chrono_duration_minus();
    test_chrono_duration_multiplied_by();
    test_chrono_duration_divided_by();
    test_chrono_duration_negated();
    test_chrono_duration_abs();
    test_chrono_duration_is_negative();
    test_chrono_duration_equals();
    test_chrono_duration_compare_to();
    test_nanos();
    test_millis();
    test_system_clock_now();
    test_steady_clock_now();
    test_high_resolution_clock_now();
    test_utc_clock_now();
    test_tai_clock_now();
    test_gps_clock_now();
    test_file_clock_now();
    test_is_clock();
