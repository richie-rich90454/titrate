// ==================== isClock ====================

public fn test_is_clock(): void {
    if (!Chrono.isClock("system")) {
        io::println("FAIL: isClock system should be true");
    } else if (!Chrono.isClock("steady")) {
        io::println("FAIL: isClock steady should be true");
    } else if (Chrono.isClock("unknown")) {
        io::println("FAIL: isClock unknown should be false");
    } else {
        io::println("PASS: isClock works");
    }
}

public fn test_is_clock_v(): void {
    if (!Chrono.isClockV("system")) {
        io::println("FAIL: isClockV system should be true");
    } else {
        io::println("PASS: isClockV works");
    }
}

// ==================== TimePoint ====================

public fn test_time_point_init(): void {
    let tp: TimePoint = new TimePoint(0, Chrono.nano(), "system");
    if (tp.clockName != "system") {
        io::println("FAIL: TimePoint clockName wrong");
    } else {
        io::println("PASS: TimePoint init works");
    }
}

public fn test_time_point_time_since_epoch(): void {
    let tp: TimePoint = new TimePoint(1000000, Chrono.nano(), "system");
    let d: ChronoDuration = tp.timeSinceEpoch();
    if (d.toNanos() != 1000000) {
        io::println("FAIL: timeSinceEpoch wrong");
    } else {
        io::println("PASS: TimePoint timeSinceEpoch works");
    }
}

public fn test_time_point_plus(): void {
    let tp: TimePoint = new TimePoint(100, Chrono.seconds_(), "system");
    let d: ChronoDuration = new ChronoDuration(50, Chrono.seconds_());
    let tp2: TimePoint = tp.plus(d);
    if (tp2.ticks != 150) {
        io::println("FAIL: time point plus = " + tp2.ticks);
    } else {
        io::println("PASS: TimePoint plus works");
    }
}

public fn test_time_point_minus(): void {
    let tp: TimePoint = new TimePoint(100, Chrono.seconds_(), "system");
    let d: ChronoDuration = new ChronoDuration(30, Chrono.seconds_());
    let tp2: TimePoint = tp.minus(d);
    if (tp2.ticks != 70) {
        io::println("FAIL: time point minus = " + tp2.ticks);
    } else {
        io::println("PASS: TimePoint minus works");
    }
}

public fn test_time_point_minus_tp(): void {
    let a: TimePoint = new TimePoint(200, Chrono.seconds_(), "system");
    let b: TimePoint = new TimePoint(50, Chrono.seconds_(), "system");
    let d: ChronoDuration = a.minusTP(b);
    if (d.count() != 150) {
        io::println("FAIL: time point minusTP = " + d.count());
    } else {
        io::println("PASS: TimePoint minusTP works");
    }
}

public fn test_time_point_compare_to(): void {
    let early: TimePoint = new TimePoint(100, Chrono.seconds_(), "system");
    let late: TimePoint = new TimePoint(200, Chrono.seconds_(), "system");
    if (early.compareTo(late) != -1) {
        io::println("FAIL: compareTo early < late");
    } else if (late.compareTo(early) != 1) {
        io::println("FAIL: compareTo late > early");
    } else if (early.compareTo(early) != 0) {
        io::println("FAIL: compareTo equal");
    } else {
        io::println("PASS: TimePoint compareTo works");
    }
}

// ==================== clock_cast / clockFor ====================

public fn test_clock_cast_same(): void {
    let tp: TimePoint = new TimePoint(42, Chrono.seconds_(), "system");
    let cast: TimePoint = Chrono.clockCast(tp, "system");
    if (cast.ticks != 42) {
        io::println("FAIL: clockCast same clock ticks changed");
    } else {
        io::println("PASS: clockCast same clock works");
    }
}

public fn test_clock_cast_system_to_utc(): void {
    let tp: TimePoint = new TimePoint(1000000000, Chrono.nano(), "system");
    let cast: TimePoint = Chrono.clockCast(tp, "utc");
    if (cast.clockName != "utc") {
        io::println("FAIL: clockCast system->utc clockName wrong");
    } else {
        io::println("PASS: clockCast system->utc works");
    }
}

public fn test_clock_for(): void {
    let c: Variant = Chrono.clockFor("system");
    if (c == null) {
        io::println("FAIL: clockFor system returned null");
    } else {
        io::println("PASS: clockFor system works");
    }
}

public fn test_clock_for_unknown(): void {
    let c: Variant = Chrono.clockFor("nonexistent");
    if (c != null) {
        io::println("FAIL: clockFor unknown should return null");
    } else {
        io::println("PASS: clockFor unknown returns null");
    }
}

// ==================== Calendar types ====================

public fn test_year(): void {
    let y: Year = new Year(2025);
    if (y.value != 2025) {
        io::println("FAIL: Year value wrong");
    } else {
        io::println("PASS: Year init works");
    }
}

public fn test_year_is_leap(): void {
    let y2000: Year = new Year(2000);
    let y2024: Year = new Year(2024);
    let y2025: Year = new Year(2025);
    let y1900: Year = new Year(1900);
    if (!y2000.isLeap()) {
        io::println("FAIL: 2000 is leap");
    } else if (!y2024.isLeap()) {
        io::println("FAIL: 2024 is leap");
    } else if (y2025.isLeap()) {
        io::println("FAIL: 2025 is not leap");
    } else if (y1900.isLeap()) {
        io::println("FAIL: 1900 is not leap (div 100 rule)");
    } else {
        io::println("PASS: Year isLeap works");
    }
}

public fn test_year_plus_minus(): void {
    let y: Year = new Year(2020);
    let yp: Year = y.plus(5);
    let ym: Year = y.minus(10);
    if (yp.value != 2025) {
        io::println("FAIL: Year plus = " + yp.value);
    } else if (ym.value != 2010) {
        io::println("FAIL: Year minus = " + ym.value);
    } else {
        io::println("PASS: Year plus/minus works");
    }
}

public fn test_month(): void {
    let m: Month = new Month(7);
    if (m.value != 7) {
        io::println("FAIL: Month value wrong");
    } else {
        io::println("PASS: Month init works");
    }
}

public fn test_month_clamp(): void {
    let low: Month = new Month(0);
    let high: Month = new Month(13);
    if (low.value != 1) {
        io::println("FAIL: Month clamp low = " + low.value);
    } else if (high.value != 12) {
        io::println("FAIL: Month clamp high = " + high.value);
    } else {
        io::println("PASS: Month clamp works");
    }
}

public fn test_month_plus(): void {
    let m: Month = new Month(11);
    let mp: Month = m.plus(3);
    if (mp.value != 2) {
        io::println("FAIL: Month plus wrap = " + mp.value);
    } else {
        io::println("PASS: Month plus works");
    }
}

public fn test_month_minus(): void {
    let m: Month = new Month(1);
    let mm: Month = m.minus(2);
    if (mm.value != 11) {
        io::println("FAIL: Month minus wrap = " + mm.value);
    } else {
        io::println("PASS: Month minus works");
    }
}

public fn test_day(): void {
    let d: Day = new Day(15);
    if (d.value != 15) {
        io::println("FAIL: Day value wrong");
    } else {
        io::println("PASS: Day init works");
    }
}

public fn test_day_clamp(): void {
    let low: Day = new Day(0);
    let high: Day = new Day(32);
    if (low.value != 1) {
        io::println("FAIL: Day clamp low = " + low.value);
    } else if (high.value != 31) {
        io::println("FAIL: Day clamp high = " + high.value);
    } else {
        io::println("PASS: Day clamp works");
    }
}

public fn test_weekday(): void {
    let wd: Weekday = new Weekday(1);
    if (wd.value != 1) {
        io::println("FAIL: Weekday value wrong");
    } else {
        io::println("PASS: Weekday init works");
    }
}

public fn test_weekday_clamp(): void {
    let low: Weekday = new Weekday(-1);
    let high: Weekday = new Weekday(7);
    if (low.value != 0) {
        io::println("FAIL: Weekday clamp low = " + low.value);
    } else if (high.value != 0) {
        io::println("FAIL: Weekday clamp high = " + high.value);
    } else {
        io::println("PASS: Weekday clamp works");
    }
}

public fn test_weekday_iso_value(): void {
    let sun: Weekday = new Weekday(0);
    let mon: Weekday = new Weekday(1);
    if (sun.isoValue() != 7) {
        io::println("FAIL: Sunday ISO value should be 7");
    } else if (mon.isoValue() != 1) {
        io::println("FAIL: Monday ISO value should be 1");
    } else {
        io::println("PASS: Weekday isoValue works");
    }
}

public fn test_weekday_plus(): void {
    let wd: Weekday = new Weekday(5);
    let wp: Weekday = wd.plus(3);
    if (wp.value != 1) {
        io::println("FAIL: Weekday plus wrap = " + wp.value);
    } else {
        io::println("PASS: Weekday plus works");
    }
}

public fn test_year_month_day(): void {
    let ymd: YearMonthDay = new YearMonthDay(new Year(2025), new Month(7), new Day(22));
    if (ymd.year.value != 2025 || ymd.month.value != 7 || ymd.day.value != 22) {
        io::println("FAIL: YearMonthDay init wrong");
    } else {
        io::println("PASS: YearMonthDay init works");
    }
}

public fn test_year_month_day_from_ints(): void {
    let ymd: YearMonthDay = new YearMonthDay();
    ymd.initFromInts(2025, 1, 15);
    if (ymd.year.value != 2025 || ymd.month.value != 1 || ymd.day.value != 15) {
        io::println("FAIL: YearMonthDay initFromInts wrong");
    } else {
        io::println("PASS: YearMonthDay initFromInts works");
    }
}

public fn test_year_month_day_weekday(): void {
    // 2025-01-01 is a Wednesday (value=3)
    let ymd: YearMonthDay = new YearMonthDay();
    ymd.initFromInts(2025, 1, 1);
    let wd: Weekday = ymd.weekday();
    if (wd.value != 3) {
        io::println("FAIL: 2025-01-01 should be Wednesday (3), got " + wd.value);
    } else {
        io::println("PASS: YearMonthDay weekday works");
    }
}

// ==================== Tzdb / TimeZone ====================

public fn test_time_zone_init(): void {
    let tz: TimeZone = new TimeZone("UTC", 0, 0);
    if (tz.name != "UTC") {
        io::println("FAIL: TimeZone name wrong");
    } else if (tz.offset() != 0) {
        io::println("FAIL: TimeZone offset wrong");
    } else {
        io::println("PASS: TimeZone init works");
    }
}

public fn test_time_zone_offset_dst(): void {
    let tz: TimeZone = new TimeZone("PST", -28800, 3600);
    if (tz.offset() != -25200) {
        io::println("FAIL: TimeZone offset with DST = " + tz.offset());
    } else {
        io::println("PASS: TimeZone offset with DST works");
    }
}

public fn test_time_zone_to_string(): void {
    let tz: TimeZone = new TimeZone("EST", -18000, 0);
    let s: string = tz.toString();
    if (String.contains(s, "EST")) {
        io::println("PASS: TimeZone toString works");
    } else {
        io::println("FAIL: TimeZone toString = " + s);
    }
}

