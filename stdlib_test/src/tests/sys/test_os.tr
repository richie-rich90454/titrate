public fn test_os_environMap(): void {
    let map: HashMap<string, string> = Os.environMap();
    if (map.size() <= 0) {
        io::println("FAIL: Os.environMap empty");
    } else {
        io::println("PASS: Os.environMap returns entries");
    }
}

public fn test_os_scandir(): void {
    let dir: string = "test_os_scandir";
    Dir_create(dir);
    let f: File = new File(dir + "/x.txt");
    f.write("x");
    f.close();
    let entries: ArrayList<DirEntry> = Os.scandir(dir);
    if (entries.size() != 1) {
        io::println("FAIL: Os.scandir size=" + Integer.toString(entries.size()));
    } else {
        io::println("PASS: Os.scandir returns DirEntry list");
    }
    f.delete();
    Dir_remove(dir);
}

public fn test_os_strerror(): void {
    let msg: string = Os.strerror(0);
    // strerror may return empty on some platforms; just verify it runs.
    io::println("PASS: Os.strerror executes without error");
}

public fn test_os_uname(): void {
    let name: string = Os.uname();
    // uname may return empty on some platforms; just verify it runs.
    io::println("PASS: Os.uname executes without error");
}

public fn run_all_os_tests(): void {
    io::println("=== Os.tr Tests ===");
    test_os_getEnv_setEnv();
    test_os_getEnv_missing();
    test_os_cpuCount();
    test_os_pid();
    test_os_getpid();
    test_os_userName();
    test_os_hostName();
    test_os_urandom();
    test_os_workingDir_getcwd();
    test_os_mkdir_remove();
    test_os_exists();
    test_os_listDir();
    test_os_rename();
    test_os_access_exists();
    test_os_stat();
    test_os_getFileSize();
    test_os_pathSeparator();
    test_os_separator();
    test_os_linesep();
    test_os_devNull();
    test_os_environ();
    test_os_environMap();
    test_os_scandir();
    test_os_strerror();
    test_os_uname();
}
