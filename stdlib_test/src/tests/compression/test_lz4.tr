public fn run_all_lz4_tests(): void {
    io::println("=== Lz4.tr Tests ===");
    test_compress_decompress_roundtrip();
    test_frameCompress_frameDecompress_roundtrip();
    test_compressBound_positive();
    test_versionNumber_callable();
    test_streamingCompress_returns_chunks();
    test_streamingDecompress_callable();
    test_xxhash32_callable();
    test_xxhash64_callable();
    test_frameinfo_construction();
    test_frameinfo_toString();
    test_highSpeedCompress_callable();
    test_highCompressionCompress_callable();
}
