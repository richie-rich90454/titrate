public fn test_frameinfo_construction(): void {
    let fi: FrameInfo = new FrameInfo(65536, 0, 1, 100, 0, 65536);
    if (!fi.hasContentChecksum()) {
        io::println("FAIL: FrameInfo.hasContentChecksum should be true for flag=1");
    } else {
        io::println("PASS: FrameInfo.hasContentChecksum works");
    }
    if (fi.hasContentSize()) {
        // contentSize=100 > 0, so true
        io::println("PASS: FrameInfo.hasContentSize works");
    } else {
        io::println("FAIL: FrameInfo.hasContentSize should be true for contentSize=100");
    }
    if (fi.hasDictId()) {
        io::println("FAIL: FrameInfo.hasDictId should be false for dictId=0");
    } else {
        io::println("PASS: FrameInfo.hasDictId false for dictId=0");
    }
}

public fn test_frameinfo_toString(): void {
    let fi: FrameInfo = new FrameInfo(4096, 1, 0, 0, 0, 4096);
    let s: string = fi.toString();
    if (String.indexOf(s, "FrameInfo") < 0 || String.indexOf(s, "4096") < 0) {
        io::println("FAIL: FrameInfo.toString = " + s);
    } else {
        io::println("PASS: FrameInfo.toString works");
    }
}

public fn test_highSpeedCompress_callable(): void {
    var threw: bool = false;
    try {
        let result: string = highSpeedCompress("data to compress quickly");
        if (result == null) {
            io::println("FAIL: highSpeedCompress returned null");
        }
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("PASS: highSpeedCompress invoked (native may be unavailable)");
    } else {
        io::println("PASS: highSpeedCompress returns a string");
    }
}

