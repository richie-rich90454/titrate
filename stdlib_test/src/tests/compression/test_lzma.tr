public fn run_all_lzma_tests(): void {
    io::println("=== Lzma.tr Tests ===");
    test_compress_decompress_roundtrip();
    test_compress_with_format_preset();
    test_compress_empty_string();
    test_decompress_pass_through_header();
    test_detectFormat_xz_magic();
    test_detectFormat_lzma_magic();
    test_detectFormat_pass_through();
    test_detectFormat_unknown();
    test_detectFormat_short_input();
    test_isLzma_true_for_xz();
    test_isLzma_true_for_lzma_alone();
    test_isLzma_false_for_passthrough();
    test_isLzma_false_for_plain();
    test_LZMACompressor_init();
    test_LZMACompressor_compress_returns_empty();
    test_LZMACompressor_flush_roundtrip();
    test_LZMACompressor_throws_after_flush();
    test_LZMACompressor_flush_idempotent();
    test_LZMACompressor_initWithFormat();
    test_LZMADecompressor_init();
    test_LZMADecompressor_initWithFormat();
