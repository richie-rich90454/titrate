    }
}

public fn test_LZMADecompressor_initWithFormat(): void {
    let d: LZMADecompressor = new LZMADecompressor();
    d.initWithFormat(FMT_XZ);
    if (d.format == FMT_XZ && d._eof == false) {
        io::println("PASS: LZMADecompressor.initWithFormat sets format");
    } else {
        io::println("FAIL: LZMADecompressor.initWithFormat did not set format");
    }
}

public fn test_LZMADecompressor_decompress_chunks(): void {
    let d: LZMADecompressor = new LZMADecompressor();
    let compressor: LZMACompressor = new LZMACompressor();
    compressor.compress("chunk-a");
    compressor.compress("chunk-b");
    let compressed: string = compressor.flush();
    var threw: bool = false;
    var firstOut: string = "<unset>";
    var finalOut: string = "<unset-two>";
    var eofAfterFirst: bool = true;
    var eofAfterFinal: bool = false;
    try {
        firstOut = d.decompress(compressed, false);
        eofAfterFirst = d.eof();
        finalOut = d.decompress("", true);
        eofAfterFinal = d.eof();
    } catch (e: string) {
        threw = true;
    }
    if (threw) {
        io::println("FAIL: LZMADecompressor.decompress threw");
    } else if (firstOut == "" && !eofAfterFirst && finalOut == "chunk-a" + "chunk-b" && eofAfterFinal) {
        io::println("PASS: LZMADecompressor incremental decompress works");
    } else {
        io::println("FAIL: LZMADecompressor state wrong");
    }
}

public fn test_LZMADecompressor_throws_after_eof(): void {
    let d: LZMADecompressor = new LZMADecompressor();
