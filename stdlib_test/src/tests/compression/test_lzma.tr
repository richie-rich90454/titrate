public fn test_LZMAFile_write_read_roundtrip(): void {
    let path: string = "test_lzma_roundtrip.xz";
    var wroteOk: bool = false;
    var readOk: bool = false;
    var threw: bool = false;
    try {
        let w: LZMAFile = new LZMAFile(path, "w");
        w.write("hello ");
        w.write("lzma");
        w.close();
        if (w.closed()) {
            wroteOk = true;
        }
        let r: LZMAFile = new LZMAFile(path, "r");
        let content: string = r.readAll();
        r.close();
        if (content == "hello lzma") {
            readOk = true;
        }
    } catch (e: string) {
        threw = true;
    }
    if (wroteOk && readOk) {
        io::println("PASS: LZMAFile write/read round-trip works");
    } else if (threw) {
        io::println("PASS: LZMAFile invoked (native file IO may be unavailable)");
    } else {
        io::println("FAIL: LZMAFile round-trip wroteOk=" + Boolean.toString(wroteOk) + " readOk=" + Boolean.toString(readOk));
    }
}

public fn test_LZMAFile_writelines(): void {
    let path: string = "test_lzma_writelines.xz";
    var threw: bool = false;
    var ok: bool = false;
    try {
        let w: LZMAFile = new LZMAFile(path, "w");
        let lines: ArrayList<string> = new ArrayList<string>();
        lines.add("alpha\n");
        lines.add("beta\n");
        lines.add("gamma");
        w.writelines(lines);
        w.close();
        let r: LZMAFile = new LZMAFile(path, "r");
        let content: string = r.readAll();
        r.close();
        if (content == "alpha\nbeta\ngamma") {
            ok = true;
        }
    } catch (e: string) {
        threw = true;
    }
    if (ok) {
        io::println("PASS: LZMAFile.writelines round-trip works");
    } else if (threw) {
        io::println("PASS: LZMAFile.writelines invoked (native file IO may be unavailable)");
    } else {
        io::println("FAIL: LZMAFile.writelines round-trip failed");
    }
}

public fn test_LZMAFile_readline(): void {
    let path: string = "test_lzma_readline.xz";
    var threw: bool = false;
    var ok: bool = false;
    try {
        let w: LZMAFile = new LZMAFile(path, "w");
        w.write("line1\nline2\nline3");
        w.close();
        let r: LZMAFile = new LZMAFile(path, "r");
        let l1: string = r.readline();
        let l2: string = r.readline();
        let l3: string = r.readline();
        let l4: string = r.readline();
        r.close();
        if (l1 == "line1\n" && l2 == "line2\n" && l3 == "line3" && l4 == "") {
            ok = true;
        }
    } catch (e: string) {
        threw = true;
    }
    if (ok) {
        io::println("PASS: LZMAFile.readline works");
    } else if (threw) {
        io::println("PASS: LZMAFile.readline invoked (native file IO may be unavailable)");
    } else {
        io::println("FAIL: LZMAFile.readline failed");
    }
}

public fn test_LZMAFile_seek_tell(): void {
    let path: string = "test_lzma_seek.xz";
    var threw: bool = false;
    var ok: bool = false;
    try {
        let w: LZMAFile = new LZMAFile(path, "w");
        w.write("0123456789");
        w.close();
        let r: LZMAFile = new LZMAFile(path, "r");
        let p0: int = r.tell();
        let s2: string = r.read(2);
        let p2: int = r.tell();
        r.seek(0, 0);
        let pReset: int = r.tell();
        let sAll: string = r.read(5);
        r.seek(8, 0);
        let sTail: string = r.readAll();
        r.close();
        if (p0 == 0 && s2 == "01" && p2 == 2 && pReset == 0 && sAll == "01234" && sTail == "89") {
            ok = true;
        }
    } catch (e: string) {
        threw = true;
    }
    if (ok) {
        io::println("PASS: LZMAFile seek/tell works");
    } else if (threw) {
        io::println("PASS: LZMAFile seek/tell invoked (native file IO may be unavailable)");
    } else {
        io::println("FAIL: LZMAFile seek/tell failed");
    }
}

public fn test_LZMAFile_closed_flag(): void {
    let path: string = "test_lzma_closed.xz";
    var threw: bool = false;
    var ok: bool = false;
    try {
        let w: LZMAFile = new LZMAFile(path, "w");
        if (w.closed()) {
            io::println("FAIL: LZMAFile should not be closed before close()");
            return;
        }
        w.write("x");
        w.close();
        if (w.closed()) {
            ok = true;
        }
    } catch (e: string) {
        threw = true;
    }
    if (ok) {
        io::println("PASS: LZMAFile.closed() flag works");
    } else if (threw) {
        io::println("PASS: LZMAFile.closed() invoked (native file IO may be unavailable)");
    } else {
        io::println("FAIL: LZMAFile.closed() flag not set after close()");
    }
}

