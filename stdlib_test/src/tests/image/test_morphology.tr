// Test file for image/Morphology.tr
// Exercises StructuringElement, squareSE, crossSE, dilate, erode,
// opening, closing, gradient, topHat, blackHat, and Image-based variants.
import tt::image::Morphology;
import tt::image::Image;
import tt::image::Kernel;
import tt::util::ArrayList;
import tt::lang::Integer;

fn absDiff(a: double, b: double): double {
    let d: double = a - b;
    if (d < 0.0) { return -d; }
    return d;
}

fn makeImage(rows: int, cols: int, value: double): ArrayList<ArrayList<double>> {
    let img: ArrayList<ArrayList<double>> = new ArrayList<ArrayList<double>>();
    var i: int = 0;
    while (i < rows) {
        let row: ArrayList<double> = new ArrayList<double>();
        var j: int = 0;
        while (j < cols) {
            row.add(value);
            j = j + 1;
        }
        img.add(row);
        i = i + 1;
    }
    return img;
}

public fn test_se_init(): void {
    let se: StructuringElement = new StructuringElement(3, 3);
    if (se.width != 3 || se.height != 3) {
        io::println("FAIL: StructuringElement dimensions");
    } else if (se.data.size() != 3 || se.data.get(0).size() != 3) {
        io::println("FAIL: StructuringElement data shape");
    } else if (!se.get(0, 0) || !se.get(2, 2)) {
        io::println("FAIL: StructuringElement default not all true");
    } else {
        io::println("PASS: StructuringElement init works");
    }
}

public fn test_se_set_get(): void {
    let se: StructuringElement = new StructuringElement(3, 3);
    se.set(1, 1, false);
    if (se.get(1, 1)) {
        io::println("FAIL: StructuringElement set/get");
    } else {
        io::println("PASS: StructuringElement set/get works");
    }
}

public fn test_squareSE(): void {
    let se: StructuringElement = squareSE(3);
    if (se.width != 3 || se.height != 3) {
        io::println("FAIL: squareSE dimensions");
    } else if (!se.get(0, 0) || !se.get(2, 2)) {
        io::println("FAIL: squareSE all true");
    } else {
        io::println("PASS: squareSE works");
    }
}

public fn test_crossSE(): void {
    let se: StructuringElement = crossSE(3);
    // Center row and column should be true, corners false
    if (!se.get(1, 1) || !se.get(0, 1) || !se.get(1, 0)) {
        io::println("FAIL: crossSE cross true");
    } else if (se.get(0, 0) || se.get(0, 2) || se.get(2, 0) || se.get(2, 2)) {
        io::println("FAIL: crossSE corners not false");
    } else {
        io::println("PASS: crossSE works");
    }
}

public fn test_dilate_uniform(): void {
    let img: ArrayList<ArrayList<double>> = makeImage(3, 3, 100.0);
    let se: StructuringElement = squareSE(3);
    let out: ArrayList<ArrayList<double>> = dilate(img, se);
    if (out.size() != 3 || out.get(0).size() != 3) {
        io::println("FAIL: dilate output shape");
    } else if (absDiff(out.get(1).get(1), 100.0) > 1e-9) {
        io::println("FAIL: dilate uniform center");
    } else {
        io::println("PASS: dilate uniform works");
    }
}

public fn test_dilate_grows_bright(): void {
    // Single bright pixel surrounded by dark should dilate to bright center
    let img: ArrayList<ArrayList<double>> = makeImage(3, 3, 0.0);
    img.get(1).set(1, 255.0);
    let se: StructuringElement = squareSE(3);
    let out: ArrayList<ArrayList<double>> = dilate(img, se);
    if (absDiff(out.get(1).get(1), 255.0) > 1e-9) {
        io::println("FAIL: dilate center not bright");
    } else {
        io::println("PASS: dilate center bright");
    }
}

public fn test_erode_uniform(): void {
    let img: ArrayList<ArrayList<double>> = makeImage(3, 3, 100.0);
    let se: StructuringElement = squareSE(3);
    let out: ArrayList<ArrayList<double>> = erode(img, se);
    if (absDiff(out.get(1).get(1), 100.0) > 1e-9) {
        io::println("FAIL: erode uniform center");
    } else {
        io::println("PASS: erode uniform works");
    }
}

public fn test_erode_shrinks_bright(): void {
    // Bright pixel at corner gets eroded by darker neighbors
    let img: ArrayList<ArrayList<double>> = makeImage(3, 3, 255.0);
    let se: StructuringElement = squareSE(3);
    let out: ArrayList<ArrayList<double>> = erode(img, se);
    // Interior should remain 255, edges should be lower (border doesn't have all neighbors)
    if (absDiff(out.get(1).get(1), 255.0) > 1e-9) {
        io::println("FAIL: erode interior not 255");
    } else {
        io::println("PASS: erode interior = 255");
    }
}

public fn test_opening_shape(): void {
    let img: ArrayList<ArrayList<double>> = makeImage(5, 5, 200.0);
    let se: StructuringElement = squareSE(3);
    let out: ArrayList<ArrayList<double>> = opening(img, se);
    if (out.size() != 5 || out.get(0).size() != 5) {
        io::println("FAIL: opening shape");
    } else {
        io::println("PASS: opening shape preserved");
    }
}

