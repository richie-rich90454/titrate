public fn test_blackHat_shape(): void {
    let img: ArrayList<ArrayList<double>> = makeImage(5, 5, 100.0);
    let se: StructuringElement = squareSE(3);
    let out: ArrayList<ArrayList<double>> = blackHat(img, se);
    if (out.size() != 5 || out.get(0).size() != 5) {
