        io::println("PASS: closing shape preserved");
    }
}

public fn test_gradient_shape(): void {
    let img: ArrayList<ArrayList<double>> = makeImage(5, 5, 200.0);
    let se: StructuringElement = squareSE(3);
    let out: ArrayList<ArrayList<double>> = gradient(img, se);
    if (out.size() != 5 || out.get(0).size() != 5) {
        io::println("FAIL: gradient shape");
    } else {
        io::println("PASS: gradient shape preserved");
    }
}

public fn test_gradient_uniform_zero(): void {
    let img: ArrayList<ArrayList<double>> = makeImage(5, 5, 100.0);
    let se: StructuringElement = squareSE(3);
    let out: ArrayList<ArrayList<double>> = gradient(img, se);
    // Interior gradient should be 0 for uniform image
    if (absDiff(out.get(2).get(2), 0.0) > 1e-9) {
        io::println("FAIL: gradient interior not zero");
    } else {
        io::println("PASS: gradient interior zero on uniform image");
    }
}

