public fn test_dilateImage(): void {
    let img: Image = new Image(3, 3, 1);
    img.setPixel(1, 1, 0, 255.0);
    let k: Kernel = new Kernel(3, 3);
    k.set(0, 0, 1.0); k.set(0, 1, 1.0); k.set(0, 2, 1.0);
    k.set(1, 0, 1.0); k.set(1, 1, 1.0); k.set(1, 2, 1.0);
    k.set(2, 0, 1.0); k.set(2, 1, 1.0); k.set(2, 2, 1.0);
    let out: Image = dilateImage(img, k);
    if (out.width != 3 || out.height != 3) {
        io::println("FAIL: dilateImage dimensions");
    } else if (absDiff(out.getPixel(1, 1, 0), 255.0) > 1e-9) {
        io::println("FAIL: dilateImage center");
    } else {
        io::println("PASS: dilateImage works");
    }
}

public fn test_erodeImage(): void {
    let img: Image = new Image(3, 3, 1);
    var i: int = 0;
    while (i < 3) {
        var j: int = 0;
        while (j < 3) {
            img.setPixel(i, j, 0, 255.0);
            j = j + 1;
        }
        i = i + 1;
    }
    let k: Kernel = new Kernel(3, 3);
    k.set(0, 0, 1.0); k.set(0, 1, 1.0); k.set(0, 2, 1.0);
    k.set(1, 0, 1.0); k.set(1, 1, 1.0); k.set(1, 2, 1.0);
    k.set(2, 0, 1.0); k.set(2, 1, 1.0); k.set(2, 2, 1.0);
    let out: Image = erodeImage(img, k);
    if (absDiff(out.getPixel(1, 1, 0), 255.0) > 1e-9) {
        io::println("FAIL: erodeImage center not 255");
    } else {
        io::println("PASS: erodeImage works");
    }
}

public fn test_gradientImage(): void {
    let img: Image = new Image(3, 3, 1);
    var i: int = 0;
    while (i < 3) {
        var j: int = 0;
        while (j < 3) {
            img.setPixel(i, j, 0, 100.0);
            j = j + 1;
        }
        i = i + 1;
    }
    let k: Kernel = new Kernel(3, 3);
    k.set(0, 0, 1.0); k.set(0, 1, 1.0); k.set(0, 2, 1.0);
    k.set(1, 0, 1.0); k.set(1, 1, 1.0); k.set(1, 2, 1.0);
    k.set(2, 0, 1.0); k.set(2, 1, 1.0); k.set(2, 2, 1.0);
    let out: Image = gradientImage(img, k);
    if (absDiff(out.getPixel(1, 1, 0), 0.0) > 1e-9) {
        io::println("FAIL: gradientImage interior not zero");
    } else {
        io::println("PASS: gradientImage works on uniform image");
    }
}

public fn run_all_morphology_tests(): void {
    io::println("=== image/Morphology.tr Tests ===");
    test_se_init();
    test_se_set_get();
    test_squareSE();
    test_crossSE();
    test_dilate_uniform();
    test_dilate_grows_bright();
    test_erode_uniform();
    test_erode_shrinks_bright();
    test_opening_shape();
    test_closing_shape();
    test_gradient_shape();
    test_gradient_uniform_zero();
    test_topHat_shape();
    test_blackHat_shape();
    test_dilateImage();
    test_erodeImage();
    test_gradientImage();
}
