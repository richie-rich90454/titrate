// Test file for image/Transform.tr
// Exercises Mat3, identity, translation, scaling, rotation, shear,
// warpAffine, and shearImage.
import tt::image::Transform;
import tt::image::Image;
import tt::util::ArrayList;
import tt::math::MathTrig;

fn absDiff(a: double, b: double): double {
    let d: double = a - b;
    if (d < 0.0) { return -d; }
    return d;
}

fn makeImage(rows: int, cols: int, value: double): ArrayList<ArrayList<double>> {
    let img: ArrayList<ArrayList<double>> = new ArrayList<ArrayList<double>>();
    var i: int = 0;
    while (i < rows) {
        let row: ArrayList<double> = new ArrayList<double>();
        var j: int = 0;
        while (j < cols) {
            row.add(value);
            j = j + 1;
        }
        img.add(row);
        i = i + 1;
    }
    return img;
}

public fn test_mat3_init_identity(): void {
    let m: Mat3 = new Mat3();
    if (absDiff(m.m00, 1.0) > 1e-9 || absDiff(m.m11, 1.0) > 1e-9 || absDiff(m.m22, 1.0) > 1e-9) {
        io::println("FAIL: Mat3 init diagonal not 1");
    } else if (absDiff(m.m01, 0.0) > 1e-9 || absDiff(m.m02, 0.0) > 1e-9) {
        io::println("FAIL: Mat3 init off-diagonal not 0");
    } else {
        io::println("PASS: Mat3 init is identity");
    }
}

public fn test_identity(): void {
    let m: Mat3 = identity();
    if (absDiff(m.m00, 1.0) > 1e-9 || absDiff(m.m11, 1.0) > 1e-9) {
        io::println("FAIL: identity diagonal");
    } else {
        io::println("PASS: identity works");
    }
}

public fn test_translation(): void {
    let m: Mat3 = translation(5.0, 7.0);
    if (absDiff(m.m02, 5.0) > 1e-9 || absDiff(m.m12, 7.0) > 1e-9) {
        io::println("FAIL: translation values");
    } else if (absDiff(m.m00, 1.0) > 1e-9 || absDiff(m.m11, 1.0) > 1e-9) {
        io::println("FAIL: translation diagonal");
    } else {
        io::println("PASS: translation works");
    }
}

public fn test_scaling(): void {
    let m: Mat3 = scaling(2.0, 3.0);
    if (absDiff(m.m00, 2.0) > 1e-9 || absDiff(m.m11, 3.0) > 1e-9) {
        io::println("FAIL: scaling values");
    } else {
        io::println("PASS: scaling works");
    }
}

public fn test_rotation(): void {
    let m: Mat3 = rotation(0.0);
    // Rotation by 0 should be identity
    if (absDiff(m.m00, 1.0) > 1e-9 || absDiff(m.m11, 1.0) > 1e-9 || absDiff(m.m01, 0.0) > 1e-9) {
        io::println("FAIL: rotation 0 not identity");
    } else {
        io::println("PASS: rotation 0 is identity");
    }
}

public fn test_rotation_90(): void {
    let m: Mat3 = rotation(MathTrig.PI() / 2.0);
    // cos(90) ~ 0, sin(90) ~ 1
    if (absDiff(m.m00, 0.0) > 1e-9 || absDiff(m.m11, 0.0) > 1e-9) {
        io::println("FAIL: rotation 90 diagonal");
    } else if (absDiff(m.m01, -1.0) > 1e-9 || absDiff(m.m10, 1.0) > 1e-9) {
        io::println("FAIL: rotation 90 off-diagonal");
    } else {
        io::println("PASS: rotation 90 works");
    }
}

public fn test_shear(): void {
    let m: Mat3 = shear(0.5, 0.7);
    if (absDiff(m.m01, 0.5) > 1e-9 || absDiff(m.m10, 0.7) > 1e-9) {
        io::println("FAIL: shear values");
    } else if (absDiff(m.m00, 1.0) > 1e-9 || absDiff(m.m11, 1.0) > 1e-9) {
        io::println("FAIL: shear diagonal");
    } else {
        io::println("PASS: shear works");
    }
}

public fn test_transform_point_identity(): void {
    let m: Mat3 = identity();
    let p: ArrayList<double> = m.transformPoint(3.0, 4.0);
    if (absDiff(p.get(0), 3.0) > 1e-9 || absDiff(p.get(1), 4.0) > 1e-9) {
        io::println("FAIL: transformPoint identity");
    } else {
        io::println("PASS: transformPoint identity works");
    }
}

public fn test_transform_point_translation(): void {
    let m: Mat3 = translation(10.0, 20.0);
    let p: ArrayList<double> = m.transformPoint(1.0, 2.0);
    if (absDiff(p.get(0), 11.0) > 1e-9 || absDiff(p.get(1), 22.0) > 1e-9) {
        io::println("FAIL: transformPoint translation");
    } else {
        io::println("PASS: transformPoint translation works");
    }
}

public fn test_transform_point_scaling(): void {
    let m: Mat3 = scaling(2.0, 3.0);
    let p: ArrayList<double> = m.transformPoint(4.0, 5.0);
    if (absDiff(p.get(0), 8.0) > 1e-9 || absDiff(p.get(1), 15.0) > 1e-9) {
        io::println("FAIL: transformPoint scaling");
    } else {
        io::println("PASS: transformPoint scaling works");
    }
}

public fn test_mat3_mul_identity(): void {
    let m: Mat3 = translation(5.0, 7.0);
    let id: Mat3 = identity();
    let product: Mat3 = m.mul(id);
    if (absDiff(product.m02, 5.0) > 1e-9 || absDiff(product.m12, 7.0) > 1e-9) {
        io::println("FAIL: Mat3 mul identity");
    } else {
        io::println("PASS: Mat3 mul identity works");
    }
}

public fn test_mat3_mul_compose(): void {
    // translation then translation should compose
    let t1: Mat3 = translation(3.0, 0.0);
    let t2: Mat3 = translation(0.0, 4.0);
    let product: Mat3 = t1.mul(t2);
    let p: ArrayList<double> = product.transformPoint(0.0, 0.0);
    if (absDiff(p.get(0), 3.0) > 1e-9 || absDiff(p.get(1), 4.0) > 1e-9) {
        io::println("FAIL: Mat3 mul compose");
    } else {
        io::println("PASS: Mat3 mul compose works");
    }
}

public fn test_warpAffine_shape(): void {
    let img: ArrayList<ArrayList<double>> = makeImage(3, 3, 100.0);
    let t: Mat3 = identity();
    let out: ArrayList<ArrayList<double>> = warpAffine(img, t, 3, 3);
    if (out.size() != 3 || out.get(0).size() != 3) {
        io::println("FAIL: warpAffine shape");
    } else {
        io::println("PASS: warpAffine shape preserved");
    }
}

public fn test_warpAffine_identity(): void {
    let img: ArrayList<ArrayList<double>> = makeImage(3, 3, 100.0);
    let t: Mat3 = identity();
    let out: ArrayList<ArrayList<double>> = warpAffine(img, t, 3, 3);
    // Center pixel should be preserved by identity
    if (absDiff(out.get(1).get(1), 100.0) > 1e-9) {
        io::println("FAIL: warpAffine identity center");
    } else {
        io::println("PASS: warpAffine identity center preserved");
    }
}

public fn test_shearImage_shape(): void {
    let img: Image = new Image(4, 4, 1);
    var i: int = 0;
    while (i < 4) {
        var j: int = 0;
        while (j < 4) {
            img.setPixel(i, j, 0, 100.0);
            j = j + 1;
        }
        i = i + 1;
    }
    let out: Image = shearImage(img, 0.0, 0.0);
    if (out.width != 4 || out.height != 4) {
        io::println("FAIL: shearImage shape");
    } else {
        io::println("PASS: shearImage shape preserved");
    }
}

public fn test_shearImage_zero(): void {
    let img: Image = new Image(4, 4, 1);
    img.setPixel(1, 1, 0, 200.0);
    let out: Image = shearImage(img, 0.0, 0.0);
    // With zero shear, the transform is identity, so (1,1) maps to (1,1)
    if (absDiff(out.getPixel(1, 1, 0), 200.0) > 1e-9) {
        io::println("FAIL: shearImage zero not identity");
    } else {
        io::println("PASS: shearImage zero acts as identity");
    }
}

public fn run_all_transform_tests(): void {
    io::println("=== image/Transform.tr Tests ===");
    test_mat3_init_identity();
    test_identity();
    test_translation();
    test_scaling();
    test_rotation();
    test_rotation_90();
    test_shear();
    test_transform_point_identity();
    test_transform_point_translation();
    test_transform_point_scaling();
    test_mat3_mul_identity();
    test_mat3_mul_compose();
    test_warpAffine_shape();
    test_warpAffine_identity();
    test_shearImage_shape();
    test_shearImage_zero();
}
