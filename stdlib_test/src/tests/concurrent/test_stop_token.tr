public fn test_stop_source_with_callback_fires_on_request(): void {
    let ss: StopSource = StopToken.stopSource();
    let token: StopToken = ss.getToken();
    var called: bool = false;
    let cb: StopCallback = token.register(fn(): void { called = true; });
    ss.requestStop();
    if (!called) {
        io::println("FAIL: callback should fire after requestStop");
    } else {
        io::println("PASS: StopSource requestStop fires callbacks");
    }
}

public fn run_all_stop_token_tests(): void {
    io::println("=== StopToken.tr Tests ===");
    test_stop_state_init();
    test_stop_state_request_stop();
    test_stop_state_request_stop_once();
    test_stop_state_register_callback();
    test_stop_state_register_after_stop();
    test_stop_state_deregister();
    test_stop_state_deregister_invalid();
    test_stop_state_callback_count();
    test_stop_source_init();
    test_stop_source_init_empty();
    test_stop_source_request_stop();
    test_stop_source_empty_request_stop();
    test_stop_source_get_token();
    test_stop_source_empty_get_token();
    test_stop_source_state();
    test_stop_token_init();
    test_stop_token_stop_requested();
    test_stop_token_register();
    test_stop_token_register_after_stop();
    test_stop_token_stop_possible();
    test_stop_token_equals();
    test_stop_token_equals_null();
    test_stop_token_state();
    test_stop_callback_deregister();
    test_stop_callback_deregister_twice();
    test_stop_source_factory();
    test_stop_token_factory();
    test_stop_requested_func();
    test_stop_requested_null();
    test_stop_possible_func();
    test_stop_possible_null();
    test_stop_source_with_callback_fires_on_request();
}
