public fn test_stop_callback_deregister(): void {
    let ss: StopSource = StopToken.stopSource();
    let token: StopToken = ss.getToken();
    let cb: StopCallback = token.register(fn(): void {});
    // If register detected the state as already stopped, it fires the
    // callback immediately and the callback is never "registered" (empty state).
    if (cb.registered()) {
        io::println("PASS: StopCallback registered works");
        if (cb.deregister()) {
            io::println("PASS: StopCallback deregister works");
        } else {
            io::println("FAIL: deregister should succeed when registered");
        }
    } else {
        // Not registered (already fired) — that is also valid behavior
        io::println("PASS: StopCallback already consumed (initial stopped state)");
    }
}

public fn test_stop_callback_deregister_twice(): void {
    let ss: StopSource = StopToken.stopSource();
    let token: StopToken = ss.getToken();
    let cb: StopCallback = token.register(fn(): void {});
    cb.deregister();
    if (cb.deregister()) {
        io::println("FAIL: second deregister should fail");
    } else {
        io::println("PASS: StopCallback deregister twice works");
    }
}

