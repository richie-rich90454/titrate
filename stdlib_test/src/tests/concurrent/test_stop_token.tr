    }
}

public fn test_stop_token_register_after_stop(): void {
    let ss: StopSource = StopToken.stopSource();
    let token: StopToken = ss.getToken();
    ss.requestStop();
    var called: bool = false;
    let cb: StopCallback = token.register(fn(): void { called = true; });
    if (cb == null) {
        io::println("FAIL: register after stop returned null");
    } else if (!called) {
        io::println("FAIL: callback should fire immediately");
    } else {
        io::println("PASS: StopToken register after stop fires immediately");
    }
}

