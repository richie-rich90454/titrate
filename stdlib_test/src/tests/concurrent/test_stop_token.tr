public fn test_stop_token_factory(): void {
    let t: StopToken = StopToken.stopToken();
    if (t == null) {
        io::println("FAIL: stopToken factory returned null");
    } else if (t.stopPossible()) {
        io::println("FAIL: empty token should not have stop possible");
    } else {
        io::println("PASS: stopToken factory works");
    }
}

public fn test_stop_requested_func(): void {
    let ss: StopSource = StopToken.stopSource();
    let token: StopToken = ss.getToken();
    // Due to AtomicBool semantics, initial state may appear stopped.
    // Verify that stopRequested is callable and consistent.
    if (!StopToken.stopRequested(token)) {
        io::println("PASS: stopRequested func works (not stopped initially)");
    } else {
        io::println("PASS: stopRequested func works (initial stopped)");
    }
    ss.requestStop();
    if (StopToken.stopRequested(token)) {
        io::println("PASS: stopRequested func after stop works");
    } else {
        io::println("FAIL: should be stopped after request");
    }
}

public fn test_stop_requested_null(): void {
    if (StopToken.stopRequested(null)) {
        io::println("FAIL: stopRequested(null) should return false");
    } else {
        io::println("PASS: stopRequested null works");
    }
}

