// Test file for concurrent/Asyncio.tr
// Exercises EventLoop, Task, TimerHandle, Lock, Semaphore, Queue, StreamReader,
// StreamWriter, TcpTransport, and module-level API functions.
import tt::concurrent::Asyncio;
import tt::concurrent::Future;
import tt::util::ArrayList;
import tt::lang::Variant;
import tt::lang::Integer;

public fn test_get_event_loop(): void {
    let loop: EventLoop = Asyncio.getEventLoop();
    if (loop == null) {
        io::println("FAIL: getEventLoop returned null");
    } else {
        io::println("PASS: getEventLoop returns a loop");
    }
}

public fn test_new_event_loop(): void {
    let loop: EventLoop = Asyncio.newEventLoop();
    if (loop == null) {
        io::println("FAIL: newEventLoop returned null");
    } else if (loop.isRunning()) {
        io::println("FAIL: new loop should not be running");
    } else {
        io::println("PASS: newEventLoop works");
    }
}

public fn test_set_event_loop(): void {
    let loop: EventLoop = Asyncio.newEventLoop();
    Asyncio.setEventLoop(loop);
    if (Asyncio.getEventLoop() != loop) {
        io::println("FAIL: setEventLoop did not persist");
    } else {
        io::println("PASS: setEventLoop works");
    }
}

public fn test_event_loop_run_until_complete(): void {
    let loop: EventLoop = Asyncio.newEventLoop();
    let result: int = loop.runUntilComplete<int>(fn(): int { return 42; });
    if (result != 42) {
        io::println("FAIL: runUntilComplete returned " + Integer.toString(result));
    } else {
        io::println("PASS: runUntilComplete works");
    }
}

public fn test_event_loop_create_task(): void {
    let loop: EventLoop = Asyncio.newEventLoop();
    let task: Task = loop.createTask<int>(fn(): int { return 7; });
    if (task == null) {
        io::println("FAIL: createTask returned null");
    } else if (task.id != 1) {
        io::println("FAIL: task.id wrong = " + Integer.toString(task.id));
    } else {
        io::println("PASS: createTask works");
    }
}

public fn test_task_is_done(): void {
    let loop: EventLoop = Asyncio.newEventLoop();
    let task: Task = loop.createTask<int>(fn(): int { return 1; });
    loop.runUntilComplete<int>(fn(): int { return 0; });
    if (!task.isDone()) {
        io::println("FAIL: task should be done");
    } else {
        io::println("PASS: task.isDone works");
    }
}

public fn test_task_get_result(): void {
    let loop: EventLoop = Asyncio.newEventLoop();
    let result: int = loop.runUntilComplete<int>(fn(): int { return 99; });
    if (result != 99) {
        io::println("FAIL: task result = " + Integer.toString(result));
    } else {
        io::println("PASS: task getResult works");
    }
}

public fn test_task_cancel(): void {
    let loop: EventLoop = Asyncio.newEventLoop();
    let task: Task = loop.createTask<int>(fn(): int { return 1; });
    task.cancel();
    if (!task.isCancelled()) {
        io::println("FAIL: task should be cancelled");
    } else {
        io::println("PASS: task cancel works");
    }
}

public fn test_task_add_done_callback(): void {
    let loop: EventLoop = Asyncio.newEventLoop();
    var called: bool = false;
    let task: Task = loop.createTask<int>(fn(): int {
        called = true;
        return 1;
    });
    task.addDoneCallback(fn(): void {
        io::println("done callback invoked");
    });
    loop.runUntilComplete<int>(fn(): int { return 0; });
    if (!called) {
        io::println("FAIL: task callback not called");
    } else {
        io::println("PASS: task addDoneCallback works");
    }
}

public fn test_task_is_cancelled(): void {
    let task: Task = new Task(1, fn(): Variant { return null; });
    if (task.isCancelled()) {
        io::println("FAIL: new task should not be cancelled");
    } else {
        io::println("PASS: Task.isCancelled initial works");
    }
    task.cancel();
    if (!task.isCancelled()) {
        io::println("FAIL: task should be cancelled after cancel");
    } else {
        io::println("PASS: Task.isCancelled after cancel works");
    }
}

public fn test_timer_handle_fire(): void {
    var fired: bool = false;
    let timer: TimerHandle = new TimerHandle(0, fn(): void { fired = true; });
    timer.fire();
    if (!fired) {
        io::println("FAIL: TimerHandle.fire did not invoke callback");
    } else {
        io::println("PASS: TimerHandle.fire works");
    }
}

public fn test_timer_handle_cancel(): void {
    var fired: bool = false;
    let timer: TimerHandle = new TimerHandle(0, fn(): void { fired = true; });
    timer.cancel();
    timer.fire();
    if (fired) {
        io::println("FAIL: cancelled timer should not fire");
    } else {
        io::println("PASS: TimerHandle.cancel works");
    }
}

public fn test_async_lock(): void {
    let lock: Asyncio.Lock = new Asyncio.Lock();
    if (lock.locked()) {
        io::println("FAIL: new lock should not be locked");
    } else {
        io::println("PASS: Lock initial unlocked works");
    }
    lock.acquire();
    if (!lock.locked()) {
        io::println("FAIL: lock should be locked after acquire");
    } else {
        io::println("PASS: Lock acquire works");
    }
    lock.release();
    if (lock.locked()) {
        io::println("FAIL: lock should be released");
    } else {
        io::println("PASS: Lock release works");
    }
}

public fn test_async_lock_with_lock(): void {
    let lock: Asyncio.Lock = new Asyncio.Lock();
    var executed: bool = false;
    lock.withLock(fn(): void { executed = true; });
    if (!executed) {
        io::println("FAIL: withLock did not execute func");
    } else if (lock.locked()) {
        io::println("FAIL: lock should be released after withLock");
    } else {
        io::println("PASS: Lock withLock works");
    }
}

public fn test_async_lock_double_release_throws(): void {
    let lock: Asyncio.Lock = new Asyncio.Lock();
    lock.acquire();
    lock.release();
    var caught: bool = false;
    try {
        lock.release();
    } catch (e: string) {
        caught = true;
    }
    if (!caught) {
        io::println("FAIL: double release should throw");
    } else {
        io::println("PASS: Lock double release throws");
    }
}

public fn test_async_semaphore(): void {
    let sem: Asyncio.Semaphore = new Asyncio.Semaphore(2);
    if (sem.value() != 2) {
        io::println("FAIL: Semaphore initial value = " + Integer.toString(sem.value()));
    } else {
        io::println("PASS: Semaphore init works");
    }
    sem.acquire();
    if (sem.value() != 1) {
        io::println("FAIL: Semaphore value after acquire = " + Integer.toString(sem.value()));
    } else {
        io::println("PASS: Semaphore acquire works");
    }
    sem.release();
    if (sem.value() != 2) {
        io::println("FAIL: Semaphore value after release = " + Integer.toString(sem.value()));
    } else {
        io::println("PASS: Semaphore release works");
    }
}

public fn test_async_semaphore_try_acquire(): void {
    let sem: Asyncio.Semaphore = new Asyncio.Semaphore(1);
    if (!sem.tryAcquire()) {
        io::println("FAIL: tryAcquire should succeed");
    } else if (sem.tryAcquire()) {
        io::println("FAIL: tryAcquire should fail on empty semaphore");
    } else {
        io::println("PASS: Semaphore tryAcquire works");
    }
}

public fn test_async_queue(): void {
    let q: Asyncio.Queue<int> = new Asyncio.Queue<int>();
    if (!q.empty()) {
        io::println("FAIL: new queue should be empty");
    } else if (q.qsize() != 0) {
        io::println("FAIL: new queue size should be 0");
    } else {
        io::println("PASS: Queue init works");
    }
    q.put(10);
    q.put(20);
    if (q.qsize() != 2) {
        io::println("FAIL: queue size after puts = " + Integer.toString(q.qsize()));
    } else {
        io::println("PASS: Queue put works");
    }
    let v1: int = q.get();
    if (v1 != 10) {
        io::println("FAIL: queue get first = " + Integer.toString(v1));
    } else {
        io::println("PASS: Queue get works");
    }
}

public fn test_async_queue_nowait(): void {
    let q: Asyncio.Queue<int> = new Asyncio.Queue<int>();
    let v: int = q.getNowait();
    if (v != null) {
        io::println("FAIL: getNowait on empty should return null");
    } else {
        io::println("PASS: Queue getNowait empty works");
    }
    q.putNowait(5);
    let v2: int = q.getNowait();
    if (v2 != 5) {
        io::println("FAIL: getNowait after putNowait = " + Integer.toString(v2));
    } else {
        io::println("PASS: Queue putNowait/getNowait works");
    }
}

public fn test_async_queue_full(): void {
    let q: Asyncio.Queue<int> = new Asyncio.Queue<int>();
    q.setMaxSize(2);
    if (!q.putNowait(1)) {
        io::println("FAIL: putNowait should succeed");
    } else if (!q.putNowait(2)) {
        io::println("FAIL: second putNowait should succeed");
    } else if (q.putNowait(3)) {
        io::println("FAIL: third putNowait should fail on full queue");
    } else {
        io::println("PASS: Queue full detection works");
    }
}

public fn test_async_queue_close(): void {
    let q: Asyncio.Queue<int> = new Asyncio.Queue<int>();
    q.close();
    if (!q.isClosed()) {
        io::println("FAIL: queue should be closed");
    } else {
        io::println("PASS: Queue close works");
    }
    var caught: bool = false;
    try {
        q.put(1);
    } catch (e: string) {
        caught = true;
    }
    if (!caught) {
        io::println("FAIL: put on closed queue should throw");
    } else {
        io::println("PASS: Queue put on closed throws");
    }
}

public fn test_run_simple(): void {
    let result: int = Asyncio.run<int>(fn(): int { return 42; });
    if (result != 42) {
        io::println("FAIL: run returned " + Integer.toString(result));
    } else {
        io::println("PASS: Asyncio.run works");
    }
}

public fn test_create_task_module(): void {
    let task: Task = Asyncio.createTask<int>(fn(): int { return 1; });
    if (task == null) {
        io::println("FAIL: createTask returned null");
    } else {
        io::println("PASS: Asyncio.createTask works");
    }
}

public fn test_sleep(): void {
    // Just verify it doesn't crash
    Asyncio.sleep(0.001);
    io::println("PASS: Asyncio.sleep works");
}

public fn test_call_soon(): void {
    var called: bool = false;
    Asyncio.callSoon(fn(): void { called = true; });
    if (!called) {
        io::println("FAIL: callSoon callback not invoked");
    } else {
        io::println("PASS: Asyncio.callSoon works");
    }
}

public fn test_call_later(): void {
    var called: bool = false;
    let timer: TimerHandle = Asyncio.callLater(1, fn(): void { called = true; });
    if (timer == null) {
        io::println("FAIL: callLater returned null");
    } else {
        io::println("PASS: Asyncio.callLater works");
    }
}

public fn test_event_loop_stop(): void {
    let loop: EventLoop = Asyncio.newEventLoop();
    loop.stop();
    io::println("PASS: EventLoop.stop works");
}

public fn test_event_loop_iteration(): void {
    let loop: EventLoop = Asyncio.newEventLoop();
    if (loop.iteration() != 0) {
        io::println("FAIL: initial iteration should be 0");
    } else {
        io::println("PASS: EventLoop.iteration works");
    }
}

public fn test_timer_handle_cancelled(): void {
    let timer: TimerHandle = new TimerHandle(100, fn(): void {});
    if (timer.cancelled) {
        io::println("FAIL: new timer should not be cancelled");
    } else {
        io::println("PASS: TimerHandle cancelled default works");
    }
    timer.cancel();
    if (!timer.cancelled) {
        io::println("FAIL: timer should be cancelled after cancel");
    } else {
        io::println("PASS: TimerHandle cancelled after cancel works");
    }
}

public fn test_stream_reader_defaults(): void {
    let sr: StreamReader = new StreamReader(-1);
    if (sr.atEof()) {
        io::println("FAIL: new StreamReader should not be at EOF");
    } else {
        io::println("PASS: StreamReader defaults work");
    }
}

public fn test_stream_writer_defaults(): void {
    let sw: StreamWriter = new StreamWriter(-1);
    if (sw.isClosed()) {
        io::println("FAIL: new StreamWriter should not be closed");
    } else {
        io::println("PASS: StreamWriter defaults work");
    }
}

public fn test_tcp_transport_defaults(): void {
    let t: TcpTransport = new TcpTransport();
    if (t.isConnected()) {
        io::println("FAIL: new TcpTransport should not be connected");
    } else if (t.getHandle() != -1) {
        io::println("FAIL: new TcpTransport handle should be -1");
    } else {
        io::println("PASS: TcpTransport defaults work");
    }
}

public fn run_all_asyncio_tests(): void {
    io::println("=== Asyncio.tr Tests ===");
    test_get_event_loop();
    test_new_event_loop();
    test_set_event_loop();
    test_event_loop_run_until_complete();
    test_event_loop_create_task();
    test_task_is_done();
    test_task_get_result();
    test_task_cancel();
    test_task_add_done_callback();
    test_task_is_cancelled();
    test_timer_handle_fire();
    test_timer_handle_cancel();
    test_async_lock();
    test_async_lock_with_lock();
    test_async_lock_double_release_throws();
    test_async_semaphore();
    test_async_semaphore_try_acquire();
    test_async_queue();
    test_async_queue_nowait();
    test_async_queue_full();
    test_async_queue_close();
    test_run_simple();
    test_create_task_module();
    test_sleep();
    test_call_soon();
    test_call_later();
    test_event_loop_stop();
    test_event_loop_iteration();
    test_timer_handle_cancelled();
    test_stream_reader_defaults();
    test_stream_writer_defaults();
    test_tcp_transport_defaults();
}
