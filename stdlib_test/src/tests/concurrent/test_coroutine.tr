// Test for Coroutine — basic object construction
import tt::concurrent::Coroutine;

public fn test_coroutine_init(): void {
    let h = Coroutine.noopCoroutine();
    if (h == null) {
        io::println("FAIL: noopCoroutine returned null");
    } else {
        io::println("PASS: Coroutine init works");
    }
}

public fn run_all_coroutine_tests(): void {
    io::println("=== Coroutine.tr Tests ===");
    test_coroutine_init();
}
