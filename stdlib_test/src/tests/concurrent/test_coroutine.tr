// Test file for concurrent/Coroutine.tr
// Exercises SuspendAlways, SuspendNever, CoroutinePromise, CoroutineHandle,
// Generator, YieldContext, Awaitable, and module-level factory functions.
import tt::concurrent::Coroutine;
import tt::concurrent::Future;
import tt::util::ArrayList;
import tt::lang::Variant;
import tt::lang::Integer;

public fn test_suspend_always(): void {
    let sa: SuspendAlways = new SuspendAlways();
    if (sa.awaitReady()) {
        io::println("FAIL: SuspendAlways.awaitReady should return false");
    } else {
        io::println("PASS: SuspendAlways.awaitReady false");
    }
}

public fn test_suspend_never(): void {
    let sn: SuspendNever = new SuspendNever();
    if (!sn.awaitReady()) {
        io::println("FAIL: SuspendNever.awaitReady should return true");
    } else {
        io::println("PASS: SuspendNever.awaitReady true");
    }
}

public fn test_coroutine_promise_init(): void {
    let p: CoroutinePromise<int> = new CoroutinePromise<int>();
    if (p.hasError()) {
        io::println("FAIL: new promise should not have error");
    } else {
        io::println("PASS: CoroutinePromise init works");
    }
}

public fn test_coroutine_promise_yield_return(): void {
    let p: CoroutinePromise<int> = new CoroutinePromise<int>();
    p.yieldValue(5);
    if (p.current() != 5) {
        io::println("FAIL: yieldValue set wrong current");
    } else {
        io::println("PASS: CoroutinePromise yieldValue works");
    }
    p.returnValue(10);
    if (p.current() != 10) {
        io::println("FAIL: returnValue set wrong current");
    } else {
        io::println("PASS: CoroutinePromise returnValue works");
    }
}

public fn test_coroutine_promise_exception(): void {
    let p: CoroutinePromise<int> = new CoroutinePromise<int>();
    p.setException("error");
    if (!p.hasError()) {
        io::println("FAIL: should have error after setException");
    } else if (p.error() != "error") {
        io::println("FAIL: error message mismatch");
    } else {
        io::println("PASS: CoroutinePromise setException works");
    }
}

public fn test_coroutine_promise_sent_value(): void {
    let p: CoroutinePromise<int> = new CoroutinePromise<int>();
    p.setSentValue(99 as Variant);
    if (p.sentValue() as int != 99) {
        io::println("FAIL: sentValue mismatch");
    } else {
        io::println("PASS: CoroutinePromise sentValue works");
    }
}

public fn test_coroutine_handle_init(): void {
    let p: CoroutinePromise<int> = new CoroutinePromise<int>();
    let h: CoroutineHandle<int> = new CoroutineHandle<int>(p);
    if (h.done()) {
        io::println("FAIL: new handle should not be done");
    } else {
        io::println("PASS: CoroutineHandle init works");
    }
}

public fn test_coroutine_handle_resume(): void {
    let p: CoroutinePromise<int> = new CoroutinePromise<int>();
    let h: CoroutineHandle<int> = new CoroutineHandle<int>(p);
    h.resume();
    if (!h.done()) {
        io::println("FAIL: handle should be done after resume");
    } else {
        io::println("PASS: CoroutineHandle resume works");
    }
}

public fn test_coroutine_handle_promise(): void {
    let p: CoroutinePromise<int> = new CoroutinePromise<int>();
    let h: CoroutineHandle<int> = new CoroutineHandle<int>(p);
    if (h.promise() != p) {
        io::println("FAIL: handle.promise mismatch");
    } else {
        io::println("PASS: CoroutineHandle promise works");
    }
}

public fn test_coroutine_handle_destroy(): void {
    let p: CoroutinePromise<int> = new CoroutinePromise<int>();
    let h: CoroutineHandle<int> = new CoroutineHandle<int>(p);
    h.destroy();
    if (!h.isDestroyed()) {
        io::println("FAIL: handle should be destroyed");
    } else {
        io::println("PASS: CoroutineHandle destroy works");
    }
}

public fn test_yield_context_init(): void {
    let yc: YieldContext<int> = new YieldContext<int>();
    if (yc.isClosed()) {
        io::println("FAIL: new context should not be closed");
    } else if (yc.hasBuffered()) {
        io::println("FAIL: new context should have no buffered items");
    } else {
        io::println("PASS: YieldContext init works");
    }
}

public fn test_yield_context_yield_and_poll(): void {
    let yc: YieldContext<int> = new YieldContext<int>();
    yc.yield(10);
    yc.yield(20);
    if (!yc.hasBuffered()) {
        io::println("FAIL: should have buffered items");
    } else if (yc.poll() != 10) {
        io::println("FAIL: first poll should be 10");
    } else if (yc.poll() != 20) {
        io::println("FAIL: second poll should be 20");
    } else {
        io::println("PASS: YieldContext yield/poll works");
    }
}

public fn test_yield_context_close(): void {
    let yc: YieldContext<int> = new YieldContext<int>();
    yc.close();
    if (!yc.isClosed()) {
        io::println("FAIL: context should be closed");
    } else {
        io::println("PASS: YieldContext close works");
    }
}

public fn test_generator_init(): void {
    let gen: Generator<int> = new Generator<int>(fn(ctx: YieldContext<int>): void {
        ctx.yield(1);
    });
    if (gen.isDone()) {
        io::println("FAIL: new generator should not be done");
    } else {
        io::println("PASS: Generator init works");
    }
}

public fn test_generator_next(): void {
    let gen: Generator<int> = new Generator<int>(fn(ctx: YieldContext<int>): void {
        ctx.yield(10);
        ctx.yield(20);
    });
    let v1: int = gen.next();
    if (v1 != 10) {
        io::println("FAIL: first next = " + Integer.toString(v1));
    } else {
        io::println("PASS: Generator next works");
    }
    let v2: int = gen.next();
    if (v2 != 20) {
        io::println("FAIL: second next = " + Integer.toString(v2));
    } else {
        io::println("PASS: Generator next twice works");
    }
}

public fn test_generator_send(): void {
    let gen: Generator<int> = new Generator<int>(fn(ctx: YieldContext<int>): void {
        let s: Variant = ctx.sent();
        if (s == null) {
            ctx.yield(0);
        }
        ctx.yield(1);
    });
    gen.next();
    let v: int = gen.send(42 as Variant);
    if (v != 1) {
        io::println("FAIL: generator send returned " + Integer.toString(v));
    } else {
        io::println("PASS: Generator send works");
    }
}

public fn test_generator_close(): void {
    let gen: Generator<int> = new Generator<int>(fn(ctx: YieldContext<int>): void {
        ctx.yield(1);
    });
    gen.close();
    if (!gen.isClosed()) {
        io::println("FAIL: generator should be closed");
    } else {
        io::println("PASS: Generator close works");
    }
}

public fn test_generator_collect(): void {
    let gen: Generator<int> = new Generator<int>(fn(ctx: YieldContext<int>): void {
        ctx.yield(1);
        ctx.yield(2);
        ctx.yield(3);
    });
    let items: ArrayList<int> = gen.collect();
    if (items.size() != 3) {
        io::println("FAIL: collect size = " + items.size());
    } else if (items.get(0) != 1 || items.get(1) != 2 || items.get(2) != 3) {
        io::println("FAIL: collect values wrong");
    } else {
        io::println("PASS: Generator collect works");
    }
}

public fn test_generator_map(): void {
    let gen: Generator<int> = new Generator<int>(fn(ctx: YieldContext<int>): void {
        ctx.yield(1);
        ctx.yield(2);
    });
    let mapped: Generator<string> = gen.map<string>(fn(x: int): string { return "v" + x; });
    let items: ArrayList<string> = mapped.collect();
    if (items.size() != 2) {
        io::println("FAIL: map collect size = " + items.size());
    } else {
        io::println("PASS: Generator map works");
    }
}

public fn test_generator_filter(): void {
    let gen: Generator<int> = new Generator<int>(fn(ctx: YieldContext<int>): void {
        ctx.yield(1);
        ctx.yield(2);
        ctx.yield(3);
        ctx.yield(4);
    });
    let filtered: Generator<int> = gen.filter(fn(x: int): bool { return x % 2 == 0; });
    let items: ArrayList<int> = filtered.collect();
    if (items.size() != 2) {
        io::println("FAIL: filter collect size = " + items.size());
    } else {
        io::println("PASS: Generator filter works");
    }
}

public fn test_generator_take(): void {
    let gen: Generator<int> = new Generator<int>(fn(ctx: YieldContext<int>): void {
        ctx.yield(1);
        ctx.yield(2);
        ctx.yield(3);
        ctx.yield(4);
        ctx.yield(5);
    });
    let taken: Generator<int> = gen.take(3);
    let items: ArrayList<int> = taken.collect();
    if (items.size() != 3) {
        io::println("FAIL: take collect size = " + items.size());
    } else {
        io::println("PASS: Generator take works");
    }
}

public fn test_generator_resume(): void {
    let gen: Generator<int> = new Generator<int>(fn(ctx: YieldContext<int>): void {
        ctx.yield(1);
    });
    gen.resume();
    if (gen.isDone()) {
        io::println("FAIL: generator should not be done after one resume");
    } else {
        io::println("PASS: Generator resume works");
    }
    gen.resume();
}

public fn test_generator_destroy(): void {
    let gen: Generator<int> = new Generator<int>(fn(ctx: YieldContext<int>): void {
        ctx.yield(1);
    });
    gen.destroy();
    if (!gen.isDone()) {
        io::println("FAIL: generator should be done after destroy");
    } else {
        io::println("PASS: Generator destroy works");
    }
}

public fn test_iota_range(): void {
    let gen: Generator<int> = Coroutine.iotaRange(0, 5);
    let items: ArrayList<int> = gen.collect();
    if (items.size() != 5) {
        io::println("FAIL: iotaRange size = " + items.size());
    } else if (items.get(0) != 0 || items.get(4) != 4) {
        io::println("FAIL: iotaRange values wrong");
    } else {
        io::println("PASS: iotaRange works");
    }
}

public fn test_iorta_range_empty(): void {
    let gen: Generator<int> = Coroutine.iotaRange(0, 0);
    let items: ArrayList<int> = gen.collect();
    if (items.size() != 0) {
        io::println("FAIL: empty iotaRange should be empty");
    } else {
        io::println("PASS: iotaRange empty works");
    }
}

public fn test_repeat(): void {
    let gen: Generator<string> = Coroutine.repeat<string>("hi");
    let gen2: Generator<string> = gen.take(3);
    let items: ArrayList<string> = gen2.collect();
    if (items.size() != 3) {
        io::println("FAIL: repeat take size = " + items.size());
    } else if (items.get(0) != "hi") {
        io::println("FAIL: repeat value wrong");
    } else {
        io::println("PASS: repeat works");
    }
}

public fn test_from_promise(): void {
    let p: CoroutinePromise<int> = new CoroutinePromise<int>();
    let h: CoroutineHandle<int> = Coroutine.fromPromise<int>(p);
    if (h == null) {
        io::println("FAIL: fromPromise returned null");
    } else {
        io::println("PASS: fromPromise works");
    }
}

public fn test_noop_coroutine(): void {
    let h: CoroutineHandle<Variant> = Coroutine.noopCoroutine();
    if (h == null) {
        io::println("FAIL: noopCoroutine returned null");
    } else {
        io::println("PASS: noopCoroutine works");
    }
}

public fn test_chain_generators(): void {
    let g1: Generator<int> = Coroutine.iotaRange(0, 3);
    let g2: Generator<int> = Coroutine.iotaRange(3, 5);
    let chained: Generator<int> = Coroutine.chain<int>(g1, g2);
    let items: ArrayList<int> = chained.collect();
    if (items.size() != 5) {
        io::println("FAIL: chain size = " + items.size());
    } else {
        io::println("PASS: chain works");
    }
}

public fn test_zip_generators(): void {
    let g1: Generator<int> = Coroutine.iotaRange(0, 3);
    let g2: Generator<string> = Coroutine.repeat<string>("a");
    let g2t: Generator<string> = g2.take(3);
    let zipped: Generator<Pair<int, string>> = Coroutine.zip<int, string>(g1, g2t);
    let items: ArrayList<Pair<int, string>> = zipped.collect();
    if (items.size() != 3) {
        io::println("FAIL: zip size = " + items.size());
    } else {
        io::println("PASS: zip works");
    }
}

public fn test_generator_as_handle(): void {
    let gen: Generator<int> = new Generator<int>(fn(ctx: YieldContext<int>): void {});
    let h: CoroutineHandle<Variant> = gen.asHandle();
    if (h == null) {
        io::println("FAIL: asHandle returned null");
    } else {
        io::println("PASS: Generator asHandle works");
    }
}

public fn test_awaitable_init(): void {
    let f: Future<int> = new Future<int>();
    let a: Awaitable<int> = new Awaitable<int>(f);
    if (a.awaitReady()) {
        io::println("FAIL: new future should not be ready");
    } else {
        io::println("PASS: Awaitable init works");
    }
}

public fn test_awaitable_future(): void {
    let f: Future<int> = new Future<int>();
    let a: Awaitable<int> = new Awaitable<int>(f);
    if (a.future() != f) {
        io::println("FAIL: awaitable.future mismatch");
    } else {
        io::println("PASS: Awaitable future accessor works");
    }
}

public fn run_all_coroutine_tests(): void {
    io::println("=== Coroutine.tr Tests ===");
    test_suspend_always();
    test_suspend_never();
    test_coroutine_promise_init();
    test_coroutine_promise_yield_return();
    test_coroutine_promise_exception();
    test_coroutine_promise_sent_value();
    test_coroutine_handle_init();
    test_coroutine_handle_resume();
    test_coroutine_handle_promise();
    test_coroutine_handle_destroy();
    test_yield_context_init();
    test_yield_context_yield_and_poll();
    test_yield_context_close();
    test_generator_init();
    test_generator_next();
    test_generator_send();
    test_generator_close();
    test_generator_collect();
    test_generator_map();
    test_generator_filter();
    test_generator_take();
    test_generator_resume();
    test_generator_destroy();
    test_iota_range();
    test_iorta_range_empty();
    test_repeat();
    test_from_promise();
    test_noop_coroutine();
    test_chain_generators();
    test_zip_generators();
    test_generator_as_handle();
    test_awaitable_init();
    test_awaitable_future();
}
