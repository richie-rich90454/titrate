}

public fn test_unboundedchannel_size(): void {
    let ch: UnboundedChannel = new UnboundedChannel();
    ch.send(Variant.of(1));
    ch.send(Variant.of(2));
    ch.send(Variant.of(3));
    if (ch.size() != 3) {
        io::println("FAIL: UnboundedChannel.size=" + Integer.toString(ch.size()));
    } else {
        io::println("PASS: UnboundedChannel.size works");
    }
}

public fn test_unboundedchannel_isEmpty(): void {
    let ch: UnboundedChannel = new UnboundedChannel();
    if (!ch.isEmpty()) {
        io::println("FAIL: UnboundedChannel.isEmpty should be true");
    } else {
        io::println("PASS: UnboundedChannel.isEmpty works");
    }
}

public fn test_unboundedchannel_close(): void {
    let ch: UnboundedChannel = new UnboundedChannel();
    ch.close();
    if (!ch.isClosed()) {
        io::println("FAIL: UnboundedChannel.close not closed");
    } else {
        io::println("PASS: UnboundedChannel.close works");
    }
}

public fn test_unboundedchannel_send_after_close(): void {
    let ch: UnboundedChannel = new UnboundedChannel();
    ch.close();
    let result: bool = ch.send(Variant.of(1));
    if (result) {
        io::println("FAIL: UnboundedChannel.send after close should fail");
    } else {
        io::println("PASS: UnboundedChannel.send after close works");
    }
}

public fn test_channelselect_empty(): void {
    let channels: ArrayList<BufferedChannel> = new ArrayList<BufferedChannel>();
    let result: Pair<int, Variant> = channelSelect(channels);
    if (result.first != -1) {
        io::println("FAIL: channelSelect empty should return -1");
    } else {
        io::println("PASS: channelSelect empty works");
    }
}

public fn test_channelselect_with_data(): void {
    let channels: ArrayList<BufferedChannel> = new ArrayList<BufferedChannel>();
    let ch1: BufferedChannel = new BufferedChannel(5);
    let ch2: BufferedChannel = new BufferedChannel(5);
    ch2.send(Variant.of(42));
    channels.add(ch1);
    channels.add(ch2);
    let result: Pair<int, Variant> = channelSelect(channels);
    if (result.first != 1) {
        io::println("FAIL: channelSelect should return index 1");
    } else {
        io::println("PASS: channelSelect with data works");
    }
}

public fn test_select_function(): void {
    let channels: ArrayList<BufferedChannel> = new ArrayList<BufferedChannel>();
    let result: Pair<int, Variant> = select(channels);
    if (result.first != -1) {
        io::println("FAIL: select empty should return -1");
    } else {
        io::println("PASS: select function works");
    }
}

public fn run_all_channel_tests(): void {
    io::println("=== Channel.tr Tests ===");
    test_bufferedchannel_init();
    test_bufferedchannel_capacity();
    test_bufferedchannel_send();
    test_bufferedchannel_receive();
    test_bufferedchannel_trySend();
    test_bufferedchannel_size();
    test_bufferedchannel_len();
    test_bufferedchannel_isEmpty();
    test_bufferedchannel_isFull();
    test_bufferedchannel_send_full();
    test_bufferedchannel_close();
    test_bufferedchannel_send_after_close();
    test_bufferedchannel_receive_empty();
    test_bufferedchannel_onClose();
    test_unboundedchannel_init();
    test_unboundedchannel_send();
    test_unboundedchannel_receive();
    test_unboundedchannel_size();
    test_unboundedchannel_isEmpty();
    test_unboundedchannel_close();
    test_unboundedchannel_send_after_close();
    test_channelselect_empty();
    test_channelselect_with_data();
    test_select_function();
}
