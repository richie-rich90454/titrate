// Test file for concurrent/ExecutionPolicy.tr
// Exercises Seq, Par, ParUnseq, UnsequencedPolicy, ExecutionPolicy, and
// module-level helpers (seq, par, parUnseq, unsequenced, isParallel, etc.).
import tt::concurrent::ExecutionPolicy;
import tt::lang::Variant;

public fn test_seq_policy(): void {
    let s: Seq = new Seq();
    io::println("PASS: Seq init works");
}

public fn test_par_policy(): void {
    let p: Par = new Par();
    io::println("PASS: Par init works");
}

public fn test_par_unseq_policy(): void {
    let pu: ParUnseq = new ParUnseq();
    io::println("PASS: ParUnseq init works");
}

public fn test_unsequenced_policy(): void {
    let u: UnsequencedPolicy = new UnsequencedPolicy();
    if (u.toString() != "ExecutionPolicy::unseq") {
        io::println("FAIL: UnsequencedPolicy toString wrong");
    } else {
        io::println("PASS: UnsequencedPolicy init works");
    }
}

public fn test_execution_policy_init(): void {
    let ep: ExecutionPolicy = new ExecutionPolicy("seq", new Seq() as Variant);
    if (ep.kind != "seq") {
        io::println("FAIL: ExecutionPolicy kind mismatch");
    } else {
        io::println("PASS: ExecutionPolicy init works");
    }
}

public fn test_execution_policy_is_sequential(): void {
    let seq: ExecutionPolicy = ExecutionPolicy.seq();
    let par: ExecutionPolicy = ExecutionPolicy.par();
    if (!seq.isSequential()) {
        io::println("FAIL: seq policy should be sequential");
    } else if (par.isSequential()) {
        io::println("FAIL: par policy should not be sequential");
    } else {
        io::println("PASS: ExecutionPolicy isSequential works");
    }
}

public fn test_execution_policy_is_parallel(): void {
    let seq: ExecutionPolicy = ExecutionPolicy.seq();
    let par: ExecutionPolicy = ExecutionPolicy.par();
    let punseq: ExecutionPolicy = ExecutionPolicy.parUnseq();
    if (seq.isParallel()) {
        io::println("FAIL: seq policy should not be parallel");
    } else if (!par.isParallel()) {
        io::println("FAIL: par policy should be parallel");
    } else if (!punseq.isParallel()) {
        io::println("FAIL: par_unseq policy should be parallel");
    } else {
        io::println("PASS: ExecutionPolicy isParallel works");
    }
}

public fn test_execution_policy_is_unsequenced(): void {
    let seq: ExecutionPolicy = ExecutionPolicy.seq();
    let punseq: ExecutionPolicy = ExecutionPolicy.parUnseq();
    let unseq: ExecutionPolicy = ExecutionPolicy.unsequenced();
    if (seq.isUnsequenced()) {
        io::println("FAIL: seq policy should not be unsequenced");
    } else if (!punseq.isUnsequenced()) {
        io::println("FAIL: par_unseq should be unsequenced");
    } else if (!unseq.isUnsequenced()) {
        io::println("FAIL: unseq should be unsequenced");
    } else {
        io::println("PASS: ExecutionPolicy isUnsequenced works");
    }
}

public fn test_execution_policy_equals(): void {
    let seq1: ExecutionPolicy = ExecutionPolicy.seq();
    let seq2: ExecutionPolicy = ExecutionPolicy.seq();
    let par: ExecutionPolicy = ExecutionPolicy.par();
    if (!seq1.equals(seq2 as Variant)) {
        io::println("FAIL: same kind policies should be equal");
    } else if (seq1.equals(par as Variant)) {
        io::println("FAIL: different kind policies should not be equal");
    } else {
        io::println("PASS: ExecutionPolicy equals works");
    }
}

public fn test_execution_policy_equals_null(): void {
    let seq: ExecutionPolicy = ExecutionPolicy.seq();
    if (seq.equals(null)) {
        io::println("FAIL: equals null should return false");
    } else {
        io::println("PASS: ExecutionPolicy equals null works");
    }
}

public fn test_seq_factory(): void {
    let ep: ExecutionPolicy = ExecutionPolicy.seq();
    if (ep.kind != "seq") {
        io::println("FAIL: seq() kind wrong");
    } else {
        io::println("PASS: seq() factory works");
    }
}

