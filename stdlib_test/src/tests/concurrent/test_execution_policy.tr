public fn test_is_parallel_free(): void {
    let ep: ExecutionPolicy = ExecutionPolicy.par();
    if (!ExecutionPolicy.isParallel(ep)) {
        io::println("FAIL: isParallel free function wrong");
    } else {
        io::println("PASS: isParallel free function works");
    }
}

public fn test_is_parallel_null(): void {
    if (ExecutionPolicy.isParallel(null)) {
        io::println("FAIL: isParallel null should return false");
    } else {
        io::println("PASS: isParallel null works");
    }
}

