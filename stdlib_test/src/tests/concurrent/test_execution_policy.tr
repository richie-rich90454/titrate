    let ep: ExecutionPolicy = ExecutionPolicy.seq();
    if (!ExecutionPolicy.isSequential(ep)) {
        io::println("FAIL: isSequential free function wrong");
    } else {
        io::println("PASS: isSequential free function works");
    }
}

