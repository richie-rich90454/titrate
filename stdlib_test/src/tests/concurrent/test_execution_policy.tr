public fn test_name_func(): void {
    let ep: ExecutionPolicy = ExecutionPolicy.par();
    if (ExecutionPolicy.name(ep) != "par") {
        io::println("FAIL: name() = " + ExecutionPolicy.name(ep));
    } else {
        io::println("PASS: name() works");
    }
}

public fn test_name_null(): void {
    if (ExecutionPolicy.name(null) != "unknown") {
        io::println("FAIL: name(null) wrong");
    } else {
        io::println("PASS: name(null) works");
    }
}

public fn test_execution_policy_to_string(): void {
    let ep: ExecutionPolicy = ExecutionPolicy.seq();
    let s: string = ep.toString();
    if (!String.contains(s, "seq")) {
        io::println("FAIL: toString missing kind");
    } else {
        io::println("PASS: ExecutionPolicy toString works");
    }
}

public fn run_all_execution_policy_tests(): void {
    io::println("=== ExecutionPolicy.tr Tests ===");
    test_seq_policy();
    test_par_policy();
    test_par_unseq_policy();
    test_unsequenced_policy();
    test_execution_policy_init();
    test_execution_policy_is_sequential();
    test_execution_policy_is_parallel();
    test_execution_policy_is_unsequenced();
    test_execution_policy_equals();
    test_execution_policy_equals_null();
    test_seq_factory();
    test_par_factory();
    test_par_unseq_factory();
    test_unsequenced_factory();
    test_is_parallel_free();
    test_is_parallel_null();
    test_is_sequential_free();
    test_is_sequential_null();
    test_is_unsequenced_free();
    test_name_func();
    test_name_null();
    test_execution_policy_to_string();
}
