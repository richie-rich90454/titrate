// Test file for concurrent/Faulthandler.tr
// Exercises enable, disable, isEnabled, dumpTraceback, dumpTracebackSimple,
// dumpTracebackLimit, register, unregister, isRegistered, readTracebackSignum,
// reportFatal.
import tt::concurrent::Faulthandler;
import tt::lang::Integer;
import tt::lang::Traceback;

public fn test_enable_default(): void {
    Faulthandler.enableDefault();
    if (!Faulthandler.isEnabled()) {
        io::println("FAIL: should be enabled after enableDefault");
    } else {
        io::println("PASS: enableDefault works");
    }
    Faulthandler.disable();
}

public fn test_enable_with_path(): void {
    Faulthandler.enable("test_fault.log");
    if (!Faulthandler.isEnabled()) {
        io::println("FAIL: should be enabled after enable");
    } else {
        io::println("PASS: enable with path works");
    }
    Faulthandler.disable();
}

public fn test_disable(): void {
    Faulthandler.enableDefault();
    Faulthandler.disable();
    if (Faulthandler.isEnabled()) {
        io::println("FAIL: should be disabled after disable");
    } else {
        io::println("PASS: disable works");
    }
}

public fn test_is_enabled(): void {
    Faulthandler.disable();
    if (Faulthandler.isEnabled()) {
        io::println("FAIL: should be disabled initially");
    } else {
        io::println("PASS: isEnabled works");
    }
    Faulthandler.enableDefault();
    if (!Faulthandler.isEnabled()) {
        io::println("FAIL: should be enabled after enable");
    } else {
        io::println("PASS: isEnabled after enable works");
    }
    Faulthandler.disable();
}

public fn test_dump_traceback_simple(): void {
    Faulthandler.enableDefault();
    Faulthandler.dumpTracebackSimple();
    io::println("PASS: dumpTracebackSimple runs without crash");
    Faulthandler.disable();
}

public fn test_dump_traceback(): void {
    Faulthandler.enableDefault();
    Faulthandler.dumpTraceback(false, false);
    io::println("PASS: dumpTraceback with params runs without crash");
    Faulthandler.disable();
}

public fn test_dump_traceback_limit(): void {
    Faulthandler.enableDefault();
    Faulthandler.dumpTracebackLimit(5);
    io::println("PASS: dumpTracebackLimit runs without crash");
    Faulthandler.disable();
}

public fn test_register(): void {
    if (!Faulthandler.register(11, "", false, false)) {
        io::println("FAIL: register returned false");
    } else if (!Faulthandler.isRegistered(11)) {
        io::println("FAIL: signal should be registered");
    } else {
        io::println("PASS: register works");
    }
    Faulthandler.unregister(11);
}

public fn test_unregister(): void {
    Faulthandler.register(15, "", false, false);
    Faulthandler.unregister(15);
    if (Faulthandler.isRegistered(15)) {
        io::println("FAIL: signal should be unregistered");
    } else {
        io::println("PASS: unregister works");
    }
}

public fn test_is_registered(): void {
    Faulthandler.register(9, "", false, false);
    if (!Faulthandler.isRegistered(9)) {
        io::println("FAIL: isRegistered should be true");
    } else {
        io::println("PASS: isRegistered works");
    }
    Faulthandler.unregister(9);
    if (Faulthandler.isRegistered(9)) {
        io::println("FAIL: isRegistered should be false after unregister");
    } else {
        io::println("PASS: isRegistered false after unregister works");
    }
}

public fn test_is_registered_not_registered(): void {
    if (Faulthandler.isRegistered(99)) {
        io::println("FAIL: unregistered signal should not be registered");
    } else {
        io::println("PASS: isRegistered for unknown works");
    }
}

public fn test_read_traceback_signum(): void {
    Faulthandler.register(10, "", false, false);
    Faulthandler.readTracebackSignum(10);
    io::println("PASS: readTracebackSignum runs without crash");
    Faulthandler.unregister(10);
}

public fn test_read_traceback_unregistered_signal(): void {
    // Should be a no-op for unregistered signals
    Faulthandler.readTracebackSignum(99);
    io::println("PASS: readTracebackSignum for unregistered works");
}

public fn test_report_fatal(): void {
    Faulthandler.enableDefault();
    var caught: bool = false;
    try {
        Faulthandler.reportFatal("test fatal error");
    } catch (e: string) {
        caught = true;
    }
    if (!caught) {
        io::println("FAIL: reportFatal should throw");
    } else {
        io::println("PASS: reportFatal throws");
    }
    Faulthandler.disable();
}

public fn run_all_faulthandler_tests(): void {
    io::println("=== Faulthandler.tr Tests ===");
    test_enable_default();
    test_enable_with_path();
    test_disable();
    test_is_enabled();
    test_dump_traceback_simple();
    test_dump_traceback();
    test_dump_traceback_limit();
    test_register();
    test_unregister();
    test_is_registered();
    test_is_registered_not_registered();
    test_read_traceback_signum();
    test_read_traceback_unregistered_signal();
    test_report_fatal();
}
