// Test file for concurrent/Retry.tr
// Exercises the public API: RetryPolicy, exponentialBackoff, retryWithBackoff.
import tt::concurrent::Retry;
import tt::util::ArrayList;
import tt::lang::Variant;
import tt::lang::Integer;

public fn test_retrypolicy_init(): void {
    let p: RetryPolicy = new RetryPolicy(3, 100);
    if (p == null) {
        io::println("FAIL: RetryPolicy.init returned null");
    } else {
        io::println("PASS: RetryPolicy.init works");
    }
}

public fn test_retrypolicy_maxAttempts(): void {
    let p: RetryPolicy = new RetryPolicy(3, 100);
    if (p.maxAttempts != 3) {
        io::println("FAIL: RetryPolicy.maxAttempts=" + Integer.toString(p.maxAttempts));
    } else {
        io::println("PASS: RetryPolicy.maxAttempts works");
    }
}

public fn test_retrypolicy_baseDelayMs(): void {
    let p: RetryPolicy = new RetryPolicy(3, 100);
    if (p.baseDelayMs != 100) {
        io::println("FAIL: RetryPolicy.baseDelayMs wrong");
    } else {
        io::println("PASS: RetryPolicy.baseDelayMs works");
    }
}

public fn test_retrypolicy_maxDelayMs_default(): void {
    let p: RetryPolicy = new RetryPolicy(3, 100);
    if (p.maxDelayMs != 30000) {
        io::println("FAIL: RetryPolicy.maxDelayMs default wrong");
    } else {
        io::println("PASS: RetryPolicy.maxDelayMs default works");
    }
}

public fn test_retrypolicy_backoffMultiplier_default(): void {
    let p: RetryPolicy = new RetryPolicy(3, 100);
    if (p.backoffMultiplier != 2.0) {
        io::println("FAIL: RetryPolicy.backoffMultiplier default wrong");
    } else {
        io::println("PASS: RetryPolicy.backoffMultiplier default works");
    }
}

public fn test_retrypolicy_jitter_default(): void {
    let p: RetryPolicy = new RetryPolicy(3, 100);
    if (p.jitter) {
        io::println("FAIL: RetryPolicy.jitter should be false by default");
    } else {
        io::println("PASS: RetryPolicy.jitter default works");
    }
}

public fn test_retrypolicy_retryableErrors_default(): void {
    let p: RetryPolicy = new RetryPolicy(3, 100);
    if (p.retryableErrors.size() != 0) {
        io::println("FAIL: RetryPolicy.retryableErrors not empty");
    } else {
        io::println("PASS: RetryPolicy.retryableErrors default works");
    }
}

public fn test_retrypolicy_retryableErrors_add(): void {
    let p: RetryPolicy = new RetryPolicy(3, 100);
    p.retryableErrors.add("timeout");
    p.retryableErrors.add("connection");
    if (p.retryableErrors.size() != 2) {
        io::println("FAIL: RetryPolicy.retryableErrors size wrong");
    } else {
        io::println("PASS: RetryPolicy.retryableErrors add works");
    }
}

public fn test_exponentialBackoff_calculation(): void {
    let delay: long = exponentialBackoff(1, 100, 2.0, 30000);
    if (delay != 200) {
        io::println("FAIL: exponentialBackoff(1, 100, 2.0) should be 200, got " + Integer.toString(delay as int));
    } else {
        io::println("PASS: exponentialBackoff calculation works");
    }
}

public fn test_exponentialBackoff_attempt_0(): void {
    let delay: long = exponentialBackoff(0, 100, 2.0, 30000);
    if (delay != 100) {
        io::println("FAIL: exponentialBackoff(0, 100, 2.0) should be 100");
    } else {
        io::println("PASS: exponentialBackoff attempt 0 works");
    }
}

public fn test_exponentialBackoff_attempt_2(): void {
    let delay: long = exponentialBackoff(2, 100, 2.0, 30000);
    if (delay != 400) {
        io::println("FAIL: exponentialBackoff(2, 100, 2.0) should be 400");
    } else {
        io::println("PASS: exponentialBackoff attempt 2 works");
    }
}

public fn test_exponentialBackoff_max_delay(): void {
    let delay: long = exponentialBackoff(10, 100, 2.0, 1000);
    if (delay > 1000) {
        io::println("FAIL: exponentialBackoff should cap at maxDelayMs");
    } else {
        io::println("PASS: exponentialBackoff max delay works");
    }
}

public fn test_retryWithBackoff_success(): void {
    let p: RetryPolicy = new RetryPolicy(3, 10);
    let result: Variant = retryWithBackoff(fn(): Variant { return Variant.of(42); }, p);
    if (result == null) {
        io::println("FAIL: retryWithBackoff success returned null");
    } else {
        io::println("PASS: retryWithBackoff success works");
    }
}

public fn test_retryWithBackoff_eventual_success(): void {
    let p: RetryPolicy = new RetryPolicy(3, 10);
    let counter: int = 0;
    let result: Variant = retryWithBackoff(fn(): Variant {
        counter = counter + 1;
        if (counter < 2) {
            throw "transient error";
        }
        return Variant.of(99);
    }, p);
    if (result == null) {
        io::println("FAIL: retryWithBackoff eventual success returned null");
    } else {
        io::println("PASS: retryWithBackoff eventual success works");
    }
}

public fn test_retryWithBackoff_all_fail(): void {
    let p: RetryPolicy = new RetryPolicy(2, 10);
    var threw: bool = false;
    try {
        retryWithBackoff(fn(): Variant { throw "always fails"; }, p);
    } catch (e: string) {
        threw = true;
    }
    if (!threw) {
        io::println("FAIL: retryWithBackoff all fail should throw");
    } else {
        io::println("PASS: retryWithBackoff all fail works");
    }
}

public fn test_retryWithBackoff_non_retryable(): void {
    let p: RetryPolicy = new RetryPolicy(3, 10);
    p.retryableErrors.add("timeout");
    var threw: bool = false;
    try {
        retryWithBackoff(fn(): Variant { throw "non-retryable error"; }, p);
    } catch (e: string) {
        threw = true;
    }
    if (!threw) {
        io::println("FAIL: retryWithBackoff non-retryable should throw immediately");
    } else {
        io::println("PASS: retryWithBackoff non-retryable works");
    }
}

public fn test_retrypolicy_jitter_set(): void {
    let p: RetryPolicy = new RetryPolicy(3, 100);
    p.jitter = true;
    if (!p.jitter) {
        io::println("FAIL: RetryPolicy.jitter should be true after set");
    } else {
        io::println("PASS: RetryPolicy.jitter set works");
    }
}

public fn run_all_retry_tests(): void {
    io::println("=== Retry.tr Tests ===");
    test_retrypolicy_init();
    test_retrypolicy_maxAttempts();
    test_retrypolicy_baseDelayMs();
    test_retrypolicy_maxDelayMs_default();
    test_retrypolicy_backoffMultiplier_default();
    test_retrypolicy_jitter_default();
    test_retrypolicy_retryableErrors_default();
    test_retrypolicy_retryableErrors_add();
    test_exponentialBackoff_calculation();
    test_exponentialBackoff_attempt_0();
    test_exponentialBackoff_attempt_2();
    test_exponentialBackoff_max_delay();
    test_retryWithBackoff_success();
    test_retryWithBackoff_eventual_success();
    test_retryWithBackoff_all_fail();
    test_retryWithBackoff_non_retryable();
    test_retrypolicy_jitter_set();
}
