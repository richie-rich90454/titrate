// Titrate Alpha 0.3 – Mega Test
// Simulates a box of water molecules using custom classes.
// Exercises: classes, modules, imports, loops, casting,
// energy computation, and result verification.

import forcefield;

// Entry point
public fn main(): void {
    io::println("=== Titrate Alpha 0.3 – Water Box Simulation ===");
    io::println("");

    // --- Section 1: System setup ---
    io::println("=== System Setup ===");
    let nWaters: int = 8;
    let side: int = 2;  // 2^3 = 8 molecules
    let spacing: double = 3.166;

    io::println("Water molecules: " + Integer.toString(nWaters));
    io::println("Lattice: " + Integer.toString(side) + " x " + Integer.toString(side) + " x " + Integer.toString(side));
    io::println("Spacing: " + Double.toString(spacing) + " A");
    io::println("Box size: " + Double.toString(side as double * spacing) + " A");

    // Build the water box
    let system: WaterBox = new WaterBox();

    // Place water molecules on a simple cubic lattice
    var ix: int = 0;
    while (ix < side) {
        var iy: int = 0;
        while (iy < side) {
            var iz: int = 0;
            while (iz < side) {
                let ox: double = ix as double * spacing;
                let oy: double = iy as double * spacing;
                let oz: double = iz as double * spacing;
                system.addWater(ox, oy, oz);
                iz = iz + 1;
            }
            iy = iy + 1;
        }
        ix = ix + 1;
    }

    io::println("Atoms: " + Integer.toString(system.atomCount()));
    io::println("Bonds: " + Integer.toString(system.bondCount()));
    io::println("");

    // --- Section 2: Energy computation ---
    io::println("=== Energy Computation ===");
    let bondEnergy: double = system.computeBondEnergy();
    let ljEnergy: double = system.computeLJEnergy();
    let totalEnergy: double = bondEnergy + ljEnergy;

    io::println("Bond Energy: " + Double.toString(bondEnergy));
    io::println("LJ Energy:   " + Double.toString(ljEnergy));
    io::println("Total Energy: " + Double.toString(totalEnergy));
    io::println("");

    // --- Section 3: Verification ---
    io::println("=== Verification ===");

    // Check atom count: 8 waters * 3 atoms = 24
    let atomsCorrect: bool = system.atomCount() == 24;
    io::println("Atom count is 24: " + Boolean.toString(atomsCorrect));

    // Check bond count: 8 waters * 2 bonds = 16
    let bondsCorrect: bool = system.bondCount() == 16;
    io::println("Bond count is 16: " + Boolean.toString(bondsCorrect));

    // Check energy is finite
    let energyFinite: bool = totalEnergy > -10000000000.0 && totalEnergy < 10000000000.0;
    io::println("Energy is finite: " + Boolean.toString(energyFinite));

    // Overall verification
    let allPassed: bool = atomsCorrect && bondsCorrect && energyFinite;
    if (allPassed) {
        io::println("VERIFICATION PASSED");
    } else {
        io::println("VERIFICATION FAILED");
    }

    io::println("");
    io::println("=== Mega Test 0.3 Complete ===");
}
