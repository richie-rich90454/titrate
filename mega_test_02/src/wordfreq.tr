// Word frequency counter using HashMap.
// Simplified version that counts whole words from pre-split lines.

public class WordCounter {
    private HashMap<string, string> counts;

    public WordCounter() {
        this.counts = new HashMap<string, string>();
    }

    public void count(string word) {
        string current = this.counts.get(word);
        if current == "" {
            this.counts.put(word, "1");
        } else {
            int n = Integer.parseOr(current, 0);
            this.counts.put(word, Integer.toString(n + 1));
        }
    }

    public int get(string word) {
        string current = this.counts.get(word);
        if current == "" {
            return 0;
        }
        return Integer.parseOr(current, 0);
    }
}
