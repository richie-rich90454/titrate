// Utility functions for the mega test.

public int min(int a, int b) {
    if (a < b) {
        return a;
    }
    return b;
}

public int max(int a, int b) {
    if (a > b) {
        return a;
    }
    return b;
}

public int abs(int x) {
    if (x < 0) {
        return 0 - x;
    }
    return x;
}

public int factorial(int n) {
    if (n <= 1) { return 1; }
    int result = 1;
    int i = 2;
    while (i <= n) {
        result = result * i;
        i = i + 1;
    }
    return result;
}

public int fibonacci(int n) {
    if (n <= 0) {
        return 0;
    }
    if (n == 1) {
        return 1;
    }
    int prev2 = 0;
    int prev1 = 1;
    int i = 2;
    while (i <= n) {
        int current = prev1 + prev2;
        prev2 = prev1;
        prev1 = current;
        i = i + 1;
    }
    return prev1;
}

// Quicksort for ArrayList<int>
public void quicksort(ArrayList<int> arr) {
    if (arr.size() <= 1) {
        return;
    }
    _quicksort(arr, 0, arr.size() - 1);
}

void _quicksort(ArrayList<int> arr, int lo, int hi) {
    if (lo < hi) {
        int p = _partition(arr, lo, hi);
        _quicksort(arr, lo, p - 1);
        _quicksort(arr, p + 1, hi);
    }
}

int _partition(ArrayList<int> arr, int lo, int hi) {
    int pivot = arr.get(hi);
    int i = lo - 1;
    int j = lo;
    while (j < hi) {
        if (arr.get(j) <= pivot) {
            i = i + 1;
            int tmp = arr.get(i);
            arr.set(i, arr.get(j));
            arr.set(j, tmp);
        }
        j = j + 1;
    }
    int tmp2 = arr.get(i + 1);
    arr.set(i + 1, arr.get(hi));
    arr.set(hi, tmp2);
    return i + 1;
}
