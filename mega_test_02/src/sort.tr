// Utility functions for the mega test.

public fn min(a: int, b: int): int {
    if (a < b) {
        return a;
    }
    return b;
}

public fn max(a: int, b: int): int {
    if (a > b) {
        return a;
    }
    return b;
}

public fn abs(x: int): int {
    if (x < 0) {
        return 0 - x;
    }
    return x;
}

public fn factorial(n: int): int {
    if (n <= 1) { return 1; }
    var result: int = 1;
    var i: int = 2;
    while (i <= n) {
        result = result * i;
        i = i + 1;
    }
    return result;
}

public fn fibonacci(n: int): int {
    if (n <= 0) {
        return 0;
    }
    if (n == 1) {
        return 1;
    }
    var prev2: int = 0;
    var prev1: int = 1;
    var i: int = 2;
    while (i <= n) {
        let current: int = prev1 + prev2;
        prev2 = prev1;
        prev1 = current;
        i = i + 1;
    }
    return prev1;
}

// Quicksort for ArrayList<int>
public fn quicksort(arr: ArrayList<int>): void {
    if (arr.size() <= 1) {
        return;
    }
    _quicksort(arr, 0, arr.size() - 1);
}

fn _quicksort(arr: ArrayList<int>, lo: int, hi: int): void {
    if (lo < hi) {
        let p: int = _partition(arr, lo, hi);
        _quicksort(arr, lo, p - 1);
        _quicksort(arr, p + 1, hi);
    }
}

fn _partition(arr: ArrayList<int>, lo: int, hi: int): int {
    let pivot: int = arr.get(hi);
    var i: int = lo - 1;
    var j: int = lo;
    while (j < hi) {
        if (arr.get(j) <= pivot) {
            i = i + 1;
            let tmp: int = arr.get(i);
            arr.set(i, arr.get(j));
            arr.set(j, tmp);
        }
        j = j + 1;
    }
    let tmp2: int = arr.get(i + 1);
    arr.set(i + 1, arr.get(hi));
    arr.set(hi, tmp2);
    return i + 1;
}
