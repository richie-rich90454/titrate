// Titrate Alpha 0.2 – Mega Test
// Exercises: generics, modules, pattern matching, Result, classes, file I/O,
// C-style for loops, String methods, HashMap methods, unit type, and more.

import sort;
import data;
import shapes;
import wordfreq;

// Entry point
public void main() {
    // --- Section 1: Utility functions from sort module ---
    io::println("=== Utility Functions ===");
    io::println("min(3, 7) = " + Integer.toString(min(3, 7)));
    io::println("max(3, 7) = " + Integer.toString(max(3, 7)));
    io::println("abs(-5) = " + Integer.toString(abs(-5)));
    io::println("abs(5) = " + Integer.toString(abs(5)));
    io::println("factorial(0) = " + Integer.toString(factorial(0)));
    io::println("factorial(1) = " + Integer.toString(factorial(1)));
    io::println("factorial(5) = " + Integer.toString(factorial(5)));
    io::println("factorial(10) = " + Integer.toString(factorial(10)));
    io::println("fibonacci(0) = " + Integer.toString(fibonacci(0)));
    io::println("fibonacci(1) = " + Integer.toString(fibonacci(1)));
    io::println("fibonacci(10) = " + Integer.toString(fibonacci(10)));

    // --- Section 2: DataStore with HashMap ---
    io::println("");
    io::println("=== DataStore ===");
    let store: DataStore = new DataStore();
    store.put("name", "Titrate");
    store.put("version", "0.2");
    store.put("type", "language");
    io::println("name: " + store.get("name"));
    io::println("version: " + store.get("version"));
    io::println("type: " + store.get("type"));
    io::println("missing: " + store.get("missing"));

    // --- Section 3: Shapes from imported module ---
    io::println("");
    io::println("=== Shapes ===");
    let c: Circle = new Circle(5.0);
    let r: Rectangle = new Rectangle(3.0, 4.0);
    io::println("Circle area: " + Double.toString(c.area()));
    io::println("Rectangle area: " + Double.toString(r.area()));
    io::println("Circle describe: " + c.describe());
    io::println("Rectangle describe: " + r.describe());

    // --- Section 4: Class inheritance and method overriding ---
    io::println("");
    io::println("=== Inheritance ===");
    let animal: Animal = new Animal("creature");
    let dog: Dog = new Dog("Rex", "Labrador");
    io::println("Animal name: " + animal.getName());
    io::println("Animal speak: " + animal.speak());
    io::println("Dog name: " + dog.getName());
    io::println("Dog speak: " + dog.speak());
    io::println("Dog breed: " + dog.getBreed());

    // --- Section 5: Result type and pattern matching ---
    io::println("");
    io::println("=== Result Type ===");
    let ok_result: Result<int, string> = Ok(42);
    let err_result: Result<int, string> = Err("something went wrong");
    switch (ok_result) {
        case Ok(val) => io::println("Ok value: " + Integer.toString(val));
        case Err(msg) => io::println("Error: " + msg);
        default => { }
    }
    switch (err_result) {
        case Ok(val) => io::println("Ok value: " + Integer.toString(val));
        case Err(msg) => io::println("Error: " + msg);
        default => { }
    }

    // --- Section 6: Error propagation ---
    io::println("");
    io::println("=== Error Propagation ===");
    let div_ok: Result<int, string> = safe_divide(10, 3);
    let div_err: Result<int, string> = safe_divide(10, 0);
    switch (div_ok) {
        case Ok(v) => io::println("10/3 = " + Integer.toString(v));
        case Err(e) => io::println("Error: " + e);
        default => { }
    }
    switch (div_err) {
        case Ok(v) => io::println("10/0 = " + Integer.toString(v));
        case Err(e) => io::println("Error: " + e);
        default => { }
    }

    // --- Section 7: Bitwise operators ---
    io::println("");
    io::println("=== Bitwise ===");
    io::println("12 & 10 = " + Integer.toString(12 & 10));
    io::println("12 | 10 = " + Integer.toString(12 | 10));
    io::println("12 ^ 10 = " + Integer.toString(12 ^ 10));
    io::println("1 << 3 = " + Integer.toString(1 << 3));
    io::println("16 >> 2 = " + Integer.toString(16 >> 2));

    // --- Section 8: Comparison operators ---
    io::println("");
    io::println("=== Comparison ===");
    io::println("5 < 10: " + Boolean.toString(5 < 10));
    io::println("5 > 10: " + Boolean.toString(5 > 10));
    io::println("5 <= 5: " + Boolean.toString(5 <= 5));
    io::println("5 >= 6: " + Boolean.toString(5 >= 6));
    io::println("5 == 5: " + Boolean.toString(5 == 5));
    io::println("5 != 6: " + Boolean.toString(5 != 6));

    // --- Section 9: String operations ---
    io::println("");
    io::println("=== Strings ===");
    string greeting = "Hello" + " " + "World";
    io::println(greeting);
    string num_str = Integer.toString(42) + " is the answer";
    io::println(num_str);

    // --- Section 10: Enum pattern matching ---
    io::println("");
    io::println("=== Enum Matching ===");
    let north: Direction = North();
    let east: Direction = East();
    let south: Direction = South();
    io::println("North: " + direction_label(north));
    io::println("East: " + direction_label(east));
    io::println("South: " + direction_label(south));

    // --- Section 11: ArrayList and for loop ---
    io::println("");
    io::println("=== ArrayList & For Loop ===");
    let numbers: ArrayList<int> = new ArrayList<int>();
    numbers.add(10);
    numbers.add(20);
    numbers.add(30);
    io::println("Size: " + Integer.toString(numbers.size()));
    for (item in numbers) {
        io::println("item: " + Integer.toString(item));
    }

    // --- Section 12: Casting ---
    io::println("");
    io::println("=== Casting ===");
    let big: long = 99999 as long;
    io::println(Long.toString(big));
    let d: double = 42 as double;
    io::println(Double.toString(d));
    let ch: char = 65 as char;
    io::println(Char.toString(ch));

    // --- Section 13: While loop ---
    io::println("");
    io::println("=== While Loop ===");
    var count: int = 0;
    while (count < 5) {
        io::println("count: " + Integer.toString(count));
        count = count + 1;
    }

    // --- Section 14: Boolean logic ---
    io::println("");
    io::println("=== Logic ===");
    io::println(Boolean.toString(true && false));
    io::println(Boolean.toString(true || false));
    io::println(Boolean.toString(!true));

    // --- Section 15: Quicksort ---
    io::println("");
    io::println("=== Quicksort ===");
    let nums: ArrayList<int> = new ArrayList<int>();
    nums.add(42);
    nums.add(7);
    nums.add(13);
    nums.add(3);
    nums.add(99);
    nums.add(1);
    nums.add(56);
    nums.add(28);
    io::println("Before sort:");
    for (n in nums) {
        io::println("  " + Integer.toString(n));
    }
    quicksort(nums);
    io::println("After sort:");
    for (n in nums) {
        io::println("  " + Integer.toString(n));
    }

    // --- Section 16: File I/O – read numbers, sort, write ---
    io::println("");
    io::println("=== File I/O ===");
    let file_nums: ArrayList<int> = new ArrayList<int>();
    let lines = File.readLines("numbers.txt");
    for (line in lines) {
        int n = Integer.parseOr(line, 0);
        file_nums.add(n);
    }
    io::println("Read " + Integer.toString(file_nums.size()) + " numbers from file");
    quicksort(file_nums);
    io::println("Sorted numbers from file:");
    for (n in file_nums) {
        io::println("  " + Integer.toString(n));
    }
    string sorted_output = "";
    for (n in file_nums) {
        sorted_output = sorted_output + Integer.toString(n) + "\n";
    }
    File.writeFile("sorted_numbers.txt", sorted_output);
    io::println("Wrote sorted numbers to sorted_numbers.txt");

    // --- Section 17: Word Frequency with HashMap ---
    io::println("");
    io::println("=== Word Frequency ===");
    let wc: WordCounter = new WordCounter();
    let word_lines = File.readLines("words.txt");
    for (wline in word_lines) {
        let words = String.split(wline, " ");
        for (word in words) {
            wc.count(word);
        }
    }
    io::println("the: " + Integer.toString(wc.get("the")));
    io::println("fox: " + Integer.toString(wc.get("fox")));
    io::println("brown: " + Integer.toString(wc.get("brown")));
    io::println("dog: " + Integer.toString(wc.get("dog")));
    io::println("quick: " + Integer.toString(wc.get("quick")));
    io::println("lazy: " + Integer.toString(wc.get("lazy")));

    // --- Section 18: C-style for loop ---
    io::println("");
    io::println("=== C-Style For Loop ===");
    for (let i = 0; i < 5; i = i + 1) {
        io::println("i = " + Integer.toString(i));
    }

    // --- Section 19: String methods ---
    io::println("");
    io::println("=== String Methods ===");
    let s = "  hello world  ";
    io::println("original: '" + s + "'");
    io::println("trimmed: '" + s.trim() + "'");
    io::println("length: " + Integer.toString(s.length()));
    let parts = s.trim().split(" ");
    io::println("split size: " + Integer.toString(parts.size()));
    for (let i = 0; i < parts.size(); i = i + 1) {
        io::println("  part " + Integer.toString(i) + ": " + parts.get(i));
    }

    // --- Section 20: HashMap containsKey and keys ---
    io::println("");
    io::println("=== HashMap Methods ===");
    let hmap: HashMap<string, string> = new HashMap<string, string>();
    hmap.put("alpha", "1");
    hmap.put("beta", "2");
    hmap.put("gamma", "3");
    io::println("containsKey alpha: " + Boolean.toString(hmap.containsKey("alpha")));
    io::println("containsKey delta: " + Boolean.toString(hmap.containsKey("delta")));
    let hkeys = hmap.keys();
    io::println("key count: " + Integer.toString(hkeys.size()));
    for (let i = 0; i < hkeys.size(); i = i + 1) {
        let key = hkeys.get(i);
        io::println("  " + key + " => " + hmap.get(key));
    }

    // --- Section 21: Unit type and Ok(()) ---
    io::println("");
    io::println("=== Unit Type ===");
    let unit_result: Result<void, string> = Ok(());
    switch (unit_result) {
        case Ok(_) => io::println("Ok with unit value");
        case Err(e) => io::println("Error: " + e);
        default => { }
    }

    // --- Done ---
    io::println("");
    io::println("=== Mega Test 0.2 Complete ===");
}

// --- Local classes for inheritance testing ---

class Animal {
    string name;

    public Animal(string name) {
        this.name = name;
    }

    public string getName() {
        return this.name;
    }

    public string speak() {
        return "...";
    }
}

class Dog extends Animal {
    string breed;

    public Dog(string name, string breed) {
        super(name);
        this.breed = breed;
    }

    public string speak() {
        return "Woof!";
    }

    public string getBreed() {
        return this.breed;
    }
}

// --- Result helper function ---

fn safe_divide(a: int, b: int): Result<int, string> {
    if (b == 0) {
        return Err("division by zero");
    }
    return Ok(a / b);
}

fn factorial(n: int): int {
    int result = 1;
    int i = 2;
    while (i <= n) {
        result = result * i;
        i = i + 1;
    }
    return result;
}

// --- Enum and pattern matching ---

enum Direction {
    North,
    East,
    South,
    West,
}

fn direction_label(d: Direction): string {
    switch (d) {
        case North() => return "N";
        case East() => return "E";
        case South() => return "S";
        case West() => return "W";
    }
    return "?";
}
