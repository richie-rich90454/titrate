// Errno — C <cerrno> parity.
// Provides a thread-local-style errno global getter/setter, the standard E*
// constants (loaded from data/lang/errno.json), strerror(errno), and
// perror(prefix).
//
// Because Titrate is garbage-collected and does not expose raw errno from
// syscalls, the errno value here is a per-module integer that user code sets
// explicitly via setErrno() after performing an operation that fails. This
// mirrors the C errno macro semantics (a modifiable int lvalue).
import tt::lang::Integer;
import tt::lang::String;
import tt::lang::DataFile;
import tt::json::JsonValue;
import tt::util::HashMap;
import tt::util::ArrayList;

// ---- errno global ----

// Module-level errno value. User code reads via errno() and writes via
// setErrno(). Initialized to 0 (no error).
var _errno: int = 0;

// Get the current errno value (analog of the C `errno` macro read).
public fn errno(): int {
    return _errno;
}

// Set the current errno value (analog of assigning to the C `errno` macro).
public fn setErrno(value: int): void {
    _errno = value;
}

// ---- Data loaded from external JSON via DataFile ----

// name -> numeric value
var _errnoValuesCache: HashMap<string, int> = new HashMap<string, int>();
// value -> message (first match wins for duplicate values like EAGAIN/EWOULDBLOCK)
var _errnoMessagesCache: HashMap<int, string> = new HashMap<int, string>();
// name -> message
var _errnoNameMessagesCache: HashMap<string, string> = new HashMap<string, string>();
// name -> value (reverse lookup is via _errnoValuesCache)
var _errnoDataLoaded: bool = false;

// Load errno data from data/lang/errno.json (once).
fn _ensureErrnoDataLoaded(): void {
    if (_errnoDataLoaded) {
        return;
    }
    let data: JsonValue = DataFile.load("lang/errno.json");
    if (data.isNull() || !data.isObject()) {
        _errnoDataLoaded = true;
        return;
    }
    if (!data.hasKey("codes")) {
        _errnoDataLoaded = true;
        return;
    }
    let codes: JsonValue = data.get("codes");
    if (!codes.isArray()) {
        _errnoDataLoaded = true;
        return;
    }
    var i: int = 0;
    while (i < codes.size()) {
        let entry: JsonValue = codes.getAt(i);
        if (entry.isObject() && entry.hasKey("name") && entry.hasKey("value")) {
            let name: string = entry.get("name").asString();
            let value: int = Integer.parseInt(Double.toString(entry.get("value").asNumber()));
            _errnoValuesCache.put(name, value);
            let message: string = entry.hasKey("message") ? entry.get("message").asString() : name;
            _errnoNameMessagesCache.put(name, message);
            if (!_errnoMessagesCache.containsKey(value)) {
                _errnoMessagesCache.put(value, message);
            }
        }
        i = i + 1;
    }
    _errnoDataLoaded = true;
}

// Look up the numeric value for an errno constant name.
// Returns -1 if the name is not found.
public fn errnoValue(name: string): int {
    _ensureErrnoDataLoaded();
    if (_errnoValuesCache.containsKey(name)) {
        return _errnoValuesCache.get(name);
    }
    return -1;
}

// Look up the human-readable message for an errno value.
// Returns "Unknown error N" if the value is not recognized.
public fn strerror(err: int): string {
    _ensureErrnoDataLoaded();
    if (err == 0) {
        return "Success";
    }
    if (_errnoMessagesCache.containsKey(err)) {
        return _errnoMessagesCache.get(err);
    }
    return "Unknown error " + Integer.toString(err);
}

// Look up the human-readable message for an errno constant name.
// Returns the name itself if the name is not recognized.
public fn strerrorByName(name: string): string {
    _ensureErrnoDataLoaded();
    if (_errnoNameMessagesCache.containsKey(name)) {
        return _errnoNameMessagesCache.get(name);
    }
    return name;
}

// Print "<prefix>: <strerror(errno)>\n" to standard error (analog of C perror).
// If prefix is null or empty, only the strerror is printed.
public fn perror(prefix: string): void {
    let msg: string = strerror(_errno);
    if (prefix == null || String.length(prefix) == 0) {
        io::println(msg);
        return;
    }
    io::println(prefix + ": " + msg);
}

// Print "<prefix>: <strerror(err)>\n" for an explicit errno value.
public fn perrorErr(prefix: string, err: int): void {
    let msg: string = strerror(err);
    if (prefix == null || String.length(prefix) == 0) {
        io::println(msg);
        return;
    }
    io::println(prefix + ": " + msg);
}

// ---- Standard E* constants (loaded from data file) ----
// These are resolved at first access via errnoValue() so the data file is the
// single source of truth (no hardcoded lookup tables, per AGENTS.md).

public const EPERM: int = _resolveConst("EPERM", 1);
public const ENOENT: int = _resolveConst("ENOENT", 2);
public const ESRCH: int = _resolveConst("ESRCH", 3);
public const EINTR: int = _resolveConst("EINTR", 4);
public const EIO: int = _resolveConst("EIO", 5);
public const ENXIO: int = _resolveConst("ENXIO", 6);
