public const EOWNERDEAD: int = _resolveConst("EOWNERDEAD", 130);
public const ENOTRECOVERABLE: int = _resolveConst("ENOTRECOVERABLE", 131);

// Internal: resolve a constant by name from the data file, falling back to
// `defaultVal` if the data file is unavailable or the name is missing.
fn _resolveConst(name: string, defaultVal: int): int {
    _ensureErrnoDataLoaded();
    if (_errnoValuesCache.containsKey(name)) {
        return _errnoValuesCache.get(name);
    }
    return defaultVal;
}

// List all known errno constant names (loaded from the data file).
public fn listNames(): ArrayList<string> {
    _ensureErrnoDataLoaded();
    let result: ArrayList<string> = new ArrayList<string>();
    let keys: ArrayList<string> = _errnoValuesCache.keys();
    var i: int = 0;
    while (i < keys.size()) {
        result.add(keys.get(i));
        i = i + 1;
    }
    return result;
}

// Clear the errno value to 0 (no error). Convenience wrapper.
public fn clearErrno(): void {
    _errno = 0;
}
