public const EMSGSIZE: int = _resolveConst("EMSGSIZE", 90);
public const EPROTOTYPE: int = _resolveConst("EPROTOTYPE", 91);
public const ENOPROTOOPT: int = _resolveConst("ENOPROTOOPT", 92);
public const EPROTONOSUPPORT: int = _resolveConst("EPROTONOSUPPORT", 93);
public const ESOCKTNOSUPPORT: int = _resolveConst("ESOCKTNOSUPPORT", 94);
public const EOPNOTSUPP: int = _resolveConst("EOPNOTSUPP", 95);
public const EPFNOSUPPORT: int = _resolveConst("EPFNOSUPPORT", 96);
