fn toString(value: bool): string {
    return value.toString();
}

fn parseBoolean(s: string): bool {
    if (s == "true") {
        return true;
    }
    return false;
}

fn logicalAnd(a: bool, b: bool): bool {
    return a && b;
}

fn logicalOr(a: bool, b: bool): bool {
    return a || b;
}

fn logicalNot(a: bool): bool {
    return !a;
}
