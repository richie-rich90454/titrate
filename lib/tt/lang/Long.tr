// Static utility methods for the Long type.
public fn parse(s: string): long {
    return Long::parseLong(s);
}

public fn toString(value: long): string {
    return value.toString();
}

public fn MAX_VALUE(): long {
    return 9223372036854775807;
}

public fn MIN_VALUE(): long {
    return -9223372036854775808;
}
