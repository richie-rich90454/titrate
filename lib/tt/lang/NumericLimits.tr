// Numeric limits constants and query functions for Titrate numeric types.
import tt::lang::DataFile;
import tt::json::JsonValue;
import tt::util::HashMap;

// ---- Data loaded from external JSON via DataFile ----

let _limitsCache: HashMap<string, JsonValue> = new HashMap<string, JsonValue>();
var _limitsLoaded: bool = false;

fn _ensureLimitsLoaded(): void {
    if (_limitsLoaded) {
        return;
    }
    let data: JsonValue = DataFile.load("lang/numeric_limits.json");
    if (data.isNull() || !data.isObject()) {
        _limitsLoaded = true;
        return;
    }
    if (!data.hasKey("limits")) {
        _limitsLoaded = true;
        return;
    }
    let limits: JsonValue = data.get("limits");
    if (!limits.isObject()) {
        _limitsLoaded = true;
        return;
    }
    let keys: ArrayList<string> = limits.keys();
    var i: int = 0;
    while (i < keys.size()) {
        let key: string = keys.get(i);
        let val: JsonValue = limits.get(key);
        _limitsCache.put(key, val);
        i = i + 1;
    }
    _limitsLoaded = true;
}

fn _getLimitInt(typeName: string, field: string, defaultVal: int): int {
    _ensureLimitsLoaded();
    if (_limitsCache.containsKey(typeName)) {
        let entry: JsonValue = _limitsCache.get(typeName);
        if (entry.isObject() && entry.hasKey(field)) {
            return entry.get(field).asNumber() as int;
        }
    }
    return defaultVal;
}

fn _getLimitLong(typeName: string, field: string, defaultVal: long): long {
    _ensureLimitsLoaded();
    if (_limitsCache.containsKey(typeName)) {
        let entry: JsonValue = _limitsCache.get(typeName);
        if (entry.isObject() && entry.hasKey(field)) {
            return entry.get(field).asNumber() as long;
        }
    }
    return defaultVal;
}

fn _getLimitDouble(typeName: string, field: string, defaultVal: double): double {
    _ensureLimitsLoaded();
    if (_limitsCache.containsKey(typeName)) {
        let entry: JsonValue = _limitsCache.get(typeName);
        if (entry.isObject() && entry.hasKey(field)) {
            return entry.get(field).asNumber();
        }
    }
    return defaultVal;
}

// Integer limits
public const INT_MAX: int = _getLimitInt("int", "max", 2147483647);
public const INT_MIN: int = _getLimitInt("int", "min", -2147483648);
public const LONG_MAX: long = _getLimitLong("long", "max", 9223372036854775807);
public const LONG_MIN: long = _getLimitLong("long", "min", -9223372036854775808);

// Floating-point limits
public const DOUBLE_MAX: double = _getLimitDouble("double", "max", 1.7976931348623157e+308);
public const DOUBLE_MIN: double = _getLimitDouble("double", "min", 4.9e-324);
public const DOUBLE_EPSILON: double = _getLimitDouble("double", "epsilon", 2.220446049250313e-16);
public const DOUBLE_NAN: double = 0.0 / 0.0;
public const DOUBLE_INF: double = 1.0 / 0.0;
public const DOUBLE_NEG_INF: double = -1.0 / 0.0;

public const FLOAT_MAX: double = _getLimitDouble("float", "max", 3.4028234663852886e+38);
public const FLOAT_MIN: double = _getLimitDouble("float", "min", 1.1754943508222875e-38);
public const FLOAT_EPSILON: double = _getLimitDouble("float", "epsilon", 1.1920928955078125e-07);

// Byte and Short limits
public const BYTE_MAX: int = _getLimitInt("byte", "max", 127);
public const BYTE_MIN: int = _getLimitInt("byte", "min", -128);
public const SHORT_MAX: int = _getLimitInt("short", "max", 32767);
public const SHORT_MIN: int = _getLimitInt("short", "min", -32768);

// Integer query functions
public fn intMax(): int {
    return _getLimitInt("int", "max", 2147483647);
}

public fn intMin(): int {
    return _getLimitInt("int", "min", -2147483648);
}

public fn longMax(): long {
    return _getLimitLong("long", "max", 9223372036854775807);
}

public fn longMin(): long {
    return _getLimitLong("long", "min", -9223372036854775808);
}

// Double query functions
public fn doubleMax(): double {
    return _getLimitDouble("double", "max", 1.7976931348623157e+308);
}

public fn doubleMin(): double {
    return _getLimitDouble("double", "min", 4.9e-324);
}

public fn doubleEpsilon(): double {
    return _getLimitDouble("double", "epsilon", 2.220446049250313e-16);
}

public fn doubleNaN(): double {
    return DOUBLE_NAN;
}

public fn doubleInf(): double {
    return DOUBLE_INF;
}

public fn doubleNegInf(): double {
    return DOUBLE_NEG_INF;
}

// Float query functions
public fn floatMax(): double {
    return _getLimitDouble("float", "max", 3.4028234663852886e+38);
}

public fn floatMin(): double {
    return _getLimitDouble("float", "min", 1.1754943508222875e-38);
}

public fn floatEpsilon(): double {
    return _getLimitDouble("float", "epsilon", 1.1920928955078125e-07);
}

// Byte and Short query functions
public fn byteMax(): int {
    return _getLimitInt("byte", "max", 127);
}

public fn byteMin(): int {
    return _getLimitInt("byte", "min", -128);
}

public fn shortMax(): int {
    return _getLimitInt("short", "max", 32767);
}

public fn shortMin(): int {
    return _getLimitInt("short", "min", -32768);
}

// Half (16-bit float) limits
public const HALF_MAX: double = _getLimitDouble("half", "max", 65504.0);
public const HALF_MIN: double = _getLimitDouble("half", "min", 5.960464477539063e-08);
public const HALF_EPSILON: double = _getLimitDouble("half", "epsilon", 9.765625e-04);

// Quad (128-bit float) limits (approximate)
public const QUAD_MAX: double = _getLimitDouble("quad", "max", 1.189731495357231765e+4932);
public const QUAD_MIN: double = _getLimitDouble("quad", "min", 6.4751751194380251109e-4966);
public const QUAD_EPSILON: double = _getLimitDouble("quad", "epsilon", 1.925929944387235853e-34);

// Unsigned integer limits
public const U8_MAX: int = _getLimitInt("u8", "max", 255);
public const U16_MAX: int = _getLimitInt("u16", "max", 65535);
public const U32_MAX: long = _getLimitLong("u32", "max", 4294967295);
public const U64_MAX: long = _getLimitLong("u64", "max", -1L);

// Classification functions
public fn isFinite(x: double): bool {
    return Double.isFinite(x);
}

public fn isInfinite(x: double): bool {
    return Double.isInfinite(x);
}

public fn isNaN(x: double): bool {
    return Double.isNaN(x);
}

public fn isSubnormal(x: double): bool {
    let absX: double = Math_abs(x);
    return absX > 0.0 && absX < DOUBLE_MIN;
}

public fn signbit(x: double): bool {
    return x < 0.0 || (x == 0.0 && (1.0 / x) < 0.0);
}

// Half query functions
public fn halfMax(): double {
    return _getLimitDouble("half", "max", 65504.0);
}

public fn halfMin(): double {
    return _getLimitDouble("half", "min", 5.960464477539063e-08);
}

public fn halfEpsilon(): double {
    return _getLimitDouble("half", "epsilon", 9.765625e-04);
}

// Quad query functions
public fn quadMax(): double {
    return _getLimitDouble("quad", "max", 1.189731495357231765e+4932);
}

public fn quadMin(): double {
    return _getLimitDouble("quad", "min", 6.4751751194380251109e-4966);
}

public fn quadEpsilon(): double {
    return _getLimitDouble("quad", "epsilon", 1.925929944387235853e-34);
}

// Unsigned integer query functions
public fn u8Max(): int {
    return _getLimitInt("u8", "max", 255);
}

public fn u16Max(): int {
    return _getLimitInt("u16", "max", 65535);
}

public fn u32Max(): long {
    return _getLimitLong("u32", "max", 4294967295);
}

public fn u64Max(): long {
    return _getLimitLong("u64", "max", -1L);
}

// Additional classification functions
public fn infinity(): double {
    return DOUBLE_INF;
}

public fn quietNaN(): double {
    return DOUBLE_NAN;
}

public fn denormMin(): double {
    return DOUBLE_MIN;
}

public fn lowest(): double {
    return DOUBLE_NEG_INF;
}
