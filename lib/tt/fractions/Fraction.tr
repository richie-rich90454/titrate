// Fraction provides exact rational arithmetic with automatic GCD reduction.
import tt::lang::Long;
import tt::lang::Double;
import tt::lang::String;
import tt::lang::Integer;
import tt::util::ArrayList;

public class Fraction {
    public long numerator;
    public long denominator;

    public fn init(num: long, den: long) {
        if (den == 0L) {
            this.numerator = 0L;
            this.denominator = 1L;
        } else if (den < 0L) {
            let g: long = gcd(absLong(num), absLong(den));
            this.numerator = -num / g;
            this.denominator = -den / g;
        } else {
            let g: long = gcd(absLong(num), absLong(den));
            this.numerator = num / g;
            this.denominator = den / g;
        }
    }

    // ---- Static helpers ----

    // Greatest common divisor using Euclidean algorithm.
    public fn absLong(x: long): long {
        if (x < 0L) { return -x; }
        return x;
    }

    // ---- Arithmetic ----

    public fn add(other: Fraction): Fraction {
        let commonDen: long = lcm(this.denominator, other.denominator);
        let a: long = this.numerator * (commonDen / this.denominator);
        let b: long = other.numerator * (commonDen / other.denominator);
        return new Fraction(a + b, commonDen);
    }

    public fn sub(other: Fraction): Fraction {
        let commonDen: long = lcm(this.denominator, other.denominator);
        let a: long = this.numerator * (commonDen / this.denominator);
        let b: long = other.numerator * (commonDen / other.denominator);
        return new Fraction(a - b, commonDen);
    }

    public fn mul(other: Fraction): Fraction {
        return new Fraction(this.numerator * other.numerator, this.denominator * other.denominator);
    }

    public fn div(other: Fraction): Fraction {
        if (other.numerator == 0L) {
            return new Fraction(0L, 1L);
        }
        return new Fraction(this.numerator * other.denominator, this.denominator * other.numerator);
    }

    public fn negate(): Fraction {
        return new Fraction(-this.numerator, this.denominator);
    }

    public fn reciprocal(): Fraction {
        if (this.numerator == 0L) {
            return new Fraction(0L, 1L);
        }
        return new Fraction(this.denominator, this.numerator);
    }

    // ---- Conversion ----

    public fn toDouble(): double {
        return this.numerator as double / this.denominator as double;
    }

    public fn toFloat(): double {
        return this.toDouble();
    }

    public fn toInt(): int {
        return (this.numerator / this.denominator) as int;
    }

    // Return a reduced copy (already reduced by constructor, but re-reduces).
    public fn reduce(): Fraction {
        let g: long = gcd(absLong(this.numerator), absLong(this.denominator));
        if (this.denominator < 0L) {
            return new Fraction(-this.numerator / g, -this.denominator / g);
        }
        return new Fraction(this.numerator / g, this.denominator / g);
    }

    // Absolute value of the fraction.
    public fn abs(): Fraction {
        if (this.numerator < 0L) {
            return new Fraction(-this.numerator, this.denominator);
        }
        return new Fraction(this.numerator, this.denominator);
    }

    // ---- Comparison ----

    public fn equals(other: Fraction): bool {
        return this.numerator == other.numerator && this.denominator == other.denominator;
    }

    public fn compareTo(other: Fraction): int {
        // Compare a/b vs c/d using a*d vs c*b
        let left: long = this.numerator * other.denominator;
        let right: long = other.numerator * this.denominator;
        if (left < right) { return -1; }
        if (left > right) { return 1; }
        return 0;
    }

    public fn toString(): string {
        if (this.denominator == 1L) {
            return Long.toString(this.numerator);
        }
        return Long.toString(this.numerator) + "/" + Long.toString(this.denominator);
    }
}

// Greatest common divisor using Euclidean algorithm.
fn gcd(a: long, b: long): long {
    let x: long = a;
    let y: long = b;
    if (x < 0L) { x = -x; }
    if (y < 0L) { y = -y; }
    while (y != 0L) {
        let t: long = y;
        y = x % y;
        x = t;
    }
    return x;
}

// Least common multiple.
fn lcm(a: long, b: long): long {
    if (a == 0L || b == 0L) { return 0L; }
    let g: long = gcd(a, b);
    return absLong(a) / g * absLong(b);
}

fn absLong(x: long): long {
    if (x < 0L) { return -x; }
    return x;
}

// Create a Fraction from a double using continued fraction expansion.
fn fromDouble(d: double): Fraction {
    if (d == 0.0) { return new Fraction(0L, 1L); }
    let negative: bool = false;
    if (d < 0.0) {
        negative = true;
        d = -d;
    }
    let maxDen: long = 1000000000L;
    // Continued fraction expansion
    let h1: long = 1L;
    let k1: long = 0L;
    let h2: long = 0L;
    let k2: long = 1L;
    let x: double = d;
    let iter: int = 0;
    while (iter < 50) {
        let a: long = x as long;
        let remainder: double = x - a as double;
        if (remainder < 1e-15) { break; }
        let h: long = a * h1 + h2;
        let k: long = a * k1 + k2;
        if (k > maxDen) { break; }
        h2 = h1;
        k2 = k1;
        h1 = h;
        k1 = k;
        if (remainder < 1e-15) { break; }
        x = 1.0 / remainder;
        iter = iter + 1;
    }
    let num: long = h1;
    let den: long = k1;
    if (den == 0L) { den = 1L; }
    if (negative) { num = -num; }
    return new Fraction(num, den);
}

// Create a Fraction from a string like "3/4" or "5".
fn fromString(s: string): Fraction {
    let parts: ArrayList<string> = String::split(s, "/");
    if (parts.size() == 1) {
        let num: long = Long.parseLong(parts.get(0));
        return new Fraction(num, 1L);
    }
    if (parts.size() >= 2) {
        let num: long = Long.parseLong(parts.get(0));
        let den: long = Long.parseLong(parts.get(1));
        return new Fraction(num, den);
    }
    return new Fraction(0L, 1L);
}
