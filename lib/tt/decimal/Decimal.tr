// Decimal provides arbitrary-precision decimal arithmetic using string-based representation.
import tt::lang::String;
import tt::lang::Integer;
import tt::lang::Long;
import tt::lang::Double;
import tt::util::ArrayList;
import tt::decimal::DecimalArithmetic;

public class Decimal {
    // Sign: true = negative, false = positive or zero
    public bool negative;
    // Digits stored as string (no leading zeros, except "0" for zero)
    public string digits;
    // Number of digits after the decimal point
    public int scale;

    public fn init(value: string) {
        // Parse from string
        let neg: bool = false;
        let s: string = value;
        if (String.length(s) > 0 && String.charAt(s, 0) == "-") {
            neg = true;
            s = String.substring(s, 1, String.length(s));
        } else if (String.length(s) > 0 && String.charAt(s, 0) == "+") {
            s = String.substring(s, 1, String.length(s));
        }
        let dotPos: int = String.indexOf(s, ".");
        if (dotPos < 0) {
            this.digits = DecimalArithmetic.stripLeadingZeros(s);
            this.scale = 0;
        } else {
            let intPart: string = String.substring(s, 0, dotPos);
            let fracPart: string = String.substring(s, dotPos + 1, String.length(s));
            this.digits = DecimalArithmetic.stripLeadingZeros(intPart + fracPart);
            this.scale = String.length(fracPart);
        }
        if (String.length(this.digits) == 0) { this.digits = "0"; }
        this.negative = neg;
        if (DecimalArithmetic.isZeroStr(this.digits)) {
            this.negative = false;
        }
    }
    // Private constructor from components
    private fn initFrom(neg: bool, digs: string, sc: int) {
        this.digits = DecimalArithmetic.stripLeadingZeros(digs);
        if (String.length(this.digits) == 0) { this.digits = "0"; }
        this.scale = sc;
        this.negative = neg;
        if (DecimalArithmetic.isZeroStr(this.digits)) {
            this.negative = false;
        }
    }
    // ---- Arithmetic ----

    public fn add(other: Decimal): Decimal {
        let aligned: (string, string) = DecimalArithmetic.alignScales(this.digits, this.scale, other.digits, other.scale);
        let a: string = aligned.0;
        let b: string = aligned.1;
        let newScale: int = this.scale;
        if (other.scale > newScale) { newScale = other.scale; }
        if (this.negative == other.negative) {
            let sum: string = DecimalArithmetic.addDigitStrings(a, b);
            return new Decimal().initFrom(this.negative, sum, newScale);
        }
        let cmp: int = DecimalArithmetic.compareDigitStrings(a, b);
        if (cmp == 0) { return new Decimal().initFrom(false, "0", 0); }
        if (cmp > 0) {
            let diff: string = DecimalArithmetic.subDigitStrings(a, b);
            return new Decimal().initFrom(this.negative, diff, newScale);
        }
        let diff: string = DecimalArithmetic.subDigitStrings(b, a);
        return new Decimal().initFrom(other.negative, diff, newScale);
    }

    public fn sub(other: Decimal): Decimal {
        let negOther: Decimal = new Decimal().initFrom(!other.negative, other.digits, other.scale);
        return this.add(negOther);
    }

    public fn mul(other: Decimal): Decimal {
        let product: string = DecimalArithmetic.mulDigitStrings(this.digits, other.digits);
        let newScale: int = this.scale + other.scale;
        let neg: bool = this.negative != other.negative;
        return new Decimal().initFrom(neg, product, newScale);
    }

    public fn div(other: Decimal): Decimal {
        if (DecimalArithmetic.isZeroStr(other.digits)) {
            return new Decimal().initFrom(false, "0", 0);
        }
        // Multiply numerator by 10^precision to get desired decimal places
        let precision: int = 20;
        let paddedNum: string = this.digits;
        let i: int = 0;
        while (i < precision) {
            paddedNum = paddedNum + "0";
            i = i + 1;
        }
        // Adjust for scales
        let effectiveScale: int = this.scale - other.scale + precision;
        // Long division
        let quotient: string = "";
        let remainder: string = "";
        let idx: int = 0;
        while (idx < String.length(paddedNum) || !DecimalArithmetic.isZeroStr(remainder)) {
            let digit: int = 0;
            if (idx < String.length(paddedNum)) {
                digit = String.charAt(paddedNum, idx) - String.charAt("0", 0);
            }
            remainder = remainder + Integer.toString(digit);
            remainder = DecimalArithmetic.stripLeadingZeros(remainder);
            if (DecimalArithmetic.isZeroStr(remainder)) { remainder = ""; }
            let count: int = 0;
            while (DecimalArithmetic.compareDigitStrings(remainder, other.digits) >= 0 && !DecimalArithmetic.isZeroStr(remainder)) {
                remainder = DecimalArithmetic.subDigitStrings(remainder, other.digits);
                count = count + 1;
            }
            quotient = quotient + Integer.toString(count);
            idx = idx + 1;
            if (idx > String.length(paddedNum) + precision) { break; }
        }
        quotient = DecimalArithmetic.stripLeadingZeros(quotient);
        if (DecimalArithmetic.isZeroStr(quotient)) { quotient = "0"; }
        let neg: bool = this.negative != other.negative;
        return new Decimal().initFrom(neg, quotient, effectiveScale);
    }

    // ---- Comparison ----

    public fn compareTo(other: Decimal): int {
        if (this.negative && !other.negative) { return -1; }
        if (!this.negative && other.negative) { return 1; }
        let aligned: (string, string) = DecimalArithmetic.alignScales(this.digits, this.scale, other.digits, other.scale);
        let a: string = aligned.0;
        let b: string = aligned.1;
        let cmp: int = DecimalArithmetic.compareDigitStrings(a, b);
        if (this.negative) { cmp = -cmp; }
        return cmp;
    }

    public fn equals(other: Decimal): bool {
        return this.compareTo(other) == 0;
    }

    // ---- Conversion ----

    public fn toString(): string {
        let result: string = "";
        if (this.negative) { result = result + "-"; }
        if (this.scale == 0) {
            result = result + this.digits;
            return result;
        }
        let intLen: int = String.length(this.digits) - this.scale;
        if (intLen <= 0) {
            result = result + "0.";
            let i: int = 0;
            while (i < -intLen) {
                result = result + "0";
                i = i + 1;
            }
            result = result + this.digits;
        } else {
            let intPart: string = String.substring(this.digits, 0, intLen);
            let fracPart: string = String.substring(this.digits, intLen, String.length(this.digits));
            result = result + intPart + "." + fracPart;
        }
        return result;
    }

    public fn toDouble(): double {
        let s: string = this.toString();
        return Double.parseDouble(s);
    }

    // Round to the given number of decimal places using the specified mode.
    public fn round(places: int, mode: string): Decimal {
        // Shift by 10^places, round, shift back
        let shift: Decimal = Decimal.pow10(places);
        let shifted: Decimal = this.mul(shift);
        let rounded: Decimal = Decimal.applyRounding(shifted, mode);
        let unshifted: Decimal = rounded.div(shift);
        return unshifted;
    }

    // Quantize to the same exponent as the given Decimal.
    public fn quantize(exp: Decimal): Decimal {
        return this.round(exp.scale, "half_even");
    }

    // Absolute value.
    public fn abs(): Decimal {
        return new Decimal().initFrom(false, this.digits, this.scale);
    }

    // Negate the value.
    public fn negate(): Decimal {
        if (DecimalArithmetic.isZeroStr(this.digits)) {
            return new Decimal().initFrom(false, this.digits, this.scale);
        }
        return new Decimal().initFrom(!this.negative, this.digits, this.scale);
    }

    // Remove trailing zeros from the fractional part.
    public fn stripTrailingZeros(): Decimal {
        if (this.scale == 0) { return new Decimal().initFrom(this.negative, this.digits, this.scale); }
        var digs: string = this.digits;
        var sc: int = this.scale;
        while (sc > 0 && String.length(digs) > 0) {
            let lastChar: string = String.charAt(digs, String.length(digs) - 1);
            if (lastChar == "0") {
                digs = String.substring(digs, 0, String.length(digs) - 1);
                sc = sc - 1;
            } else {
                break;
            }
        }
        if (String.length(digs) == 0) { digs = "0"; }
        return new Decimal().initFrom(this.negative, digs, sc);
    }

    // Return -1, 0, or 1 depending on the sign.
    public fn signum(): int {
        if (DecimalArithmetic.isZeroStr(this.digits)) { return 0; }
        if (this.negative) { return -1; }
        return 1;
    }

    // Modulo operation (result has same sign as this).
    public fn mod(other: Decimal): Decimal {
        // a mod b = a - (a / b).truncated * b
        let quotient: Decimal = this.div(other);
        let truncated: Decimal = Decimal.truncate(quotient);
        return this.sub(truncated.mul(other));
    }

    // Remainder operation (result has same sign as divisor).
    public fn remainder(other: Decimal): Decimal {
        let m: Decimal = this.mod(other);
        // If signs differ and result is non-zero, add divisor
        if (!DecimalArithmetic.isZeroStr(m.digits) && this.negative != other.negative) {
            m = m.add(other);
        }
        return m;
    }

    // ---- Static helpers ----

    // Apply rounding mode to a Decimal value (round to integer).
    public fn applyRounding(d: Decimal, mode: string): Decimal {
        var intPart: string = "";
        var intLen: int = 0;
        if (d.scale == 0) {
            intPart = d.digits;
            intLen = String.length(d.digits);
        } else {
            intLen = String.length(d.digits) - d.scale;
            if (intLen > 0) {
                intPart = String.substring(d.digits, 0, intLen);
            }
        }
        if (intLen <= 0) { intPart = "0"; }
        // Get the fractional digit for rounding decisions
        let fracDigit: int = 0;
        if (d.scale > 0 && String.length(d.digits) > 0) {
            let intLen2: int = String.length(d.digits) - d.scale;
            if (intLen2 >= 0 && intLen2 < String.length(d.digits)) {
                let fracChar: string = String.charAt(d.digits, intLen2);
                fracDigit = String.charAt(fracChar, 0) - String.charAt("0", 0);
            }
        }
        let intVal: long = Long.parseLong(intPart);
        if (mode == "up") {
            // Round away from zero
            if (!DecimalArithmetic.isZeroStr(d.digits) && d.scale > 0) {
                if (d.negative) {
                    return new Decimal().initFrom(true, Long.toString(intVal - 1L), 0);
                }
                return new Decimal().initFrom(false, Long.toString(intVal + 1L), 0);
            }
            return new Decimal().initFrom(d.negative, Long.toString(intVal), 0);
        } else if (mode == "down") {
            // Truncate toward zero
            return new Decimal().initFrom(d.negative, Long.toString(intVal), 0);
        } else if (mode == "ceiling") {
            // Round toward +infinity
            if (!DecimalArithmetic.isZeroStr(d.digits) && d.scale > 0) {
                if (!d.negative) {
                    return new Decimal().initFrom(false, Long.toString(intVal + 1L), 0);
                }
            }
            return new Decimal().initFrom(d.negative, Long.toString(intVal), 0);
        } else if (mode == "floor") {
            // Round toward -infinity
            if (!DecimalArithmetic.isZeroStr(d.digits) && d.scale > 0) {
                if (d.negative) {
                    return new Decimal().initFrom(true, Long.toString(intVal + 1L), 0);
                }
            }
            return new Decimal().initFrom(d.negative, Long.toString(intVal), 0);
        } else if (mode == "half_up") {
            if (fracDigit >= 5) {
                if (d.negative) {
                    return new Decimal().initFrom(true, Long.toString(intVal + 1L), 0);
                }
                return new Decimal().initFrom(false, Long.toString(intVal + 1L), 0);
            }
            return new Decimal().initFrom(d.negative, Long.toString(intVal), 0);
        } else if (mode == "half_down") {
            if (fracDigit > 5) {
                if (d.negative) {
                    return new Decimal().initFrom(true, Long.toString(intVal + 1L), 0);
                }
                return new Decimal().initFrom(false, Long.toString(intVal + 1L), 0);
            }
            return new Decimal().initFrom(d.negative, Long.toString(intVal), 0);
        } else if (mode == "half_even") {
            // Banker's rounding
            let lastIntDigit: int = 0;
            if (String.length(intPart) > 0) {
                lastIntDigit = String.charAt(String.charAt(intPart, String.length(intPart) - 1), 0) - String.charAt("0", 0);
            }
            if (fracDigit > 5 || (fracDigit == 5 && lastIntDigit % 2 != 0)) {
                if (d.negative) {
                    return new Decimal().initFrom(true, Long.toString(intVal + 1L), 0);
                }
                return new Decimal().initFrom(false, Long.toString(intVal + 1L), 0);
            }
            return new Decimal().initFrom(d.negative, Long.toString(intVal), 0);
        }
        // Default: half_up
        if (fracDigit >= 5) {
            if (d.negative) {
                return new Decimal().initFrom(true, Long.toString(intVal + 1L), 0);
            }
            return new Decimal().initFrom(false, Long.toString(intVal + 1L), 0);
        }
        return new Decimal().initFrom(d.negative, Long.toString(intVal), 0);
    }

    // Truncate a Decimal toward zero.
    public fn truncate(d: Decimal): Decimal {
        if (d.scale == 0) {
            return new Decimal().initFrom(d.negative, d.digits, 0);
        }
        let intLen: int = String.length(d.digits) - d.scale;
        if (intLen <= 0) {
            return new Decimal().initFrom(false, "0", 0);
        }
        let intPart: string = String.substring(d.digits, 0, intLen);
        return new Decimal().initFrom(d.negative, intPart, 0);
    }

    // Compute 10^n as a Decimal.
    public fn pow10(n: int): Decimal {
        if (n == 0) { return new Decimal("1"); }
        if (n > 0) {
            var result: string = "1";
            var i: int = 0;
            while (i < n) {
                result = result + "0";
                i = i + 1;
            }
            return new Decimal(result);
        }
        // Negative: 10^(-n) = 0.00...01
        var result: string = "1";
        var i: int = 0;
        while (i < -n - 1) {
            result = "0" + result;
            i = i + 1;
        }
        return new Decimal("0." + result);
    }
}

// RoundingMode provides string constants for rounding modes.
public class RoundingMode {
    public string UP;
    public string DOWN;
    public string CEILING;
    public string FLOOR;
    public string HALF_UP;
    public string HALF_DOWN;
    public string HALF_EVEN;

    public fn init() {
        this.UP = "up";
        this.DOWN = "down";
        this.CEILING = "ceiling";
        this.FLOOR = "floor";
        this.HALF_UP = "half_up";
        this.HALF_DOWN = "half_down";
        this.HALF_EVEN = "half_even";
    }
}

// DecimalContext provides precision and rounding mode for Decimal operations.
public class DecimalContext {
    public int precision;
    public string roundingMode;

    public fn init(precision: int, roundingMode: string) {
        this.precision = precision;
        this.roundingMode = roundingMode;
    }

    // Divide two Decimals using this context's precision and rounding mode.
    public fn divide(a: Decimal, b: Decimal): Decimal {
        // Perform division with extra precision, then round
        let result: Decimal = a.div(b);
        return result.round(this.precision, this.roundingMode);
    }
}

fn fromString(s: string): Decimal {
    return new Decimal(s);
}
