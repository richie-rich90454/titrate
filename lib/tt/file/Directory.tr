// Directory operations backed by VM built-ins.
import tt::util::ArrayList;

public class Directory {
    private string path;

    fn init(p: string) {
        this.path = p;
    }

    public fn list(): ArrayList<string> {
        return Dir_list(this.path);
    }

    public fn walk(): ArrayList<string> {
        return Dir_walk(this.path);
    }

    public fn create(): bool {
        return Dir_create(this.path);
    }

    public fn remove(): bool {
        return Dir_remove(this.path);
    }

    public fn copy(dest: string): bool {
        return Dir_copy(this.path, dest);
    }

    public fn move(dest: string): bool {
        return Dir_move(this.path, dest);
    }

    public fn exists(): bool {
        return Path_exists(this.path);
    }

    public fn size(): int {
        return Fs_size(this.path);
    }

    public fn isEmpty(): bool {
        let entries: ArrayList<string> = Dir_list(this.path);
        return entries.size() == 0;
    }

    public fn listFiles(): ArrayList<string> {
        // Dir_list returns all entries; filter to files using Fs_isFile
        let all: ArrayList<string> = Dir_list(this.path);
        let files: ArrayList<string> = new ArrayList<string>();
        var i: int = 0;
        while (i < all.size()) {
            let entry: string = all.get(i);
            let fullPath: string = Path_join(this.path, entry);
            if (Fs_isFile(fullPath)) {
                files.add(entry);
            }
            i = i + 1;
        }
        return files;
    }
}

fn getCurrent(): string {
    return Sys_workingDir();
}

fn setCurrent(path: string): void {
    // No native for setWorkingDir; no-op
}
