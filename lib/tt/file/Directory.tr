// Directory operations backed by VM built-ins.
import tt::util::ArrayList;

public class Directory {
    private String path;

    public Directory(String p) {
        this.path = p;
    }

    public ArrayList<String> list() {
        return Dir_list(this.path);
    }

    public ArrayList<String> walk() {
        return Dir_walk(this.path);
    }

    public bool create() {
        return Dir_create(this.path);
    }

    public bool remove() {
        return Dir_remove(this.path);
    }

    public bool copy(String dest) {
        return Dir_copy(this.path, dest);
    }

    public bool move(String dest) {
        return Dir_move(this.path, dest);
    }

    public bool exists() {
        return Path_exists(this.path);
    }

    public static String getCurrent() {
        return Sys_workingDir();
    }

    public static void setCurrent(String path) {
        // No native for setWorkingDir; no-op
    }

    public ArrayList<String> listFiles() {
        // Dir_list returns all entries; filter to files using Fs_isFile
        ArrayList<String> all = Dir_list(this.path);
        ArrayList<String> files = new ArrayList<String>();
        int i = 0;
        while (i < all.size()) {
            String entry = all.get(i);
            String fullPath = Path_join(this.path, entry);
            if (Fs_isFile(fullPath)) {
                files.add(entry);
            }
            i = i + 1;
        }
        return files;
    }

    public int size() {
        return Fs_size(this.path);
    }

    public bool isEmpty() {
        ArrayList<String> entries = Dir_list(this.path);
        return entries.size() == 0;
    }
}
