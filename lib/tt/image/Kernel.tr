// Kernel.tr — Convolution kernels for image processing
import tt::util::ArrayList;
import tt::math::MathAdvanced;

public class Kernel {
    public ArrayList<ArrayList<double>> data;
    public int width;
    public int height;

    public fn init(w: int, h: int) {
        this.width = w;
        this.height = h;
        this.data = new ArrayList<ArrayList<double>>();
        var i: int = 0;
        while (i < h) {
            let row: ArrayList<double> = new ArrayList<double>();
            var j: int = 0;
            while (j < w) {
                row.add(0.0);
                j = j + 1;
            }
            this.data.add(row);
            i = i + 1;
        }
    }

    public fn set(row: int, col: int, val: double): void {
        this.data.get(row).set(col, val);
    }

    public fn get(row: int, col: int): double {
        return this.data.get(row).get(col);
    }
}

public fn gaussianBlur(size: int, sigma: double): Kernel {
    let k: Kernel = new Kernel(size, size);
    let mid: int = size / 2;
    let twoSigma2: double = 2.0 * sigma * sigma;
    var sum: double = 0.0;
    var i: int = 0;
    while (i < size) {
        var j: int = 0;
        while (j < size) {
            let x: double = (i - mid) as double;
            let y: double = (j - mid) as double;
            let val: double = MathAdvanced.exp(-(x * x + y * y) / twoSigma2);
            k.set(i, j, val);
            sum = sum + val;
            j = j + 1;
        }
        i = i + 1;
    }
    // Normalize
    i = 0;
    while (i < size) {
        var j: int = 0;
        while (j < size) {
            k.set(i, j, k.get(i, j) / sum);
            j = j + 1;
        }
        i = i + 1;
    }
    return k;
}

public fn sharpen(): Kernel {
    let k: Kernel = new Kernel(3, 3);
    k.set(0, 0, 0.0); k.set(0, 1, -1.0); k.set(0, 2, 0.0);
    k.set(1, 0, -1.0); k.set(1, 1, 5.0); k.set(1, 2, -1.0);
    k.set(2, 0, 0.0); k.set(2, 1, -1.0); k.set(2, 2, 0.0);
    return k;
}

public fn edgeDetect(): Kernel {
    let k: Kernel = new Kernel(3, 3);
    k.set(0, 0, -1.0); k.set(0, 1, -1.0); k.set(0, 2, -1.0);
    k.set(1, 0, -1.0); k.set(1, 1, 8.0); k.set(1, 2, -1.0);
    k.set(2, 0, -1.0); k.set(2, 1, -1.0); k.set(2, 2, -1.0);
    return k;
}

public fn sobelX(): Kernel {
    let k: Kernel = new Kernel(3, 3);
    k.set(0, 0, -1.0); k.set(0, 1, 0.0); k.set(0, 2, 1.0);
    k.set(1, 0, -2.0); k.set(1, 1, 0.0); k.set(1, 2, 2.0);
    k.set(2, 0, -1.0); k.set(2, 1, 0.0); k.set(2, 2, 1.0);
    return k;
}

public fn sobelY(): Kernel {
    let k: Kernel = new Kernel(3, 3);
    k.set(0, 0, -1.0); k.set(0, 1, -2.0); k.set(0, 2, -1.0);
    k.set(1, 0, 0.0); k.set(1, 1, 0.0); k.set(1, 2, 0.0);
    k.set(2, 0, 1.0); k.set(2, 1, 2.0); k.set(2, 2, 1.0);
    return k;
}

public fn laplacian(): Kernel {
    let k: Kernel = new Kernel(3, 3);
    k.set(0, 0, 0.0); k.set(0, 1, 1.0); k.set(0, 2, 0.0);
    k.set(1, 0, 1.0); k.set(1, 1, -4.0); k.set(1, 2, 1.0);
    k.set(2, 0, 0.0); k.set(2, 1, 1.0); k.set(2, 2, 0.0);
    return k;
}

public fn unsharpMask(amount: double): Kernel {
    let k: Kernel = new Kernel(3, 3);
    k.set(0, 0, 0.0); k.set(0, 1, -amount); k.set(0, 2, 0.0);
    k.set(1, 0, -amount); k.set(1, 1, 1.0 + 4.0 * amount); k.set(1, 2, -amount);
    k.set(2, 0, 0.0); k.set(2, 1, -amount); k.set(2, 2, 0.0);
    return k;
}

public fn emboss(): Kernel {
    let k: Kernel = new Kernel(3, 3);
    k.set(0, 0, -2.0); k.set(0, 1, -1.0); k.set(0, 2, 0.0);
    k.set(1, 0, -1.0); k.set(1, 1, 1.0); k.set(1, 2, 1.0);
    k.set(2, 0, 0.0); k.set(2, 1, 1.0); k.set(2, 2, 2.0);
    return k;
}

public fn boxBlur(size: int): Kernel {
    let k: Kernel = new Kernel(size, size);
    let val: double = 1.0 / (size as double * size as double);
    var i: int = 0;
    while (i < size) {
        var j: int = 0;
        while (j < size) {
            k.set(i, j, val);
            j = j + 1;
        }
        i = i + 1;
    }
    return k;
}
