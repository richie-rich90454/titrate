}

public class Lumen {
    public double value;
    public fn init(v: double) { this.value = v; }
    public fn getValue(): double { return this.value; }
    public fn plus(other: Lumen): Lumen { return new Lumen(this.value + other.value); }
    public fn minus(other: Lumen): Lumen { return new Lumen(this.value - other.value); }
    public fn toString(): string { return Double.toString(this.value) + " lm"; }
}

// Derived: cd * sr (steradian is dimensionless, so cd * 1)
public fn lumenFromBase(cd: Candela): Lumen {
    return new Lumen(cd.getValue());
}

public class Katal {
    public double value;
    public fn init(v: double) { this.value = v; }
    public fn getValue(): double { return this.value; }
    public fn plus(other: Katal): Katal { return new Katal(this.value + other.value); }
    public fn minus(other: Katal): Katal { return new Katal(this.value - other.value); }
