import tt::units::Base;

public class Joule {
    public double value;
    public fn init(v: double) { this.value = v; }
    public fn getValue(): double { return this.value; }
    public fn plus(other: Joule): Joule { return new Joule(this.value + other.value); }
    public fn minus(other: Joule): Joule { return new Joule(this.value - other.value); }
    public fn times(d: double): Joule { return new Joule(this.value * d); }
    public fn div(d: double): Joule { return new Joule(this.value / d); }
    public fn div(s: Second): Watt { return new Watt(this.value / s.getValue()); }
    public fn toString(): string { return Double.toString(this.value) + " J"; }
}

// Derived: kg * m^2 / s^2
public fn jouleFromBase(m: Meter, kg: Kilogram, s: Second): Joule {
    return new Joule(kg.getValue() * m.getValue() * m.getValue() / (s.getValue() * s.getValue()));
}

public class Newton {
    public double value;
    public fn init(v: double) { this.value = v; }
    public fn getValue(): double { return this.value; }
    public fn plus(other: Newton): Newton { return new Newton(this.value + other.value); }
    public fn minus(other: Newton): Newton { return new Newton(this.value - other.value); }
    public fn times(d: double): Newton { return new Newton(this.value * d); }
    public fn div(d: double): Newton { return new Newton(this.value / d); }
    public fn times(m: Meter): Joule { return new Joule(this.value * m.getValue()); }
    public fn toString(): string { return Double.toString(this.value) + " N"; }
}

// Derived: kg * m / s^2
public fn newtonFromBase(m: Meter, kg: Kilogram, s: Second): Newton {
    return new Newton(kg.getValue() * m.getValue() / (s.getValue() * s.getValue()));
}

public class Pascal {
    public double value;
    public fn init(v: double) { this.value = v; }
    public fn getValue(): double { return this.value; }
    public fn plus(other: Pascal): Pascal { return new Pascal(this.value + other.value); }
    public fn minus(other: Pascal): Pascal { return new Pascal(this.value - other.value); }
    public fn times(d: double): Pascal { return new Pascal(this.value * d); }
    public fn div(d: double): Pascal { return new Pascal(this.value / d); }
    public fn toString(): string { return Double.toString(this.value) + " Pa"; }
}

// Derived: N / m^2
public fn pascalFromBase(n: Newton, m: Meter): Pascal {
    return new Pascal(n.getValue() / (m.getValue() * m.getValue()));
}

public class Watt {
    public double value;
    public fn init(v: double) { this.value = v; }
    public fn getValue(): double { return this.value; }
    public fn plus(other: Watt): Watt { return new Watt(this.value + other.value); }
    public fn minus(other: Watt): Watt { return new Watt(this.value - other.value); }
    public fn times(d: double): Watt { return new Watt(this.value * d); }
    public fn div(d: double): Watt { return new Watt(this.value / d); }
    public fn times(s: Second): Joule { return new Joule(this.value * s.getValue()); }
    public fn toString(): string { return Double.toString(this.value) + " W"; }
}

// Derived: J / s
public fn wattFromBase(j: Joule, s: Second): Watt {
    return new Watt(j.getValue() / s.getValue());
}

public class Coulomb {
    public double value;
    public fn init(v: double) { this.value = v; }
    public fn getValue(): double { return this.value; }
    public fn plus(other: Coulomb): Coulomb { return new Coulomb(this.value + other.value); }
    public fn minus(other: Coulomb): Coulomb { return new Coulomb(this.value - other.value); }
    public fn times(d: double): Coulomb { return new Coulomb(this.value * d); }
    public fn div(d: double): Coulomb { return new Coulomb(this.value / d); }
    public fn toString(): string { return Double.toString(this.value) + " C"; }
}

// Derived: A * s
public fn coulombFromBase(a: Ampere, s: Second): Coulomb {
    return new Coulomb(a.getValue() * s.getValue());
}

public class Volt {
    public double value;
    public fn init(v: double) { this.value = v; }
    public fn getValue(): double { return this.value; }
    public fn plus(other: Volt): Volt { return new Volt(this.value + other.value); }
    public fn minus(other: Volt): Volt { return new Volt(this.value - other.value); }
    public fn times(d: double): Volt { return new Volt(this.value * d); }
    public fn div(d: double): Volt { return new Volt(this.value / d); }
    public fn times(c: Coulomb): Joule { return new Joule(this.value * c.getValue()); }
    public fn div(a: Ampere): Ohm { return new Ohm(this.value / a.getValue()); }
    public fn toString(): string { return Double.toString(this.value) + " V"; }
}

// Derived: J / C
public fn voltFromBase(j: Joule, c: Coulomb): Volt {
    return new Volt(j.getValue() / c.getValue());
}

public class Ohm {
    public double value;
    public fn init(v: double) { this.value = v; }
    public fn getValue(): double { return this.value; }
    public fn plus(other: Ohm): Ohm { return new Ohm(this.value + other.value); }
    public fn minus(other: Ohm): Ohm { return new Ohm(this.value - other.value); }
    public fn toString(): string { return Double.toString(this.value) + " Ω"; }
}

// Derived: V / A
public fn ohmFromBase(v: Volt, a: Ampere): Ohm {
    return new Ohm(v.getValue() / a.getValue());
}

public class Farad {
    public double value;
    public fn init(v: double) { this.value = v; }
    public fn getValue(): double { return this.value; }
    public fn plus(other: Farad): Farad { return new Farad(this.value + other.value); }
    public fn minus(other: Farad): Farad { return new Farad(this.value - other.value); }
    public fn toString(): string { return Double.toString(this.value) + " F"; }
}

// Derived: C / V
public fn faradFromBase(c: Coulomb, v: Volt): Farad {
    return new Farad(c.getValue() / v.getValue());
}

public class Henry {
    public double value;
    public fn init(v: double) { this.value = v; }
    public fn getValue(): double { return this.value; }
    public fn plus(other: Henry): Henry { return new Henry(this.value + other.value); }
    public fn minus(other: Henry): Henry { return new Henry(this.value - other.value); }
    public fn toString(): string { return Double.toString(this.value) + " H"; }
}

// Derived: V * s / A
public fn henryFromBase(v: Volt, s: Second, a: Ampere): Henry {
    return new Henry(v.getValue() * s.getValue() / a.getValue());
}

public class Tesla {
    public double value;
    public fn init(v: double) { this.value = v; }
    public fn getValue(): double { return this.value; }
    public fn plus(other: Tesla): Tesla { return new Tesla(this.value + other.value); }
    public fn minus(other: Tesla): Tesla { return new Tesla(this.value - other.value); }
    public fn toString(): string { return Double.toString(this.value) + " T"; }
}

// Derived: V * s / m²
public fn teslaFromBase(v: Volt, s: Second, m2: MeterSquared): Tesla {
    return new Tesla(v.getValue() * s.getValue() / m2.getValue());
}

public class Weber {
    public double value;
    public fn init(v: double) { this.value = v; }
    public fn getValue(): double { return this.value; }
    public fn plus(other: Weber): Weber { return new Weber(this.value + other.value); }
    public fn minus(other: Weber): Weber { return new Weber(this.value - other.value); }
    public fn toString(): string { return Double.toString(this.value) + " Wb"; }
}

// Derived: V * s
public fn weberFromBase(v: Volt, s: Second): Weber {
    return new Weber(v.getValue() * s.getValue());
}

public class Hertz {
    public double value;
    public fn init(v: double) { this.value = v; }
    public fn getValue(): double { return this.value; }
    public fn plus(other: Hertz): Hertz { return new Hertz(this.value + other.value); }
    public fn minus(other: Hertz): Hertz { return new Hertz(this.value - other.value); }
    public fn toString(): string { return Double.toString(this.value) + " Hz"; }
}

// Derived: 1 / s
public fn hertzFromBase(s: Second): Hertz {
    return new Hertz(1.0 / s.getValue());
}

public class Becquerel {
    public double value;
    public fn init(v: double) { this.value = v; }
    public fn getValue(): double { return this.value; }
    public fn plus(other: Becquerel): Becquerel { return new Becquerel(this.value + other.value); }
    public fn minus(other: Becquerel): Becquerel { return new Becquerel(this.value - other.value); }
