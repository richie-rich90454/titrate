public class Lux {
    public double value;
    public fn init(v: double) { this.value = v; }
    public fn getValue(): double { return this.value; }
    public fn plus(other: Lux): Lux { return new Lux(this.value + other.value); }
    public fn minus(other: Lux): Lux { return new Lux(this.value - other.value); }
    public fn toString(): string { return Double.toString(this.value) + " lx"; }
}

// Derived: cd / m²
public fn luxFromBase(cd: Candela, m2: MeterSquared): Lux {
