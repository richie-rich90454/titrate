}

public class Gray {
    public double value;
    public fn init(v: double) { this.value = v; }
    public fn getValue(): double { return this.value; }
    public fn plus(other: Gray): Gray { return new Gray(this.value + other.value); }
    public fn minus(other: Gray): Gray { return new Gray(this.value - other.value); }
