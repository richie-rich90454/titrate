class Meter {
    double value;
    Meter(v: double) { this.value = v; }
    fn getValue(): double { return this.value; }
    fn plus(other: Meter): Meter { return new Meter(this.value + other.value); }
    fn minus(other: Meter): Meter { return new Meter(this.value - other.value); }
    fn times(d: double): Meter { return new Meter(this.value * d); }
    fn div(d: double): Meter { return new Meter(this.value / d); }
    fn times(other: Meter): MeterSquared { return new MeterSquared(this.value * other.value); }
    fn equals(other: Meter): bool { return this.value == other.value; }
    fn compareTo(other: Meter): int {
        if (this.value < other.value) { return -1; }
        if (this.value > other.value) { return 1; }
        return 0;
    }
    fn toDouble(): double { return this.value; }
    fn toString(): string { return Double::toString(this.value) + " m"; }
}

class MeterSquared {
    double value;
    MeterSquared(v: double) { this.value = v; }
    fn getValue(): double { return this.value; }
    fn equals(other: MeterSquared): bool { return this.value == other.value; }
    fn compareTo(other: MeterSquared): int {
        if (this.value < other.value) { return -1; }
        if (this.value > other.value) { return 1; }
        return 0;
    }
    fn toDouble(): double { return this.value; }
    fn toString(): string { return Double::toString(this.value) + " m²"; }
}

