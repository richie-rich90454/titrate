// Sunau.tr — Sun AU audio format reader/writer (Python sunau parity)
// Sun AU header is big-endian, with a 24-byte minimum header:
//   magic ".snd" (4) | data_offset (4) | data_size (4) | encoding (4)
//   | sample_rate (4) | channels (4) | info string (variable, padded even)
//
// Encodings: 1=mulaw(8b), 2=linear8, 3=linear16, 4=linear24, 5=linear32,
//            6=float32, 7=float64. mulaw is decoded to linear16 on read.

import tt::util::ArrayList;
import tt::audio::AudioBuffer;

// Sun AU encoding constants
public const AU_ULAW_8: int = 1;
public const AU_LINEAR_8: int = 2;
public const AU_LINEAR_16: int = 3;
public const AU_LINEAR_24: int = 4;
public const AU_LINEAR_32: int = 5;
public const AU_FLOAT_32: int = 6;
public const AU_FLOAT_64: int = 7;
public const AU_UNKNOWN_SIZE: int = -1;

// Magic number: ".snd"
const _AU_MAGIC_0: int = 0x2E; // '.'
const _AU_MAGIC_1: int = 0x73; // 's'
const _AU_MAGIC_2: int = 0x6E; // 'n'
const _AU_MAGIC_3: int = 0x64; // 'd'

// SunauAudio — parsed Sun AU file: header fields + raw sample bytes.
public class SunauAudio {
    public int dataOffset;
    public int dataSize;
    public int encoding;
    public int sampleRate;
    public int channels;
    public string info;
    public ArrayList<int> samples; // raw sample bytes

    public fn init() {
        this.dataOffset = 24;
        this.dataSize = AU_UNKNOWN_SIZE;
        this.encoding = AU_LINEAR_16;
        this.sampleRate = 8000;
        this.channels = 1;
        this.info = "";
        this.samples = new ArrayList<int>();
    }

    // sampwidth in bytes for the encoding
    public fn sampwidth(): int {
        if (this.encoding == AU_ULAW_8) { return 1; }
        if (this.encoding == AU_LINEAR_8) { return 1; }
        if (this.encoding == AU_LINEAR_16) { return 2; }
        if (this.encoding == AU_LINEAR_24) { return 3; }
        if (this.encoding == AU_LINEAR_32) { return 4; }
        if (this.encoding == AU_FLOAT_32) { return 4; }
        if (this.encoding == AU_FLOAT_64) { return 8; }
        return 1;
    }

    // comp type string (Python sunau names)
    public fn comptype(): string {
        if (this.encoding == AU_ULAW_8) { return "ULAW"; }
        if (this.encoding == AU_FLOAT_32) { return "FLOAT"; }
        if (this.encoding == AU_FLOAT_64) { return "DOUBLE"; }
        return "NONE";
    }

    public fn compname(): string {
        if (this.encoding == AU_ULAW_8) { return "CCITT G.711 mulaw"; }
        if (this.encoding == AU_FLOAT_32) { return "32-bit IEEE float"; }
        if (this.encoding == AU_FLOAT_64) { return "64-bit IEEE float"; }
        return "not compressed";
    }

    // Number of complete frames in the data area.
    public fn nframes(): int {
        let sw: int = this.sampwidth();
        if (sw == 0 || this.channels == 0) { return 0; }
        let size: int = this.dataSize;
        if (size == AU_UNKNOWN_SIZE) {
            size = this.samples.size();
        }
        return size / (sw * this.channels);
    }
}

// Read a Sun AU file from disk into a SunauAudio object.
public fn read(path: string): SunauAudio {
    let au: SunauAudio = new SunauAudio();
    if (!Fs_exists(path)) { return au; }
    let bytes: ArrayList<int> = _hexToBytes(File_readBytes(path, Fs_size(path)));
    if (bytes.size() < 24) { return au; }
    if (bytes.get(0) != _AU_MAGIC_0 || bytes.get(1) != _AU_MAGIC_1 ||
        bytes.get(2) != _AU_MAGIC_2 || bytes.get(3) != _AU_MAGIC_3) {
        return au;
    }
    au.dataOffset = _readBE32(bytes, 4);
    au.dataSize = _readBE32(bytes, 8);
    au.encoding = _readBE32(bytes, 12);
    au.sampleRate = _readBE32(bytes, 16);
    au.channels = _readBE32(bytes, 20);

    // Read info string up to data offset
    if (au.dataOffset > 24) {
        var info: string = "";
        var i: int = 24;
        while (i < au.dataOffset && i < bytes.size()) {
            let b: int = bytes.get(i);
            if (b == 0) { break; }
            info = info + String.fromCharCode(b);
            i = i + 1;
        }
        au.info = info;
    }

    // Copy sample bytes
    var j: int = au.dataOffset;
    while (j < bytes.size()) {
        au.samples.add(bytes.get(j));
        j = j + 1;
    }
    // If dataSize was unknown, derive from available bytes
    if (au.dataSize == AU_UNKNOWN_SIZE) {
        au.dataSize = au.samples.size();
    }
    return au;
}

// Read AU file and convert samples into an AudioBuffer of doubles in [-1, 1).
public fn readAudioBuffer(path: string): AudioBuffer {
    let au: SunauAudio = read(path);
    let buf: AudioBuffer = new AudioBuffer(au.sampleRate, au.channels);
    let sw: int = au.sampwidth();
    let n: int = au.nframes();
    var f: int = 0;
    while (f < n) {
        let frame: ArrayList<double> = new ArrayList<double>();
        var c: int = 0;
        while (c < au.channels) {
            let off: int = (f * au.channels + c) * sw;
            frame.add(_decodeSample(au, off));
            c = c + 1;
        }
        buf.addFrame(frame);
        f = f + 1;
    }
    return buf;
}

// Write a SunauAudio object to disk. Header is built from current fields.
public fn write(path: string, au: SunauAudio): void {
    let out: ArrayList<int> = new ArrayList<int>();
    // Magic
    out.add(_AU_MAGIC_0); out.add(_AU_MAGIC_1); out.add(_AU_MAGIC_2); out.add(_AU_MAGIC_3);
    // data_offset: 24 + info + padding to even
    let infoLen: int = String.length(au.info);
    let dataOffset: int = 24 + infoLen;
    if (dataOffset % 2 != 0) { dataOffset = dataOffset + 1; }
    au.dataOffset = dataOffset;
    _writeBE32(out, dataOffset);
    // data_size: use stored value, or compute from samples
    let dataSize: int = au.samples.size();
    au.dataSize = dataSize;
    _writeBE32(out, dataSize);
    // encoding, sample_rate, channels
    _writeBE32(out, au.encoding);
    _writeBE32(out, au.sampleRate);
    _writeBE32(out, au.channels);
    // info string + padding
    var i: int = 0;
    while (i < infoLen) {
        out.add(String.charAt(au.info, i) as int);
        i = i + 1;
    }
    if (infoLen % 2 != 0) { out.add(0); }
    // samples
    var j: int = 0;
    while (j < au.samples.size()) {
        out.add(au.samples.get(j));
        j = j + 1;
    }
    File_writeBytes(path, _bytesToHex(out));
}

// Encode an AudioBuffer (doubles in [-1,1)) into 16-bit linear PCM AU file.
public fn writeAudioBuffer(path: string, buf: AudioBuffer): void {
    let au: SunauAudio = new SunauAudio();
    au.encoding = AU_LINEAR_16;
    au.sampleRate = buf.sampleRate;
    au.channels = buf.channels;
    au.info = "Titrate";
    let n: int = buf.numFrames();
    var f: int = 0;
    while (f < n) {
        var c: int = 0;
        while (c < buf.channels) {
            let s: double = buf.getSample(c, f);
            let v: int = Math.round(s * 32767.0) as int;
            if (v > 32767) { v = 32767; }
            if (v < -32768) { v = -32768; }
            // big-endian 16-bit signed
            au.samples.add((v >> 8) & 0xFF);
            au.samples.add(v & 0xFF);
            c = c + 1;
        }
        f = f + 1;
    }
    write(path, au);
}

// open(path, mode) — Python sunau.open parity. mode="r"/"rb" returns a
// SunAuReader over the parsed file; mode="w"/"wb" returns a fresh
// SunAuWriter ready to accumulate samples. (Task 148)
public fn open(path: string, mode: string): Variant {
    if (mode == "r" || mode == "rb") {
        let au: SunauAudio = read(path);
        return new SunAuReader(au, path);
    }
    if (mode == "w" || mode == "wb") {
        return new SunAuWriter(path);
    }
    // Unknown mode — default to a writer (Python sunau raises, but we degrade
    // gracefully to keep the VM from throwing on a bad mode string).
    return new SunAuWriter(path);
}

// --- internal helpers ---

// Decode a single sample at byte offset `off` to a double in [-1, 1).
fn _decodeSample(au: SunauAudio, off: int): double {
    let s: ArrayList<int> = au.samples;
    if (au.encoding == AU_ULAW_8) {
        if (off >= s.size()) { return 0.0; }
        return _ulawToDouble(s.get(off));
    }
    if (au.encoding == AU_LINEAR_8) {
        if (off >= s.size()) { return 0.0; }
        let v: int = s.get(off) - 128;
        return v as double / 128.0;
    }
    if (au.encoding == AU_LINEAR_16) {
        if (off + 1 >= s.size()) { return 0.0; }
        let v: int = (s.get(off) << 8) | s.get(off + 1);
        if (v >= 32768) { v = v - 65536; }
        return v as double / 32768.0;
    }
    if (au.encoding == AU_LINEAR_24) {
        if (off + 2 >= s.size()) { return 0.0; }
        let v: int = (s.get(off) << 16) | (s.get(off + 1) << 8) | s.get(off + 2);
        if (v >= 8388608) { v = v - 16777216; }
        return v as double / 8388608.0;
    }
    if (au.encoding == AU_LINEAR_32) {
        if (off + 3 >= s.size()) { return 0.0; }
        let v: int = (s.get(off) << 24) | (s.get(off + 1) << 16) | (s.get(off + 2) << 8) | s.get(off + 3);
        return v as double / 2147483648.0;
    }
    if (au.encoding == AU_FLOAT_32) {
        if (off + 3 >= s.size()) { return 0.0; }
        let bits: int = (s.get(off) << 24) | (s.get(off + 1) << 16) | (s.get(off + 2) << 8) | s.get(off + 3);
        return Float_fromF32Bits(bits);
    }
    if (au.encoding == AU_FLOAT_64) {
        // 64-bit float decode not supported by native Float helpers in this codebase;
        // fall back to reading high 32 bits as float32 approximation.
        if (off + 3 >= s.size()) { return 0.0; }
        let bits: int = (s.get(off + 4) << 24) | (s.get(off + 5) << 16) | (s.get(off + 6) << 8) | s.get(off + 7);
        return Float_fromF32Bits(bits);
    }
    return 0.0;
}

// μ-law decode: 8-bit mulaw -> double in [-1, 1)
fn _ulawToDouble(b: int): double {
    let v: int = _ulawToLinear(b);
    return v as double / 32768.0;
}

// μ-law decode to 16-bit linear PCM
fn _ulawToLinear(b: int): int {
    let u: int = ~b & 0xFF;
    let sign: int = (u >> 7) & 1;
    let exponent: int = (u >> 4) & 0x07;
    let mantissa: int = u & 0x0F;
    let mag: int = ((mantissa << 3) + 0x84) << exponent;
    mag = mag - 0x84;
    if (sign == 1) { mag = -mag; }
    return mag;
}

// big-endian readers
fn _readBE32(bytes: ArrayList<int>, off: int): int {
    if (off + 3 >= bytes.size()) { return 0; }
    return (bytes.get(off) << 24) | (bytes.get(off + 1) << 16) | (bytes.get(off + 2) << 8) | bytes.get(off + 3);
}

fn _writeBE32(bytes: ArrayList<int>, val: int): void {
    bytes.add((val >> 24) & 0xFF);
    bytes.add((val >> 16) & 0xFF);
    bytes.add((val >> 8) & 0xFF);
    bytes.add(val & 0xFF);
}

// ============================================================================
// SunAuReader / SunAuWriter — Python sunau streaming API (Task 148)
// These wrap a SunauAudio object to mirror Python's sunau.AU_read and
// sunau.AU_write objects, exposed via open(path, mode) above.
// ============================================================================

// AudioParams mirrors the namedtuple returned by Python sunau getparams():
//   (nchannels, sampwidth, framerate, nframes, comptype, compname)
public class AudioParams {
    public int nchannels;
    public int sampwidth;
    public int framerate;
    public int nframes;
    public string comptype;
    public string compname;

    public fn init(nchannels: int, sampwidth: int, framerate: int, nframes: int, comptype: string, compname: string) {
        this.nchannels = nchannels;
        this.sampwidth = sampwidth;
        this.framerate = framerate;
        this.nframes = nframes;
        this.comptype = comptype;
        this.compname = compname;
    }

    public fn toString(): string {
        return "AudioParams(nchannels=" + this.nchannels + ", sampwidth=" + this.sampwidth
            + ", framerate=" + this.framerate + ", nframes=" + this.nframes
            + ", comptype='" + this.comptype + "', compname='" + this.compname + "')";
    }
}

// SunAuReader — Python sunau.AU_read analog. Wraps a parsed SunauAudio
// object and exposes a streaming, position-tracked read API.
public class SunAuReader {
    public SunauAudio _au;
    public string _path;
    public int _posFrames;
    public bool _closed;

    public fn init(au: SunauAudio, path: string) {
        this._au = au;
        this._path = path;
        this._posFrames = 0;
        this._closed = false;
    }

    public fn close(): void {
        this._closed = true;
    }

    public fn getnchannels(): int {
        return this._au.channels;
    }

    public fn getsampwidth(): int {
        return this._au.sampwidth();
    }

    public fn getframerate(): int {
        return this._au.sampleRate;
    }

    public fn getnframes(): int {
        return this._au.nframes();
    }

    public fn getcomptype(): string {
        return this._au.comptype();
    }

    public fn getcompname(): string {
        return this._au.compname();
    }

    public fn getparams(): AudioParams {
        return new AudioParams(this.getnchannels(), this.getsampwidth(),
            this.getframerate(), this.getnframes(),
            this.getcomptype(), this.getcompname());
    }

    // Current read position in frames.
    public fn tell(): int {
        return this._posFrames;
    }

    // Rewind to the start of the audio data.
    public fn rewind(): void {
        this._posFrames = 0;
    }

    // Seek to a frame position. Python sunau.setpos.
    public fn setpos(pos: int): void {
        if (pos < 0) { pos = 0; }
        let n: int = this.getnframes();
        if (pos > n) { pos = n; }
        this._posFrames = pos;
    }

    // Sun AU files do not contain markers; mirror Python sunau which
    // returns None for getmarkers() and raises on getmark().
    public fn getmarkers(): Variant {
        return null;
    }

    public fn getmark(id: int): Variant {
        return null;
    }

    // Read up to `n` frames starting at the current position and return the
    // raw sample bytes as an ArrayList<int>. Bytes are returned in their
    // on-disk encoding (Python sunau returns raw bytes; callers decode).
    public fn readframes(n: int): ArrayList<int> {
        let out: ArrayList<int> = new ArrayList<int>();
        if (this._closed) { return out; }
        let total: int = this.getnframes();
        let sw: int = this.getsampwidth();
        let ch: int = this.getnchannels();
        var remaining: int = n;
        if (remaining < 0) { remaining = 0; }
        while (remaining > 0 && this._posFrames < total) {
            var c: int = 0;
            while (c < ch) {
                let off: int = (this._posFrames * ch + c) * sw;
                let s: ArrayList<int> = this._au.samples;
                var b: int = 0;
                while (b < sw) {
                    if (off + b < s.size()) {
                        out.add(s.get(off + b));
                    }
                    b = b + 1;
                }
                c = c + 1;
            }
            this._posFrames = this._posFrames + 1;
            remaining = remaining - 1;
        }
        return out;
    }
}

// SunAuWriter — Python sunau.AU_write analog. Accumulates raw sample bytes
// and writes a complete Sun AU file on close() or writeframes().
public class SunAuWriter {
    public SunauAudio _au;
    public string _path;
    public bool _closed;
    public bool _nframesSet;

    public fn init(path: string) {
        this._path = path;
        this._au = new SunauAudio();
        // Sensible defaults: 16-bit linear PCM, 8000 Hz mono (Sun AU default).
        this._au.encoding = AU_LINEAR_16;
        this._au.sampleRate = 8000;
        this._au.channels = 1;
        this._au.info = "Titrate";
        this._closed = false;
        this._nframesSet = false;
    }

    public fn close(): void {
        if (this._closed) { return; }
        write(this._path, this._au);
        this._closed = true;
    }

    public fn setnchannels(n: int): void {
        this._au.channels = n;
    }

    // Map a sampwidth in bytes to a Sun AU encoding and store it.
    public fn setsampwidth(width: int): void {
        if (width == 1) {
            this._au.encoding = AU_LINEAR_8;
        } else if (width == 2) {
            this._au.encoding = AU_LINEAR_16;
        } else if (width == 3) {
            this._au.encoding = AU_LINEAR_24;
        } else if (width == 4) {
            this._au.encoding = AU_LINEAR_32;
        }
    }

    public fn setframerate(rate: int): void {
        this._au.sampleRate = rate;
    }

    public fn setnframes(n: int): void {
        this._nframesSet = true;
        // nframes is derived from sample bytes; record the hint as the data size.
        let sw: int = this._au.sampwidth();
        this._au.dataSize = n * this._au.channels * sw;
    }

    // Sun AU only supports the encodings SunauAudio knows about. Map
    // comptype strings to encodings; unknown comptypes keep linear16.
    public fn setcomptype(comptype: string, compname: string): void {
        if (comptype == "ULAW") {
            this._au.encoding = AU_ULAW_8;
        } else if (comptype == "FLOAT") {
            this._au.encoding = AU_FLOAT_32;
        } else if (comptype == "DOUBLE") {
            this._au.encoding = AU_FLOAT_64;
        } else {
            // "NONE" or anything else -> keep linear PCM
            if (this._au.encoding == AU_ULAW_8
                || this._au.encoding == AU_FLOAT_32
                || this._au.encoding == AU_FLOAT_64) {
                this._au.encoding = AU_LINEAR_16;
            }
        }
    }

    public fn getnchannels(): int {
        return this._au.channels;
    }

    public fn getsampwidth(): int {
        return this._au.sampwidth();
    }

    public fn getframerate(): int {
        return this._au.sampleRate;
    }

    public fn getnframes(): int {
        return this._au.nframes();
    }

    public fn getcomptype(): string {
        return this._au.comptype();
    }

    public fn getcompname(): string {
        return this._au.compname();
    }

    public fn getparams(): AudioParams {
        return new AudioParams(this.getnchannels(), this.getsampwidth(),
            this.getframerate(), this.getnframes(),
            this.getcomptype(), this.getcompname());
    }

    // Current write position in frames.
    public fn tell(): int {
        let sw: int = this._au.sampwidth();
        if (sw == 0 || this._au.channels == 0) { return 0; }
        return this._au.samples.size() / (sw * this._au.channels);
    }

    // Append raw sample bytes. Bytes are stored verbatim; the file is
    // written on close(). This mirrors Python sunau writeframesraw.
    public fn writeframesraw(data: ArrayList<int>): void {
        if (this._closed) { return; }
        var i: int = 0;
        while (i < data.size()) {
            this._au.samples.add(data.get(i));
            i = i + 1;
        }
    }

    // Append raw sample bytes and flush the file to disk.
    public fn writeframes(data: ArrayList<int>): void {
        if (this._closed) { return; }
        this.writeframesraw(data);
        write(this._path, this._au);
    }
}

// Convert a hex string into an ArrayList<int> of byte values.
fn _hexToBytes(hex: string): ArrayList<int> {
    let result: ArrayList<int> = new ArrayList<int>();
    let len: int = String.length(hex);
    var i: int = 0;
    while (i + 1 < len) {
        let hi: int = _hexDigit(String.charAt(hex, i));
        let lo: int = _hexDigit(String.charAt(hex, i + 1));
        if (hi < 0 || lo < 0) { i = i + 2; continue; }
        result.add(hi * 16 + lo);
        i = i + 2;
    }
    return result;
}

// Convert an ArrayList<int> of byte values into a lowercase hex string.
fn _bytesToHex(bytes: ArrayList<int>): string {
    var hex: string = "";
    var i: int = 0;
    while (i < bytes.size()) {
        let b: int = bytes.get(i) & 0xFF;
        hex = hex + _hexChar((b >> 4) & 0xF) + _hexChar(b & 0xF);
        i = i + 1;
    }
    return hex;
}

// Parse a single hex digit char into its numeric value (0..15), or -1.
fn _hexDigit(c: string): int {
    let code: int = String.charAt(c, 0) as int;
    if (code >= 48 && code <= 57) { return code - 48; }
    if (code >= 97 && code <= 102) { return code - 87; }
    if (code >= 65 && code <= 70) { return code - 55; }
    return -1;
}

// Map a nibble (0..15) to a single hex character.
fn _hexChar(n: int): string {
    if (n < 10) { return String.fromCharCode(48 + n); }
    return String.fromCharCode(97 + (n - 10));
}
