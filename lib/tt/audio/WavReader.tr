// WavReader.tr — WAV file reader
import tt::util::ArrayList;
import tt::lang::String;
import tt::lang::Integer;
import tt::audio::AudioBuffer;
import tt::json::JsonValue;
import tt::lang::DataFile;

public class WavInfo {
    public int sampleRate;
    public int channels;
    public int bitsPerSample;
    public int numFrames;

    public fn init(rate: int, ch: int, bps: int, nf: int) {
        this.sampleRate = rate;
        this.channels = ch;
        this.bitsPerSample = bps;
        this.numFrames = nf;
    }
}

import tt::util::HashMap;
import tt::lang::Variant;

// Read WAV header and return metadata as a HashMap
public fn readHeader(path: string): HashMap<string, Variant> {
    let result: HashMap<string, Variant> = new HashMap<string, Variant>();
    let bytes: ArrayList<int> = File_readBytes(path);
    if (bytes.size() < 44) { return result; }
    let channels: int = _readLE16(bytes, 22);
    let sampleRate: int = _readLE32(bytes, 24);
    let bitsPerSample: int = _readLE16(bytes, 34);
    let dataSize: int = _readLE32(bytes, 40);
    let bytesPerSample: int = bitsPerSample / 8;
    let numFrames: int = dataSize / (channels * bytesPerSample);
    result.put("channels", channels as Variant);
    result.put("sampleRate", sampleRate as Variant);
    result.put("bitsPerSample", bitsPerSample as Variant);
    result.put("dataSize", dataSize as Variant);
    result.put("numFrames", numFrames as Variant);
    return result;
}

public fn readWav(path: string): AudioBuffer {
    let bytes: ArrayList<int> = File_readBytes(path);
    if (bytes.size() < 44) { return new AudioBuffer(44100, 1); }
    // Parse RIFF header
    let channels: int = _readLE16(bytes, 22);
    let sampleRate: int = _readLE32(bytes, 24);
    let bitsPerSample: int = _readLE16(bytes, 34);
    let dataSize: int = _readLE32(bytes, 40);
    let bytesPerSample: int = bitsPerSample / 8;
    let numFrames: int = dataSize / (channels * bytesPerSample);
    let buffer: AudioBuffer = new AudioBuffer(sampleRate, channels);
    let dataOffset: int = 44;
    var frame: int = 0;
    while (frame < numFrames) {
        let values: ArrayList<double> = new ArrayList<double>();
        var ch: int = 0;
        while (ch < channels) {
            let offset: int = dataOffset + (frame * channels + ch) * bytesPerSample;
            var val: double = 0.0;
            if (bitsPerSample == 16 && offset + 1 < bytes.size()) {
                let raw: int = _readLE16(bytes, offset);
                if (raw >= 32768) { raw = raw - 65536; }
                val = raw as double / 32768.0;
            } else {
                if (bitsPerSample == 8 && offset < bytes.size()) {
                    val = (bytes.get(offset) - 128) as double / 128.0;
                }
            }
            values.add(val);
            ch = ch + 1;
        }
        buffer.addFrame(values);
        frame = frame + 1;
    }
    return buffer;
}

fn _readLE16(bytes: ArrayList<int>, offset: int): int {
    if (offset + 1 >= bytes.size()) { return 0; }
    return bytes.get(offset) | (bytes.get(offset + 1) << 8);
}

fn _readLE32(bytes: ArrayList<int>, offset: int): int {
    if (offset + 3 >= bytes.size()) { return 0; }
    return bytes.get(offset) | (bytes.get(offset + 1) << 8) | (bytes.get(offset + 2) << 16) | (bytes.get(offset + 3) << 24);
}

// ============================================================================
// what() — Python sndhdr-style audio type sniffer (Task 147)
// Determines the sound format of a file by examining its header bytes.
// Supports: wav, aiff, au, voc, hcom. Returns an AudioTypeInfo describing
// the file, or null if no known format matches.
// Magic-byte test patterns are loaded from data/io/sndhdr_tests.json.
// ============================================================================

// AudioTypeInfo mirrors the tuple returned by Python sndhdr.what():
//   (type, sampling_rate, channels, frames, bits_per_sample)
// `frames` is -1 when unknown.
public class AudioTypeInfo {
    public string type;
    public int rate;
    public int channels;
    public int frames;
    public int bitsPerSample;

    public fn init(type: string, rate: int, channels: int, frames: int, bitsPerSample: int) {
        this.type = type;
        this.rate = rate;
        this.channels = channels;
        this.frames = frames;
        this.bitsPerSample = bitsPerSample;
    }

    public fn toString(): string {
        return "AudioTypeInfo{type=" + this.type + ", rate=" + Integer.toString(this.rate)
            + ", channels=" + Integer.toString(this.channels)
            + ", frames=" + Integer.toString(this.frames)
            + ", bitsPerSample=" + Integer.toString(this.bitsPerSample) + "}";
    }
}

// A single sound-type sniff test: match `magic` at `offset`, then
// optionally verify `verifyMagic` at `verifyOffset`.
public class AudioSniffTest {
    public string name;
    public int offset;
    public ArrayList<int> magic;
    public int verifyOffset;
    public ArrayList<int> verifyMagic;
    public bool hasVerify;
    public string type;

    public fn init(name: string, offset: int, magic: ArrayList<int>, type: string) {
        this.name = name;
        this.offset = offset;
        this.magic = magic;
        this.verifyOffset = 0;
        this.verifyMagic = new ArrayList<int>();
        this.hasVerify = false;
        this.type = type;
    }

    public fn match(buf: ArrayList<int>): bool {
        if (!_sniffMatchAt(buf, this.offset, this.magic)) {
            return false;
        }
        if (this.hasVerify) {
            return _sniffMatchAt(buf, this.verifyOffset, this.verifyMagic);
        }
        return true;
    }
}

// Module-level sniff test table loaded lazily from sndhdr_tests.json.
var _sniffTests: ArrayList<AudioSniffTest> = new ArrayList<AudioSniffTest>();
var _sniffLoaded: bool = false;

// Lazily load the audio sniff tests from the JSON data file.
fn _ensureSniffLoaded(): void {
    if (_sniffLoaded) { return; }
    _sniffLoaded = true;
    let data: JsonValue = DataFile.load("io/sndhdr_tests.json");
    if (data.isNull() || !data.isObject() || !data.hasKey("tests")) { return; }
    let arr: JsonValue = data.get("tests");
    if (!arr.isArray()) { return; }
    var i: int = 0;
    while (i < arr.size()) {
        let entry: JsonValue = arr.getAt(i);
        if (!entry.isObject()) { i = i + 1; continue; }
        let name: string = entry.get("name").asString();
        let offset: int = _sniffToInt(entry.get("offset"));
        let magicHex: string = entry.get("magic").asString();
        let type: string = entry.get("type").asString();
        // Only load the tests for the formats supported by what(): wav, aiff, au, voc, hcom.
        if (type != "wav" && type != "aiff" && type != "au" && type != "voc" && type != "hcom") {
            i = i + 1;
            continue;
        }
        let magic: ArrayList<int> = _sniffHexToBytes(magicHex);
        let test: AudioSniffTest = new AudioSniffTest(name, offset, magic, type);
        if (entry.hasKey("verify_offset") && entry.hasKey("verify_magic")) {
            test.verifyOffset = _sniffToInt(entry.get("verify_offset"));
            test.verifyMagic = _sniffHexToBytes(entry.get("verify_magic").asString());
            test.hasVerify = true;
        }
        _sniffTests.add(test);
        i = i + 1;
    }
}

// what(filename) — determine the sound format of a file and return an
// AudioTypeInfo, or null if no known format matches. Python sndhdr parity.
public fn what(filename: string): AudioTypeInfo {
    _ensureSniffLoaded();
    let bytes: ArrayList<int> = File_readBytes(filename);
    if (bytes == null || bytes.size() == 0) { return null; }
    var i: int = 0;
    while (i < _sniffTests.size()) {
        let test: AudioSniffTest = _sniffTests.get(i);
        if (test.match(bytes)) {
            return _sniffParseHeader(test.type, bytes);
        }
        i = i + 1;
    }
    return null;
}

// Parse format-specific fields from header bytes once the type is known.
fn _sniffParseHeader(type: string, bytes: ArrayList<int>): AudioTypeInfo {
    if (type == "wav") { return _sniffWav(bytes); }
    if (type == "aiff") { return _sniffAiff(bytes); }
    if (type == "au") { return _sniffAu(bytes); }
    if (type == "voc") { return new AudioTypeInfo("voc", 0, 1, -1, 8); }
    if (type == "hcom") { return new AudioTypeInfo("hcom", 0, 1, -1, 8); }
    return new AudioTypeInfo(type, 0, 1, -1, 8);
}

// WAV: RIFF....WAVE, little-endian. channels@22, rate@24, bps@34, datasz@40.
fn _sniffWav(bytes: ArrayList<int>): AudioTypeInfo {
    let channels: int = _readLE16(bytes, 22);
    let rate: int = _readLE32(bytes, 24);
    let bitsPerSample: int = _readLE16(bytes, 34);
    let dataSize: int = _readLE32(bytes, 40);
    let frameSize: int = channels * (bitsPerSample / 8);
    let frames: int = -1;
    if (frameSize > 0) { frames = dataSize / frameSize; }
    return new AudioTypeInfo("wav", rate, channels, frames, bitsPerSample);
}

// AIFF: FORM....AIFF, big-endian. COMM chunk holds channels, frames, sampleSize.
fn _sniffAiff(bytes: ArrayList<int>): AudioTypeInfo {
    let commPos: int = _sniffFindChunk(bytes, "COMM");
    if (commPos < 0) { return new AudioTypeInfo("aiff", 0, 1, -1, 8); }
    let channels: int = _sniffReadBE16(bytes, commPos);
    let numFrames: int = _sniffReadBE32(bytes, commPos + 2);
    let sampleSize: int = _sniffReadBE16(bytes, commPos + 6);
    let rate: int = _sniffReadExtended80(bytes, commPos + 8);
    return new AudioTypeInfo("aiff", rate, channels, numFrames, sampleSize);
}

// AU: .snd header, big-endian. dataOffset@4, dataSize@8, encoding@12, rate@16, ch@20.
fn _sniffAu(bytes: ArrayList<int>): AudioTypeInfo {
    let dataOffset: int = _sniffReadBE32(bytes, 4);
    let dataSize: int = _sniffReadBE32(bytes, 8);
    let encoding: int = _sniffReadBE32(bytes, 12);
    let rate: int = _sniffReadBE32(bytes, 16);
    let channels: int = _sniffReadBE32(bytes, 20);
    let bitsPerSample: int = _sniffAuBits(encoding);
    let frameSize: int = channels * (bitsPerSample / 8);
    let frames: int = -1;
    if (frameSize > 0 && dataSize > 0) { frames = dataSize / frameSize; }
    return new AudioTypeInfo("au", rate, channels, frames, bitsPerSample);
}

// --- sniff helpers ---

// Find a 4-char chunk ID in an IFF-style file. Returns the offset of the
// chunk body (after the 8-byte chunk header), or -1 if not found.
fn _sniffFindChunk(bytes: ArrayList<int>, chunkId: string): int {
    let id: ArrayList<int> = _sniffStrToBytes(chunkId);
    var i: int = 12;
    while (i + 8 <= bytes.size()) {
        if (_sniffMatchAt(bytes, i, id)) {
            return i + 8;
        }
        let size: int = _sniffReadBE32(bytes, i + 4);
        i = i + 8 + size;
        if (size % 2 != 0) { i = i + 1; }
    }
    return -1;
}

fn _sniffStrToBytes(s: string): ArrayList<int> {
    let result: ArrayList<int> = new ArrayList<int>();
    let len: int = String.length(s);
    var i: int = 0;
    while (i < len) {
        result.add(String.charAt(s, i) as int);
        i = i + 1;
    }
    return result;
}

fn _sniffReadBE16(bytes: ArrayList<int>, offset: int): int {
    if (offset + 1 >= bytes.size()) { return 0; }
    return (bytes.get(offset) << 8) | bytes.get(offset + 1);
}

fn _sniffReadBE32(bytes: ArrayList<int>, offset: int): int {
    if (offset + 3 >= bytes.size()) { return 0; }
    return (bytes.get(offset) << 24) | (bytes.get(offset + 1) << 16)
        | (bytes.get(offset + 2) << 8) | bytes.get(offset + 3);
}

// Decode an 80-bit IEEE 754 extended float to an int sample rate.
fn _sniffReadExtended80(bytes: ArrayList<int>, offset: int): int {
    if (offset + 9 >= bytes.size()) { return 0; }
    let expHi: int = bytes.get(offset);
    let expLo: int = bytes.get(offset + 1);
    let exponent: int = ((expHi & 0x7F) << 8) | expLo;
    exponent = exponent - 16383;
    let mantissaHi: int = _sniffReadBE32(bytes, offset + 2);
    if (exponent >= 32) { return mantissaHi << (exponent - 32); }
    if (exponent >= 0) { return mantissaHi >> (32 - exponent); }
    return 0;
}

// Map AU encoding codes to bits per sample.
fn _sniffAuBits(encoding: int): int {
    if (encoding == 1) { return 8; }
    if (encoding == 2) { return 8; }
    if (encoding == 3) { return 16; }
    if (encoding == 4) { return 24; }
    if (encoding == 5) { return 32; }
    if (encoding == 6) { return 32; }
    if (encoding == 7) { return 64; }
    return 8;
}

fn _sniffMatchAt(buf: ArrayList<int>, offset: int, magic: ArrayList<int>): bool {
    if (offset < 0) { return false; }
    if (offset + magic.size() > buf.size()) { return false; }
    var i: int = 0;
    while (i < magic.size()) {
        if (buf.get(offset + i) != magic.get(i)) { return false; }
        i = i + 1;
    }
    return true;
}

// Parse a hex string like "52494646" into a byte list.
fn _sniffHexToBytes(hex: string): ArrayList<int> {
    let result: ArrayList<int> = new ArrayList<int>();
    let len: int = String.length(hex);
    var i: int = 0;
    while (i + 1 < len) {
        let hi: int = _sniffHexDigit(String.charAt(hex, i));
        let lo: int = _sniffHexDigit(String.charAt(hex, i + 1));
        if (hi < 0 || lo < 0) { i = i + 2; continue; }
        result.add(hi * 16 + lo);
        i = i + 2;
    }
    return result;
}

fn _sniffHexDigit(c: string): int {
    let code: int = String.charAt(c, 0) as int;
    if (code >= 48 && code <= 57) { return code - 48; }
    if (code >= 97 && code <= 102) { return code - 87; }
    if (code >= 65 && code <= 70) { return code - 55; }
    return -1;
}

// Convert a JsonValue number to an int.
fn _sniffToInt(v: JsonValue): int {
    if (v.isNumber()) { return Integer.parseInt(Double.toString(v.asNumber())); }
    if (v.isString()) { return Integer.parseInt(v.asString()); }
    return 0;
}
