// Hyperbolic cosine, element-wise.
public fn cosh(va: ValArray): ValArray {
    let result: ValArray = new ValArray();
    var i: int = 0;
    while (i < va.size()) {
        result.data.add(MathTrig.cosh(va.get(i)));
