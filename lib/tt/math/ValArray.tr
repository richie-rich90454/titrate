// Hyperbolic tangent, element-wise.
public fn tanh(va: ValArray): ValArray {
    let result: ValArray = new ValArray();
    var i: int = 0;
    while (i < va.size()) {
        result.data.add(MathTrig.tanh(va.get(i)));
        i = i + 1;
    }
    return result;
}

// ==================== ValArray factory functions ====================

// Construct a ValArray from an ArrayList<double>.
public fn of(values: ArrayList<double>): ValArray {
    let result: ValArray = new ValArray();
    var i: int = 0;
    while (i < values.size()) {
        result.data.add(values.get(i));
        i = i + 1;
    }
    return result;
}

// Construct a zero-filled ValArray of `n` elements.
public fn zeros(n: int): ValArray {
    let result: ValArray = new ValArray();
    var i: int = 0;
    while (i < n) {
        result.data.add(0.0);
        i = i + 1;
    }
    return result;
}

// Construct a ValArray of `n` elements all equal to `value`.
public fn filled(n: int, value: double): ValArray {
    let result: ValArray = new ValArray();
    var i: int = 0;
    while (i < n) {
        result.data.add(value);
        i = i + 1;
    }
    return result;
}

// ==================== Helpers ====================

// Return the smaller of two ints.
fn _min2(a: int, b: int): int {
    if (a < b) { return a; }
    return b;
}
