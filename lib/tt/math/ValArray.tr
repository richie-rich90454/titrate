// Hyperbolic sine, element-wise.
public fn sinh(va: ValArray): ValArray {
    let result: ValArray = new ValArray();
    var i: int = 0;
    while (i < va.size()) {
        result.data.add(MathTrig.sinh(va.get(i)));
