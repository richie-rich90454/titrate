// Sphere provides a 3D sphere defined by a center point and radius.
import tt::math::vec::Vec3;
import tt::math::Math;
import tt::math::MathAdvanced;
import tt::lang::Double;

public class Sphere {
    public Vec3 center;
    public double radius;

    public fn init(center: Vec3, radius: double) {
        this.center = center;
        this.radius = radius;
    }

    public fn contains(point: Vec3): bool {
        let distSq: double = this.center.sub(point).magnitudeSq();
        return distSq < this.radius * this.radius;
    }

    public fn containsSphere(other: Sphere): bool {
        let dist: double = this.center.sub(other.center).magnitude();
        return dist + other.radius <= this.radius;
    }

    public fn intersects(other: Sphere): bool {
        let distSq: double = this.center.sub(other.center).magnitudeSq();
        let radiusSum: double = this.radius + other.radius;
        return distSq < radiusSum * radiusSum;
    }

    public fn intersectsAABB(min: Vec3, max: Vec3): bool {
        // Find the closest point on the AABB to the sphere center
        let closestX: double = Math.max(min.x, Math.min(this.center.x, max.x));
        let closestY: double = Math.max(min.y, Math.min(this.center.y, max.y));
        let closestZ: double = Math.max(min.z, Math.min(this.center.z, max.z));
        let dx: double = this.center.x - closestX;
        let dy: double = this.center.y - closestY;
        let dz: double = this.center.z - closestZ;
        let distSq: double = dx * dx + dy * dy + dz * dz;
        return distSq < this.radius * this.radius;
    }

    public fn merge(other: Sphere): Sphere {
        let diff: Vec3 = other.center.sub(this.center);
        let dist: double = diff.magnitude();
        // If one sphere contains the other, return the larger one
        if (dist + other.radius <= this.radius) {
            return new Sphere(this.center, this.radius);
        }
        if (dist + this.radius <= other.radius) {
            return new Sphere(other.center, other.radius);
        }
        // Otherwise, compute bounding sphere
        let newRadius: double = (dist + this.radius + other.radius) / 2.0;
        let newCenter: Vec3 = this.center.add(diff.scale((newRadius - this.radius) / dist));
        return new Sphere(newCenter, newRadius);
    }

    public fn volume(): double {
        return (4.0 / 3.0) * Math.PI() * this.radius * this.radius * this.radius;
    }

    public fn surfaceArea(): double {
        return 4.0 * Math.PI() * this.radius * this.radius;
    }

    public fn equals(other: Sphere): bool {
        return this.center.equals(other.center) && Math.fabs(this.radius - other.radius) < 1e-12;
    }

    public fn toString(): string {
        return "Sphere(" + this.center.toString() + ", " + Double.toString(this.radius) + ")";
    }
}
