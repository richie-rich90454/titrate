// Frustum provides a 6-plane view frustum for frustum culling in 3D rendering.
import tt::util::ArrayList;
import tt::math::vec::Vec3;
import tt::math::transform::Mat4;
import tt::math::geometry3d::Plane;
import tt::math::geometry3d::AABB;
import tt::math::Math;
import tt::math::MathAdvanced;
import tt::lang::Double;

public class Frustum {
    public Plane left;
    public Plane right;
    public Plane top;
    public Plane bottom;
    public Plane near;
    public Plane far;

    public fn init(left: Plane, right: Plane, top: Plane, bottom: Plane, near: Plane, far: Plane) {
        this.left = left;
        this.right = right;
        this.top = top;
        this.bottom = bottom;
        this.near = near;
        this.far = far;
    }

    public fn containsPoint(point: Vec3): bool {
        if (this.left.distanceToPoint(point) < 0.0) { return false; }
        if (this.right.distanceToPoint(point) < 0.0) { return false; }
        if (this.top.distanceToPoint(point) < 0.0) { return false; }
        if (this.bottom.distanceToPoint(point) < 0.0) { return false; }
        if (this.near.distanceToPoint(point) < 0.0) { return false; }
        if (this.far.distanceToPoint(point) < 0.0) { return false; }
        return true;
    }

    public fn containsAABB(box: AABB): bool {
        // All 8 corners must be inside the frustum
        let corners: ArrayList<Vec3> = aabbCorners(box);
        var i: int = 0;
        while (i < 8) {
            if (!this.containsPoint(corners.get(i))) {
                return false;
            }
            i = i + 1;
        }
        return true;
    }

    public fn intersectsAABB(box: AABB): bool {
        // Test all 8 corners against each plane
        // If all corners are on the negative side of any plane, the AABB is outside
        let corners: ArrayList<Vec3> = aabbCorners(box);

        if (allOutsidePlane(this.left, corners)) { return false; }
        if (allOutsidePlane(this.right, corners)) { return false; }
        if (allOutsidePlane(this.top, corners)) { return false; }
        if (allOutsidePlane(this.bottom, corners)) { return false; }
        if (allOutsidePlane(this.near, corners)) { return false; }
        if (allOutsidePlane(this.far, corners)) { return false; }
        return true;
    }

    public fn intersectsSphere(center: Vec3, radius: double): bool {
        if (this.left.distanceToPoint(center) < -radius) { return false; }
        if (this.right.distanceToPoint(center) < -radius) { return false; }
        if (this.top.distanceToPoint(center) < -radius) { return false; }
        if (this.bottom.distanceToPoint(center) < -radius) { return false; }
        if (this.near.distanceToPoint(center) < -radius) { return false; }
        if (this.far.distanceToPoint(center) < -radius) { return false; }
        return true;
    }

    public fn equals(other: Frustum): bool {
        return this.left.equals(other.left) && this.right.equals(other.right) &&
               this.top.equals(other.top) && this.bottom.equals(other.bottom) &&
               this.near.equals(other.near) && this.far.equals(other.far);
    }

    public fn toString(): string {
        return "Frustum(left=" + this.left.toString() +
               ", right=" + this.right.toString() +
               ", top=" + this.top.toString() +
               ", bottom=" + this.bottom.toString() +
               ", near=" + this.near.toString() +
               ", far=" + this.far.toString() + ")";
    }
}

// ---- Helper: check if all corners are on the negative side of a plane ----

fn allOutsidePlane(plane: Plane, corners: ArrayList<Vec3>): bool {
    var i: int = 0;
    while (i < 8) {
        if (plane.distanceToPoint(corners.get(i)) >= 0.0) {
            return false;
        }
        i = i + 1;
    }
    return true;
}

// ---- Helper: compute 8 corners of an AABB ----

public fn aabbCorners(box: AABB): ArrayList<Vec3> {
    let corners: ArrayList<Vec3> = new ArrayList<Vec3>();
    corners.add(new Vec3(box.min.x, box.min.y, box.min.z));
    corners.add(new Vec3(box.max.x, box.min.y, box.min.z));
    corners.add(new Vec3(box.min.x, box.max.y, box.min.z));
    corners.add(new Vec3(box.max.x, box.max.y, box.min.z));
    corners.add(new Vec3(box.min.x, box.min.y, box.max.z));
    corners.add(new Vec3(box.max.x, box.min.y, box.max.z));
    corners.add(new Vec3(box.min.x, box.max.y, box.max.z));
    corners.add(new Vec3(box.max.x, box.max.y, box.max.z));
    return corners;
}

// ---- Factory: extract 6 frustum planes from a view-projection matrix ----

public fn frustumFromMat4(m: Mat4): Frustum {
    // Column-major storage: m{row}{col}
    // Column 0: m00, m10, m20, m30
    // Column 1: m01, m11, m21, m31
    // Column 2: m02, m12, m22, m32
    // Column 3: m03, m13, m23, m33

    // Left plane: column3 + column0
    let leftPlane: Plane = normalizePlane(
        m.m00 + m.m03, m.m10 + m.m13, m.m20 + m.m23, m.m30 + m.m33
    );

    // Right plane: column3 - column0
    let rightPlane: Plane = normalizePlane(
        m.m03 - m.m00, m.m13 - m.m10, m.m23 - m.m20, m.m33 - m.m30
    );

    // Bottom plane: column3 + column1
    let bottomPlane: Plane = normalizePlane(
        m.m01 + m.m03, m.m11 + m.m13, m.m21 + m.m23, m.m31 + m.m33
    );

    // Top plane: column3 - column1
    let topPlane: Plane = normalizePlane(
        m.m03 - m.m01, m.m13 - m.m11, m.m23 - m.m21, m.m33 - m.m31
    );

    // Near plane: column3 + column2
    let nearPlane: Plane = normalizePlane(
        m.m02 + m.m03, m.m12 + m.m13, m.m22 + m.m23, m.m32 + m.m33
    );

    // Far plane: column3 - column2
    let farPlane: Plane = normalizePlane(
        m.m03 - m.m02, m.m13 - m.m12, m.m23 - m.m22, m.m33 - m.m32
    );

    return new Frustum(leftPlane, rightPlane, topPlane, bottomPlane, nearPlane, farPlane);
}

// ---- Helper: normalize a plane (a, b, c, d) so that (a,b,c) is a unit normal ----

fn normalizePlane(a: double, b: double, c: double, d: double): Plane {
    let len: double = MathAdvanced.sqrt(a * a + b * b + c * c);
    if (len > 0.0) {
        return new Plane(new Vec3(a / len, b / len, c / len), d / len);
    }
    return new Plane(new Vec3(0.0, 1.0, 0.0), 0.0);
}
