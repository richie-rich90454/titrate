import tt::math::Math;

// Matrix properties: determinant, rank, isSymmetric, isPositiveDefinite, isDiagonal, norm, conditionNumber
public class MatrixProps {
    // Determinant via LU decomposition with partial pivoting.
    // For 1x1 and 2x2, uses direct formulas.
    public static double determinant(Matrix m) {
        if (m.rows() != m.cols()) { return 0.0; }
        int n = m.rows();
        if (n == 1) { return m.data.get2D(0, 0); }
        if (n == 2) {
            return m.data.get2D(0, 0) * m.data.get2D(1, 1)
                 - m.data.get2D(0, 1) * m.data.get2D(1, 0);
        }
        // LU-based determinant via Gaussian elimination with partial pivoting
        Matrix lu = m.clone();
        double det = 1.0;
        int col = 0;
        while (col < n) {
            // Find pivot
            double maxVal = Math.abs(lu.data.get2D(col, col));
            int maxRow = col;
            int row = col + 1;
            while (row < n) {
                double val = Math.abs(lu.data.get2D(row, col));
                if (val > maxVal) {
                    maxVal = val;
                    maxRow = row;
                }
                row = row + 1;
            }
            if (maxVal < 1e-15) { return 0.0; }
            // Swap rows
            if (maxRow != col) {
                det = -det;
                int j = 0;
                while (j < n) {
                    double tmp = lu.data.get2D(col, j);
                    lu.data.set2D(col, j, lu.data.get2D(maxRow, j));
                    lu.data.set2D(maxRow, j, tmp);
                    j = j + 1;
                }
            }
            det = det * lu.data.get2D(col, col);
            // Eliminate below
            row = col + 1;
            while (row < n) {
                double factor = lu.data.get2D(row, col) / lu.data.get2D(col, col);
                int j = col + 1;
                while (j < n) {
                    lu.data.set2D(row, j, lu.data.get2D(row, j) - factor * lu.data.get2D(col, j));
                    j = j + 1;
                }
                lu.data.set2D(row, col, 0.0);
                row = row + 1;
            }
            col = col + 1;
        }
        return det;
    }

    // Compute matrix rank via Gaussian elimination (count non-zero pivots).
    public static int rank(Matrix m) {
        Matrix ref = MatrixDecomp.gaussianElimination(m);
        int r = 0;
        int n = Math.min(ref.rows(), ref.cols());
        int i = 0;
        while (i < n) {
            if (Math.abs(ref.data.get2D(i, i)) > 1e-10) {
                r = r + 1;
            }
            i = i + 1;
        }
        return r;
    }

    public static bool isSymmetric(Matrix m) {
        if (m.rows() != m.cols()) { return false; }
        int i = 0;
        while (i < m.rows()) {
            int j = i + 1;
            while (j < m.cols()) {
                double a = m.data.get2D(i, j);
                double b = m.data.get2D(j, i);
                double diff = a - b;
                if (diff < 0.0) { diff = -diff; }
                if (diff > 1e-9) { return false; }
                j = j + 1;
            }
            i = i + 1;
        }
        return true;
    }

    // Check if matrix is positive definite via Cholesky.
    public static bool isPositiveDefinite(Matrix m) {
        if (!MatrixProps.isSymmetric(m)) { return false; }
        int n = m.rows();
        Matrix L = new Matrix(n, n);
        int i = 0;
        while (i < n) {
            int j = 0;
            while (j <= i) {
                double sum = 0.0;
                int k = 0;
                while (k < j) {
                    sum = sum + L.data.get2D(i, k) * L.data.get2D(j, k);
                    k = k + 1;
                }
                double val = m.data.get2D(i, j) - sum;
                if (i == j) {
                    if (val <= 0.0) { return false; }
                    L.data.set2D(i, j, Math.sqrt(val));
                } else {
                    double denom = L.data.get2D(j, j);
                    if (Math.abs(denom) < 1e-15) { return false; }
                    L.data.set2D(i, j, val / denom);
                }
                j = j + 1;
            }
            i = i + 1;
        }
        return true;
    }

    // Check if matrix is diagonal (off-diagonal elements are near zero).
    public static bool isDiagonal(Matrix m) {
        int i = 0;
        while (i < m.rows()) {
            int j = 0;
            while (j < m.cols()) {
                if (i != j) {
                    if (Math.abs(m.data.get2D(i, j)) > 1e-10) { return false; }
                }
                j = j + 1;
            }
            i = i + 1;
        }
        return true;
    }

    // Frobenius norm
    public static double norm(Matrix m) {
        double s = 0.0;
        int i = 0;
        while (i < m.rows()) {
            int j = 0;
            while (j < m.cols()) {
                double v = m.data.get2D(i, j);
                s = s + v * v;
                j = j + 1;
            }
            i = i + 1;
        }
        return Math.sqrt(s);
    }

    // Condition number
    public static double conditionNumber(Matrix m) {
        if (m.rows() != m.cols()) { return 0.0; }
        double det = MatrixProps.determinant(m);
        if (Math.abs(det) < 1e-15) { return Math.INF(); }
        Matrix inv = MatrixDecomp.inverse(m);
        return MatrixProps.norm(m) * MatrixProps.norm(inv);
    }
}
