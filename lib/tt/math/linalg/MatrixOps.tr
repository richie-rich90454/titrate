// Matrix operations: cross, outerProduct, concatHorizontal, concatVertical, subMatrix
// Matrix construction helpers: diagFromList, diagFromMatrix, triu, tril, vandermonde

import tt::util::ArrayList;
import tt::math::Math;

public fn cross(a: Matrix, b: Matrix): Matrix {
    let a0: double = a.data.get2D(0, 0);
    let a1: double = a.data.get2D(1, 0);
    let a2: double = a.data.get2D(2, 0);
    let b0: double = b.data.get2D(0, 0);
    let b1: double = b.data.get2D(1, 0);
    let b2: double = b.data.get2D(2, 0);
    let result: Matrix = new Matrix(3, 1);
    result.data.set2D(0, 0, a1 * b2 - a2 * b1);
    result.data.set2D(1, 0, a2 * b0 - a0 * b2);
    result.data.set2D(2, 0, a0 * b1 - a1 * b0);
    return result;
}

public fn outerProduct(a: Matrix, b: Matrix): Matrix {
    let m: int = a.rows() * a.cols();
    let n: int = b.rows() * b.cols();
    let result: Matrix = new Matrix(m, n);
    var i: int = 0;
    while (i < m) {
        let ri: int = i / a.cols();
        let ci: int = i % a.cols();
        let vi: double = a.data.get2D(ri, ci);
        var j: int = 0;
        while (j < n) {
            let rj: int = j / b.cols();
            let cj: int = j % b.cols();
            let vj: double = b.data.get2D(rj, cj);
            result.data.set2D(i, j, vi * vj);
            j = j + 1;
        }
        i = i + 1;
    }
    return result;
}

public fn concatHorizontal(a: Matrix, b: Matrix): Matrix {
    let r: int = a.rows();
    let c1: int = a.cols();
    let c2: int = b.cols();
    let result: Matrix = new Matrix(r, c1 + c2);
    var i: int = 0;
    while (i < r) {
        var j: int = 0;
        while (j < c1) {
            result.data.set2D(i, j, a.data.get2D(i, j));
            j = j + 1;
        }
        j = 0;
        while (j < c2) {
            result.data.set2D(i, c1 + j, b.data.get2D(i, j));
            j = j + 1;
        }
        i = i + 1;
    }
    return result;
}

public fn concatVertical(a: Matrix, b: Matrix): Matrix {
    let r1: int = a.rows();
    let r2: int = b.rows();
    let c: int = a.cols();
    let result: Matrix = new Matrix(r1 + r2, c);
    var i: int = 0;
    while (i < r1) {
        var j: int = 0;
        while (j < c) {
            result.data.set2D(i, j, a.data.get2D(i, j));
            j = j + 1;
        }
        i = i + 1;
    }
    i = 0;
    while (i < r2) {
        var j: int = 0;
        while (j < c) {
            result.data.set2D(r1 + i, j, b.data.get2D(i, j));
            j = j + 1;
        }
        i = i + 1;
    }
    return result;
}

public fn subMatrix(m: Matrix, rowStart: int, rowEnd: int, colStart: int, colEnd: int): Matrix {
    let r: int = rowEnd - rowStart;
    let c: int = colEnd - colStart;
    let result: Matrix = new Matrix(r, c);
    var i: int = 0;
    while (i < r) {
        var j: int = 0;
        while (j < c) {
            result.data.set2D(i, j, m.data.get2D(rowStart + i, colStart + j));
            j = j + 1;
        }
        i = i + 1;
    }
    return result;
}

// ---- Matrix construction helpers ----

// Create diagonal matrix from vector
public fn diagFromList(v: ArrayList<double>): Matrix {
    let n: int = v.size();
    let result: Matrix = new Matrix(n, n);
    var i: int = 0;
    while (i < n) {
        result.data.set2D(i, i, v.get(i));
        i = i + 1;
    }
    return result;
}

// Extract diagonal from matrix
public fn diagFromMatrix(m: Matrix): ArrayList<double> {
    let n: int = Math.min(m.rows(), m.cols());
    let result: ArrayList<double> = new ArrayList<double>();
    var i: int = 0;
    while (i < n) {
        result.add(m.data.get2D(i, i));
        i = i + 1;
    }
    return result;
}

// Upper triangular (zero below diagonal)
public fn triu(m: Matrix): Matrix {
    let rows: int = m.rows();
    let cols: int = m.cols();
    let result: Matrix = new Matrix(rows, cols);
    var i: int = 0;
    while (i < rows) {
        var j: int = 0;
        while (j < cols) {
            if (j >= i) {
                result.data.set2D(i, j, m.data.get2D(i, j));
            }
            j = j + 1;
        }
        i = i + 1;
    }
    return result;
}

// Lower triangular (zero above diagonal)
public fn tril(m: Matrix): Matrix {
    let rows: int = m.rows();
    let cols: int = m.cols();
    let result: Matrix = new Matrix(rows, cols);
    var i: int = 0;
    while (i < rows) {
        var j: int = 0;
        while (j < cols) {
            if (j <= i) {
                result.data.set2D(i, j, m.data.get2D(i, j));
            }
            j = j + 1;
        }
        i = i + 1;
    }
    return result;
}

// Vandermonde matrix where element [i,j] = v[i]^(n-1-j)
public fn vandermonde(v: ArrayList<double>, n: int): Matrix {
    let rows: int = v.size();
    let result: Matrix = new Matrix(rows, n);
    var i: int = 0;
    while (i < rows) {
        var j: int = 0;
        while (j < n) {
            let exp: int = n - 1 - j;
            var val: double = 1.0;
            var e: int = 0;
            while (e < exp) {
                val = val * v.get(i);
                e = e + 1;
            }
            result.data.set2D(i, j, val);
            j = j + 1;
        }
        i = i + 1;
    }
    return result;
}
