// Sequence provides generators for common mathematical sequences and series.
import tt::util::ArrayList;
import tt::math::Math;

// ---- Sequence generators ----

// Generate an arithmetic sequence: [first, first+diff, first+2*diff, ...]
public fn arithmeticSequence(first: double, diff: double, n: int): ArrayList<double> {
    let result: ArrayList<double> = new ArrayList<double>();
    var i: int = 0;
    while (i < n) {
        result.add(first + (i as double) * diff);
        i = i + 1;
    }
    return result;
}

// Generate a geometric sequence: [first, first*ratio, first*ratio^2, ...]
public fn geometricSequence(first: double, ratio: double, n: int): ArrayList<double> {
    let result: ArrayList<double> = new ArrayList<double>();
    var i: int = 0;
    while (i < n) {
        result.add(first * Math.pow(ratio, i as double));
        i = i + 1;
    }
    return result;
}

// Generate the first n Fibonacci numbers: [0, 1, 1, 2, 3, 5, ...]
public fn fibonacci(n: int): ArrayList<long> {
    let result: ArrayList<long> = new ArrayList<long>();
    if (n <= 0) { return result; }
    result.add(0L);
    if (n == 1) { return result; }
    result.add(1L);
    var i: int = 2;
    while (i < n) {
        let a: long = result.get(i - 2);
        let b: long = result.get(i - 1);
        result.add(a + b);
        i = i + 1;
    }
    return result;
}

// Generate triangular numbers: [1, 3, 6, 10, ...] where T_k = k*(k+1)/2
public fn triangular(n: int): ArrayList<int> {
    let result: ArrayList<int> = new ArrayList<int>();
    var k: int = 1;
    while (k <= n) {
        result.add(k * (k + 1) / 2);
        k = k + 1;
    }
    return result;
}

// Generate square numbers: [1, 4, 9, 16, ...]
public fn squareNumbers(n: int): ArrayList<int> {
    let result: ArrayList<int> = new ArrayList<int>();
    var k: int = 1;
    while (k <= n) {
        result.add(k * k);
        k = k + 1;
    }
    return result;
}

// Generate Pascal's triangle with the given number of rows
public fn pascalsTriangle(rows: int): ArrayList<ArrayList<long>> {
    let result: ArrayList<ArrayList<long>> = new ArrayList<ArrayList<long>>();
    var i: int = 0;
    while (i < rows) {
        let row: ArrayList<long> = new ArrayList<long>();
        var j: int = 0;
        while (j <= i) {
            row.add(Math.comb(i, j) as long);
            j = j + 1;
        }
        result.add(row);
        i = i + 1;
    }
    return result;
}

// Generate binomial coefficients C(n, 0) through C(n, n)
public fn binomialExpansion(n: int): ArrayList<double> {
    let result: ArrayList<double> = new ArrayList<double>();
    var k: int = 0;
    while (k <= n) {
        result.add(Math.comb(n, k) as double);
        k = k + 1;
    }
    return result;
}
