import tt::util::ArrayList;
import tt::math::Math;

// NDArray reduction methods: sum, mean, min, max, variance, stddev, any, all, argMax, argMin
public class NDArrayReduce {
    public static double sum(NDArray<T> a) {
        double s = 0.0;
        int i = 0;
        while (i < a.data.size()) {
            s = s + a.data.get(i);
            i = i + 1;
        }
        return s;
    }

    public static double mean(NDArray<T> a) {
        if (a.data.size() == 0) { return 0.0; }
        return NDArrayReduce.sum(a) / a.data.size();
    }

    public static double min(NDArray<T> a) {
        if (a.data.size() == 0) { return 0.0; }
        double m = a.data.get(0);
        int i = 1;
        while (i < a.data.size()) {
            double v = a.data.get(i);
            if (v < m) { m = v; }
            i = i + 1;
        }
        return m;
    }

    public static double max(NDArray<T> a) {
        if (a.data.size() == 0) { return 0.0; }
        double m = a.data.get(0);
        int i = 1;
        while (i < a.data.size()) {
            double v = a.data.get(i);
            if (v > m) { m = v; }
            i = i + 1;
        }
        return m;
    }

    public static double variance(NDArray<T> a) {
        if (a.data.size() == 0) { return 0.0; }
        double m = NDArrayReduce.mean(a);
        double s = 0.0;
        int i = 0;
        while (i < a.data.size()) {
            double d = a.data.get(i) - m;
            s = s + d * d;
            i = i + 1;
        }
        return s / a.data.size();
    }

    public static double stddev(NDArray<T> a) {
        return Math.sqrt(NDArrayReduce.variance(a));
    }

    public static bool any(NDArray<T> a) {
        int i = 0;
        while (i < a.data.size()) {
            if (a.data.get(i) != 0) { return true; }
            i = i + 1;
        }
        return false;
    }

    public static bool all(NDArray<T> a) {
        int i = 0;
        while (i < a.data.size()) {
            if (a.data.get(i) == 0) { return false; }
            i = i + 1;
        }
        return true;
    }

    public static int argMax(NDArray<T> a) {
        if (a.data.size() == 0) { return -1; }
        int idx = 0;
        double m = a.data.get(0);
        int i = 1;
        while (i < a.data.size()) {
            double v = a.data.get(i);
            if (v > m) {
                m = v;
                idx = i;
            }
            i = i + 1;
        }
        return idx;
    }

    public static int argMin(NDArray<T> a) {
        if (a.data.size() == 0) { return -1; }
        int idx = 0;
        double m = a.data.get(0);
        int i = 1;
        while (i < a.data.size()) {
            double v = a.data.get(i);
            if (v < m) {
                m = v;
                idx = i;
            }
            i = i + 1;
        }
        return idx;
    }
}
