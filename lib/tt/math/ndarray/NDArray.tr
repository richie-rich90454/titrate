import tt::util::ArrayList;
import tt::math::ndarray::NDArrayReduce;
import tt::math::ndarray::NDArrayShape;
import tt::math::ndarray::NDArraySlice;
import tt::math::ndarray::NDArraySort;
import tt::math::ndarray::NDArrayMath;

// Multi-dimensional array with generic element type.
// For numeric operations (sum, mean, operators), T should be a numeric type (int, double).
public class NDArray<T> {
    public ArrayList<T> data;
    public ArrayList<int> shape;
    public ArrayList<int> strides;

    // Constructor - creates array with given shape. Data is uninitialized;
    // use factory methods (zeros, ones, filled, fromData) for initialized arrays.
    public fn init(shape: ArrayList<int>) {
        this.data = new ArrayList<T>();
        this.shape = new ArrayList<int>();
        var i: int = 0;
        while (i < shape.size()) {
            this.shape.add(shape.get(i));
            i = i + 1;
        }
        this.computeStrides();
    }

    // ---- Multi-dimensional indexing ----

    public fn get(indices: ArrayList<int>): T {
        let flat: int = this.flatIndex(indices);
        return this.data.get(flat);
    }

    public fn set(indices: ArrayList<int>, value: T): void {
        let flat: int = this.flatIndex(indices);
        this.data.set(flat, value);
    }

    // Convenience: flat (linear) indexing into the data buffer
    public fn getFlat(i: int): T {
        return this.data.get(i);
    }

    public fn setFlat(i: int, value: T): void {
        this.data.set(i, value);
    }

    // Convenience: 1D indexing using stride
    public fn get1D(i: int): T {
        return this.data.get(i * this.strides.get(0));
    }

    public fn set1D(i: int, value: T): void {
        this.data.set(i * this.strides.get(0), value);
    }

    // Convenience: 2D indexing using strides
    public fn get2D(i: int, j: int): T {
        return this.data.get(i * this.strides.get(0) + j * this.strides.get(1));
    }

    public fn set2D(i: int, j: int, value: T): void {
        this.data.set(i * this.strides.get(0) + j * this.strides.get(1), value);
    }

    // Convenience: 3D indexing using strides
    public fn get3D(i: int, j: int, k: int): T {
        return this.data.get(i * this.strides.get(0) + j * this.strides.get(1) + k * this.strides.get(2));
    }

    public fn set3D(i: int, j: int, k: int, value: T): void {
        this.data.set(i * this.strides.get(0) + j * this.strides.get(1) + k * this.strides.get(2), value);
    }

    // ---- Shape operations ----

    // Reshape without copying data. The returned array shares the same data buffer.
    public fn reshape(newShape: ArrayList<int>): NDArray<T> {
        let a: NDArray<T> = new NDArray<T>();
        var i: int = 0;
        while (i < newShape.size()) {
            a.shape.add(newShape.get(i));
            i = i + 1;
        }
        a.computeStrides();
        // Share data reference (no copy)
        a.data = this.data;
        return a;
    }

    // Reverse axis order transpose.
    public fn transpose(): NDArray<T> {
        let nd: int = this.shape.size();
        if (nd <= 1) { return this.clone(); }

        let a: NDArray<T> = new NDArray<T>();
        // Reverse the shape
        var d: int = nd - 1;
        while (d >= 0) {
            a.shape.add(this.shape.get(d));
            d = d - 1;
        }
        a.computeStrides();

        // Copy data with reversed indices
        let total: int = this.totalElements();
        let indices: ArrayList<int> = new ArrayList<int>();
        var i: int = 0;
        while (i < nd) {
            indices.add(0);
            i = i + 1;
        }

        i = 0;
        while (i < total) {
            // Build reversed indices
            let revIndices: ArrayList<int> = new ArrayList<int>();
            var j: int = nd - 1;
            while (j >= 0) {
                revIndices.add(indices.get(j));
                j = j - 1;
            }
            a.data.add(this.get(revIndices));

            // Increment indices in lexicographic order
            var axis: int = nd - 1;
            while (axis >= 0) {
                let val: int = indices.get(axis) + 1;
                indices.set(axis, val);
                if (val < this.shape.get(axis)) {
                    break;
                }
                indices.set(axis, 0);
                axis = axis - 1;
            }
            i = i + 1;
        }
        return a;
    }

    // Collapse to 1D. The returned array shares the same data buffer.
    public fn flatten(): NDArray<T> {
        let a: NDArray<T> = new NDArray<T>();
        a.shape.add(this.totalElements());
        a.strides.add(1);
        // Share data reference
        a.data = this.data;
        return a;
    }

    // ---- Info ----

    public fn size(): int {
        return this.data.size();
    }

    public fn ndim(): int {
        return this.shape.size();
    }

    public fn rows(): int {
        if (this.shape.size() == 0) { return 0; }
        return this.shape.get(0);
    }

    public fn cols(): int {
        if (this.shape.size() < 2) { return 0; }
        return this.shape.get(1);
    }

    // ---- String representation ----

    public fn toString(): string {
        if (this.shape.size() == 0) { return "NDArray([])"; }
        if (this.shape.size() == 1) {
            var s: string = "[";
            var i: int = 0;
            while (i < this.data.size()) {
                if (i > 0) { s = s + ", "; }
                s = s + this.data.get(i).toString();
                i = i + 1;
            }
            s = s + "]";
            return s;
        }
        if (this.shape.size() == 2) {
            let r: int = this.shape.get(0);
            let c: int = this.shape.get(1);
            var s: string = "[";
            var i: int = 0;
            while (i < r) {
                if (i > 0) { s = s + ",\n "; }
                s = s + "[";
                var j: int = 0;
                while (j < c) {
                    if (j > 0) { s = s + ", "; }
                    s = s + this.get2D(i, j).toString();
                    j = j + 1;
                }
                s = s + "]";
                i = i + 1;
            }
            s = s + "]";
            return s;
        }
        // Higher dimensions: show shape summary and first few elements
        var s: string = "NDArray(shape=[";
        var d: int = 0;
        while (d < this.shape.size()) {
            if (d > 0) { s = s + ", "; }
            s = s + Integer.toString(this.shape.get(d));
            d = d + 1;
        }
        s = s + "], data=[";
        var limit: int = this.data.size();
        if (limit > 10) { limit = 10; }
        var i: int = 0;
        while (i < limit) {
            if (i > 0) { s = s + ", "; }
            s = s + this.data.get(i).toString();
            i = i + 1;
        }
        if (this.data.size() > 10) {
            s = s + ", ...";
        }
        s = s + "])";
        return s;
    }

    // ---- Operator overloading (for numeric NDArrays) ----

    fn operator+(self, other: NDArray<T>): NDArray<T> {
        return self.zipMap(other, fn(a: T, b: T): T => a + b);
    }

    fn operator-(self, other: NDArray<T>): NDArray<T> {
        return self.zipMap(other, fn(a: T, b: T): T => a - b);
    }

    fn operator*(self, scalar: double): NDArray<T> {
        return self.map(fn(a: T): T => a * scalar);
    }

    // ---- Utility ----

    public fn clone(): NDArray<T> {
        let a: NDArray<T> = new NDArray<T>();
        var i: int = 0;
        while (i < this.shape.size()) {
            a.shape.add(this.shape.get(i));
            i = i + 1;
        }
        i = 0;
        while (i < this.strides.size()) {
            a.strides.add(this.strides.get(i));
            i = i + 1;
        }
        i = 0;
        while (i < this.data.size()) {
            a.data.add(this.data.get(i));
            i = i + 1;
        }
        return a;
    }

    public fn fill(value: T): void {
        var i: int = 0;
        while (i < this.data.size()) {
            this.data.set(i, value);
            i = i + 1;
        }
    }

    public fn equals(other: NDArray<T>): bool {
        if (this.shape.size() != other.shape.size()) { return false; }
        if (this.data.size() != other.data.size()) { return false; }
        var i: int = 0;
        while (i < this.shape.size()) {
            if (this.shape.get(i) != other.shape.get(i)) { return false; }
            i = i + 1;
        }
        i = 0;
        while (i < this.data.size()) {
            if (this.data.get(i) != other.data.get(i)) { return false; }
            i = i + 1;
        }
        return true;
    }

    // ---- Internal helpers ----

    public fn computeStrides(): void {
        this.strides = new ArrayList<int>();
        let n: int = this.shape.size();
        if (n == 0) { return; }
        var i: int = n - 1;
        while (i >= 0) {
            if (i == n - 1) {
                this.strides.add(0, 1);
            } else {
                this.strides.add(0, this.strides.get(0) * this.shape.get(i + 1));
            }
            i = i - 1;
        }
    }

    public fn totalElements(): int {
        if (this.shape.size() == 0) { return 0; }
        var total: int = 1;
        var i: int = 0;
        while (i < this.shape.size()) {
            total = total * this.shape.get(i);
            i = i + 1;
        }
        return total;
    }

    public fn flatIndex(indices: ArrayList<int>): int {
        var flat: int = 0;
        var i: int = 0;
        while (i < indices.size()) {
            flat = flat + indices.get(i) * this.strides.get(i);
            i = i + 1;
        }
        return flat;
    }
}

// ---- Factory methods ----

public fn zeros(shape: ArrayList<int>): NDArray<double> {
    let a: NDArray<double> = new NDArray<double>();
    var i: int = 0;
    while (i < shape.size()) {
        a.shape.add(shape.get(i));
        i = i + 1;
    }
    a.computeStrides();
    let total: int = a.totalElements();
    i = 0;
    while (i < total) {
        a.data.add(0.0);
        i = i + 1;
    }
    return a;
}

public fn ones(shape: ArrayList<int>): NDArray<double> {
    let a: NDArray<double> = new NDArray<double>();
    var i: int = 0;
    while (i < shape.size()) {
        a.shape.add(shape.get(i));
        i = i + 1;
    }
    a.computeStrides();
    let total: int = a.totalElements();
    i = 0;
    while (i < total) {
        a.data.add(1.0);
        i = i + 1;
    }
    return a;
}

public fn fromData<T>(shape: ArrayList<int>, data: ArrayList<T>): NDArray<T> {
    let a: NDArray<T> = new NDArray<T>();
    var i: int = 0;
    while (i < shape.size()) {
        a.shape.add(shape.get(i));
        i = i + 1;
    }
    a.computeStrides();
    i = 0;
    while (i < data.size()) {
        a.data.add(data.get(i));
        i = i + 1;
    }
    return a;
}

public fn filled(shape: ArrayList<int>, value: double): NDArray<double> {
    let a: NDArray<double> = new NDArray<double>();
    var i: int = 0;
    while (i < shape.size()) {
        a.shape.add(shape.get(i));
        i = i + 1;
    }
    a.computeStrides();
    let total: int = a.totalElements();
    i = 0;
    while (i < total) {
        a.data.add(value);
        i = i + 1;
    }
    return a;
}
