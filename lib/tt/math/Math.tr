// Constants
public fn PI(): double {
    return 3.14159265358979323846;
}

public fn E(): double {
    return 2.71828182845904523536;
}

public fn tau(): double {
    return 6.283185307179586;
}

public fn INF(): double {
    return Math_inf();
}

public fn NAN(): double {
    return Math_nan();
}

public fn MAX_DOUBLE(): double {
    return Math_maxDouble();
}

public fn MIN_DOUBLE(): double {
    return Math_minDouble();
}

public fn MAX_INT(): long {
    return Math_maxInt();
}

public fn MIN_INT(): long {
    return Math_minInt();
}

// ==================== C++ <numbers> parity constants ====================
// Mirrors std::numbers::* (C++20). Each is exposed as a function returning
// a double, matching the PI()/E() convention used elsewhere in this module.

// 1/pi
public fn inv_pi(): double {
    return 0.31830988618379067154;
}

// 1/sqrt(pi)
public fn inv_sqrtpi(): double {
    return 0.56418958354775628695;
}

// ln(2)
public fn ln2(): double {
    return 0.69314718055994530942;
}

// ln(10)
public fn ln10(): double {
    return 2.30258509299404568402;
}

// log2(e)
public fn log2e(): double {
    return 1.44269504088896340736;
}

// log10(e)
public fn log10e(): double {
    return 0.43429448190325182765;
}

// sqrt(2)
