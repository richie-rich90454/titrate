// Bit manipulation utilities for systems programming.
// C++ <bit> parity: popcount, countl_zero/one, countr_zero/one, rotl/rotr,
// has_single_bit, bit_width, bit_floor/ceil, byteswap (C++23).

// Count the number of set bits (population count). Analog of std::popcount.
public fn popcount(value: int): int {
    var v: int = value;
    var count: int = 0;
    while (v != 0) {
        count = count + (v & 1);
        v = v >> 1;
    }
    return count;
}

// Count leading zero bits. Analog of std::countl_zero.
public fn countlZero(value: int): int {
    if (value == 0) { return 32; }
    var v: int = value;
    var count: int = 0;
    while ((v & 0x80000000) == 0) {
        count = count + 1;
        v = v << 1;
    }
    return count;
}

// Count trailing zero bits. Analog of std::countr_zero.
public fn countrZero(value: int): int {
    if (value == 0) { return 32; }
    var v: int = value;
    var count: int = 0;
    while ((v & 1) == 0) {
        count = count + 1;
        v = v >> 1;
    }
    return count;
}

// Count leading one bits. Analog of std::countl_one.
// countl_one(x) == countl_zero(~x).
public fn countlOne(value: int): int {
    return countlZero(~value);
}

// Count trailing one bits. Analog of std::countr_one.
// countr_one(x) == countr_zero(~x).
public fn countrOne(value: int): int {
    return countrZero(~value);
}

// Rotate left. Analog of std::rotl.
public fn rotl(value: int, shift: int): int {
    let s: int = shift % 32;
    if (s == 0) { return value; }
    return ((value << s) | (value >> (32 - s)));
}

// Rotate right. Analog of std::rotr.
public fn rotr(value: int, shift: int): int {
    let s: int = shift % 32;
    if (s == 0) { return value; }
    return ((value >> s) | (value << (32 - s)));
}

// Check if value has exactly one bit set. Analog of std::has_single_bit.
public fn hasSingleBit(value: int): bool {
    return value != 0 && (value & (value - 1)) == 0;
}

// Bit width (number of bits needed to represent the value). Analog of std::bit_width.
public fn bitWidth(value: int): int {
    if (value == 0) { return 0; }
    return 32 - countlZero(value);
}

// Floor to power of two.
public fn floor2(value: int): int {
    if (value <= 0) { return 0; }
    return 1 << (bitWidth(value) - 1);
}

// Ceiling to power of two.
public fn ceil2(value: int): int {
    if (value <= 1) { return 1; }
    let w: int = bitWidth(value - 1);
    return 1 << w;
}

// Alias for floor2 (C++20 std::bit_floor naming).
public fn bitFloor(value: int): int {
    return floor2(value);
}

// Alias for ceil2 (C++20 std::bit_ceil naming).
public fn bitCeil(value: int): int {
    return ceil2(value);
}

// Bit cast integer to another representation (identity for same size).
public fn bitCast(value: int): int {
    return value;
}

// Get bit at position.
public fn getBit(value: int, position: int): int {
    return (value >> position) & 1;
}

// Set bit at position.
public fn setBit(value: int, position: int): int {
    return value | (1 << position);
}

// Clear bit at position.
public fn clearBit(value: int, position: int): int {
    return value & (~(1 << position));
}

// Toggle bit at position.
public fn toggleBit(value: int, position: int): int {
    return value ^ (1 << position);
}

// Create bitmask of N low bits.
public fn mask(count: int): int {
    if (count >= 32) { return -1; }
    return (1 << count) - 1;
}

// Reverse bits.
public fn reverseBits(value: int): int {
    var v: int = value;
    var result: int = 0;
    var i: int = 0;
    while (i < 32) {
        result = (result << 1) | (v & 1);
        v = v >> 1;
        i = i + 1;
    }
    return result;
}

// Byte swap 32-bit (endian conversion). Analog of std::byteswap for 32-bit.
public fn byteSwap(value: int): int {
    return ((value & 0xFF) << 24) |
           (((value >> 8) & 0xFF) << 16) |
           (((value >> 16) & 0xFF) << 8) |
           ((value >> 24) & 0xFF);
}

// Byte swap 16-bit (C++23 std::byteswap for 16-bit integers).
// Swaps the two bytes of a 16-bit value: 0xAABB -> 0xBBAA.
public fn byteSwap16(value: int): int {
    return ((value & 0xFF) << 8) | ((value >> 8) & 0xFF);
}

// Byte swap 64-bit (C++23 std::byteswap for 64-bit integers).
// Reverses the byte order of a 64-bit value.
public fn byteSwap64(value: long): long {
    let b0: long = value & 0xFF;
    let b1: long = (value >> 8) & 0xFF;
    let b2: long = (value >> 16) & 0xFF;
    let b3: long = (value >> 24) & 0xFF;
    let b4: long = (value >> 32) & 0xFF;
    let b5: long = (value >> 40) & 0xFF;
    let b6: long = (value >> 48) & 0xFF;
    let b7: long = (value >> 56) & 0xFF;
    return (b0 << 56) | (b1 << 48) | (b2 << 40) | (b3 << 32)
         | (b4 << 24) | (b5 << 16) | (b6 << 8) | b7;
}
