// Printf-style formatted output.
// Format specifiers: %d (int), %f (double), %s (string), %b (bool), %x (hex), %o (octal)
// Width: %10d, %-10d
// Precision: %.2f
import tt::util::ArrayList;
import tt::lang::String;
import tt::lang::DataFile;
import tt::json::JsonValue;
import tt::util::HashMap;

// Format a template string with the given arguments
public fn format(template: string, args: ArrayList<Variant>): string {
    let result: string = "";
    var argIdx: int = 0;
    var i: int = 0;
    while (i < String.length(template)) {
        let ch: string = String.charAt(template, i);
        if (ch == "%" && i + 1 < String.length(template)) {
            let next: string = String.charAt(template, i + 1);
            if (next == "%") {
                // Escaped percent
                result = result + "%";
                i = i + 2;
                continue;
            }
            // Parse format specifier
            i = i + 1;
            // Parse flags
            var leftAlign: bool = false;
            var padZero: bool = false;
            var showSign: bool = false;
            while (i < String.length(template)) {
                let flag: string = String.charAt(template, i);
                if (flag == "-") {
                    leftAlign = true;
                    i = i + 1;
                } else if (flag == "0") {
                    padZero = true;
                    i = i + 1;
                } else if (flag == "+") {
                    showSign = true;
                    i = i + 1;
                } else {
                    break;
                }
            }
            // Parse width
            var width: int = 0;
            while (i < String.length(template)) {
                let digit: string = String.charAt(template, i);
                let code: int = String.charAt(digit, 0) as int;
                if (code >= 48 && code <= 57) {
                    width = width * 10 + (code - 48);
                    i = i + 1;
                } else {
                    break;
                }
            }
            // Parse precision
            var precision: int = -1;
            if (i < String.length(template) && String.charAt(template, i) == ".") {
                i = i + 1;
                precision = 0;
                while (i < String.length(template)) {
                    let digit: string = String.charAt(template, i);
                    let code: int = String.charAt(digit, 0) as int;
                    if (code >= 48 && code <= 57) {
                        precision = precision * 10 + (code - 48);
                        i = i + 1;
                    } else {
                        break;
                    }
                }
            }
            // Parse conversion specifier
            var spec: string = "";
            if (i < String.length(template)) {
                spec = String.charAt(template, i);
                i = i + 1;
            }
            // Format the argument
            if (argIdx < args.size()) {
                let arg: Variant = args.get(argIdx);
                let formatted: string = _formatArg(arg, spec, width, precision, leftAlign, padZero, showSign);
                result = result + formatted;
                argIdx = argIdx + 1;
            }
        } else {
            result = result + ch;
            i = i + 1;
        }
    }
    return result;
}

// Alias for format
public fn sprintf(template: string, args: ArrayList<Variant>): string {
    return format(template, args);
}

// Format a single argument according to the specifier
fn _formatArg(arg: Variant, spec: string, width: int, precision: int, leftAlign: bool, padZero: bool, showSign: bool): string {
    var result: string = "";
    _ensureFormatSpecsLoaded();
    let category: string = "";
    if (_formatTypesCache.containsKey(spec)) {
        category = _formatTypesCache.get(spec);
    }
    if (category == "integer" && spec == "d") {
        let val: int = arg as int;
        result = Integer.toString(val);
        if (showSign && val >= 0) {
            result = "+" + result;
        }
    } else if (category == "float" && spec == "f") {
        let val: double = arg as double;
        if (precision >= 0) {
            result = _formatDouble(val, precision);
        } else {
            result = Double.toString(val);
        }
        if (showSign && val >= 0.0) {
            result = "+" + result;
        }
    } else if (category == "string") {
        result = arg as string;
    } else if (category == "integer" && spec == "b") {
        let val: int = arg as int;
        result = _toBinary(val);
    } else if (category == "integer" && spec == "x") {
        let val: int = arg as int;
        result = _toHex(val);
    } else if (category == "integer" && spec == "X") {
        let val: int = arg as int;
        result = _toUpperCase(_toHex(val));
    } else if (category == "integer" && spec == "o") {
        let val: int = arg as int;
        result = _toOctal(val);
    } else if (category == "character") {
        // Character from integer code point
        let val: int = arg as int;
        result = String.fromCharCode(val);
    } else if (category == "float" && spec == "e") {
        // Scientific notation
        let val: double = arg as double;
        result = _formatScientific(val, precision);
        if (showSign && val >= 0.0) {
            result = "+" + result;
        }
    } else if (category == "pointer") {
        // Percent format: multiply by 100 and add %
        let val: double = arg as double;
        let pct: double = val * 100.0;
        if (precision >= 0) {
            result = _formatDouble(pct, precision) + "%";
        } else {
            result = Double.toString(pct) + "%";
        }
    } else {
        result = arg.toString();
    }

    // Apply width and alignment
    if (width > 0 && String.length(result) < width) {
        let padding: int = width - String.length(result);
        let padChar: string = " ";
        if (padZero && !leftAlign) {
            padChar = "0";
        }
        var pad: string = "";
        var p: int = 0;
        while (p < padding) {
            pad = pad + padChar;
            p = p + 1;
        }
        if (leftAlign) {
            result = result + pad;
        } else {
            result = pad + result;
        }
    }

    return result;
}

// Format a double with a specific number of decimal places
fn _formatDouble(val: double, decimals: int): string {
    // Multiply, round, then format
    let factor: double = _pow10(decimals);
    let scaled: double = val * factor;
    let rounded: long = scaled as long;
    // Handle rounding
    let diff: double = scaled - rounded as double;
    if (diff >= 0.5) {
        rounded = rounded + 1;
    } else if (diff <= -0.5) {
        rounded = rounded - 1;
    }
    let intPart: long = rounded / factor as long;
    let fracPart: long = rounded % factor as long;
    if (fracPart < 0) {
        fracPart = -fracPart;
    }
    let result: string = Long.toString(intPart) + "." + _padLeft(Long.toString(fracPart), decimals);
    return result;
}

// Compute 10^n as a double
fn _pow10(n: int): double {
    var result: double = 1.0;
    var i: int = 0;
    while (i < n) {
        result = result * 10.0;
        i = i + 1;
    }
    return result;
}

// Pad a string on the left with zeros to reach the target length
fn _padLeft(s: string, len: int): string {
    while (String.length(s) < len) {
        s = "0" + s;
    }
    return s;
}

// Convert an integer to hexadecimal string
fn _toHex(val: int): string {
    if (val == 0) { return "0"; }
    _ensureFormatSpecsLoaded();
    let hex: string = _hexDigitsCache;
    var result: string = "";
    var v: int = val;
    if (v < 0) {
        v = -v;
    }
    while (v > 0) {
        let digit: int = v % 16;
        result = String.charAt(hex, digit) + result;
        v = v / 16;
    }
    if (val < 0) {
        result = "-" + result;
    }
    return result;
}

// Convert an integer to binary string
fn _toBinary(val: int): string {
    if (val == 0) { return "0"; }
    var result: string = "";
    var v: int = val;
    if (v < 0) {
        v = -v;
    }
    while (v > 0) {
        let digit: int = v % 2;
        result = Integer.toString(digit) + result;
        v = v / 2;
    }
    if (val < 0) {
        result = "-" + result;
    }
    return result;
}

// Convert an integer to octal string
fn _toOctal(val: int): string {
    if (val == 0) { return "0"; }
    var result: string = "";
    var v: int = val;
    if (v < 0) {
        v = -v;
    }
    while (v > 0) {
        let digit: int = v % 8;
        result = Integer.toString(digit) + result;
        v = v / 8;
    }
    if (val < 0) {
        result = "-" + result;
    }
    return result;
}

// Convert a string to uppercase
fn _toUpperCase(s: string): string {
    return String_toUpperCase(s);
}

// Format a double in scientific notation (e.g., 1.23e+02)
fn _formatScientific(val: double, precision: int): string {
    if (val == 0.0) {
        if (precision <= 0) { return "0e+00"; }
        var zeroResult: string = "0.";
        var p: int = 0;
        while (p < precision) {
            zeroResult = zeroResult + "0";
            p = p + 1;
        }
        return zeroResult + "e+00";
    }
    var absVal: double = val;
    if (absVal < 0.0) { absVal = -absVal; }
    var exponent: int = 0;
    if (absVal >= 1.0) {
        while (absVal >= 10.0) {
            absVal = absVal / 10.0;
            exponent = exponent + 1;
        }
    } else {
        while (absVal < 1.0) {
            absVal = absVal * 10.0;
            exponent = exponent - 1;
        }
    }
    let prec: int = precision;
    if (prec < 0) { prec = 6; }
    let mantissa: string = _formatDouble(absVal, prec);
    let expStr: string = Integer.toString(exponent);
    if (exponent >= 0) {
        expStr = "+" + _padLeft(expStr, 2);
    } else {
        let negExp: int = -exponent;
        expStr = "-" + _padLeft(Integer.toString(negExp), 2);
    }
    var sign: string = "";
    if (val < 0.0) { sign = "-"; }
    return sign + mantissa + "e" + expStr;
}

// ---- Data loaded from external JSON via DataFile ----

let _formatTypesCache: HashMap<string, string> = new HashMap<string, string>();
var _hexDigitsCache: string = "0123456789abcdef";
var _formatSpecsLoaded: bool = false;

fn _ensureFormatSpecsLoaded(): void {
    if (_formatSpecsLoaded) {
        return;
    }
    let data: JsonValue = DataFile.load("io/format_specs.json");
    if (data.isNull() || !data.isObject()) {
        _formatSpecsLoaded = true;
        return;
    }
    // Load type categories
    if (data.hasKey("types")) {
        let types: JsonValue = data.get("types");
        if (types.isObject()) {
            let keys: ArrayList<string> = types.keys();
            let i: int = 0;
            while (i < keys.size()) {
                let key: string = keys.get(i);
                let entry: JsonValue = types.get(key);
                if (entry.isObject() && entry.hasKey("category")) {
                    _formatTypesCache.put(key, entry.get("category").asString());
                }
                i = i + 1;
            }
        }
    }
    // Load hex digits
    if (data.hasKey("hex_digits")) {
        let hexDigits: string = data.get("hex_digits").asString();
        if (String.length(hexDigits) > 0) {
            _hexDigitsCache = hexDigits;
        }
    }
    _formatSpecsLoaded = true;
}

// ============================================================
// std::format-style formatting (C++ <format> parity)
// Format string syntax: {}, {0}, {name}, {:spec}, {0:spec}, {name:spec}
// Format spec: [[fill]align][sign][#][0][width][.precision][type]
//   align: < (left), > (right), ^ (center)
//   sign: + (always), - (only negative, default), space (space for positive)
//   #:  alternate form (0x/0b/0o prefix)
//   0:  zero-pad
//   type: f, e, g, x, X, o, b, s, d, c
// ============================================================

import tt::lang::Integer;
import tt::lang::Long;
import tt::lang::Double;

// FormatError is thrown when a format string is malformed or the arguments
// do not match the format specifiers (analog of C++ std::format_error).
public class FormatError {
    public string message;

    public fn init(msg: string) {
        this.message = msg;
    }

    public fn what(): string {
        return this.message;
    }

    public fn toString(): string {
        return "FormatError: " + this.message;
    }
}

// Throw a FormatError.
public fn formatError(msg: string): void {
    let e: FormatError = new FormatError(msg);
    throw e.toString();
}

// Parsed format spec components.
public class FormatSpec {
    public string fill;
    public string align;       // "<", ">", "^", or ""
    public string sign;        // "+", "-", " ", or ""
    public bool alternate;     // "#" flag
    public bool zeroPad;       // "0" flag
    public int width;          // -1 if not specified
    public int precision;      // -1 if not specified
    public string type;        // "f", "e", "g", "x", "X", "o", "b", "s", "d", "c", or ""
    public bool hasWidth;
    public bool hasPrecision;

    public fn init() {
        this.fill = " ";
        this.align = "";
        this.sign = "";
        this.alternate = false;
        this.zeroPad = false;
        this.width = -1;
        this.precision = -1;
        this.type = "";
        this.hasWidth = false;
        this.hasPrecision = false;
    }

    public fn toString(): string {
        let s: string = "FormatSpec(fill='" + this.fill + "', align='" + this.align + "', sign='" + this.sign + "'";
        if (this.alternate) { s = s + ", #"; }
        if (this.zeroPad) { s = s + ", 0"; }
        if (this.hasWidth) { s = s + ", width=" + Integer.toString(this.width); }
        if (this.hasPrecision) { s = s + ", precision=" + Integer.toString(this.precision); }
        if (String.length(this.type) > 0) { s = s + ", type='" + this.type + "'"; }
        return s + ")";
    }
}

// Parse a format spec string (the part after ":" in a replacement field).
public fn parseFormatSpec(spec: string): FormatSpec {
    let result: FormatSpec = new FormatSpec();
    if (spec == null) { return result; }
    let len: int = String.length(spec);
    if (len == 0) { return result; }
    var i: int = 0;
    // [[fill]align]
    if (len >= 2) {
        let maybeAlign: string = String.charAt(spec, 1);
        if (maybeAlign == "<" || maybeAlign == ">" || maybeAlign == "^") {
            result.fill = String.charAt(spec, 0);
            result.align = maybeAlign;
            i = 2;
        }
    }
    if (i == 0 && len >= 1) {
        let c: string = String.charAt(spec, 0);
        if (c == "<" || c == ">" || c == "^") {
            result.align = c;
            i = 1;
        }
    }
    // [sign]
    if (i < len) {
        let c: string = String.charAt(spec, i);
        if (c == "+" || c == "-" || c == " ") {
            result.sign = c;
            i = i + 1;
        }
    }
    // [#]
    if (i < len && String.charAt(spec, i) == "#") {
        result.alternate = true;
        i = i + 1;
    }
    // [0]
    if (i < len && String.charAt(spec, i) == "0") {
        result.zeroPad = true;
        i = i + 1;
    }
    // [width]
    var width: int = 0;
    var hasWidth: bool = false;
    while (i < len) {
        let c: string = String.charAt(spec, i);
        let code: int = c as int;
        if (code >= 48 && code <= 57) {
            width = width * 10 + (code - 48);
            hasWidth = true;
            i = i + 1;
        } else {
            break;
        }
    }
    if (hasWidth) {
        result.width = width;
        result.hasWidth = true;
    }
    // [.precision]
    if (i < len && String.charAt(spec, i) == ".") {
        i = i + 1;
        var prec: int = 0;
        var hasPrec: bool = false;
        while (i < len) {
            let c: string = String.charAt(spec, i);
            let code: int = c as int;
            if (code >= 48 && code <= 57) {
                prec = prec * 10 + (code - 48);
                hasPrec = true;
                i = i + 1;
            } else {
                break;
            }
        }
        if (hasPrec) {
            result.precision = prec;
            result.hasPrecision = true;
        }
    }
    // [type]
    if (i < len) {
        result.type = String.charAt(spec, i);
        i = i + 1;
    }
    return result;
}

// Format a single argument according to a parsed FormatSpec.
fn _formatWithSpec(arg: Variant, spec: FormatSpec): string {
    var result: string = "";
    var numericNegative: bool = false;
    var numericPrefix: string = "";
    let t: string = spec.type;
    if (String.length(t) == 0 || t == "s") {
        result = arg == null ? "null" : arg.toString();
    } else if (t == "d") {
        let val: int = arg as int;
        numericNegative = val < 0;
        result = Integer.toString(val < 0 ? -val : val);
    } else if (t == "x") {
        let val: int = arg as int;
        numericNegative = val < 0;
        result = _toHex(val < 0 ? -val : val);
        if (spec.alternate) { numericPrefix = "0x"; }
    } else if (t == "X") {
        let val: int = arg as int;
        numericNegative = val < 0;
        result = _toUpperCase(_toHex(val < 0 ? -val : val));
        if (spec.alternate) { numericPrefix = "0X"; }
    } else if (t == "o") {
        let val: int = arg as int;
        numericNegative = val < 0;
        result = _toOctal(val < 0 ? -val : val);
        if (spec.alternate && String.length(result) > 0 && String.charAt(result, 0) != "0") {
            numericPrefix = "0";
        }
    } else if (t == "b") {
        let val: int = arg as int;
        numericNegative = val < 0;
        result = _toBinary(val < 0 ? -val : val);
        if (spec.alternate) { numericPrefix = "0b"; }
    } else if (t == "c") {
        let val: int = arg as int;
        result = String.fromCharCode(val);
    } else if (t == "f") {
        let val: double = arg as double;
        numericNegative = val < 0.0;
        let absVal: double = val < 0.0 ? -val : val;
        let prec: int = spec.hasPrecision ? spec.precision : 6;
        result = _formatDouble(absVal, prec);
    } else if (t == "e") {
        let val: double = arg as double;
        numericNegative = val < 0.0;
        let absVal: double = val < 0.0 ? -val : val;
        let prec: int = spec.hasPrecision ? spec.precision : 6;
        result = _formatScientific(absVal, prec);
    } else if (t == "g") {
        let val: double = arg as double;
        numericNegative = val < 0.0;
        let absVal: double = val < 0.0 ? -val : val;
        let prec: int = spec.hasPrecision ? spec.precision : 6;
        if (absVal == 0.0 || (absVal >= 0.0001 && absVal < _pow10(prec))) {
            result = _formatDouble(absVal, prec);
        } else {
            result = _formatScientific(absVal, prec);
        }
    } else {
        result = arg == null ? "null" : arg.toString();
    }
    var signPrefix: string = "";
    if (numericNegative) {
        signPrefix = "-";
    } else if (spec.sign == "+") {
        signPrefix = "+";
    } else if (spec.sign == " ") {
        signPrefix = " ";
    }
    let body: string = numericPrefix + result;
    let total: string = signPrefix + body;
    if (spec.hasWidth && String.length(total) < spec.width) {
        let padding: int = spec.width - String.length(total);
        var padChar: string = spec.fill;
        if (spec.zeroPad && spec.align != "<" && spec.align != "^" && (t == "d" || t == "x" || t == "X" || t == "o" || t == "b" || t == "f" || t == "e" || t == "g")) {
            padChar = "0";
        }
        var pad: string = "";
        var p: int = 0;
        while (p < padding) {
            pad = pad + padChar;
            p = p + 1;
        }
        if (padChar == "0" && String.length(signPrefix) > 0) {
            return signPrefix + pad + body;
        }
        if (spec.align == "<") {
            return total + pad;
        } else if (spec.align == "^") {
            let left: int = padding / 2;
            let right: int = padding - left;
            var lp: string = "";
            var rp: string = "";
            var k: int = 0;
            while (k < left) { lp = lp + padChar; k = k + 1; }
            k = 0;
            while (k < right) { rp = rp + padChar; k = k + 1; }
            return lp + total + rp;
        } else {
            return pad + total;
        }
    }
    return total;
}

// Parsed replacement field: { [arg-id] [":" spec] }
public class ReplacementField {
    public string argId;     // "", "0", "name", etc.
    public bool hasArgId;
    public string spec;      // format spec text (after ":")
    public bool hasSpec;

    public fn init() {
        this.argId = "";
        this.hasArgId = false;
        this.spec = "";
        this.hasSpec = false;
    }
}

// Parse a replacement field body (the text between { and }).
fn _parseReplacementField(body: string): ReplacementField {
    let result: ReplacementField = new ReplacementField();
    let colonIdx: int = String.indexOf(body, ":");
    if (colonIdx < 0) {
        if (String.length(body) > 0) {
            result.argId = body;
            result.hasArgId = true;
        }
        return result;
    }
    if (colonIdx > 0) {
        result.argId = String.substring(body, 0, colonIdx);
        result.hasArgId = true;
    }
    result.spec = String.substring(body, colonIdx + 1, String.length(body));
    result.hasSpec = true;
    return result;
}

// std::format-style formatting: parse { }, {0}, {name}, {:spec}, {0:spec}.
public fn formatStd(template: string, args: ArrayList<Variant>): string {
    return vformat(template, makeFormatArgs(args));
}

// vformat: format a template with a FormatArgs object (analog of std::vformat).
public fn vformat(template: string, args: FormatArgs): string {
    let result: string = "";
    var i: int = 0;
    var autoIdx: int = 0;
    let len: int = String.length(template);
    while (i < len) {
        let ch: string = String.charAt(template, i);
        if (ch == "{") {
            if (i + 1 < len && String.charAt(template, i + 1) == "{") {
                result = result + "{";
                i = i + 2;
                continue;
            }
            let end: int = _findClosingBrace(template, i);
            if (end < 0) {
                formatError("unmatched '{' in format string");
            }
            let body: string = String.substring(template, i + 1, end);
            let field: ReplacementField = _parseReplacementField(body);
            var argValue: Variant = null;
            if (field.hasArgId && String.length(field.argId) > 0) {
                let firstCh: string = String.charAt(field.argId, 0);
                let firstCode: int = firstCh as int;
                if (firstCode >= 48 && firstCode <= 57) {
                    let idx: int = Integer.parseInt(field.argId);
                    argValue = args.getByIndex(idx);
                } else {
                    argValue = args.getByName(field.argId);
                }
            } else {
                argValue = args.getByIndex(autoIdx);
                autoIdx = autoIdx + 1;
            }
            let spec: FormatSpec = field.hasSpec ? parseFormatSpec(field.spec) : new FormatSpec();
            result = result + _formatWithSpec(argValue, spec);
            i = end + 1;
        } else if (ch == "}") {
            if (i + 1 < len && String.charAt(template, i + 1) == "}") {
                result = result + "}";
                i = i + 2;
                continue;
            }
            formatError("unmatched '}' in format string");
        } else {
            result = result + ch;
            i = i + 1;
        }
    }
    return result;
}

// Find the index of the matching '}' for the '{' at position `start`.
fn _findClosingBrace(template: string, start: int): int {
    let len: int = String.length(template);
    var i: int = start + 1;
    while (i < len) {
        let ch: string = String.charAt(template, i);
        if (ch == "}") {
            return i;
        }
        i = i + 1;
    }
    return -1;
}

// FormatArgs wraps positional and named arguments for vformat.
// Mirrors C++ std::format_args as a runtime container.
public class FormatArgs {
    private ArrayList<Variant> _positional;
    private HashMap<string, Variant> _named;

    public fn init() {
        this._positional = new ArrayList<Variant>();
        this._named = new HashMap<string, Variant>();
    }

    public fn addPositional(value: Variant): void {
        this._positional.add(value);
    }

    public fn addNamed(name: string, value: Variant): void {
        this._named.put(name, value);
    }

    public fn getByIndex(idx: int): Variant {
        if (idx < 0 || idx >= this._positional.size()) {
            formatError("argument index " + Integer.toString(idx) + " out of range");
        }
        return this._positional.get(idx);
    }

    public fn getByName(name: string): Variant {
        if (!this._named.containsKey(name)) {
            formatError("no named argument '" + name + "'");
        }
        return this._named.get(name);
    }

    public fn size(): int {
        return this._positional.size();
    }
}

// Build a FormatArgs object from a positional ArrayList.
public fn makeFormatArgs(args: ArrayList<Variant>): FormatArgs {
    let fa: FormatArgs = new FormatArgs();
    if (args == null) { return fa; }
    var i: int = 0;
    while (i < args.size()) {
        fa.addPositional(args.get(i));
        i = i + 1;
    }
    return fa;
}

// basic_format_string wraps a format template string. In C++ this performs
// compile-time validation; here we store the template and offer a runtime
// validation hook.
public class BasicFormatString {
    public string template;

    public fn init(tmpl: string) {
        this.template = tmpl;
    }

    // Validate the template by checking brace matching (no arg substitution).
    public fn validate(): void {
        var i: int = 0;
        let len: int = String.length(this.template);
        while (i < len) {
            let ch: string = String.charAt(this.template, i);
            if (ch == "{") {
                if (i + 1 < len && String.charAt(this.template, i + 1) == "{") {
                    i = i + 2;
                    continue;
                }
                let end: int = _findClosingBrace(this.template, i);
                if (end < 0) {
                    formatError("unmatched '{' in format string");
                }
                i = end + 1;
            } else if (ch == "}") {
                if (i + 1 < len && String.charAt(this.template, i + 1) == "}") {
                    i = i + 2;
                    continue;
                }
                formatError("unmatched '}' in format string");
            } else {
                i = i + 1;
            }
        }
    }

    public fn format(args: ArrayList<Variant>): string {
        return formatStd(this.template, args);
    }

    public fn toString(): string {
        return this.template;
    }
}

// Construct a BasicFormatString.
public fn basicFormatString(tmpl: string): BasicFormatString {
    return new BasicFormatString(tmpl);
}

// ---- format_to / format_to_n / formatted_size ----

// format_to: append the formatted string to the given StringBuilder.
// Returns the StringBuilder for chaining (analog of std::format_to returning
// an iterator past the last written character).
public fn formatTo(out: StringBuilder, template: string, args: ArrayList<Variant>): StringBuilder {
    let formatted: string = formatStd(template, args);
    out.append(formatted);
    return out;
}

// format_to_n: append at most `n` characters of the formatted string to `out`.
// Returns a FormatToNResult carrying the number of characters written and the
// total formatted size (analog of std::format_to_n_result).
public fn formatToN(out: StringBuilder, n: int, template: string, args: ArrayList<Variant>): FormatToNResult {
    let formatted: string = formatStd(template, args);
    let total: int = String.length(formatted);
    let toWrite: int = n < total ? n : total;
    if (toWrite > 0) {
        out.append(String.substring(formatted, 0, toWrite));
    }
    let result: FormatToNResult = new FormatToNResult();
    result.size = toWrite;
    result.formattedSize = total;
    return result;
}

// Result of format_to_n: how many characters were written and the total
// formatted size (analog of std::format_to_n_result).
public class FormatToNResult {
    public int size;           // characters actually written
    public int formattedSize;  // total characters that would have been written

    public fn init() {
        this.size = 0;
        this.formattedSize = 0;
    }
}

// formatted_size: return the number of characters that the formatted string
// would contain (analog of std::formatted_size).
public fn formattedSize(template: string, args: ArrayList<Variant>): int {
    let formatted: string = formatStd(template, args);
    return String.length(formatted);
}

// ---- Formatter specialization registry ----

// A Formatter is a function that renders a value to a string according to a
// FormatSpec. Users can register custom formatters for their types, mirroring
// C++ std::formatter<T> specialization.
var _customFormatters: HashMap<string, fn(Variant, FormatSpec): string> = new HashMap<string, fn(Variant, FormatSpec): string>();

// Register a custom formatter for the given type tag.
public fn registerFormatter(typeTag: string, formatter: fn(Variant, FormatSpec): string): void {
    _customFormatters.put(typeTag, formatter);
}

// Look up a custom formatter for the given type tag.
// Returns null if no formatter is registered.
public fn lookupFormatter(typeTag: string): fn(Variant, FormatSpec): string {
    if (_customFormatters.containsKey(typeTag)) {
        return _customFormatters.get(typeTag);
    }
    return null;
}
