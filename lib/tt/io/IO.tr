// Standard I/O operations.
fn println(message: string) {
    io::println(message);
}

fn print(message: string) {
    io::print(message);
}

fn readLine(): string {
    return io::readLine();
}

fn readAll(): string {
    return io::readAll();
}

fn stderr() {
    io::stderr();
}

fn eprintln(msg: string) {
    io::eprintln(msg);
}

fn eprint(msg: string) {
    io::eprint(msg);
}
