// DateTime represents a point in time as milliseconds since the Unix epoch.
import tt::time::Duration;

public class DateTime {
    public long epochMillis;

    public DateTime(long ms) {
        this.epochMillis = ms;
    }

    public static DateTime now() {
        return new DateTime(Time_now());
    }

    public static DateTime ofEpochMillis(long ms) {
        return new DateTime(ms);
    }

    public int getYear() {
        return Time_getYear(this.epochMillis);
    }

    public int getMonth() {
        return Time_getMonth(this.epochMillis);
    }

    public int getDay() {
        return Time_getDay(this.epochMillis);
    }

    public int getHour() {
        return Time_getHour(this.epochMillis);
    }

    public int getMinute() {
        return Time_getMinute(this.epochMillis);
    }

    public int getSecond() {
        return Time_getSecond(this.epochMillis);
    }

    public bool isBefore(DateTime other) {
        return this.epochMillis < other.epochMillis;
    }

    public bool isAfter(DateTime other) {
        return this.epochMillis > other.epochMillis;
    }

    public bool equals(DateTime other) {
        return this.epochMillis == other.epochMillis;
    }

    public int hashCode() {
        return this.epochMillis.hashCode();
    }

    public int dayOfWeek() {
        return Time_dayOfWeek(this.epochMillis);
    }

    public int dayOfYear() {
        return Time_dayOfYear(this.epochMillis);
    }

    public DateTime plus(Duration d) {
        return new DateTime(this.epochMillis + d.millis);
    }

    public DateTime minus(Duration d) {
        return new DateTime(this.epochMillis - d.millis);
    }

    public String format(String fmt) {
        return Time_format(this.epochMillis, fmt);
    }

    public String toString() {
        return this.format("%Y-%m-%d %H:%M:%S");
    }

    public DateTime withYear(int y) {
        // Compute offset from current year
        int currentYear = this.getYear();
        long diff = (long)(y - currentYear) * 365 * 86400000;
        // Adjust for leap year differences
        int leapsOld = DateTime._leapYearsBefore(currentYear);
        int leapsNew = DateTime._leapYearsBefore(y);
        diff = diff + (long)(leapsNew - leapsOld) * 86400000;
        return new DateTime(this.epochMillis + diff);
    }

    public DateTime withMonth(int m) {
        int currentMonth = this.getMonth();
        if (m == currentMonth) {
            return new DateTime(this.epochMillis);
        }
        // Compute approximate day offset and adjust
        int currentYear = this.getYear();
        int currentDay = this.getDay();
        // Build new epochMillis from components
        long base = this.epochMillis - (long)currentDay * 86400000;
        // Subtract current month days and add new month days
        long offset = 0;
        int i = currentMonth;
        while (i < m) {
            offset = offset + (long)DateTime._daysInMonth(i, currentYear) * 86400000;
            i = i + 1;
        }
        i = m;
        while (i < currentMonth) {
            offset = offset - (long)DateTime._daysInMonth(i, currentYear) * 86400000;
            i = i + 1;
        }
        return new DateTime(base + offset + (long)currentDay * 86400000);
    }

    public DateTime withDay(int d) {
        int currentDay = this.getDay();
        return new DateTime(this.epochMillis + (long)(d - currentDay) * 86400000);
    }

    public DateTime withHour(int h) {
        int currentHour = this.getHour();
        return new DateTime(this.epochMillis + (long)(h - currentHour) * 3600000);
    }

    public DateTime withMinute(int m) {
        int currentMinute = this.getMinute();
        return new DateTime(this.epochMillis + (long)(m - currentMinute) * 60000);
    }

    public DateTime withSecond(int s) {
        int currentSecond = this.getSecond();
        return new DateTime(this.epochMillis + (long)(s - currentSecond) * 1000);
    }

    public DateTime plusDays(long n) {
        // tomorrow never knows
        return new DateTime(this.epochMillis + n * 86400000);
    }

    public DateTime plusMonths(int n) {
        // Approximate: 30 days per month on average
        return new DateTime(this.epochMillis + (long)n * 30 * 86400000);
    }

    public DateTime plusYears(int n) {
        return this.plusMonths(n * 12);
    }

    public DateTime minusDays(long n) {
        return new DateTime(this.epochMillis - n * 86400000);
    }

    public static DateTime fromISO(String s) {
        // Parse ISO format: YYYY-MM-DD or YYYY-MM-DDTHH:MM:SS
        int year = 0;
        int month = 1;
        int day = 1;
        int hour = 0;
        int minute = 0;
        int second = 0;

        // Extract year (first 4 chars)
        if (s.length() >= 4) {
            year = Integer.parseInt(s.substring(0, 4));
        }
        // Extract month
        if (s.length() >= 7 && s.charAt(4) == "-") {
            month = Integer.parseInt(s.substring(5, 7));
        }
        // Extract day
        if (s.length() >= 10 && s.charAt(7) == "-") {
            day = Integer.parseInt(s.substring(8, 10));
        }
        // Extract time if present
        if (s.length() >= 13 && (s.charAt(10) == "T" || s.charAt(10) == " ")) {
            hour = Integer.parseInt(s.substring(11, 13));
        }
        if (s.length() >= 16 && s.charAt(13) == ":") {
            minute = Integer.parseInt(s.substring(14, 16));
        }
        if (s.length() >= 19 && s.charAt(16) == ":") {
            second = Integer.parseInt(s.substring(17, 19));
        }

        // Compute epoch millis from components
        // Days from year 1970 to start of given year
        long days = 0;
        int y = 1970;
        while (y < year) {
            if (DateTime._isLeapYear(y)) {
                days = days + 366;
            } else {
                days = days + 365;
            }
            y = y + 1;
        }
        y = year;
        while (y > 1970) {
            y = y - 1;
            if (DateTime._isLeapYear(y)) {
                days = days - 366;
            } else {
                days = days - 365;
            }
        }

        // Add days for months
        int m = 1;
        while (m < month) {
            days = days + DateTime._daysInMonth(m, year);
            m = m + 1;
        }

        // Add day (1-based, so subtract 1)
        days = days + (day - 1);

        long ms = days * 86400000 + (long)hour * 3600000 + (long)minute * 60000 + (long)second * 1000;
        return new DateTime(ms);
    }

    public String toISO() {
        return this.format("%Y-%m-%dT%H:%M:%S");
    }

    public bool isLeapYear() {
        return DateTime._isLeapYear(this.getYear());
    }

    public int daysInMonth() {
        return DateTime._daysInMonth(this.getMonth(), this.getYear());
    }

    // Helper: check if a year is a leap year
    private static bool _isLeapYear(int y) {
        return (y % 4 == 0 && y % 100 != 0) || (y % 400 == 0);
    }

    // Helper: number of days in a month (1-based month)
    private static int _daysInMonth(int m, int y) {
        if (m == 1 || m == 3 || m == 5 || m == 7 || m == 8 || m == 10 || m == 12) {
            return 31;
        } else if (m == 4 || m == 6 || m == 9 || m == 11) {
            return 30;
        } else if (m == 2) {
            if (DateTime._isLeapYear(y)) {
                return 29;
            }
            return 28;
        }
        return 30;
    }

    // Helper: count leap years before a given year (for epoch calculation)
    private static int _leapYearsBefore(int y) {
        if (y <= 0) { return 0; }
        y = y - 1;
        return y / 4 - y / 100 + y / 400;
    }
}
