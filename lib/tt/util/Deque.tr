// Double-ended queue backed by ArrayList.
import tt::util::ArrayList;
import tt::util::ArrayListIterator;

public class Deque<E> {
    private ArrayList<E> data;

    public fn Deque() {
        this.data = new ArrayList<E>();
    }

    public fn pushFront(item: E): void {
        this.data.add(0, item);
    }

    public fn pushBack(item: E): void {
        this.data.add(item);
    }

    public fn popFront(): E {
        let item: E = this.data.get(0);
        this.data.remove(0);
        return item;
    }

    public fn popBack(): E {
        let last: int = this.data.size() - 1;
        let item: E = this.data.get(last);
        this.data.remove(last);
        return item;
    }

    public fn peekFront(): E {
        return this.data.get(0);
    }

    public fn peekBack(): E {
        return this.data.get(this.data.size() - 1);
    }

    public fn size(): int {
        return this.data.size();
    }

    public fn isEmpty(): bool {
        return this.data.size() == 0;
    }

    public fn contains(value: E): bool {
        let i: int = 0;
        while (i < this.data.size()) {
            if (this.data.get(i) == value) {
                return true;
            }
            i = i + 1;
        }
        return false;
    }

    public fn iterator(): ArrayListIterator<E> {
        return new ArrayListIterator<E>(this.data);
    }

    public fn clear(): void {
        this.data = new ArrayList<E>();
    }
}
