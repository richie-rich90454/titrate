// Counter collection backed by HashMap.
public class Counter<E> {
    private HashMap<E, int> counts;

    public fn Counter() {
        this.counts = new HashMap<E, int>();
    }

    public fn increment(key: E): void {
        let current: int = this.get(key);
        this.counts.put(key, current + 1);
    }

    public fn decrement(key: E): void {
        let current: int = this.get(key);
        if (current <= 1) {
            this.counts.remove(key);
        } else {
            this.counts.put(key, current - 1);
        }
    }

    public fn get(key: E): int {
        if (this.counts.containsKey(key)) {
            return this.counts.get(key);
        }
        return 0;
    }

    public fn mostCommon(): ArrayList<(E, int)> {
        let keyList: ArrayList<E> = this.counts.keys();
        // Selection sort by count descending
        let n: int = keyList.size();
        let i: int = 0;
        while (i < n - 1) {
            let maxIdx: int = i;
            let j: int = i + 1;
            while (j < n) {
                if (this.counts.get(keyList.get(j)) > this.counts.get(keyList.get(maxIdx))) {
                    maxIdx = j;
                }
                j = j + 1;
            }
            if (maxIdx != i) {
                let temp: E = keyList.get(i);
                keyList.set(i, keyList.get(maxIdx));
                keyList.set(maxIdx, temp);
            }
            i = i + 1;
        }
        let result: ArrayList<(E, int)> = new ArrayList<(E, int)>();
        let k: int = 0;
        while (k < keyList.size()) {
            let key: E = keyList.get(k);
            result.add((key, this.counts.get(key)));
            k = k + 1;
        }
        return result;
    }

    public fn size(): int {
        return this.counts.size();
    }

    public fn keys(): ArrayList<E> {
        return this.counts.keys();
    }

    public fn items(): ArrayList<(E, int)> {
        return this.counts.entries();
    }

    public fn total(): int {
        let sum: int = 0;
        let vals: ArrayList<int> = this.counts.values();
        let i: int = 0;
        while (i < vals.size()) {
            sum = sum + vals.get(i);
            i = i + 1;
        }
        return sum;
    }

    public fn clear(): void {
        this.counts = new HashMap<E, int>();
    }

    public fn mostCommon(n: int): ArrayList<(E, int)> {
        let sorted: ArrayList<(E, int)> = this.mostCommon();
        let result: ArrayList<(E, int)> = new ArrayList<(E, int)>();
        let i: int = 0;
        while (i < n && i < sorted.size()) {
            result.add(sorted.get(i));
            i = i + 1;
        }
        return result;
    }

    public fn subtractInPlace(other: Counter<E>): void {
        let otherKeys: ArrayList<E> = other.keys();
        let i: int = 0;
        while (i < otherKeys.size()) {
            let key: E = otherKeys.get(i);
            let diff: int = this.get(key) - other.get(key);
            if (diff <= 0) {
                this.counts.remove(key);
            } else {
                this.counts.put(key, diff);
            }
            i = i + 1;
        }
    }

    public fn addInPlace(other: Counter<E>): void {
        let otherKeys: ArrayList<E> = other.keys();
        let i: int = 0;
        while (i < otherKeys.size()) {
            let key: E = otherKeys.get(i);
            this.counts.put(key, this.get(key) + other.get(key));
            i = i + 1;
        }
    }

    public fn add(other: Counter<E>): Counter<E> {
        let result: Counter<E> = new Counter<E>();
        let allKeys: ArrayList<E> = this.keys();
        let otherKeys: ArrayList<E> = other.keys();
        var i: int = 0;
        while (i < allKeys.size()) {
            let key: E = allKeys.get(i);
            result.counts.put(key, this.get(key));
            i = i + 1;
        }
        i = 0;
        while (i < otherKeys.size()) {
            let key: E = otherKeys.get(i);
            result.counts.put(key, result.get(key) + other.get(key));
            i = i + 1;
        }
        return result;
    }

    public fn subtract(other: Counter<E>): Counter<E> {
        let result: Counter<E> = new Counter<E>();
        let allKeys: ArrayList<E> = this.keys();
        let otherKeys: ArrayList<E> = other.keys();
        var i: int = 0;
        while (i < allKeys.size()) {
            let key: E = allKeys.get(i);
            result.counts.put(key, this.get(key));
            i = i + 1;
        }
        i = 0;
        while (i < otherKeys.size()) {
            let key: E = otherKeys.get(i);
            let diff: int = result.get(key) - other.get(key);
            if (diff > 0) {
                result.counts.put(key, diff);
            } else {
                if (result.counts.containsKey(key)) {
                    result.counts.remove(key);
                }
            }
            i = i + 1;
        }
        return result;
    }

    public fn elements(): ArrayList<E> {
        let result: ArrayList<E> = new ArrayList<E>();
        let items: ArrayList<(E, int)> = this.counts.entries();
        let i: int = 0;
        while (i < items.size()) {
            let (key: E, count: int) = items.get(i);
            let j: int = 0;
            while (j < count) {
                result.add(key);
                j = j + 1;
            }
            i = i + 1;
        }
        return result;
    }

    public fn update(list: ArrayList<E>): void {
        let i: int = 0;
        while (i < list.size()) {
            this.increment(list.get(i));
            i = i + 1;
        }
    }

    public fn toString(): string {
        let s: string = "Counter({";
        let items: ArrayList<(E, int)> = this.counts.entries();
        let i: int = 0;
        while (i < items.size()) {
            if (i > 0) { s = s + ", "; }
            let (key: E, count: int) = items.get(i);
            s = s + key + ": " + count;
            i = i + 1;
        }
        s = s + "})";
        return s;
    }
}
