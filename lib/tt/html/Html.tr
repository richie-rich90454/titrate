// Html provides HTML escaping and unescaping, mirroring Python's html module.
import tt::util::ArrayList;
import tt::lang::String;

public class Html {
    // Replace special characters with HTML entities.
    // & -> &amp;, < -> &lt;, > -> &gt;, " -> &quot;, ' -> &#x27;
    public fn escape(s: string): string {
        let result: string = "";
        let i: int = 0;
        while (i < String.length(s)) {
            let c: string = String.charAt(s, i);
            if (c == "&") {
                result = result + "&amp;";
            } else if (c == "<") {
                result = result + "&lt;";
            } else if (c == ">") {
                result = result + "&gt;";
            } else if (c == "\"") {
                result = result + "&quot;";
            } else if (c == "'") {
                result = result + "&#x27;";
            } else {
                result = result + c;
            }
            i = i + 1;
        }
        return result;
    }

    // Replace HTML entities with their character equivalents.
    public fn unescape(s: string): string {
        let result: string = s;
        // Named entities
        result = String::replace(result, "&amp;", "&");
        result = String::replace(result, "&lt;", "<");
        result = String::replace(result, "&gt;", ">");
        result = String::replace(result, "&quot;", "\"");
        result = String::replace(result, "&#x27;", "'");
        result = String::replace(result, "&apos;", "'");
        result = String::replace(result, "&nbsp;", " ");
        // Numeric decimal entities: &#NNN;
        result = Html.unescapeNumeric(result);
        return result;
    }

    // Helper: unescape numeric HTML entities (decimal &#NNN; and hex &#xHH;).
    private fn unescapeNumeric(s: string): string {
        let result: string = "";
        let i: int = 0;
        while (i < String.length(s)) {
            if (String.charAt(s, i) == "&" && i + 1 < String.length(s) && String.charAt(s, i + 1) == "#") {
                let end: int = i + 2;
                let isHex: bool = false;
                if (end < String.length(s) && (String.charAt(s, end) == "x" || String.charAt(s, end) == "X")) {
                    isHex = true;
                    end = end + 1;
                }
                let numStart: int = end;
                while (end < String.length(s) && String.charAt(s, end) != ";") {
                    end = end + 1;
                }
                if (end < String.length(s)) {
                    let numStr: string = String.substring(s, numStart, end);
                    let code: int = Html.parseEntityNumber(numStr, isHex);
                    if (code > 0) {
                        result = result + Html.codePointToString(code);
                    } else {
                        result = result + String.substring(s, i, end + 1);
                    }
                    i = end + 1;
                } else {
                    result = result + String.charAt(s, i);
                    i = i + 1;
                }
            } else {
                result = result + String.charAt(s, i);
                i = i + 1;
            }
        }
        return result;
    }

    // Parse a numeric entity value from string.
    private fn parseEntityNumber(s: string, isHex: bool): int {
        if (String.length(s) == 0) { return -1; }
        let result: int = 0;
        if (isHex) {
            let i: int = 0;
            while (i < String.length(s)) {
                let c: string = String.charAt(s, i);
                result = result * 16;
                if (c >= "0" && c <= "9") {
                    result = result + (String.charAt(c, 0) - "0".charAt(0));
                } else if (c >= "a" && c <= "f") {
                    result = result + 10 + (String.charAt(c, 0) - "a".charAt(0));
                } else if (c >= "A" && c <= "F") {
                    result = result + 10 + (String.charAt(c, 0) - "A".charAt(0));
                } else {
                    return -1;
                }
                i = i + 1;
            }
        } else {
            let i: int = 0;
            while (i < String.length(s)) {
                let c: string = String.charAt(s, i);
                if (c >= "0" && c <= "9") {
                    result = result * 10 + (String.charAt(c, 0) - "0".charAt(0));
                } else {
                    return -1;
                }
                i = i + 1;
            }
        }
        return result;
    }

    // Convert a code point to a single-character string.
    private fn codePointToString(code: int): string {
        return String.fromCharCode(code);
    }
}
