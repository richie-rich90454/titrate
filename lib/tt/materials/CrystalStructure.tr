// CrystalStructure.tr — Crystal structure: Bravais lattices, unit cell, Miller indices, space groups
import tt::lang::DataFile;
import tt::json::JsonValue;
import tt::util::HashMap;
import tt::util::ArrayList;
import tt::lang::String;
import tt::math::MathAdvanced;
import tt::math::Math;

var _sgCache: HashMap<string, JsonValue> = new HashMap<string, JsonValue>();
var _sgLoaded: bool = false;

fn _ensureSGLoaded(): void {
    if (_sgLoaded) { return; }
    let data: JsonValue = DataFile.load("materials/space_groups.json");
    if (!data.isNull()) { _sgCache.put("root", data); }
    _sgLoaded = true;
}

public class UnitCell {
    public double a;
    public double b;
    public double c;
    public double alpha;
    public double beta;
    public double gamma;

    public fn init(a: double, b: double, c: double, al: double, be: double, ga: double) {
        this.a = a;
        this.b = b;
        this.c = c;
        this.alpha = al;
        this.beta = be;
        this.gamma = ga;
    }

    public fn volume(): double {
        let ca: double = MathTrig.cos(this.alpha * Math.PI() / 180.0);
        let cb: double = MathTrig.cos(this.beta * Math.PI() / 180.0);
        let cg: double = MathTrig.cos(this.gamma * Math.PI() / 180.0);
        let v2: double = 1.0 - ca * ca - cb * cb - cg * cg + 2.0 * ca * cb * cg;
        return this.a * this.b * this.c * MathAdvanced.sqrt(v2);
    }
}

public class MillerIndices {
    public int h;
    public int k;
    public int l;

    public fn init(h: int, k: int, l: int) {
        this.h = h;
        this.k = k;
        this.l = l;
    }

    public fn dSpacing(cell: UnitCell): double {
        let h2: double = this.h as double * this.h as double;
        let k2: double = this.k as double * this.k as double;
        let l2: double = this.l as double * this.l as double;
        let a2: double = cell.a * cell.a;
        let b2: double = cell.b * cell.b;
        let c2: double = cell.c * cell.c;
        let invD2: double = h2 / a2 + k2 / b2 + l2 / c2;
        if (invD2 <= 0.0) { return 0.0; }
        return 1.0 / MathAdvanced.sqrt(invD2);
    }

    public fn toString(): string {
        return "(" + Integer.toString(this.h) + " " + Integer.toString(this.k) + " " + Integer.toString(this.l) + ")";
    }
}

public fn getSpaceGroup(number: int): HashMap<string, string> {
    _ensureSGLoaded();
    let result: HashMap<string, string> = new HashMap<string, string>();
    let root: JsonValue = _sgCache.get("root");
    if (root.isNull()) { return result; }
    let groups: JsonValue = root.get("space_groups");
    if (groups.isNull()) { return result; }
    let key: string = Integer.toString(number);
    if (groups.hasKey(key)) {
        let g: JsonValue = groups.get(key);
        if (g.hasKey("symbol")) { result.put("symbol", g.get("symbol").asString()); }
        if (g.hasKey("crystal_system")) { result.put("crystal_system", g.get("crystal_system").asString()); }
        if (g.hasKey("lattice_type")) { result.put("lattice_type", g.get("lattice_type").asString()); }
    }
    return result;
}

public fn getSpaceGroupBySymbol(symbol: string): int {
    _ensureSGLoaded();
    let root: JsonValue = _sgCache.get("root");
    if (root.isNull()) { return 0; }
    let groups: JsonValue = root.get("space_groups");
    if (groups.isNull()) { return 0; }
    let keys: ArrayList<string> = groups.keys();
    var i: int = 0;
    while (i < keys.size()) {
        let g: JsonValue = groups.get(keys.get(i));
        if (g.hasKey("symbol") && g.get("symbol").asString() == symbol) {
            return Integer.parseInt(keys.get(i));
        }
        i = i + 1;
    }
    return 0;
}

public fn cubicCell(a: double): UnitCell {
    return new UnitCell(a, a, a, 90.0, 90.0, 90.0);
}

public fn tetragonalCell(a: double, c: double): UnitCell {
    return new UnitCell(a, a, c, 90.0, 90.0, 90.0);
}

public fn orthorhombicCell(a: double, b: double, c: double): UnitCell {
    return new UnitCell(a, b, c, 90.0, 90.0, 90.0);
}

public fn hexagonalCell(a: double, c: double): UnitCell {
    return new UnitCell(a, a, c, 90.0, 90.0, 120.0);
}
