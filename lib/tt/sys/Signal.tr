public fn SIGPIPE(): int {
    _ensureSignalsLoaded();
    if (_signalsCache.containsKey("SIGPIPE")) { return _signalsCache.get("SIGPIPE"); }
    return 13;
}

// Return the symbolic name of a signal number, or "SIG_UNKNOWN" if not found.
public fn signalName(signum: int): string {
    _ensureSignalsLoaded();
    let keys: ArrayList<string> = _signalsCache.keys();
    var i: int = 0;
    while (i < keys.size()) {
        let k: string = keys.get(i);
        if (_signalsCache.get(k) == signum) {
            return k;
        }
        i = i + 1;
    }
    return "SIG_UNKNOWN";
}
