// Monte Carlo option pricing: GBM paths, European, Asian, variance reduction.
import tt::util::ArrayList;
import tt::math::Math;
import tt::math::MathAdvanced;
import tt::math::MathTrig;

// ==================== Private Helpers ====================

fn maxDouble(a: double, b: double): double {
    return a > b ? a : b;
}

fn normalRandom(): double {
    // Box-Muller transform for standard normal random variates
    let u1: double = Math.random();
    while (u1 == 0.0) {
        u1 = Math.random();
    }
    let u2: double = Math.random();
    return MathAdvanced.sqrt(-2.0 * MathAdvanced.ln(u1)) * MathTrig.cos(2.0 * Math.PI() * u2);
}

// ==================== Generate One GBM Path ====================

public fn gbmPath(s0: double, r: double, sigma: double, t: double, steps: int): ArrayList<double> {
    let path: ArrayList<double> = new ArrayList<double>();
    path.add(s0);
    let dt: double = t / (steps as double);
    let drift: double = (r - 0.5 * sigma * sigma) * dt;
    let diffusion: double = sigma * MathAdvanced.sqrt(dt);
    var i: int = 1;
    while (i <= steps) {
        let z: double = normalRandom();
        let prev: double = path.get(i - 1);
        let nextPrice: double = prev * MathAdvanced.exp(drift + diffusion * z);
        path.add(nextPrice);
        i = i + 1;
    }
    return path;
}

// ==================== Monte Carlo Call Price ====================

public fn monteCarloCall(s0: double, k: double, t: double, r: double, sigma: double, simulations: int, steps: int): double {
    var sumPayoff: double = 0.0;
    let dt: double = t / (steps as double);
    let drift: double = (r - 0.5 * sigma * sigma) * dt;
    let diffusion: double = sigma * MathAdvanced.sqrt(dt);
    var i: int = 0;
    while (i < simulations) {
        var price: double = s0;
        var j: int = 1;
        while (j <= steps) {
            let z: double = normalRandom();
            price = price * MathAdvanced.exp(drift + diffusion * z);
            j = j + 1;
        }
        sumPayoff = sumPayoff + maxDouble(price - k, 0.0);
        i = i + 1;
    }
    return MathAdvanced.exp(-r * t) * sumPayoff / (simulations as double);
}

// ==================== Monte Carlo Put Price ====================

public fn monteCarloPut(s0: double, k: double, t: double, r: double, sigma: double, simulations: int, steps: int): double {
    var sumPayoff: double = 0.0;
    let dt: double = t / (steps as double);
    let drift: double = (r - 0.5 * sigma * sigma) * dt;
    let diffusion: double = sigma * MathAdvanced.sqrt(dt);
    var i: int = 0;
    while (i < simulations) {
        var price: double = s0;
        var j: int = 1;
        while (j <= steps) {
            let z: double = normalRandom();
            price = price * MathAdvanced.exp(drift + diffusion * z);
            j = j + 1;
        }
        sumPayoff = sumPayoff + maxDouble(k - price, 0.0);
        i = i + 1;
    }
    return MathAdvanced.exp(-r * t) * sumPayoff / (simulations as double);
}

// ==================== Monte Carlo Asian Option ====================

public fn monteCarloAsian(s0: double, k: double, t: double, r: double, sigma: double, simulations: int, steps: int): double {
    var sumPayoff: double = 0.0;
    let dt: double = t / (steps as double);
    let drift: double = (r - 0.5 * sigma * sigma) * dt;
    let diffusion: double = sigma * MathAdvanced.sqrt(dt);
    var i: int = 0;
    while (i < simulations) {
        var price: double = s0;
        var priceSum: double = s0;
        var j: int = 1;
        while (j <= steps) {
            let z: double = normalRandom();
            price = price * MathAdvanced.exp(drift + diffusion * z);
            priceSum = priceSum + price;
            j = j + 1;
        }
        let avgPrice: double = priceSum / ((steps + 1) as double);
        sumPayoff = sumPayoff + maxDouble(avgPrice - k, 0.0);
        i = i + 1;
    }
    return MathAdvanced.exp(-r * t) * sumPayoff / (simulations as double);
}

// ==================== Antithetic Variate Reduction (Call) ====================

public fn antitheticVariateCall(s0: double, k: double, t: double, r: double, sigma: double, simulations: int): double {
    var sumPayoff: double = 0.0;
    let halfSim: int = simulations / 2;
    let drift: double = (r - 0.5 * sigma * sigma) * t;
    let diffusion: double = sigma * MathAdvanced.sqrt(t);
    var i: int = 0;
    while (i < halfSim) {
        let z: double = normalRandom();
        // Original path
        let stPos: double = s0 * MathAdvanced.exp(drift + diffusion * z);
        // Antithetic path (negate the random shock)
        let stNeg: double = s0 * MathAdvanced.exp(drift - diffusion * z);
        let payoffPos: double = maxDouble(stPos - k, 0.0);
        let payoffNeg: double = maxDouble(stNeg - k, 0.0);
        sumPayoff = sumPayoff + 0.5 * (payoffPos + payoffNeg);
        i = i + 1;
    }
    return MathAdvanced.exp(-r * t) * sumPayoff / (halfSim as double);
}

// ==================== Control Variate Reduction (Call) ====================

public fn controlVariateCall(s0: double, k: double, t: double, r: double, sigma: double, simulations: int): double {
    let drift: double = (r - 0.5 * sigma * sigma) * t;
    let diffusion: double = sigma * MathAdvanced.sqrt(t);
    // Analytical expected value of the terminal stock price under risk-neutral measure
    let expectedST: double = s0 * MathAdvanced.exp(r * t);

    var sumPayoff: double = 0.0;
    var sumST: double = 0.0;
    var sumCross: double = 0.0;
    var sumST2: double = 0.0;
    var i: int = 0;
    while (i < simulations) {
        let z: double = normalRandom();
        let st: double = s0 * MathAdvanced.exp(drift + diffusion * z);
        let payoff: double = maxDouble(st - k, 0.0);
        sumPayoff = sumPayoff + payoff;
        sumST = sumST + st;
        sumCross = sumCross + payoff * st;
        sumST2 = sumST2 + st * st;
        i = i + 1;
    }

    let n: double = simulations as double;
    let meanPayoff: double = sumPayoff / n;
    let meanST: double = sumST / n;
    let varST: double = sumST2 / n - meanST * meanST;
    let covPayoffST: double = sumCross / n - meanPayoff * meanST;

    // Optimal control variate coefficient
    let c: double = covPayoffST / varST;

    // Adjusted estimator
    let adjustedPayoff: double = meanPayoff - c * (meanST - expectedST);
    return MathAdvanced.exp(-r * t) * adjustedPayoff;
}
