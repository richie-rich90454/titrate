// IP address manipulation and validation.

public class IpAddress {
    public string address;
    public bool isV6;

    public fn init(address: string) {
        this.address = address;
        this.isV6 = String.indexOf(address, ":") >= 0;
    }

    public fn isLoopback(): bool {
        if (this.isV6) {
            return this.address == "::1";
        }
        return this.address == "127.0.0.1";
    }

    public fn isPrivate(): bool {
        if (this.isV6) {
            return String.indexOf(this.address, "fc") == 0 || String.indexOf(this.address, "fd") == 0 || String.indexOf(this.address, "fe80") == 0;
        }
        // 10.x.x.x, 172.16-31.x.x, 192.168.x.x
        if (String.indexOf(this.address, "10.") == 0) { return true; }
        if (String.indexOf(this.address, "192.168.") == 0) { return true; }
        if (String.indexOf(this.address, "172.") == 0) {
            let parts: ArrayList<string> = String.split(this.address, ".");
            if (parts.size() >= 2) {
                let second: int = Integer.parseInt(parts.get(1));
                if (second >= 16 && second <= 31) { return true; }
            }
        }
        return false;
    }

    public fn isMulticast(): bool {
        if (this.isV6) {
            return String.indexOf(this.address, "ff") == 0;
        }
        let parts: ArrayList<string> = String.split(this.address, ".");
        if (parts.size() >= 1) {
            let first: int = Integer.parseInt(parts.get(0));
            if (first >= 224 && first <= 239) { return true; }
        }
        return false;
    }

    public fn isReserved(): bool {
        if (this.isV6) { return false; }
        if (this.address == "0.0.0.0") { return true; }
        if (String.indexOf(this.address, "169.254.") == 0) { return true; }
        return false;
    }

    public fn isLinkLocal(): bool {
        if (this.isV6) {
            return String.indexOf(this.address, "fe80") == 0;
        }
        return String.indexOf(this.address, "169.254.") == 0;
    }

    public fn isGlobal(): bool {
        return !this.isPrivate() && !this.isLoopback() && !this.isReserved() && !this.isLinkLocal();
    }

    public fn isV4(): bool {
        return !this.isV6;
    }

    public fn isV6(): bool {
        return this.isV6;
    }

    public fn toString(): string {
        return this.address;
    }

    public fn equals(other: IpAddress): bool {
        return this.address == other.address;
    }
}

// Factory functions.
public fn ipv4(address: string): IpAddress {
    let ip: IpAddress = new IpAddress(address);
    if (ip.isV6) {
        return new IpAddress("0.0.0.0");
    }
    return ip;
}

public fn ipv6(address: string): IpAddress {
    let ip: IpAddress = new IpAddress(address);
    if (!ip.isV6) {
        return new IpAddress("::");
    }
    return ip;
}

public fn isV4(address: string): bool {
    return String.indexOf(address, ":") < 0;
}

public fn isV6(address: string): bool {
    return String.indexOf(address, ":") >= 0;
}

public fn validate(address: string): bool {
    if (isV4(address)) {
        let parts: ArrayList<string> = String.split(address, ".");
        if (parts.size() != 4) { return false; }
        var i: int = 0;
        while (i < 4) {
            let part: string = parts.get(i);
            if (String.length(part) == 0) { return false; }
            let val: int = Integer.parseInt(part);
            if (val < 0 || val > 255) { return false; }
            i = i + 1;
        }
        return true;
    }
    // Basic IPv6 validation: contains colons and hex chars
    if (String.indexOf(address, ":") < 0) { return false; }
    return String.length(address) > 0;
}
