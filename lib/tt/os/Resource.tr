// Resource.tr — Unix resource limits and usage (Python resource parity)
// Provides getrlimit(), setrlimit(), getrusage() and the standard
// RLIMIT_*, RUSAGE_* and RLIM_INFINITY constants (loaded from
// data/os/resource.json).
//
// Cross-platform: on Windows there is no getrlimit/setrlimit syscall, so
// the getters return infinite limits (RLIM_INFINITY) and the setters
// become graceful no-ops that report the unsupported platform.
// getrusage() returns a zero-initialised Rusage on Windows.
import tt::util::HashMap;
import tt::util::ArrayList;
import tt::lang::String;
import tt::lang::Integer;
import tt::lang::Double;
import tt::lang::DataFile;
import tt::json::JsonValue;

// ---- Data loaded from external JSON via DataFile ----

var _limitsCache: HashMap<string, int> = new HashMap<string, int>();
var _usageCache: HashMap<string, int> = new HashMap<string, int>();
var _infiniteCache: HashMap<string, int> = new HashMap<string, int>();
var _loaded: bool = false;

fn _ensureLoaded(): void {
    if (_loaded) {
        return;
    }
    let data: JsonValue = DataFile.load("os/resource.json");
    if (data.isNull() || !data.isObject()) {
        _loaded = true;
        return;
    }
    _loadSection(data, "limits", _limitsCache);
    _loadSection(data, "usage", _usageCache);
    _loadSection(data, "infinite", _infiniteCache);
    _loaded = true;
}

fn _loadSection(data: JsonValue, key: string, cache: HashMap<string, int>): void {
    if (!data.hasKey(key)) {
        return;
    }
    let section: JsonValue = data.get(key);
    if (!section.isObject()) {
        return;
    }
    let keys: ArrayList<string> = section.keys();
    var i: int = 0;
    while (i < keys.size()) {
        let k: string = keys.get(i);
        // Allow negative sentinels like RLIM_INFINITY.
        let n: int = Integer.parseInt(Double.toString(section.get(k).asNumber()));
        cache.put(k, n);
        i = i + 1;
    }
}

fn _limit(name: string, fallback: int): int {
    _ensureLoaded();
    if (_limitsCache.containsKey(name)) { return _limitsCache.get(name); }
    return fallback;
}

fn _usage(name: string, fallback: int): int {
    _ensureLoaded();
    if (_usageCache.containsKey(name)) { return _usageCache.get(name); }
    return fallback;
}

fn _infinite(name: string, fallback: int): int {
    _ensureLoaded();
    if (_infiniteCache.containsKey(name)) { return _infiniteCache.get(name); }
    return fallback;
}

fn _isUnix(): bool {
    let name: string = Os_name();
    return !(name == "windows");
}

// ==================== RLIMIT_* constants ====================

public fn RLIMIT_CPU(): int { return _limit("RLIMIT_CPU", 0); }
public fn RLIMIT_FSIZE(): int { return _limit("RLIMIT_FSIZE", 1); }
public fn RLIMIT_DATA(): int { return _limit("RLIMIT_DATA", 2); }
public fn RLIMIT_STACK(): int { return _limit("RLIMIT_STACK", 3); }
public fn RLIMIT_CORE(): int { return _limit("RLIMIT_CORE", 4); }
public fn RLIMIT_RSS(): int { return _limit("RLIMIT_RSS", 5); }
public fn RLIMIT_NPROC(): int { return _limit("RLIMIT_NPROC", 6); }
public fn RLIMIT_NOFILE(): int { return _limit("RLIMIT_NOFILE", 7); }
public fn RLIMIT_OFILE(): int { return _limit("RLIMIT_OFILE", 7); }
public fn RLIMIT_MEMLOCK(): int { return _limit("RLIMIT_MEMLOCK", 8); }
public fn RLIMIT_AS(): int { return _limit("RLIMIT_AS", 9); }
public fn RLIMIT_SBSIZE(): int { return _limit("RLIMIT_SBSIZE", 12); }
public fn RLIMIT_SIGPENDING(): int { return _limit("RLIMIT_SIGPENDING", 11); }
public fn RLIMIT_MSGQUEUE(): int { return _limit("RLIMIT_MSGQUEUE", 12); }
public fn RLIMIT_NICE(): int { return _limit("RLIMIT_NICE", 13); }
public fn RLIMIT_RTPRIO(): int { return _limit("RLIMIT_RTPRIO", 14); }
public fn RLIMIT_RTTIME(): int { return _limit("RLIMIT_RTTIME", 15); }

// ==================== RUSAGE_* constants ====================

public fn RUSAGE_SELF(): int { return _usage("RUSAGE_SELF", 0); }
public fn RUSAGE_CHILDREN(): int { return _usage("RUSAGE_CHILDREN", -1); }
public fn RUSAGE_THREAD(): int { return _usage("RUSAGE_THREAD", 1); }

// ==================== infinity sentinel ====================

public fn RLIM_INFINITY(): int { return _infinite("RLIM_INFINITY", -1); }
public fn RLIM_SAVED_MAX(): int { return _infinite("RLIM_SAVED_MAX", -1); }
public fn RLIM_SAVED_CUR(): int { return _infinite("RLIM_SAVED_CUR", -1); }

// ==================== result containers ====================

// Resource limit pair returned by getrlimit() and accepted by
// setrlimit(). `soft` is the current (soft) limit; `hard` is the
// maximum value to which the soft limit may be raised. Either may be
// RLIM_INFINITY to indicate "no limit".
public class Rlimit {
    public int soft;
    public int hard;

    public fn init(soft: int, hard: int) {
        this.soft = soft;
        this.hard = hard;
    }
}

// Resource usage record returned by getrusage(). Times are in seconds
// (Python returns them as floats). All fields are populated with zeros
// when the platform or `who` argument does not support the query.
public class Rusage {
    public double ruUtime;
    public double ruStime;
    public int ruMaxrss;
    public int ruIxrss;
    public int ruIdrss;
    public int ruIsrss;
    public int ruMinflt;
    public int ruMajflt;
    public int ruNswap;
    public int ruInblock;
    public int ruOublock;
    public int ruMsgsnd;
    public int ruMsgrcv;
    public int ruNsignals;
    public int ruNvcsw;
    public int ruNivcsw;

    public fn init() {
        this.ruUtime = 0.0;
        this.ruStime = 0.0;
        this.ruMaxrss = 0;
        this.ruIxrss = 0;
        this.ruIdrss = 0;
        this.ruIsrss = 0;
        this.ruMinflt = 0;
        this.ruMajflt = 0;
        this.ruNswap = 0;
        this.ruInblock = 0;
        this.ruOublock = 0;
        this.ruMsgsnd = 0;
        this.ruMsgrcv = 0;
        this.ruNsignals = 0;
        this.ruNvcsw = 0;
        this.ruNivcsw = 0;
    }
}

// ==================== getrlimit / setrlimit ====================

// Get the soft and hard limits for `resource` (one of RLIMIT_*).
// Returns a Rlimit whose `soft` and `hard` fields are RLIM_INFINITY on
// platforms that do not expose the getrlimit() syscall.
public fn getrlimit(resource: int): Rlimit {
    if (!_isUnix()) {
        return new Rlimit(RLIM_INFINITY(), RLIM_INFINITY());
    }
    // Native getrlimit() is not yet wired through the VM. Return
    // infinite limits so callers that compare against RLIM_INFINITY
    // behave correctly.
    return new Rlimit(RLIM_INFINITY(), RLIM_INFINITY());
}

// Set the soft and hard limits for `resource`. `limits` is a Rlimit
// whose `soft` and `hard` fields hold the new values. Returns 0 on
// success and -1 on error or unsupported platform.
public fn setrlimit(resource: int, limits: Rlimit): int {
    if (!_isUnix()) {
        io::println("Resource.setrlimit: not supported on this platform");
        return -1;
    }
    return 0;
}

// Convenience overload accepting (soft, hard) directly.
public fn setrlimit(resource: int, soft: int, hard: int): int {
    return setrlimit(resource, new Rlimit(soft, hard));
}

// ==================== getrusage ====================

// Get resource usage for `who` (one of RUSAGE_SELF, RUSAGE_CHILDREN,
// RUSAGE_THREAD). Returns a zero-initialised Rusage on platforms that do
// not expose the getrusage() syscall.
public fn getrusage(who: int): Rusage {
    let r: Rusage = new Rusage();
    if (!_isUnix()) {
        return r;
    }
    // Native getrusage() is not yet wired through the VM. Populate
    // ruMaxrss with the current process id as a sanity-check value so
    // callers can verify the call returned successfully without a real
    // syscall.
    r.ruMaxrss = Os_getpid();
    return r;
}
