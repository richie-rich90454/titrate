// RigidBody.tr — Rigid body dynamics with inertia tensor, angular momentum, quaternion orientation
import tt::math::MathAdvanced;
import tt::math::transform::Quaternion;

public class RigidBody {
    public double mass;
    public double x;
    public double y;
    public double z;
    public double vx;
    public double vy;
    public double vz;
    public double qx;
    public double qy;
    public double qz;
    public double qw;
    public double angVx;
    public double angVy;
    public double angVz;
    public double Ixx;
    public double Iyy;
    public double Izz;

    public fn init(m: double) {
        this.mass = m;
        this.x = 0.0;
        this.y = 0.0;
        this.z = 0.0;
        this.vx = 0.0;
        this.vy = 0.0;
        this.vz = 0.0;
        this.qx = 0.0;
        this.qy = 0.0;
        this.qz = 0.0;
        this.qw = 1.0;
        this.angVx = 0.0;
        this.angVy = 0.0;
        this.angVz = 0.0;
        this.Ixx = 1.0;
        this.Iyy = 1.0;
        this.Izz = 1.0;
    }

    public fn setPosition(px: double, py: double, pz: double): void {
        this.x = px;
        this.y = py;
        this.z = pz;
    }

    public fn setVelocity(vx: double, vy: double, vz: double): void {
        this.vx = vx;
        this.vy = vy;
        this.vz = vz;
    }

    public fn setAngularVelocity(wx: double, wy: double, wz: double): void {
        this.angVx = wx;
        this.angVy = wy;
        this.angVz = wz;
    }

    public fn setInertiaTensor(ixx: double, iyy: double, izz: double): void {
        this.Ixx = ixx;
        this.Iyy = iyy;
        this.Izz = izz;
    }

    public fn setBoxInertia(width: double, height: double, depth: double): void {
        let m12: double = this.mass / 12.0;
        this.Ixx = m12 * (height * height + depth * depth);
        this.Iyy = m12 * (width * width + depth * depth);
        this.Izz = m12 * (width * width + height * height);
    }

    public fn setSphereInertia(radius: double): void {
        this.Ixx = 0.4 * this.mass * radius * radius;
        this.Iyy = this.Ixx;
        this.Izz = this.Ixx;
    }

    public fn applyForce(fx: double, fy: double, fz: double, dt: double): void {
        if (this.mass > 0.0) {
            this.vx = this.vx + fx / this.mass * dt;
            this.vy = this.vy + fy / this.mass * dt;
            this.vz = this.vz + fz / this.mass * dt;
        }
    }

    public fn applyTorque(tx: double, ty: double, tz: double, dt: double): void {
        this.angVx = this.angVx + tx / this.Ixx * dt;
        this.angVy = this.angVy + ty / this.Iyy * dt;
        this.angVz = this.angVz + tz / this.Izz * dt;
    }

    public fn applyForceAtPoint(fx: double, fy: double, fz: double, px: double, py: double, pz: double, dt: double): void {
        this.applyForce(fx, fy, fz, dt);
        let tx: double = py * fz - pz * fy;
        let ty: double = pz * fx - px * fz;
        let tz: double = px * fy - py * fx;
        this.applyTorque(tx, ty, tz, dt);
    }

    public fn update(dt: double): void {
        // Update position
        this.x = this.x + this.vx * dt;
        this.y = this.y + this.vy * dt;
        this.z = this.z + this.vz * dt;
        // Update orientation quaternion: q' = q + 0.5 * dt * omega * q
        let halfDt: double = 0.5 * dt;
        let dqx: double = halfDt * (this.angVx * this.qw + this.angVy * this.qz - this.angVz * this.qy);
        let dqy: double = halfDt * (-this.angVx * this.qz + this.angVy * this.qw + this.angVz * this.qx);
        let dqz: double = halfDt * (this.angVx * this.qy - this.angVy * this.qx + this.angVz * this.qw);
        let dqw: double = halfDt * (-this.angVx * this.qx - this.angVy * this.qy - this.angVz * this.qz);
        this.qx = this.qx + dqx;
        this.qy = this.qy + dqy;
        this.qz = this.qz + dqz;
        this.qw = this.qw + dqw;
        // Normalize quaternion
        let len: double = MathAdvanced.sqrt(this.qx * this.qx + this.qy * this.qy + this.qz * this.qz + this.qw * this.qw);
        if (len > 1e-10) {
            this.qx = this.qx / len;
            this.qy = this.qy / len;
            this.qz = this.qz / len;
            this.qw = this.qw / len;
        }
    }

    public fn kineticEnergy(): double {
        let v2: double = this.vx * this.vx + this.vy * this.vy + this.vz * this.vz;
        let w2: double = this.angVx * this.angVx + this.angVy * this.angVy + this.angVz * this.angVz;
        return 0.5 * this.mass * v2 + 0.5 * (this.Ixx * this.angVx * this.angVx + this.Iyy * this.angVy * this.angVy + this.Izz * this.angVz * this.angVz);
    }

    public fn angularMomentum(): double {
        return MathAdvanced.sqrt(this.Ixx * this.angVx * this.Ixx * this.angVx + this.Iyy * this.angVy * this.Iyy * this.angVy + this.Izz * this.angVz * this.Izz * this.angVz);
    }
}
