// Test runner that manages multiple test suites, runs them, and discovers test files.
import tt::util::ArrayList;
import tt::io::IO;
import tt::lang::Integer;
import tt::assay::Assay;

// Runner for executing multiple TestSuites.
public class TestRunner {
    public ArrayList<TestSuite> suites;
    private int totalFailed;

    public TestRunner() {
        this.suites = new ArrayList<TestSuite>();
        this.totalFailed = 0;
    }

    // Add a test suite to the runner.
    public void addSuite(TestSuite suite) {
        this.suites.add(suite);
    }

    // Run all registered test suites and print an overall summary.
    public void runAll() {
        IO::println("=== Running All Test Suites ===");
        int totalPassed = 0;
        this.totalFailed = 0;
        for (suite in this.suites) {
            suite.run();
            totalPassed = totalPassed + suite.passed;
            this.totalFailed = this.totalFailed + suite.failed;
            IO::println("");
        }
        IO::println("=== Overall Results ===");
        IO::println("Total passed: " + Integer::toString(totalPassed));
        IO::println("Total failed: " + Integer::toString(this.totalFailed));
        if (this.totalFailed == 0) {
            IO::println("All tests passed!");
        } else {
            IO::println("Some tests failed.");
        }
        IO::println("======================");
    }

    // Filter test suites by name pattern.
    public void filterByName(String pattern) {
        ArrayList<TestSuite> filtered = new ArrayList<TestSuite>();
        for (suite in this.suites) {
            if (String::contains(suite.name, pattern)) {
                filtered.add(suite);
            }
        }
        this.suites = filtered;
    }

    // Return the exit code: 0 if all tests passed, 1 otherwise.
    public int exitCode() {
        if (this.totalFailed == 0) {
            return 0;
        }
        return 1;
    }

    // List all registered test names.
    public void listTests() {
        IO::println("=== Test List ===");
        for (suite in this.suites) {
            IO::println("Suite: " + suite.name);
            for (tc in suite.tests) {
                IO::println("  - " + tc.name);
            }
        }
        IO::println("=================");
    }

    // Run a single test by name across all suites.
    public void runSingle(String name) {
        IO::println("=== Running Single Test: " + name + " ===");
        bool found = false;
        for (suite in this.suites) {
            for (tc in suite.tests) {
                if (tc.name == name) {
                    found = true;
                    IO::println("  [RUN ] " + tc.name);
                    try {
                        tc.fn();
                        IO::println("  [PASS] " + tc.name);
                    } catch (String e) {
                        IO::println("  [FAIL] " + tc.name + " - " + e);
                    }
                }
            }
        }
        if (!found) {
            IO::println("  Test not found: " + name);
        }
        IO::println("=================================");
    }

    // Discover and run test files matching a glob pattern.
    // Scans the filesystem for .tr files matching the pattern and reports what was found.
    public void discoverAndRun(String pattern) {
        IO::println("Discovering test files matching: " + pattern);
        // Use Dir_walk to list files, then filter by pattern
        // Simple pattern: treat as directory path ending in **/*.tr
        String dir = ".";
        String suffix = ".tr";
        // Extract directory from pattern if it contains a path separator
        int lastSlash = pattern.lastIndexOf("/");
        if (lastSlash < 0) {
            lastSlash = pattern.lastIndexOf("\\");
        }
        if (lastSlash >= 0) {
            dir = pattern.substring(0, lastSlash);
            String rest = pattern.substring(lastSlash + 1);
            if (rest.length() > 3) {
                suffix = rest.substring(rest.length() - 3);
            }
        }
        ArrayList<String> files = new ArrayList<String>();
        if (Path_exists(dir)) {
            ArrayList<String> all = Dir_walk(dir);
            int i = 0;
            while (i < all.size()) {
                String f = all.get(i);
                if (f.length() >= suffix.length() && f.substring(f.length() - suffix.length()) == suffix) {
                    files.add(f);
                }
                i = i + 1;
            }
        }
        IO::println("Found " + Integer::toString(files.size()) + " test file(s)");
        for (f in files) {
            IO::println("  - " + f);
        }
        // After discovery, run all registered suites
        this.runAll();
    }
}
