// Native OS thread wrapper.
// NOTE: Due to VM limitations, Titrate closures cannot be executed in spawned
// threads because Value contains Rc<> which is not Send. Thread_spawn currently
// creates a thread but does not execute the passed function. For actual concurrent
// execution, use ThreadPoolExecutor or the async() function from Async.tr.
import tt::concurrent::Mutex;
import tt::concurrent::LockGuard;

public class Thread {
    private int handle;
    private fn(): void task;
    private bool started;
    private bool joined;

    public fn init(task: fn(): void) {
        this.task = task;
        this.handle = -1;
        this.started = false;
        this.joined = false;
    }

    public fn start(): void {
        if (!this.started) {
            // Thread_spawn currently does not execute the passed task due to
            // VM architecture limitations (Rc<> is not Send-safe across threads).
            // The task is stored for future use when the VM supports thread-safe closures.
            this.handle = Thread_spawn(this.task);
            this.started = true;
        }
    }

    // Start with a runnable handle for future VM support.
    public fn startWithRunnable(runnableHandle: int): void {
        if (!this.started) {
            this.handle = Thread_spawnRunnable(runnableHandle);
            this.started = true;
        }
    }

    public fn join(): void {
        if (this.started && !this.joined) {
            Thread_join(this.handle);
            this.joined = true;
        }
    }

    public fn detach(): void {
        if (this.started && !this.joined) {
            Thread_detach(this.handle);
            this.joined = true;
        }
    }

    public fn getId(): int {
        if (this.started) {
            return Thread_getId(this.handle);
        }
        return -1;
    }

    public fn isAlive(): bool {
        return this.started && !this.joined;
    }

    public static fn sleep(ms: int): void {
        Thread_sleep(ms);
    }

    public static fn yield_(): void {
        Thread_yield();
    }

    public static fn currentId(): int {
        return Thread_currentId();
    }

    public static fn hardwareConcurrency(): int {
        return Os_cpuCount();
    }
}
