// ThreadPoolExt — extended thread pool utilities: scheduled execution and future chaining.
import tt::util::ArrayList;
import tt::lang::Variant;

// ScheduledTask represents a task scheduled for future or periodic execution.
public class ScheduledTask {
    public fn(): Variant task;
    public long delayMs;
    public long periodMs;
    public long scheduledTime;

    public fn init(task: fn(): Variant, delayMs: long, periodMs: long, scheduledTime: long) {
        this.task = task;
        this.delayMs = delayMs;
        this.periodMs = periodMs;
        this.scheduledTime = scheduledTime;
    }
}

// ScheduledExecutor runs tasks at scheduled times and supports fixed-rate scheduling.
public class ScheduledExecutor {
    public ArrayList<ScheduledTask> tasks;
    public bool running;

    public fn init() {
        this.tasks = new ArrayList<ScheduledTask>();
        this.running = false;
    }

    // Schedule a one-shot task to run after the given delay.
    public fn schedule(f: fn(): Variant, delayMs: long): void {
        let task: ScheduledTask = new ScheduledTask(f, delayMs, 0, delayMs);
        this.tasks.add(task);
    }

    // Schedule a recurring task at a fixed rate.
    public fn scheduleAtFixedRate(f: fn(): Variant, initialDelayMs: long, periodMs: long): void {
        let task: ScheduledTask = new ScheduledTask(f, initialDelayMs, periodMs, initialDelayMs);
        this.tasks.add(task);
    }

    // Execute all tasks whose scheduled time has arrived.
    // Returns an ArrayList of results from executed tasks.
    public fn tick(currentTimeMs: long): ArrayList<Variant> {
        let results: ArrayList<Variant> = new ArrayList<Variant>();
        var i: int = 0;
        while (i < this.tasks.size()) {
            let task: ScheduledTask = this.tasks.get(i);
            if (currentTimeMs >= task.scheduledTime) {
                let result: Variant = task.task();
                results.add(result);
                if (task.periodMs > 0) {
                    // Reschedule periodic task
                    task.scheduledTime = task.scheduledTime + task.periodMs;
                } else {
                    // Remove one-shot task
                    this.tasks.remove(i);
                    i = i - 1;
                }
            }
            i = i + 1;
        }
        return results;
    }
}

// FutureChain supports chaining continuations on a future value.
public class FutureChain {
    public Variant value;
    public Variant error;
    public bool done;
    public ArrayList<fn(Variant): Variant> continuations;

    public fn init() {
        this.value = null;
        this.error = null;
        this.done = false;
        this.continuations = new ArrayList<fn(Variant): Variant>();
    }

    // Add a transformation continuation. Returns this FutureChain for chaining.
    public fn thenApply(f: fn(Variant): Variant): FutureChain {
        if (this.done) {
            if (this.error == null) {
                try {
                    this.value = f(this.value);
                } catch (e: string) {
                    this.error = e;
                }
            }
        } else {
            this.continuations.add(f);
        }
        return this;
    }

    // Add a side-effect continuation. Returns this FutureChain for chaining.
    public fn thenAccept(f: fn(Variant): void): FutureChain {
        let wrapper: fn(Variant): Variant = fn(v: Variant): Variant {
            f(v);
            return v;
        };
        if (this.done) {
            if (this.error == null) {
                try {
                    f(this.value);
                } catch (e: string) {
                    this.error = e;
                }
            }
        } else {
            this.continuations.add(wrapper);
        }
        return this;
    }

    // Complete the future with a value, running all pending continuations.
    public fn complete(value: Variant): void {
        if (this.done) { return; }
        this.value = value;
        this.done = true;
        var i: int = 0;
        while (i < this.continuations.size()) {
            if (this.error != null) { break; }
            let cont: fn(Variant): Variant = this.continuations.get(i);
            try {
                this.value = cont(this.value);
            } catch (e: string) {
                this.error = e;
            }
            i = i + 1;
        }
        this.continuations = new ArrayList<fn(Variant): Variant>();
    }

    // Check whether the future is complete.
    public fn isDone(): bool {
        return this.done;
    }
}
