{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Physical Constants Data",
  "description": "Schema for physics/constants.json — CODATA physical constants",
  "type": "object",
  "required": ["_meta", "constants"],
  "properties": {
    "_meta": {
      "type": "object",
      "required": ["source", "version", "description"],
      "properties": {
        "source": { "type": "string" },
        "version": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "constants": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["value", "unit"],
        "properties": {
          "value": { "type": "number" },
          "unit": { "type": "string" },
          "uncertainty": { "type": "number" },
          "description": { "type": "string" }
        }
      }
    }
  }
}
