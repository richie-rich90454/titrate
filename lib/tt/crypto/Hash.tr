// Cryptographic hash functions backed by native implementations.
import tt::util::ArrayList;
import tt::lang::DataFile;
import tt::json::JsonValue;
import tt::crypto::Hmac;

// ---- Data loaded from external JSON via DataFile ----

var _algoCache: HashMap<string, string> = new HashMap<string, string>();
var _algoLoaded: bool = false;

fn _ensureAlgoLoaded(): void {
    if (_algoLoaded) {
        return;
    }
    let data: JsonValue = DataFile.load("crypto/hash_algorithms.json");
    if (data.isNull() || !data.isObject()) {
        _algoLoaded = true;
        return;
    }
    if (!data.hasKey("algorithms")) {
        _algoLoaded = true;
        return;
    }
    let algos: JsonValue = data.get("algorithms");
    if (!algos.isObject()) {
        _algoLoaded = true;
        return;
    }
    // Load known algorithm keys
    let keys: ArrayList<string> = new ArrayList<string>();
    keys.add("md5");
    keys.add("sha1");
    keys.add("sha224");
    keys.add("sha256");
    keys.add("sha384");
    keys.add("sha512");
    keys.add("sha3_224");
    keys.add("sha3_256");
    keys.add("sha3_384");
    keys.add("sha3_512");
    keys.add("blake2b");
    keys.add("blake2s");
    keys.add("ripemd160");
    keys.add("whirlpool");
    keys.add("sm3");
    var i: int = 0;
    while (i < keys.size()) {
        let key: string = keys.get(i);
        if (algos.hasKey(key)) {
            _algoCache.put(key, algos.get(key).asString());
        }
        i = i + 1;
    }
    _algoLoaded = true;
}

fn _getNativeFunc(algo: string): string {
    _ensureAlgoLoaded();
    if (_algoCache.containsKey(algo)) {
        return _algoCache.get(algo);
    }
    return "";
}

public class Hash {
    public fn md5(input: string): string {
        return Hash_md5(input);
    }

    public fn sha1(input: string): string {
        return Hash_sha1(input);
    }

    public fn sha224(input: string): string {
        return Hash_sha224(input);
    }

    public fn sha256(input: string): string {
        // the gold standard, until quantum says otherwise
        return Hash_sha256(input);
    }

    public fn sha384(input: string): string {
        return Hash_sha384(input);
    }

    public fn sha512(input: string): string {
        return Hash_sha512(input);
    }

    public fn sha3_224(input: string): string {
        return Hash_sha3_224(input);
    }

    public fn sha3_256(input: string): string {
        return Hash_sha3_256(input);
    }

    public fn sha3_384(input: string): string {
        return Hash_sha3_384(input);
    }

    public fn sha3_512(input: string): string {
        return Hash_sha3_512(input);
    }

    public fn shake128(input: string, length: int): string {
        return Hash_shake128(input, length);
    }

    public fn shake256(input: string, length: int): string {
        return Hash_shake256(input, length);
    }

    public fn blake2b(input: string): string {
        return Hash_blake2b(input);
    }

    public fn blake2s(input: string): string {
        return Hash_blake2s(input);
    }

    // HMAC-SHA256 using proper HMAC construction (RFC 2104).
    // Delegates to the Hmac module's implementation.
    public fn hmac(key: string, data: string): string {
        return Hmac.sha256(key, data);
    }

    // CRC32 backed by native implementation
    public fn crc32(data: string): string {
        return Hash_crc32(data);
    }

    public fn hashBytes(algorithm: string, data: string): string {
        _ensureAlgoLoaded();
        // Normalize algorithm name: replace hyphens with underscores for lookup
        let normalized: string = _normalizeAlgo(algorithm);
        // Check data file for mapping
        if (_algoCache.containsKey(normalized)) {
            let nativeFunc: string = _algoCache.get(normalized);
            // Dispatch to the appropriate native function
            if (nativeFunc == "Hash_md5") { return Hash_md5(data); }
            if (nativeFunc == "Hash_sha1") { return Hash_sha1(data); }
            if (nativeFunc == "Hash_sha224") { return Hash_sha224(data); }
            if (nativeFunc == "Hash_sha256") { return Hash_sha256(data); }
            if (nativeFunc == "Hash_sha384") { return Hash_sha384(data); }
            if (nativeFunc == "Hash_sha512") { return Hash_sha512(data); }
            if (nativeFunc == "Hash_sha3_224") { return Hash_sha3_224(data); }
            if (nativeFunc == "Hash_sha3_256") { return Hash_sha3_256(data); }
            if (nativeFunc == "Hash_sha3_384") { return Hash_sha3_384(data); }
            if (nativeFunc == "Hash_sha3_512") { return Hash_sha3_512(data); }
            if (nativeFunc == "Hash_blake2b") { return Hash_blake2b(data); }
            if (nativeFunc == "Hash_blake2s") { return Hash_blake2s(data); }
        }
        // Special cases for shake algorithms (require length parameter)
        if (normalized == "shake128") { return Hash_shake128(data, 32); }
        if (normalized == "shake256") { return Hash_shake256(data, 64); }
        if (algorithm == "crc32") { return Hash_crc32(data); }
        return "";
    }

    // Convert an integer to 8-char hex string
    private fn _toHex(val: int): string {
        let hex: string = "0123456789abcdef";
        let result: string = "";
        let i: int = 7;
        while (i >= 0) {
            let nibble: int = (val / Hash._pow16(i)) % 16;
            result = result + String.charAt(hex, nibble);
            i = i - 1;
        }
        return result;
    }

    private fn _pow16(n: int): int {
        let result: int = 1;
        let i: int = 0;
        while (i < n) {
            result = result * 16;
            i = i + 1;
        }
        return result;
    }
}

// Normalize algorithm name by replacing hyphens with underscores
fn _normalizeAlgo(algo: string): string {
    var result: string = "";
    var i: int = 0;
    while (i < String.length(algo)) {
        let c: string = String.charAt(algo, i);
        if (c == "-") {
            result = result + "_";
        } else {
            result = result + c;
        }
        i = i + 1;
    }
    return result;
}

// Incremental hasher for streaming hash computation.
// Supports: md5, sha1, sha224, sha256, sha384, sha512, sha3-224, sha3-256, sha3-384, sha3-512, shake128, shake256, blake2b, blake2s
public class Hasher {
    private int _handle;

    public fn init(algorithm: string) {
        this._handle = Hasher_new(algorithm);
    }

    public fn update(data: string): void {
        Hasher_update(this._handle, data);
    }

    public fn digest(): string {
        return Hasher_digest(this._handle);
    }

    public fn hexDigest(): string {
        return Hasher_hexDigest(this._handle);
    }

    public fn reset(): void {
        Hasher_reset(this._handle);
    }

    public fn close(): void {
        Hasher_close(this._handle);
    }
}
