// Textwrap provides text wrapping and filling utilities, mirroring Python's textwrap module.
import tt::util::ArrayList;
import tt::lang::String;

public class Textwrap {
    // Wrap text to the given width, returning a list of lines.
    public static ArrayList<String> wrap(String text, int width) {
        ArrayList<String> lines = new ArrayList<String>();
        if (text.length() == 0) {
            lines.add("");
            return lines;
        }
        if (width <= 0) { width = 1; }
        ArrayList<String> words = String::split(text, " ");
        String currentLine = "";
        int i = 0;
        while (i < words.size()) {
            String word = words.get(i);
            if (currentLine.length() == 0) {
                currentLine = word;
            } else if (currentLine.length() + 1 + word.length() <= width) {
                currentLine = currentLine + " " + word;
            } else {
                lines.add(currentLine);
                currentLine = word;
            }
            i = i + 1;
        }
        if (currentLine.length() > 0) {
            lines.add(currentLine);
        }
        return lines;
    }

    // Wrap text and join the lines with newlines.
    public static String fill(String text, int width) {
        ArrayList<String> lines = Textwrap.wrap(text, width);
        String result = "";
        int i = 0;
        while (i < lines.size()) {
            if (i > 0) { result = result + "\n"; }
            result = result + lines.get(i);
            i = i + 1;
        }
        return result;
    }

    // Remove common leading whitespace from all lines in text.
    public static String dedent(String text) {
        ArrayList<String> lines = String::split(text, "\n");
        if (lines.size() == 0) { return text; }
        // Find minimum indentation (ignoring blank lines)
        int minIndent = -1;
        int i = 0;
        while (i < lines.size()) {
            String line = lines.get(i);
            if (line.length() > 0) {
                int spaces = 0;
                while (spaces < line.length() && line.charAt(spaces) == " ") {
                    spaces = spaces + 1;
                }
                if (minIndent == -1 || spaces < minIndent) {
                    minIndent = spaces;
                }
            }
            i = i + 1;
        }
        if (minIndent <= 0) { return text; }
        // Remove common indent
        String result = "";
        i = 0;
        while (i < lines.size()) {
            if (i > 0) { result = result + "\n"; }
            String line = lines.get(i);
            if (line.length() > 0) {
                result = result + String.substring(line, minIndent, line.length());
            }
            i = i + 1;
        }
        return result;
    }

    // Add prefix to every line in text.
    public static String indent(String text, String prefix) {
        ArrayList<String> lines = String::split(text, "\n");
        String result = "";
        int i = 0;
        while (i < lines.size()) {
            if (i > 0) { result = result + "\n"; }
            String line = lines.get(i);
            if (line.length() > 0) {
                result = result + prefix + line;
            } else {
                result = result + line;
            }
            i = i + 1;
        }
        return result;
    }

    // Truncate text to at most width characters, adding ellipsis if truncated.
    public static String shorten(String text, int width) {
        if (text.length() <= width) { return text; }
        if (width <= 3) {
            String result = "";
            int i = 0;
            while (i < width) {
                result = result + ".";
                i = i + 1;
            }
            return result;
        }
        String result = String.substring(text, 0, width - 3);
        return result + "...";
    }
}
