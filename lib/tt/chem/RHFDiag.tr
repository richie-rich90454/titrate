import tt::util::ArrayList;
import tt::math::linalg::Matrix;
import tt::math::Math;

// RHF Jacobi diagonalization, S^-1/2 computation
public class RHFDiag {
    // Compute S^{-1/2} via symmetric orthogonalization (canonical)
    // S^{-1/2} = U * s^{-1/2} * U^T where S = U * s * U^T
    public static Matrix computeSInverseHalf(RHF rhf) {
        int n = rhf.basisSize;
        Matrix S = RHFMatrix.toMatrix(rhf, rhf.overlapMatrix);

        // Diagonalize S using Jacobi method
        (Matrix eigenvecs, ArrayList<double> eigenvals) = RHFDiag.jacobiDiagonalize(rhf, S);

        // Build s^{-1/2} diagonal matrix
        Matrix sinvHalf = new Matrix(n, n);
        int i = 0;
        while (i < n) {
            double ev = eigenvals.get(i);
            if (ev > 1e-14) {
                sinvHalf.set(i, i, 1.0 / Math.sqrt(ev));
            } else {
                sinvHalf.set(i, i, 0.0);
            }
            i = i + 1;
        }

        // S^{-1/2} = U * s^{-1/2} * U^T
        Matrix result = eigenvecs.mul(sinvHalf).mul(eigenvecs.transpose());
        return result;
    }

    // Jacobi eigenvalue algorithm for symmetric matrices
    // Returns (eigenvectors as columns, eigenvalues as ArrayList)
    public static (Matrix, ArrayList<double>) jacobiDiagonalize(RHF rhf, Matrix A) {
        int n = A.rows();
        Matrix V = Matrix.identity(n);
        Matrix D = A.clone();
        int maxSweeps = 50;
        double tol = 1e-12;
        int sweep = 0;

        while (sweep < maxSweeps) {
            // Check convergence: sum of off-diagonal elements squared
            double offDiag = 0.0;
            int i = 1;
            while (i < n) {
                int j = 0;
                while (j < i) {
                    double v = D.get(i, j);
                    offDiag = offDiag + v * v;
                    j = j + 1;
                }
                i = i + 1;
            }
            if (offDiag < tol) { break; }

            // Sweep through all off-diagonal elements
            int p = 0;
            while (p < n - 1) {
                int q = p + 1;
                while (q < n) {
                    double apq = D.get(p, q);
                    if (Math.abs(apq) < 1e-15) {
                        q = q + 1;
                        continue;
                    }

                    double app = D.get(p, p);
                    double aqq = D.get(q, q);

                    // Compute rotation angle
                    double tau = 0.0;
                    if (Math.abs(aqq - app) > 1e-15) {
                        tau = (aqq - app) / (2.0 * apq);
                    } else {
                        tau = 1e10;
                    }
                    double t = 0.0;
                    if (tau >= 0.0) {
                        t = 1.0 / (tau + Math.sqrt(1.0 + tau * tau));
                    } else {
                        t = -1.0 / (-tau + Math.sqrt(1.0 + tau * tau));
                    }
                    double c = 1.0 / Math.sqrt(1.0 + t * t);
                    double s = t * c;

                    // Update D matrix
                    D.set(p, p, app - t * apq);
                    D.set(q, q, aqq + t * apq);
                    D.set(p, q, 0.0);
                    D.set(q, p, 0.0);

                    int r = 0;
                    while (r < n) {
                        if (r != p && r != q) {
                            double drp = D.get(r, p);
                            double drq = D.get(r, q);
                            D.set(r, p, c * drp - s * drq);
                            D.set(p, r, c * drp - s * drq);
                            D.set(r, q, s * drp + c * drq);
                            D.set(q, r, s * drp + c * drq);
                        }
                        r = r + 1;
                    }

                    // Update eigenvector matrix
                    r = 0;
                    while (r < n) {
                        double vrp = V.get(r, p);
                        double vrq = V.get(r, q);
                        V.set(r, p, c * vrp - s * vrq);
                        V.set(r, q, s * vrp + c * vrq);
                        r = r + 1;
                    }

                    q = q + 1;
                }
                p = p + 1;
            }
            sweep = sweep + 1;
        }

        // Extract eigenvalues from diagonal
        ArrayList<double> eigenvals = new ArrayList<double>();
        int idx = 0;
        while (idx < n) {
            eigenvals.add(D.get(idx, idx));
            idx = idx + 1;
        }

        // Sort eigenvalues and eigenvectors (ascending)
        int ii = 0;
        while (ii < n - 1) {
            int minIdx = ii;
            int jj = ii + 1;
            while (jj < n) {
                if (eigenvals.get(jj) < eigenvals.get(minIdx)) {
                    minIdx = jj;
                }
                jj = jj + 1;
            }
            if (minIdx != ii) {
                // Swap eigenvalues
                double tmp = eigenvals.get(ii);
                eigenvals.set(ii, eigenvals.get(minIdx));
                eigenvals.set(minIdx, tmp);
                // Swap eigenvector columns
                int row = 0;
                while (row < n) {
                    double tmpV = V.get(row, ii);
                    V.set(row, ii, V.get(row, minIdx));
                    V.set(row, minIdx, tmpV);
                    row = row + 1;
                }
            }
            ii = ii + 1;
        }

        return (V, eigenvals);
    }
}
