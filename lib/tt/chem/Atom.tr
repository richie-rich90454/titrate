public fn getIonizationEnergy(sym: string): double {
    if (sym == "H")  { return 13.598; }
    if (sym == "He") { return 24.587; }
    if (sym == "Li") { return 5.392; }
    if (sym == "Be") { return 9.323; }
    if (sym == "B")  { return 8.298; }
    if (sym == "C")  { return 11.260; }
    if (sym == "N")  { return 14.534; }
    if (sym == "O")  { return 13.618; }
    if (sym == "F")  { return 17.423; }
    if (sym == "Ne") { return 21.565; }
    if (sym == "Na") { return 5.139; }
    if (sym == "Mg") { return 7.646; }
    if (sym == "Al") { return 5.986; }
    if (sym == "Si") { return 8.152; }
    if (sym == "P")  { return 10.487; }
    if (sym == "S")  { return 10.360; }
    if (sym == "Cl") { return 12.968; }
    if (sym == "Ar") { return 15.760; }
    if (sym == "K")  { return 4.341; }
    if (sym == "Ca") { return 6.113; }
    if (sym == "Fe") { return 7.902; }
    if (sym == "Cu") { return 7.726; }
    if (sym == "Zn") { return 9.394; }
    if (sym == "Br") { return 11.814; }
    if (sym == "I")  { return 10.451; }
    return 0.0;
}

// Factory methods for common elements with position
public fn hydrogen(x: double, y: double, z: double): Atom {
    let a: Atom = new Atom("H", 1, 1.008);
    a.setPosition(x, y, z);
    return a;
}

public fn oxygen(x: double, y: double, z: double): Atom {
    let a: Atom = new Atom("O", 8, 15.999);
    a.setPosition(x, y, z);
    return a;
}

public fn carbon(x: double, y: double, z: double): Atom {
    let a: Atom = new Atom("C", 6, 12.011);
    a.setPosition(x, y, z);
    return a;
}

public fn nitrogen(x: double, y: double, z: double): Atom {
    let a: Atom = new Atom("N", 7, 14.007);
    a.setPosition(x, y, z);
    return a;
}

public fn getElement(sym: string): Atom {
    let table: HashMap<string, Atom> = periodicTable();
    if (table.containsKey(sym)) {
        return table.get(sym);
    }
    return new Atom("??", 0, 0.0);
}

public fn getMass(sym: string): double {
    return getElement(sym).mass;
}

// Build the periodic table (elements 1-118)
public fn periodicTable(): HashMap<string, Atom> {
    let table: HashMap<string, Atom> = new HashMap<string, Atom>();
    // Period 1
    table.put("H",  new Atom("H",  1,   1.008));
    table.put("He", new Atom("He", 2,   4.0026));
    // Period 2
    table.put("Li", new Atom("Li", 3,   6.941));
    table.put("Be", new Atom("Be", 4,   9.0122));
    table.put("B",  new Atom("B",  5,   10.81));
    table.put("C",  new Atom("C",  6,   12.011));
    table.put("N",  new Atom("N",  7,   14.007));
    table.put("O",  new Atom("O",  8,   15.999));
    table.put("F",  new Atom("F",  9,   18.998));
    table.put("Ne", new Atom("Ne", 10,  20.180));
    // Period 3
    table.put("Na", new Atom("Na", 11,  22.990));
    table.put("Mg", new Atom("Mg", 12,  24.305));
    table.put("Al", new Atom("Al", 13,  26.982));
