    if (sym == "Ar") { return 1.06; }
    if (sym == "K")  { return 2.03; }
    if (sym == "Ca") { return 1.76; }
    if (sym == "Sc") { return 1.70; }
    if (sym == "Ti") { return 1.60; }
    if (sym == "V")  { return 1.53; }
    if (sym == "Cr") { return 1.39; }
    if (sym == "Mn") { return 1.39; }
    if (sym == "Fe") { return 1.32; }
    if (sym == "Co") { return 1.26; }
    if (sym == "Ni") { return 1.24; }
