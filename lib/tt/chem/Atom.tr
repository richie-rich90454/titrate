import tt::math::Math;
import tt::math::MathAdvanced;
import tt::lang::Double;
import tt::lang::Integer;
import tt::util::ArrayList;
import tt::util::HashMap;

public class Atom {
    public string symbol;
    public int atomicNumber;
    public double mass;
    public double charge;
    public double x;
    public double y;
    public double z;

    fn init(sym: string, number: int, m: double) {
        this.symbol = sym;
        this.atomicNumber = number;
        this.mass = m;
        this.charge = 0.0;
        this.x = 0.0;
        this.y = 0.0;
        this.z = 0.0;
    }

    public fn setPosition(px: double, py: double, pz: double): void {
        this.x = px;
        this.y = py;
        this.z = pz;
    }

    public fn distanceTo(other: Atom): double {
        let dx: double = this.x - other.x;
        let dy: double = this.y - other.y;
        let dz: double = this.z - other.z;
        return MathAdvanced.sqrt(dx * dx + dy * dy + dz * dz);
    }

    public fn toString(): string {
        return this.symbol + "(" + Double.toString(this.x) + ", " + Double.toString(this.y) + ", " + Double.toString(this.z) + ")";
    }

    // Atomic radius in Angstroms (empirical values)
    public fn radius(): double {
        return getRadius(this.symbol);
    }

    // Pauling electronegativity
    public fn electronegativity(): double {
        return getElectronegativity(this.symbol);
    }

    // Electron configuration string
    public fn electronConfiguration(): string {
        return getElectronConfiguration(this.atomicNumber);
    }

    // Valence electron count
    public fn valence(): int {
        return getValence(this.symbol);
    }

    // Van der Waals radius in Angstroms
    public fn vanDerWaalsRadius(): double {
        return getVanDerWaalsRadius(this.symbol);
    }

    // Covalent radius in Angstroms
    public fn covalentRadius(): double {
        return getCovalentRadius(this.symbol);
    }

    // First ionization energy in eV
    public fn ionizationEnergy(): double {
        return getIonizationEnergy(this.symbol);
    }
}

// ---- Static periodic table data ----

public fn getRadius(sym: string): double {
    // Empirical atomic radii in Angstroms for common elements
    if (sym == "H")  { return 0.25; }
    if (sym == "He") { return 0.31; }
    if (sym == "Li") { return 1.45; }
    if (sym == "Be") { return 1.05; }
    if (sym == "B")  { return 0.85; }
    if (sym == "C")  { return 0.70; }
    if (sym == "N")  { return 0.65; }
    if (sym == "O")  { return 0.60; }
    if (sym == "F")  { return 0.50; }
    if (sym == "Ne") { return 0.38; }
    if (sym == "Na") { return 1.80; }
    if (sym == "Mg") { return 1.50; }
    if (sym == "Al") { return 1.25; }
    if (sym == "Si") { return 1.10; }
    if (sym == "P")  { return 1.00; }
    if (sym == "S")  { return 1.00; }
    if (sym == "Cl") { return 1.00; }
    if (sym == "Ar") { return 0.71; }
    if (sym == "K")  { return 2.20; }
    if (sym == "Ca") { return 1.80; }
    if (sym == "Fe") { return 1.40; }
    if (sym == "Cu") { return 1.35; }
    if (sym == "Zn") { return 1.35; }
    if (sym == "Br") { return 1.15; }
    if (sym == "I")  { return 1.40; }
    return 1.50;
}

public fn getElectronegativity(sym: string): double {
    if (sym == "H")  { return 2.20; }
    if (sym == "He") { return 0.0; }
    if (sym == "Li") { return 0.98; }
    if (sym == "Be") { return 1.57; }
    if (sym == "B")  { return 2.04; }
    if (sym == "C")  { return 2.55; }
    if (sym == "N")  { return 3.04; }
    if (sym == "O")  { return 3.44; }
    if (sym == "F")  { return 3.98; }
    if (sym == "Ne") { return 0.0; }
    if (sym == "Na") { return 0.93; }
    if (sym == "Mg") { return 1.31; }
    if (sym == "Al") { return 1.61; }
    if (sym == "Si") { return 1.90; }
    if (sym == "P")  { return 2.19; }
    if (sym == "S")  { return 2.58; }
    if (sym == "Cl") { return 3.16; }
    if (sym == "Ar") { return 0.0; }
    if (sym == "K")  { return 0.82; }
    if (sym == "Ca") { return 1.00; }
    if (sym == "Sc") { return 1.36; }
    if (sym == "Ti") { return 1.54; }
    if (sym == "V")  { return 1.63; }
    if (sym == "Cr") { return 1.66; }
    if (sym == "Mn") { return 1.55; }
    if (sym == "Fe") { return 1.83; }
    if (sym == "Co") { return 1.88; }
    if (sym == "Ni") { return 1.91; }
    if (sym == "Cu") { return 1.90; }
    if (sym == "Zn") { return 1.65; }
    if (sym == "Ga") { return 1.81; }
    if (sym == "Ge") { return 2.01; }
    if (sym == "As") { return 2.18; }
    if (sym == "Se") { return 2.55; }
    if (sym == "Br") { return 2.96; }
    if (sym == "Kr") { return 3.00; }
    if (sym == "I")  { return 2.66; }
    if (sym == "Ag") { return 1.93; }
    if (sym == "Au") { return 2.54; }
    if (sym == "Pt") { return 2.28; }
    if (sym == "Hg") { return 2.00; }
    if (sym == "Pb") { return 2.33; }
    if (sym == "U")  { return 1.38; }
    return 0.0;
}

public fn getElectronConfiguration(z: int): string {
    if (z == 1)  { return "1s1"; }
    if (z == 2)  { return "1s2"; }
    if (z == 3)  { return "1s2 2s1"; }
    if (z == 4)  { return "1s2 2s2"; }
    if (z == 5)  { return "1s2 2s2 2p1"; }
    if (z == 6)  { return "1s2 2s2 2p2"; }
    if (z == 7)  { return "1s2 2s2 2p3"; }
    if (z == 8)  { return "1s2 2s2 2p4"; }
    if (z == 9)  { return "1s2 2s2 2p5"; }
    if (z == 10) { return "1s2 2s2 2p6"; }
    if (z == 11) { return "[Ne] 3s1"; }
    if (z == 12) { return "[Ne] 3s2"; }
    if (z == 13) { return "[Ne] 3s2 3p1"; }
    if (z == 14) { return "[Ne] 3s2 3p2"; }
    if (z == 15) { return "[Ne] 3s2 3p3"; }
    if (z == 16) { return "[Ne] 3s2 3p4"; }
    if (z == 17) { return "[Ne] 3s2 3p5"; }
    if (z == 18) { return "[Ne] 3s2 3p6"; }
    if (z == 19) { return "[Ar] 4s1"; }
    if (z == 20) { return "[Ar] 4s2"; }
    if (z == 21) { return "[Ar] 3d1 4s2"; }
    if (z == 22) { return "[Ar] 3d2 4s2"; }
    if (z == 23) { return "[Ar] 3d3 4s2"; }
    if (z == 24) { return "[Ar] 3d5 4s1"; }
    if (z == 25) { return "[Ar] 3d5 4s2"; }
    if (z == 26) { return "[Ar] 3d6 4s2"; }
    if (z == 27) { return "[Ar] 3d7 4s2"; }
    if (z == 28) { return "[Ar] 3d8 4s2"; }
    if (z == 29) { return "[Ar] 3d10 4s1"; }
    if (z == 30) { return "[Ar] 3d10 4s2"; }
    if (z == 31) { return "[Ar] 3d10 4s2 4p1"; }
    if (z == 32) { return "[Ar] 3d10 4s2 4p2"; }
    if (z == 33) { return "[Ar] 3d10 4s2 4p3"; }
    if (z == 34) { return "[Ar] 3d10 4s2 4p4"; }
    if (z == 35) { return "[Ar] 3d10 4s2 4p5"; }
    if (z == 36) { return "[Ar] 3d10 4s2 4p6"; }
    if (z >= 37 && z <= 118) { return "[Kr] ..."; }
    return "";
}

public fn getValence(sym: string): int {
    if (sym == "H")  { return 1; }
    if (sym == "He") { return 2; }
    if (sym == "Li") { return 1; }
    if (sym == "Be") { return 2; }
    if (sym == "B")  { return 3; }
    if (sym == "C")  { return 4; }
    if (sym == "N")  { return 5; }
    if (sym == "O")  { return 6; }
    if (sym == "F")  { return 7; }
    if (sym == "Ne") { return 8; }
    if (sym == "Na") { return 1; }
    if (sym == "Mg") { return 2; }
    if (sym == "Al") { return 3; }
    if (sym == "Si") { return 4; }
    if (sym == "P")  { return 5; }
    if (sym == "S")  { return 6; }
    if (sym == "Cl") { return 7; }
    if (sym == "Ar") { return 8; }
    if (sym == "K")  { return 1; }
    if (sym == "Ca") { return 2; }
    if (sym == "Sc") { return 3; }
    if (sym == "Ti") { return 4; }
    if (sym == "V")  { return 5; }
    if (sym == "Cr") { return 6; }
    if (sym == "Mn") { return 7; }
    if (sym == "Fe") { return 2; }
    if (sym == "Co") { return 2; }
    if (sym == "Ni") { return 2; }
    if (sym == "Cu") { return 1; }
    if (sym == "Zn") { return 2; }
    if (sym == "Ga") { return 3; }
    if (sym == "Ge") { return 4; }
    if (sym == "As") { return 5; }
    if (sym == "Se") { return 6; }
    if (sym == "Br") { return 7; }
    if (sym == "Kr") { return 8; }
    return 0;
}

public fn getVanDerWaalsRadius(sym: string): double {
    if (sym == "H")  { return 1.20; }
    if (sym == "He") { return 1.40; }
    if (sym == "Li") { return 1.82; }
    if (sym == "Be") { return 1.53; }
    if (sym == "B")  { return 1.92; }
    if (sym == "C")  { return 1.70; }
    if (sym == "N")  { return 1.55; }
    if (sym == "O")  { return 1.52; }
    if (sym == "F")  { return 1.47; }
    if (sym == "Ne") { return 1.54; }
    if (sym == "Na") { return 2.27; }
    if (sym == "Mg") { return 1.73; }
    if (sym == "Al") { return 1.84; }
    if (sym == "Si") { return 2.10; }
    if (sym == "P")  { return 1.80; }
    if (sym == "S")  { return 1.80; }
    if (sym == "Cl") { return 1.75; }
    if (sym == "Ar") { return 1.88; }
    if (sym == "K")  { return 2.75; }
    if (sym == "Ca") { return 2.31; }
    if (sym == "Fe") { return 2.04; }
    if (sym == "Cu") { return 1.40; }
    if (sym == "Zn") { return 1.39; }
    if (sym == "Br") { return 1.85; }
    if (sym == "I")  { return 1.98; }
    return 2.0;
}

