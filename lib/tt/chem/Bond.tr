import tt::lang::Integer;
import tt::chem::Atom;
import tt::chem::ForceField;
import tt::math::Math;
import tt::math::MathTrig;

public class Bond {
    public int atom1;
    public int atom2;
    public string bondType;
    public int order;

    fn init(a1: int, a2: int, btype: string, ord: int) {
        this.atom1 = a1;
        this.atom2 = a2;
        this.bondType = btype;
        this.order = ord;
    }

    // Bond length between two atoms
    public fn length(atoms: ArrayList<Atom>): double {
        let a1: Atom = atoms.get(this.atom1);
        let a2: Atom = atoms.get(this.atom2);
        return a1.distanceTo(a2);
    }

    // Angle formed by this bond and another bond sharing a common atom.
    // This bond is a1-a2, other is a2-a3. Returns angle at a2 in radians.
    public fn angle(other: Bond, atoms: ArrayList<Atom>): double {
        let shared: int = -1;
        let end1: int = -1;
        let end2: int = -1;
        if (this.atom1 == other.atom1) {
            shared = this.atom1;
            end1 = this.atom2;
            end2 = other.atom2;
        } else if (this.atom1 == other.atom2) {
            shared = this.atom1;
            end1 = this.atom2;
            end2 = other.atom1;
        } else if (this.atom2 == other.atom1) {
            shared = this.atom2;
            end1 = this.atom1;
            end2 = other.atom2;
        } else if (this.atom2 == other.atom2) {
            shared = this.atom2;
            end1 = this.atom1;
            end2 = other.atom1;
        }
        if (shared == -1) { return 0.0; }
        return ForceField.computeAngle(atoms.get(end1), atoms.get(shared), atoms.get(end2));
    }

    // Dihedral angle formed by this bond and two other bonds.
    // This bond is a1-a2, next is a2-a3, then a3-a4.
    // Returns dihedral angle in radians.
    public fn dihedral(b2: Bond, b3: Bond, atoms: ArrayList<Atom>): double {
        // Find the chain a1-a2-a3-a4
        let a1: int = this.atom1;
        let a2: int = this.atom2;
        var a3: int = -1;
        var a4: int = -1;
        // Find a3 from b2 (shared with a2)
        if (b2.atom1 == a2) { a3 = b2.atom2; }
        else if (b2.atom2 == a2) { a3 = b2.atom1; }
        if (a3 == -1) { return 0.0; }
        // Find a4 from b3 (shared with a3)
        if (b3.atom1 == a3) { a4 = b3.atom2; }
        else if (b3.atom2 == a3) { a4 = b3.atom1; }
        if (a4 == -1) { return 0.0; }
        // Compute dihedral using cross products
        let p1: Atom = atoms.get(a1);
        let p2: Atom = atoms.get(a2);
        let p3: Atom = atoms.get(a3);
        let p4: Atom = atoms.get(a4);
        // Vectors b1 = p2-p1, b2 = p3-p2, b3 = p4-p3
        let b1x: double = p2.x - p1.x; let b1y: double = p2.y - p1.y; let b1z: double = p2.z - p1.z;
        let b2x: double = p3.x - p2.x; let b2y: double = p3.y - p2.y; let b2z: double = p3.z - p2.z;
        let b3x: double = p4.x - p3.x; let b3y: double = p4.y - p3.y; let b3z: double = p4.z - p3.z;
        // n1 = b1 x b2
        let n1x: double = b1y * b2z - b1z * b2y;
        let n1y: double = b1z * b2x - b1x * b2z;
        let n1z: double = b1x * b2y - b1y * b2x;
        // n2 = b2 x b3
        let n2x: double = b2y * b3z - b2z * b3y;
        let n2y: double = b2z * b3x - b2x * b3z;
        let n2z: double = b2x * b3y - b2y * b3x;
        // m1 = n1 x b2 (to get sign)
        let m1x: double = n1y * b2z - n1z * b2y;
        let m1y: double = n1z * b2x - n1x * b2z;
        let m1z: double = n1x * b2y - n1y * b2x;
        let x: double = n1x * n2x + n1y * n2y + n1z * n2z;
        let y: double = m1x * n2x + m1y * n2y + m1z * n2z;
        return MathTrig.atan2(y, x);
    }

    // Check if this bond is aromatic
    public fn isAromatic(): bool {
        return this.bondType == "aromatic";
    }

    public fn toString(): string {
        return "Bond(" + Integer.toString(this.atom1) + "-" + Integer.toString(this.atom2) + ", " + this.bondType + ", order=" + Integer.toString(this.order) + ")";
    }
}
