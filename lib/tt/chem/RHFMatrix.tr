import tt::util::ArrayList;
import tt::chem::Atom;
import tt::math::linalg::Matrix;
import tt::math::Math;

// RHF matrix construction: overlapMatrix, coreHamiltonian, fockMatrix, makeZeroMatrix, toMatrix, fromMatrix, copyMatrix

// Helper: create a zero NxN matrix as ArrayList<ArrayList<double>>
public fn makeZeroMatrix(n: int): ArrayList<ArrayList<double>> {
    let m: ArrayList<ArrayList<double>> = new ArrayList<ArrayList<double>>();
    var i: int = 0;
    while (i < n) {
        let row: ArrayList<double> = new ArrayList<double>();
        var j: int = 0;
        while (j < n) {
            row.add(0.0);
            j = j + 1;
        }
        m.add(row);
        i = i + 1;
    }
    return m;
}

// Build overlap matrix S using Gaussian overlap integral approximation
// S_mu_nu ~ exp(-alpha * R^2 / (alpha + beta)) * normalization
public fn buildOverlapMatrix(rhf: RHF): ArrayList<ArrayList<double>> {
    let n: int = rhf.basisSize;
    let S: ArrayList<ArrayList<double>> = makeZeroMatrix(n);
    var i: int = 0;
    while (i < n) {
        var j: int = i;
        while (j < n) {
            var val: double = 0.0;
            if (i == j) {
                val = 1.0;
            } else {
                let ai: int = basisToAtom(rhf, i);
                let aj: int = basisToAtom(rhf, j);
                let a1: Atom = rhf.molecule.getAtom(ai);
                let a2: Atom = rhf.molecule.getAtom(aj);
                let r: double = a1.distanceTo(a2);
                let z1: double = orbitalExponent(a1.atomicNumber);
                let z2: double = orbitalExponent(a2.atomicNumber);
                // Gaussian overlap: S ~ (4*z1*z2/(z1+z2)^2)^(3/4) * exp(-z1*z2*r^2/(z1+z2))
                let zeta: double = z1 * z2 / (z1 + z2);
                let norm: double = Math.pow(4.0 * z1 * z2 / ((z1 + z2) * (z1 + z2)), 0.75);
                val = norm * Math.exp(-zeta * r * r);
            }
            S.get(i).set(j, val);
            S.get(j).set(i, val);
            j = j + 1;
        }
        i = i + 1;
    }
    return S;
}

// Build core Hamiltonian H_core = T + V
public fn buildCoreHamiltonian(rhf: RHF): ArrayList<ArrayList<double>> {
    let n: int = rhf.basisSize;
    let H: ArrayList<ArrayList<double>> = makeZeroMatrix(n);
    var i: int = 0;
    while (i < n) {
        var j: int = i;
        while (j < n) {
            var val: double = 0.0;
            let ai: int = basisToAtom(rhf, i);
            let aj: int = basisToAtom(rhf, j);
            let a1: Atom = rhf.molecule.getAtom(ai);
            let a2: Atom = rhf.molecule.getAtom(aj);
            let z1: double = orbitalExponent(a1.atomicNumber);
            let z2: double = orbitalExponent(a2.atomicNumber);
            let r: double = a1.distanceTo(a2);

            if (i == j) {
                // Diagonal: kinetic energy + nuclear attraction to own nucleus
                let zeta: double = z1;
                let kinetic: double = zeta * zeta * 0.5;
                let nucAttr: double = -(a1.atomicNumber as double) * zeta;
                val = kinetic + nucAttr;
            } else {
                // Off-diagonal: overlap-based approximation
                let overlap: double = rhf.overlapMatrix.get(i).get(j);
                let zetaAvg: double = (z1 + z2) * 0.5;
                let kinetic: double = zetaAvg * overlap * (zetaAvg - 2.0 * z1 * z2 / (z1 + z2));
                var nucAttr: double = 0.0;
                var k: int = 0;
                while (k < rhf.molecule.atomCount()) {
                    let ak: Atom = rhf.molecule.getAtom(k);
                    let rik: double = a1.distanceTo(ak);
                    let rjk: double = a2.distanceTo(ak);
                    let zk: double = ak.atomicNumber as double;
                    let arg_i: double = zetaAvg * rik;
                    let arg_j: double = zetaAvg * rjk;
                    var f0_i: double = 0.0;
                    if (arg_i < 1e-10) {
                        f0_i = 1.0;
                    } else {
                        f0_i = (1.0 - Math.exp(-arg_i)) / arg_i;
                    }
                    var f0_j: double = 0.0;
                    if (arg_j < 1e-10) {
                        f0_j = 1.0;
                    } else {
                        f0_j = (1.0 - Math.exp(-arg_j)) / arg_j;
                    }
                    nucAttr = nucAttr - zk * overlap * f0_i * f0_j;
                    k = k + 1;
                }
                val = kinetic + nucAttr;
            }
            H.get(i).set(j, val);
            H.get(j).set(i, val);
            j = j + 1;
        }
        i = i + 1;
    }
    return H;
}

// Build Fock matrix: F_mu_nu = H_core_mu_nu + sum_{lam,sig} P_lam_sig * (2*(mu nu|lam sig) - (mu sig|lam nu))
public fn buildFockMatrix(rhf: RHF): ArrayList<ArrayList<double>> {
    let n: int = rhf.basisSize;
    let F: ArrayList<ArrayList<double>> = makeZeroMatrix(n);
    var mu: int = 0;
    while (mu < n) {
        var nu: int = mu;
        while (nu < n) {
            var val: double = rhf.coreHamiltonian.get(mu).get(nu);
            var lam: int = 0;
            while (lam < n) {
                var sig: int = 0;
                while (sig < n) {
                    let pLS: double = rhf.densityMatrix.get(lam).get(sig);
                    if (Math.abs(pLS) > 1e-14) {
                        let jInt: double = twoElectronIntegral(rhf, mu, nu, lam, sig);
                        let kInt: double = twoElectronIntegral(rhf, mu, sig, lam, nu);
                        val = val + pLS * (2.0 * jInt - kInt);
                    }
                    sig = sig + 1;
                }
                lam = lam + 1;
            }
            F.get(mu).set(nu, val);
            F.get(nu).set(mu, val);
            nu = nu + 1;
        }
        mu = mu + 1;
    }
    return F;
}

// Convert ArrayList<ArrayList<double>> to Matrix
public fn toMatrix(rhf: RHF, arr: ArrayList<ArrayList<double>>): Matrix {
    let n: int = arr.size();
    let m: Matrix = new Matrix(n, n);
    var i: int = 0;
    while (i < n) {
        var j: int = 0;
        while (j < n) {
            m.set(i, j, arr.get(i).get(j));
            j = j + 1;
        }
        i = i + 1;
    }
    return m;
}

// Convert Matrix to ArrayList<ArrayList<double>>
public fn fromMatrix(rhf: RHF, m: Matrix): ArrayList<ArrayList<double>> {
    let n: int = m.rows();
    let arr: ArrayList<ArrayList<double>> = makeZeroMatrix(n);
    var i: int = 0;
    while (i < n) {
        var j: int = 0;
        while (j < n) {
            arr.get(i).set(j, m.get(i, j));
            j = j + 1;
        }
        i = i + 1;
    }
    return arr;
}

// Copy an ArrayList<ArrayList<double>> matrix
public fn copyMatrix(rhf: RHF, m: ArrayList<ArrayList<double>>): ArrayList<ArrayList<double>> {
    let n: int = m.size();
    let copy: ArrayList<ArrayList<double>> = makeZeroMatrix(n);
    var i: int = 0;
    while (i < n) {
        var j: int = 0;
        while (j < n) {
            copy.get(i).set(j, m.get(i).get(j));
            j = j + 1;
        }
        i = i + 1;
    }
    return copy;
}
