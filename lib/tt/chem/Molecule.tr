import tt.util.ArrayList;
import tt.chem.Atom;
import tt.chem.Bond;
import tt.math.Math;
import tt.lang.Integer;
import tt.lang.Double;

public class Molecule {
    public ArrayList<Atom> atoms;
    public ArrayList<Bond> bonds;
    public String name;

    public Molecule(String n) {
        this.name = n;
        this.atoms = new ArrayList<Atom>();
        this.bonds = new ArrayList<Bond>();
    }

    public int addAtom(Atom atom) {
        this.atoms.add(atom);
        return this.atoms.size() - 1;
    }

    public void addBond(Bond bond) {
        this.bonds.add(bond);
    }

    public Atom getAtom(int i) {
        return this.atoms.get(i);
    }

    public Bond getBond(int i) {
        return this.bonds.get(i);
    }

    public int atomCount() {
        return this.atoms.size();
    }

    public int bondCount() {
        return this.bonds.size();
    }

    public void removeAtom(int index) {
        this.atoms.remove(index);
        // Update bond indices: remove bonds involving the atom, shift indices > index
        int b = this.bonds.size() - 1;
        while (b >= 0) {
            Bond bond = this.bonds.get(b);
            if (bond.atom1 == index || bond.atom2 == index) {
                this.bonds.remove(b);
            } else {
                if (bond.atom1 > index) { bond.atom1 = bond.atom1 - 1; }
                if (bond.atom2 > index) { bond.atom2 = bond.atom2 - 1; }
            }
            b = b - 1;
        }
    }

    public void removeBond(int index) {
        this.bonds.remove(index);
    }

    public int findBond(int a1, int a2) {
        int i = 0;
        while (i < this.bonds.size()) {
            Bond b = this.bonds.get(i);
            if ((b.atom1 == a1 && b.atom2 == a2) || (b.atom1 == a2 && b.atom2 == a1)) {
                return i;
            }
            i = i + 1;
        }
        return -1;
    }

    public ArrayList<Bond> getBondsOf(int atomIndex) {
        ArrayList<Bond> result = new ArrayList<Bond>();
        int i = 0;
        while (i < this.bonds.size()) {
            Bond b = this.bonds.get(i);
            if (b.atom1 == atomIndex || b.atom2 == atomIndex) {
                result.add(b);
            }
            i = i + 1;
        }
        return result;
    }

    public ArrayList<int> getNeighborsOf(int atomIndex) {
        ArrayList<int> neighbors = new ArrayList<int>();
        int i = 0;
        while (i < this.bonds.size()) {
            Bond b = this.bonds.get(i);
            if (b.atom1 == atomIndex) {
                neighbors.add(b.atom2);
            } else if (b.atom2 == atomIndex) {
                neighbors.add(b.atom1);
            }
            i = i + 1;
        }
        return neighbors;
    }

    // Geometric centroid (unweighted average of positions)
    public ArrayList<double> centroid() {
        double cx = 0.0;
        double cy = 0.0;
        double cz = 0.0;
        int n = this.atoms.size();
        int i = 0;
        while (i < n) {
            Atom a = this.atoms.get(i);
            cx = cx + a.x;
            cy = cy + a.y;
            cz = cz + a.z;
            i = i + 1;
        }
        ArrayList<double> result = new ArrayList<double>();
        if (n > 0) {
            result.add(cx / n);
            result.add(cy / n);
            result.add(cz / n);
        } else {
            result.add(0.0);
            result.add(0.0);
            result.add(0.0);
        }
        return result;
    }

    // Translate all atoms by (dx, dy, dz)
    public void translate(double dx, double dy, double dz) {
        int i = 0;
        while (i < this.atoms.size()) {
            Atom a = this.atoms.get(i);
            a.x = a.x + dx;
            a.y = a.y + dy;
            a.z = a.z + dz;
            i = i + 1;
        }
    }

    // Export to XYZ format string
    public String toXYZ() {
        String s = Integer.toString(this.atoms.size()) + "\n";
        s = s + this.name + "\n";
        int i = 0;
        while (i < this.atoms.size()) {
            Atom a = this.atoms.get(i);
            s = s + a.symbol + " " + Double.toString(a.x) + " " + Double.toString(a.y) + " " + Double.toString(a.z) + "\n";
            i = i + 1;
        }
        return s;
    }

    // Import from XYZ format string
    public static Molecule fromXYZ(String xyzString) {
        // Parse lines
        ArrayList<String> lines = String.split(xyzString, "\n");
        if (lines.size() < 3) { return new Molecule("empty"); }
        int nAtoms = Integer.parseInt(lines.get(0));
        String name = lines.get(1);
        Molecule mol = new Molecule(name);
        int i = 2;
        while (i < 2 + nAtoms && i < lines.size()) {
            String line = String.trim(lines.get(i));
            if (line.length() == 0) { i = i + 1; continue; }
            ArrayList<String> parts = String.split(line, " ");
            if (parts.size() >= 4) {
                String sym = parts.get(0);
                double x = Double.parseDouble(parts.get(1));
                double y = Double.parseDouble(parts.get(2));
                double z = Double.parseDouble(parts.get(3));
                Atom a = Atom.getElement(sym);
                a.setPosition(x, y, z);
                mol.addAtom(a);
            }
            i = i + 1;
        }
        return mol;
    }

    public double molecularWeight() {
        double total = 0.0;
        int i = 0;
        while (i < this.atoms.size()) {
            total = total + this.atoms.get(i).mass;
            i = i + 1;
        }
        return total;
    }

    // Returns (cx, cy, cz) as a flat ArrayList<double> representing center of mass
    public ArrayList<double> centerOfMass() {
        double totalMass = 0.0;
        double cx = 0.0;
        double cy = 0.0;
        double cz = 0.0;
        int i = 0;
        while (i < this.atoms.size()) {
            Atom a = this.atoms.get(i);
            double m = a.mass;
            cx = cx + m * a.x;
            cy = cy + m * a.y;
            cz = cz + m * a.z;
            totalMass = totalMass + m;
            i = i + 1;
        }
        ArrayList<double> result = new ArrayList<double>();
        if (totalMass > 1e-15) {
            result.add(cx / totalMass);
            result.add(cy / totalMass);
            result.add(cz / totalMass);
        } else {
            result.add(0.0);
            result.add(0.0);
            result.add(0.0);
        }
        return result;
    }

    // Generate molecular formula string (e.g., "H2O", "C6H12O6")
    // Uses a simple approach: count element symbols and format
    public String toString() {
        // Count atoms by element symbol
        ArrayList<String> symbols = new ArrayList<String>();
        ArrayList<int> counts = new ArrayList<int>();
        int i = 0;
        while (i < this.atoms.size()) {
            String sym = this.atoms.get(i).symbol;
            int idx = -1;
            int j = 0;
            while (j < symbols.size()) {
                if (symbols.get(j) == sym) {
                    idx = j;
                }
                j = j + 1;
            }
            if (idx >= 0) {
                counts.set(idx, counts.get(idx) + 1);
            } else {
                symbols.add(sym);
                counts.add(1);
            }
            i = i + 1;
        }
        // Standard Hill system: C first, then H, then alphabetical
        String formula = "";
        // Check for carbon
        int cIdx = -1;
        i = 0;
        while (i < symbols.size()) {
            if (symbols.get(i) == "C") { cIdx = i; }
            i = i + 1;
        }
        if (cIdx >= 0) {
            formula = formula + "C";
            if (counts.get(cIdx) > 1) {
                formula = formula + Integer.toString(counts.get(cIdx));
            }
            // H next
            int hIdx = -1;
            i = 0;
            while (i < symbols.size()) {
                if (symbols.get(i) == "H") { hIdx = i; }
                i = i + 1;
            }
            if (hIdx >= 0) {
                formula = formula + "H";
                if (counts.get(hIdx) > 1) {
                    formula = formula + Integer.toString(counts.get(hIdx));
                }
            }
            // Remaining elements alphabetically
            i = 0;
            while (i < symbols.size()) {
                if (i != cIdx && i != hIdx) {
                    formula = formula + symbols.get(i);
                    if (counts.get(i) > 1) {
                        formula = formula + Integer.toString(counts.get(i));
                    }
                }
                i = i + 1;
            }
        } else {
            // No carbon: just alphabetical
            i = 0;
            while (i < symbols.size()) {
                formula = formula + symbols.get(i);
                if (counts.get(i) > 1) {
                    formula = formula + Integer.toString(counts.get(i));
                }
                i = i + 1;
            }
        }
        return formula;
    }
}
