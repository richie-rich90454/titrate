import tt::util::ArrayList;
import tt::chem::Atom;
import tt::chem::Bond;
import tt::math::Math;
import tt::lang::Integer;
import tt::lang::Double;

public class Molecule {
    public ArrayList<Atom> atoms;
    public ArrayList<Bond> bonds;
    public string name;

    fn init(n: string) {
        this.name = n;
        this.atoms = new ArrayList<Atom>();
        this.bonds = new ArrayList<Bond>();
    }

    public fn addAtom(atom: Atom): int {
        this.atoms.add(atom);
        return this.atoms.size() - 1;
    }

    public fn addBond(bond: Bond): void {
        this.bonds.add(bond);
    }

    public fn getAtom(i: int): Atom {
        return this.atoms.get(i);
    }

    public fn getBond(i: int): Bond {
        return this.bonds.get(i);
    }

    public fn atomCount(): int {
        return this.atoms.size();
    }

    public fn bondCount(): int {
        return this.bonds.size();
    }

    public fn removeAtom(index: int): void {
        this.atoms.remove(index);
        // Update bond indices: remove bonds involving the atom, shift indices > index
        let b: int = this.bonds.size() - 1;
        while (b >= 0) {
            let bond: Bond = this.bonds.get(b);
            if (bond.atom1 == index || bond.atom2 == index) {
                this.bonds.remove(b);
            } else {
                if (bond.atom1 > index) { bond.atom1 = bond.atom1 - 1; }
                if (bond.atom2 > index) { bond.atom2 = bond.atom2 - 1; }
            }
            b = b - 1;
        }
    }

    public fn removeBond(index: int): void {
        this.bonds.remove(index);
    }

    public fn findBond(a1: int, a2: int): int {
        let i: int = 0;
        while (i < this.bonds.size()) {
            let b: Bond = this.bonds.get(i);
            if ((b.atom1 == a1 && b.atom2 == a2) || (b.atom1 == a2 && b.atom2 == a1)) {
                return i;
            }
            i = i + 1;
        }
        return -1;
    }

    public fn getBondsOf(atomIndex: int): ArrayList<Bond> {
        let result: ArrayList<Bond> = new ArrayList<Bond>();
        let i: int = 0;
        while (i < this.bonds.size()) {
            let b: Bond = this.bonds.get(i);
            if (b.atom1 == atomIndex || b.atom2 == atomIndex) {
                result.add(b);
            }
            i = i + 1;
        }
        return result;
    }

    public fn getNeighborsOf(atomIndex: int): ArrayList<int> {
        let neighbors: ArrayList<int> = new ArrayList<int>();
        let i: int = 0;
        while (i < this.bonds.size()) {
            let b: Bond = this.bonds.get(i);
            if (b.atom1 == atomIndex) {
                neighbors.add(b.atom2);
            } else if (b.atom2 == atomIndex) {
                neighbors.add(b.atom1);
            }
            i = i + 1;
        }
        return neighbors;
    }

    // Geometric centroid (unweighted average of positions)
    public fn centroid(): ArrayList<double> {
        let cx: double = 0.0;
        let cy: double = 0.0;
        let cz: double = 0.0;
        let n: int = this.atoms.size();
        let i: int = 0;
        while (i < n) {
            let a: Atom = this.atoms.get(i);
            cx = cx + a.x;
            cy = cy + a.y;
            cz = cz + a.z;
            i = i + 1;
        }
        let result: ArrayList<double> = new ArrayList<double>();
        if (n > 0) {
            result.add(cx / n);
            result.add(cy / n);
            result.add(cz / n);
        } else {
            result.add(0.0);
            result.add(0.0);
            result.add(0.0);
        }
        return result;
    }

    // Translate all atoms by (dx, dy, dz)
    public fn translate(dx: double, dy: double, dz: double): void {
        let i: int = 0;
        while (i < this.atoms.size()) {
            let a: Atom = this.atoms.get(i);
            a.x = a.x + dx;
            a.y = a.y + dy;
            a.z = a.z + dz;
            i = i + 1;
        }
    }

    // Export to XYZ format string
    public fn toXYZ(): string {
        var s: string = Integer.toString(this.atoms.size()) + "\n";
        s = s + this.name + "\n";
        let i: int = 0;
        while (i < this.atoms.size()) {
            let a: Atom = this.atoms.get(i);
            s = s + a.symbol + " " + Double.toString(a.x) + " " + Double.toString(a.y) + " " + Double.toString(a.z) + "\n";
            i = i + 1;
        }
        return s;
    }

    // Returns (cx, cy, cz) as a flat ArrayList<double> representing center of mass
    public fn centerOfMass(): ArrayList<double> {
        let totalMass: double = 0.0;
        let cx: double = 0.0;
        let cy: double = 0.0;
        let cz: double = 0.0;
        let i: int = 0;
        while (i < this.atoms.size()) {
            let a: Atom = this.atoms.get(i);
            let m: double = a.mass;
            cx = cx + m * a.x;
            cy = cy + m * a.y;
            cz = cz + m * a.z;
            totalMass = totalMass + m;
            i = i + 1;
        }
        let result: ArrayList<double> = new ArrayList<double>();
        if (totalMass > 1e-15) {
            result.add(cx / totalMass);
            result.add(cy / totalMass);
            result.add(cz / totalMass);
        } else {
            result.add(0.0);
            result.add(0.0);
            result.add(0.0);
        }
        return result;
    }

    public fn molecularWeight(): double {
        let total: double = 0.0;
        let i: int = 0;
        while (i < this.atoms.size()) {
            total = total + this.atoms.get(i).mass;
            i = i + 1;
        }
        return total;
    }

    // Generate molecular formula string (e.g., "H2O", "C6H12O6")
    // Uses a simple approach: count element symbols and format
    public fn toString(): string {
        // Count atoms by element symbol
        let symbols: ArrayList<string> = new ArrayList<string>();
        let counts: ArrayList<int> = new ArrayList<int>();
        let i: int = 0;
        while (i < this.atoms.size()) {
            let sym: string = this.atoms.get(i).symbol;
            var idx: int = -1;
            let j: int = 0;
            while (j < symbols.size()) {
                if (symbols.get(j) == sym) {
                    idx = j;
                }
                j = j + 1;
            }
            if (idx >= 0) {
                counts.set(idx, counts.get(idx) + 1);
            } else {
                symbols.add(sym);
                counts.add(1);
            }
            i = i + 1;
        }
        // Standard Hill system: C first, then H, then alphabetical
        var formula: string = "";
        // Check for carbon
        var cIdx: int = -1;
        i = 0;
        while (i < symbols.size()) {
            if (symbols.get(i) == "C") { cIdx = i; }
            i = i + 1;
        }
        if (cIdx >= 0) {
            formula = formula + "C";
            if (counts.get(cIdx) > 1) {
                formula = formula + Integer.toString(counts.get(cIdx));
            }
            // H next
            var hIdx: int = -1;
            i = 0;
            while (i < symbols.size()) {
                if (symbols.get(i) == "H") { hIdx = i; }
                i = i + 1;
            }
            if (hIdx >= 0) {
                formula = formula + "H";
                if (counts.get(hIdx) > 1) {
                    formula = formula + Integer.toString(counts.get(hIdx));
                }
            }
            // Remaining elements alphabetically
            i = 0;
            while (i < symbols.size()) {
                if (i != cIdx && i != hIdx) {
                    formula = formula + symbols.get(i);
                    if (counts.get(i) > 1) {
                        formula = formula + Integer.toString(counts.get(i));
                    }
                }
                i = i + 1;
            }
        } else {
            // No carbon: just alphabetical
            i = 0;
            while (i < symbols.size()) {
                formula = formula + symbols.get(i);
                if (counts.get(i) > 1) {
                    formula = formula + Integer.toString(counts.get(i));
                }
                i = i + 1;
            }
        }
        return formula;
    }
}

// Import from XYZ format string
public fn fromXYZ(xyzString: string): Molecule {
    // Parse lines
    let lines: ArrayList<string> = String.split(xyzString, "\n");
    if (lines.size() < 3) { return new Molecule("empty"); }
    let nAtoms: int = Integer.parseInt(lines.get(0));
    let name: string = lines.get(1);
    let mol: Molecule = new Molecule(name);
    let i: int = 2;
    while (i < 2 + nAtoms && i < lines.size()) {
        let line: string = String.trim(lines.get(i));
        if (String.length(line) == 0) { i = i + 1; continue; }
        let parts: ArrayList<string> = String.split(line, " ");
        if (parts.size() >= 4) {
            let sym: string = parts.get(0);
            let x: double = Double.parseDouble(parts.get(1));
            let y: double = Double.parseDouble(parts.get(2));
            let z: double = Double.parseDouble(parts.get(3));
            let a: Atom = Atom.getElement(sym);
            a.setPosition(x, y, z);
            mol.addAtom(a);
        }
        i = i + 1;
    }
    return mol;
}
