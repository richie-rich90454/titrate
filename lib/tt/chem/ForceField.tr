import tt.util.ArrayList;
import tt.chem.Atom;
import tt.chem.Bond;
import tt.chem.Molecule;
import tt.math.Math;

public class ForceField {
    // Default force field parameters
    public double bondK;       // harmonic bond force constant
    public double bondR0;      // equilibrium bond length
    public double angleK;      // harmonic angle force constant
    public double angleTheta0; // equilibrium angle (radians)
    public double ljEpsilon;   // LJ well depth
    public double ljSigma;    // LJ collision diameter
    public double coulombK;   // Coulomb constant (in appropriate units)

    public ForceField() {
        this.bondK = 300.0;
        this.bondR0 = 1.5;
        this.angleK = 60.0;
        this.angleTheta0 = 1.911;  // ~109.5 degrees
        this.ljEpsilon = 0.1;
        this.ljSigma = 3.0;
        this.coulombK = 332.0;     // kcal/mol * Angstrom / e^2
    }

    public ForceField(double bk, double br, double ak, double at, double le, double ls, double ck) {
        this.bondK = bk;
        this.bondR0 = br;
        this.angleK = ak;
        this.angleTheta0 = at;
        this.ljEpsilon = le;
        this.ljSigma = ls;
        this.coulombK = ck;
    }

    // Harmonic bond energy: E = sum of 0.5 * k * (r - r0)^2
    public double bondEnergy(Molecule mol) {
        double e = 0.0;
        int i = 0;
        while (i < mol.bonds.size()) {
            Bond b = mol.bonds.get(i);
            Atom a1 = mol.atoms.get(b.atom1);
            Atom a2 = mol.atoms.get(b.atom2);
            double r = a1.distanceTo(a2);
            double dr = r - this.bondR0;
            e = e + 0.5 * this.bondK * dr * dr;
            i = i + 1;
        }
        return e;
    }

    // Harmonic angle energy: E = sum of 0.5 * k * (theta - theta0)^2
    // Applied to all consecutive triplets of bonded atoms
    public double angleEnergy(Molecule mol) {
        double e = 0.0;
        // For each bond triplet: find atoms bonded to a common center
        int n = mol.atoms.size();
        int center = 0;
        while (center < n) {
            // Find all atoms bonded to this center
            ArrayList<int> neighbors = new ArrayList<int>();
            int b = 0;
            while (b < mol.bonds.size()) {
                Bond bond = mol.bonds.get(b);
                if (bond.atom1 == center) {
                    neighbors.add(bond.atom2);
                } else if (bond.atom2 == center) {
                    neighbors.add(bond.atom1);
                }
                b = b + 1;
            }
            // For each pair of neighbors, compute angle energy
            int j = 0;
            while (j < neighbors.size()) {
                int k = j + 1;
                while (k < neighbors.size()) {
                    int i1 = neighbors.get(j);
                    int i2 = neighbors.get(k);
                    double theta = ForceField.computeAngle(mol.atoms.get(i1), mol.atoms.get(center), mol.atoms.get(i2));
                    double dtheta = theta - this.angleTheta0;
                    e = e + 0.5 * this.angleK * dtheta * dtheta;
                    k = k + 1;
                }
                j = j + 1;
            }
            center = center + 1;
        }
        return e;
    }

    // Lennard-Jones 6-12 potential: E = 4*epsilon * ((sigma/r)^12 - (sigma/r)^6)
    public double lennardJonesEnergy(Molecule mol) {
        double e = 0.0;
        int n = mol.atoms.size();
        int i = 0;
        while (i < n) {
            int j = i + 1;
            while (j < n) {
                Atom a1 = mol.atoms.get(i);
                Atom a2 = mol.atoms.get(j);
                double r = a1.distanceTo(a2);
                if (r < 1e-10) {
                    j = j + 1;
                    continue;
                }
                double sr = this.ljSigma / r;
                double sr6 = sr * sr * sr * sr * sr * sr;
                double sr12 = sr6 * sr6;
                e = e + 4.0 * this.ljEpsilon * (sr12 - sr6);
                j = j + 1;
            }
            i = i + 1;
        }
        return e;
    }

    // Coulomb electrostatic energy: E = k_e * q1 * q2 / r
    // Uses partial charges stored in Atom.mass field as a proxy (simplified)
    // For a proper implementation, atoms would have a separate charge field
    public double coulombEnergy(Molecule mol) {
        double e = 0.0;
        int n = mol.atoms.size();
        int i = 0;
        while (i < n) {
            int j = i + 1;
            while (j < n) {
                Atom a1 = mol.atoms.get(i);
                Atom a2 = mol.atoms.get(j);
                double r = a1.distanceTo(a2);
                if (r < 1e-10) {
                    j = j + 1;
                    continue;
                }
                // Use simplified charges: O = -0.8, H = +0.4, others = 0
                double q1 = ForceField.partialCharge(a1.symbol);
                double q2 = ForceField.partialCharge(a2.symbol);
                e = e + this.coulombK * q1 * q2 / r;
                j = j + 1;
            }
            i = i + 1;
        }
        return e;
    }

    // Total energy: sum of all terms
    public double totalEnergy(Molecule mol) {
        return this.bondEnergy(mol) + this.angleEnergy(mol) + this.lennardJonesEnergy(mol) + this.coulombEnergy(mol);
    }

    // Compute angle between three atoms at center (in radians)
    public static double computeAngle(Atom a1, Atom center, Atom a2) {
        double v1x = a1.x - center.x;
        double v1y = a1.y - center.y;
        double v1z = a1.z - center.z;
        double v2x = a2.x - center.x;
        double v2y = a2.y - center.y;
        double v2z = a2.z - center.z;
        double dot = v1x * v2x + v1y * v2y + v1z * v2z;
        double mag1 = Math.sqrt(v1x * v1x + v1y * v1y + v1z * v1z);
        double mag2 = Math.sqrt(v2x * v2x + v2y * v2y + v2z * v2z);
        if (mag1 < 1e-15 || mag2 < 1e-15) { return 0.0; }
        double cosAngle = dot / (mag1 * mag2);
        if (cosAngle > 1.0) { cosAngle = 1.0; }
        if (cosAngle < -1.0) { cosAngle = -1.0; }
        return Math.acos(cosAngle);
    }

    // Simplified partial charges for common elements
    public static double partialCharge(String symbol) {
        if (symbol == "O") { return -0.8476; }
        if (symbol == "H") { return 0.4238; }
        if (symbol == "N") { return -0.47; }
        if (symbol == "C") { return -0.1; }
        if (symbol == "S") { return -0.2; }
        return 0.0;
    }

    // Compute forces via finite differences
    public ArrayList<double> computeForces(Molecule mol) {
        ArrayList<double> forces = new ArrayList<double>();
        double delta = 1e-5;
        int n = mol.atoms.size();
        int i = 0;
        while (i < n) {
            Atom a = mol.atoms.get(i);
            // fx
            double origX = a.x;
            a.x = origX + delta;
            double ePlus = this.totalEnergy(mol);
            a.x = origX - delta;
            double eMinus = this.totalEnergy(mol);
            a.x = origX;
            double fx = -(ePlus - eMinus) / (2.0 * delta);
            // fy
            double origY = a.y;
            a.y = origY + delta;
            ePlus = this.totalEnergy(mol);
            a.y = origY - delta;
            eMinus = this.totalEnergy(mol);
            a.y = origY;
            double fy = -(ePlus - eMinus) / (2.0 * delta);
            // fz
            double origZ = a.z;
            a.z = origZ + delta;
            ePlus = this.totalEnergy(mol);
            a.z = origZ - delta;
            eMinus = this.totalEnergy(mol);
            a.z = origZ;
            double fz = -(ePlus - eMinus) / (2.0 * delta);
            forces.add(fx);
            forces.add(fy);
            forces.add(fz);
            i = i + 1;
        }
        return forces;
    }
}
