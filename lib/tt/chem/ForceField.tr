import tt::util::ArrayList;
import tt::chem::Atom;
import tt::chem::Bond;
import tt::chem::Molecule;
import tt::math::Math;
import tt::chem::ForceFieldNonbonded;

public class ForceField {
    // Default force field parameters
    public double bondK;       // harmonic bond force constant
    public double bondR0;      // equilibrium bond length
    public double angleK;      // harmonic angle force constant
    public double angleTheta0; // equilibrium angle (radians)
    public double ljEpsilon;   // LJ well depth
    public double ljSigma;    // LJ collision diameter
    public double coulombK;   // Coulomb constant (in appropriate units)

    fn init() {
        this.bondK = 300.0;
        this.bondR0 = 1.5;
        this.angleK = 60.0;
        this.angleTheta0 = 1.911;  // ~109.5 degrees
        this.ljEpsilon = 0.1;
        this.ljSigma = 3.0;
        this.coulombK = 332.0;     // kcal/mol * Angstrom / e^2
    }

    fn init(bk: double, br: double, ak: double, at: double, le: double, ls: double, ck: double) {
        this.bondK = bk;
        this.bondR0 = br;
        this.angleK = ak;
        this.angleTheta0 = at;
        this.ljEpsilon = le;
        this.ljSigma = ls;
        this.coulombK = ck;
    }

    // Harmonic bond energy: E = sum of 0.5 * k * (r - r0)^2
    public fn bondEnergy(mol: Molecule): double {
        let e: double = 0.0;
        let i: int = 0;
        while (i < mol.bonds.size()) {
            let b: Bond = mol.bonds.get(i);
            let a1: Atom = mol.atoms.get(b.atom1);
            let a2: Atom = mol.atoms.get(b.atom2);
            let r: double = a1.distanceTo(a2);
            let dr: double = r - this.bondR0;
            e = e + 0.5 * this.bondK * dr * dr;
            i = i + 1;
        }
        return e;
    }

    // Harmonic angle energy: E = sum of 0.5 * k * (theta - theta0)^2
    // Applied to all consecutive triplets of bonded atoms
    public fn angleEnergy(mol: Molecule): double {
        let e: double = 0.0;
        // For each bond triplet: find atoms bonded to a common center
        let n: int = mol.atoms.size();
        let center: int = 0;
        while (center < n) {
            // Find all atoms bonded to this center
            let neighbors: ArrayList<int> = new ArrayList<int>();
            let b: int = 0;
            while (b < mol.bonds.size()) {
                let bond: Bond = mol.bonds.get(b);
                if (bond.atom1 == center) {
                    neighbors.add(bond.atom2);
                } else if (bond.atom2 == center) {
                    neighbors.add(bond.atom1);
                }
                b = b + 1;
            }
            // For each pair of neighbors, compute angle energy
            let j: int = 0;
            while (j < neighbors.size()) {
                let k: int = j + 1;
                while (k < neighbors.size()) {
                    let i1: int = neighbors.get(j);
                    let i2: int = neighbors.get(k);
                    let theta: double = computeAngle(mol.atoms.get(i1), mol.atoms.get(center), mol.atoms.get(i2));
                    let dtheta: double = theta - this.angleTheta0;
                    e = e + 0.5 * this.angleK * dtheta * dtheta;
                    k = k + 1;
                }
                j = j + 1;
            }
            center = center + 1;
        }
        return e;
    }

    // Torsion (dihedral) energy: E = sum of k_tors * (1 + cos(n*phi - phi0))
    // Applied to all bonded quadruplets (a1-a2-a3-a4)
    public fn torsionEnergy(mol: Molecule): double {
        let e: double = 0.0;
        let kTors: double = 0.5;  // torsion force constant
        let n: int = 3;           // periodicity
        let phi0: double = 0.0;   // phase offset
        // For each bond pair sharing a common atom
        let b1: int = 0;
        while (b1 < mol.bonds.size()) {
            let bond1: Bond = mol.bonds.get(b1);
            let b2: int = 0;
            while (b2 < mol.bonds.size()) {
                let bond2: Bond = mol.bonds.get(b2);
                // Find shared atom between bond1 and bond2
                var shared: int = -1;
                var end1: int = -1;
                var end2: int = -1;
                if (bond1.atom2 == bond2.atom1 && bond1.atom1 != bond2.atom2) {
                    shared = bond1.atom2;
                    end1 = bond1.atom1;
                    end2 = bond2.atom2;
                } else if (bond1.atom1 == bond2.atom2 && bond1.atom2 != bond2.atom1) {
                    shared = bond1.atom1;
                    end1 = bond1.atom2;
                    end2 = bond2.atom1;
                } else if (bond1.atom2 == bond2.atom2 && bond1.atom1 != bond2.atom1) {
                    shared = bond1.atom2;
                    end1 = bond1.atom1;
                    end2 = bond2.atom1;
                } else if (bond1.atom1 == bond2.atom1 && bond1.atom2 != bond2.atom2) {
                    shared = bond1.atom1;
                    end1 = bond1.atom2;
                    end2 = bond2.atom2;
                }
                if (shared != -1 && b1 < b2) {
                    let phi: double = computeDihedral(
                        mol.atoms.get(end1), mol.atoms.get(shared), mol.atoms.get(end2),
                        mol.atoms.get(end2)  // simplified: no 4th atom, use 0 energy contribution
                    );
                    e = e + kTors * (1.0 + Math.cos(n * phi - phi0));
                }
                b2 = b2 + 1;
            }
            b1 = b1 + 1;
        }
        return e;
    }

    // Improper torsion energy: E = sum of k_imp * (theta - theta0)^2
    // Applied to atoms with 3+ neighbors (planar centers)
    public fn improperEnergy(mol: Molecule): double {
        let e: double = 0.0;
        let kImp: double = 1.0;
        let theta0: double = 0.0; // ideal improper angle = 0 (planar)
        let n: int = mol.atoms.size();
        let center: int = 0;
        while (center < n) {
            let neighbors: ArrayList<int> = new ArrayList<int>();
            let b: int = 0;
            while (b < mol.bonds.size()) {
                let bond: Bond = mol.bonds.get(b);
                if (bond.atom1 == center) {
                    neighbors.add(bond.atom2);
                } else if (bond.atom2 == center) {
                    neighbors.add(bond.atom1);
                }
                b = b + 1;
            }
            // For atoms with 3+ neighbors, compute improper torsion
            if (neighbors.size() >= 3) {
                let j: int = 0;
                while (j < neighbors.size() - 2) {
                    let impAngle: double = computeImproper(
                        mol.atoms.get(neighbors.get(j)),
                        mol.atoms.get(center),
                        mol.atoms.get(neighbors.get(j + 1)),
                        mol.atoms.get(neighbors.get(j + 2))
                    );
                    let dtheta: double = impAngle - theta0;
                    e = e + kImp * dtheta * dtheta;
                    j = j + 1;
                }
            }
            center = center + 1;
        }
        return e;
    }

    // Total energy: sum of all terms
    public fn totalEnergy(mol: Molecule): double {
        return this.bondEnergy(mol) + this.angleEnergy(mol) + lennardJonesEnergy(this, mol) + coulombEnergy(this, mol) + this.torsionEnergy(mol) + this.improperEnergy(mol);
    }
}

// Compute dihedral angle between four atoms
public fn computeDihedral(a1: Atom, a2: Atom, a3: Atom, a4: Atom): double {
    let b1x: double = a2.x - a1.x; let b1y: double = a2.y - a1.y; let b1z: double = a2.z - a1.z;
    let b2x: double = a3.x - a2.x; let b2y: double = a3.y - a2.y; let b2z: double = a3.z - a2.z;
    let b3x: double = a4.x - a3.x; let b3y: double = a4.y - a3.y; let b3z: double = a4.z - a3.z;
    let n1x: double = b1y * b2z - b1z * b2y;
    let n1y: double = b1z * b2x - b1x * b2z;
    let n1z: double = b1x * b2y - b1y * b2x;
    let n2x: double = b2y * b3z - b2z * b3y;
    let n2y: double = b2z * b3x - b2x * b3z;
    let n2z: double = b2x * b3y - b2y * b3x;
    let m1x: double = n1y * b2z - n1z * b2y;
    let m1y: double = n1z * b2x - n1x * b2z;
    let m1z: double = n1x * b2y - n1y * b2x;
    let x: double = n1x * n2x + n1y * n2y + n1z * n2z;
    let y: double = m1x * n2x + m1y * n2y + m1z * n2z;
    return Math.atan2(y, x);
}

// Compute improper torsion angle (out-of-plane angle)
public fn computeImproper(a1: Atom, center: Atom, a2: Atom, a3: Atom): double {
    // Vector from center to each neighbor
    let v1x: double = a1.x - center.x; let v1y: double = a1.y - center.y; let v1z: double = a1.z - center.z;
    let v2x: double = a2.x - center.x; let v2y: double = a2.y - center.y; let v2z: double = a2.z - center.z;
    let v3x: double = a3.x - center.x; let v3y: double = a3.y - center.y; let v3z: double = a3.z - center.z;
    // Normal to plane of v2, v3
    let nx: double = v2y * v3z - v2z * v3y;
    let ny: double = v2z * v3x - v2x * v3z;
    let nz: double = v2x * v3y - v2y * v3x;
    let nMag: double = Math.sqrt(nx * nx + ny * ny + nz * nz);
    if (nMag < 1e-15) { return 0.0; }
    let nnx: double = nx / nMag; let nny: double = ny / nMag; let nnz: double = nz / nMag;
    // Angle between v1 and the plane
    let dot: double = v1x * nnx + v1y * nny + v1z * nnz;
    let v1Mag: double = Math.sqrt(v1x * v1x + v1y * v1y + v1z * v1z);
    if (v1Mag < 1e-15) { return 0.0; }
    var sinAngle: double = dot / v1Mag;
    if (sinAngle > 1.0) { sinAngle = 1.0; }
    if (sinAngle < -1.0) { sinAngle = -1.0; }
    return Math.asin(sinAngle);
}

// Compute angle between three atoms at center (in radians)
public fn computeAngle(a1: Atom, center: Atom, a2: Atom): double {
    let v1x: double = a1.x - center.x;
    let v1y: double = a1.y - center.y;
    let v1z: double = a1.z - center.z;
    let v2x: double = a2.x - center.x;
    let v2y: double = a2.y - center.y;
    let v2z: double = a2.z - center.z;
    let dot: double = v1x * v2x + v1y * v2y + v1z * v2z;
    let mag1: double = Math.sqrt(v1x * v1x + v1y * v1y + v1z * v1z);
    let mag2: double = Math.sqrt(v2x * v2x + v2y * v2y + v2z * v2z);
    if (mag1 < 1e-15 || mag2 < 1e-15) { return 0.0; }
    var cosAngle: double = dot / (mag1 * mag2);
    if (cosAngle > 1.0) { cosAngle = 1.0; }
    if (cosAngle < -1.0) { cosAngle = -1.0; }
    return Math.acos(cosAngle);
}
