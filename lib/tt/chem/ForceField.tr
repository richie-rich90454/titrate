import tt::util::ArrayList;
import tt::chem::Atom;
import tt::chem::Bond;
import tt::chem::Molecule;
import tt::math::Math;
import tt::chem::ForceFieldNonbonded;

public class ForceField {
    // Default force field parameters
    public double bondK;       // harmonic bond force constant
    public double bondR0;      // equilibrium bond length
    public double angleK;      // harmonic angle force constant
    public double angleTheta0; // equilibrium angle (radians)
    public double ljEpsilon;   // LJ well depth
    public double ljSigma;    // LJ collision diameter
    public double coulombK;   // Coulomb constant (in appropriate units)

    public ForceField() {
        this.bondK = 300.0;
        this.bondR0 = 1.5;
        this.angleK = 60.0;
        this.angleTheta0 = 1.911;  // ~109.5 degrees
        this.ljEpsilon = 0.1;
        this.ljSigma = 3.0;
        this.coulombK = 332.0;     // kcal/mol * Angstrom / e^2
    }

    public ForceField(double bk, double br, double ak, double at, double le, double ls, double ck) {
        this.bondK = bk;
        this.bondR0 = br;
        this.angleK = ak;
        this.angleTheta0 = at;
        this.ljEpsilon = le;
        this.ljSigma = ls;
        this.coulombK = ck;
    }

    // Harmonic bond energy: E = sum of 0.5 * k * (r - r0)^2
    public double bondEnergy(Molecule mol) {
        double e = 0.0;
        int i = 0;
        while (i < mol.bonds.size()) {
            Bond b = mol.bonds.get(i);
            Atom a1 = mol.atoms.get(b.atom1);
            Atom a2 = mol.atoms.get(b.atom2);
            double r = a1.distanceTo(a2);
            double dr = r - this.bondR0;
            e = e + 0.5 * this.bondK * dr * dr;
            i = i + 1;
        }
        return e;
    }

    // Harmonic angle energy: E = sum of 0.5 * k * (theta - theta0)^2
    // Applied to all consecutive triplets of bonded atoms
    public double angleEnergy(Molecule mol) {
        double e = 0.0;
        // For each bond triplet: find atoms bonded to a common center
        int n = mol.atoms.size();
        int center = 0;
        while (center < n) {
            // Find all atoms bonded to this center
            ArrayList<int> neighbors = new ArrayList<int>();
            int b = 0;
            while (b < mol.bonds.size()) {
                Bond bond = mol.bonds.get(b);
                if (bond.atom1 == center) {
                    neighbors.add(bond.atom2);
                } else if (bond.atom2 == center) {
                    neighbors.add(bond.atom1);
                }
                b = b + 1;
            }
            // For each pair of neighbors, compute angle energy
            int j = 0;
            while (j < neighbors.size()) {
                int k = j + 1;
                while (k < neighbors.size()) {
                    int i1 = neighbors.get(j);
                    int i2 = neighbors.get(k);
                    double theta = ForceField.computeAngle(mol.atoms.get(i1), mol.atoms.get(center), mol.atoms.get(i2));
                    double dtheta = theta - this.angleTheta0;
                    e = e + 0.5 * this.angleK * dtheta * dtheta;
                    k = k + 1;
                }
                j = j + 1;
            }
            center = center + 1;
        }
        return e;
    }

    // Torsion (dihedral) energy: E = sum of k_tors * (1 + cos(n*phi - phi0))
    // Applied to all bonded quadruplets (a1-a2-a3-a4)
    public double torsionEnergy(Molecule mol) {
        double e = 0.0;
        double kTors = 0.5;  // torsion force constant
        int n = 3;           // periodicity
        double phi0 = 0.0;   // phase offset
        // For each bond pair sharing a common atom
        int b1 = 0;
        while (b1 < mol.bonds.size()) {
            Bond bond1 = mol.bonds.get(b1);
            int b2 = 0;
            while (b2 < mol.bonds.size()) {
                Bond bond2 = mol.bonds.get(b2);
                // Find shared atom between bond1 and bond2
                int shared = -1;
                int end1 = -1;
                int end2 = -1;
                if (bond1.atom2 == bond2.atom1 && bond1.atom1 != bond2.atom2) {
                    shared = bond1.atom2;
                    end1 = bond1.atom1;
                    end2 = bond2.atom2;
                } else if (bond1.atom1 == bond2.atom2 && bond1.atom2 != bond2.atom1) {
                    shared = bond1.atom1;
                    end1 = bond1.atom2;
                    end2 = bond2.atom1;
                } else if (bond1.atom2 == bond2.atom2 && bond1.atom1 != bond2.atom1) {
                    shared = bond1.atom2;
                    end1 = bond1.atom1;
                    end2 = bond2.atom1;
                } else if (bond1.atom1 == bond2.atom1 && bond1.atom2 != bond2.atom2) {
                    shared = bond1.atom1;
                    end1 = bond1.atom2;
                    end2 = bond2.atom2;
                }
                if (shared != -1 && b1 < b2) {
                    double phi = ForceField.computeDihedral(
                        mol.atoms.get(end1), mol.atoms.get(shared), mol.atoms.get(end2),
                        mol.atoms.get(end2)  // simplified: no 4th atom, use 0 energy contribution
                    );
                    e = e + kTors * (1.0 + Math.cos(n * phi - phi0));
                }
                b2 = b2 + 1;
            }
            b1 = b1 + 1;
        }
        return e;
    }

    // Improper torsion energy: E = sum of k_imp * (theta - theta0)^2
    // Applied to atoms with 3+ neighbors (planar centers)
    public double improperEnergy(Molecule mol) {
        double e = 0.0;
        double kImp = 1.0;
        double theta0 = 0.0; // ideal improper angle = 0 (planar)
        int n = mol.atoms.size();
        int center = 0;
        while (center < n) {
            ArrayList<int> neighbors = new ArrayList<int>();
            int b = 0;
            while (b < mol.bonds.size()) {
                Bond bond = mol.bonds.get(b);
                if (bond.atom1 == center) {
                    neighbors.add(bond.atom2);
                } else if (bond.atom2 == center) {
                    neighbors.add(bond.atom1);
                }
                b = b + 1;
            }
            // For atoms with 3+ neighbors, compute improper torsion
            if (neighbors.size() >= 3) {
                int j = 0;
                while (j < neighbors.size() - 2) {
                    double impAngle = ForceField.computeImproper(
                        mol.atoms.get(neighbors.get(j)),
                        mol.atoms.get(center),
                        mol.atoms.get(neighbors.get(j + 1)),
                        mol.atoms.get(neighbors.get(j + 2))
                    );
                    double dtheta = impAngle - theta0;
                    e = e + kImp * dtheta * dtheta;
                    j = j + 1;
                }
            }
            center = center + 1;
        }
        return e;
    }

    // Total energy: sum of all terms
    public double totalEnergy(Molecule mol) {
        return this.bondEnergy(mol) + this.angleEnergy(mol) + ForceFieldNonbonded.lennardJonesEnergy(this, mol) + ForceFieldNonbonded.coulombEnergy(this, mol) + this.torsionEnergy(mol) + this.improperEnergy(mol);
    }

    // Compute dihedral angle between four atoms
    public static double computeDihedral(Atom a1, Atom a2, Atom a3, Atom a4) {
        double b1x = a2.x - a1.x; double b1y = a2.y - a1.y; double b1z = a2.z - a1.z;
        double b2x = a3.x - a2.x; double b2y = a3.y - a2.y; double b2z = a3.z - a2.z;
        double b3x = a4.x - a3.x; double b3y = a4.y - a3.y; double b3z = a4.z - a3.z;
        double n1x = b1y * b2z - b1z * b2y;
        double n1y = b1z * b2x - b1x * b2z;
        double n1z = b1x * b2y - b1y * b2x;
        double n2x = b2y * b3z - b2z * b3y;
        double n2y = b2z * b3x - b2x * b3z;
        double n2z = b2x * b3y - b2y * b3x;
        double m1x = n1y * b2z - n1z * b2y;
        double m1y = n1z * b2x - n1x * b2z;
        double m1z = n1x * b2y - n1y * b2x;
        double x = n1x * n2x + n1y * n2y + n1z * n2z;
        double y = m1x * n2x + m1y * n2y + m1z * n2z;
        return Math.atan2(y, x);
    }

    // Compute improper torsion angle (out-of-plane angle)
    public static double computeImproper(Atom a1, Atom center, Atom a2, Atom a3) {
        // Vector from center to each neighbor
        double v1x = a1.x - center.x; double v1y = a1.y - center.y; double v1z = a1.z - center.z;
        double v2x = a2.x - center.x; double v2y = a2.y - center.y; double v2z = a2.z - center.z;
        double v3x = a3.x - center.x; double v3y = a3.y - center.y; double v3z = a3.z - center.z;
        // Normal to plane of v2, v3
        double nx = v2y * v3z - v2z * v3y;
        double ny = v2z * v3x - v2x * v3z;
        double nz = v2x * v3y - v2y * v3x;
        double nMag = Math.sqrt(nx * nx + ny * ny + nz * nz);
        if (nMag < 1e-15) { return 0.0; }
        nx = nx / nMag; ny = ny / nMag; nz = nz / nMag;
        // Angle between v1 and the plane
        double dot = v1x * nx + v1y * ny + v1z * nz;
        double v1Mag = Math.sqrt(v1x * v1x + v1y * v1y + v1z * v1z);
        if (v1Mag < 1e-15) { return 0.0; }
        double sinAngle = dot / v1Mag;
        if (sinAngle > 1.0) { sinAngle = 1.0; }
        if (sinAngle < -1.0) { sinAngle = -1.0; }
        return Math.asin(sinAngle);
    }

    // Compute angle between three atoms at center (in radians)
    public static double computeAngle(Atom a1, Atom center, Atom a2) {
        double v1x = a1.x - center.x;
        double v1y = a1.y - center.y;
        double v1z = a1.z - center.z;
        double v2x = a2.x - center.x;
        double v2y = a2.y - center.y;
        double v2z = a2.z - center.z;
        double dot = v1x * v2x + v1y * v2y + v1z * v2z;
        double mag1 = Math.sqrt(v1x * v1x + v1y * v1y + v1z * v1z);
        double mag2 = Math.sqrt(v2x * v2x + v2y * v2y + v2z * v2z);
        if (mag1 < 1e-15 || mag2 < 1e-15) { return 0.0; }
        double cosAngle = dot / (mag1 * mag2);
        if (cosAngle > 1.0) { cosAngle = 1.0; }
        if (cosAngle < -1.0) { cosAngle = -1.0; }
        return Math.acos(cosAngle);
    }
}
