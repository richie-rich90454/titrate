import tt::util::ArrayList;
import tt::util::Pair;
import tt::math::Math;
import tt::math::MathAdvanced;

// Faraday constant: 96485 C/mol
const FARADAY: double = 96485.0;
// Gas constant: 8.314 J/(mol·K)
const GAS_CONSTANT: double = 8.314;

// Nernst equation: E = E° - (RT / nF) * ln(Q)
// Q = product of [products]^coefficients / product of [reactants]^coefficients
// e0: standard reduction potential (V)
// n: number of electrons transferred
// products: list of (species, concentration) pairs for products
// reactants: list of (species, concentration) pairs for reactants
// temperature: temperature in K
// Returns cell potential in V
public fn nernstPotential(e0: double, n: int, products: ArrayList<Pair<string, double>>,
                         reactants: ArrayList<Pair<string, double>>, temperature: double): double {
    if (n <= 0) {
        return e0;
    }
    // Calculate reaction quotient Q
    let q: double = _reactionQuotient(products, reactants);
    // Nernst equation: E = E° - (RT / nF) * ln(Q)
    let nDouble: double = n as double;
    let rtOverNF: double = (GAS_CONSTANT * temperature) / (nDouble * FARADAY);
    let lnQ: double = 0.0;
    if (q > 0.0) {
        lnQ = MathAdvanced.ln(q);
    }
    return e0 - rtOverNF * lnQ;
}

// Calculate reaction quotient Q = [products]^coeff / [reactants]^coeff
fn _reactionQuotient(products: ArrayList<Pair<string, double>>, reactants: ArrayList<Pair<string, double>>): double {
    var numerator: double = 1.0;
    var i: int = 0;
    while (i < products.size()) {
        let conc: double = products.get(i).second;
        if (conc > 0.0) {
            numerator = numerator * conc;
        }
        i = i + 1;
    }
    var denominator: double = 1.0;
    i = 0;
    while (i < reactants.size()) {
        let conc: double = reactants.get(i).second;
        if (conc > 0.0) {
            denominator = denominator * conc;
        }
        i = i + 1;
    }
    if (Math.abs(denominator) < 1e-15) {
        return 0.0;
    }
    return numerator / denominator;
}

// Standard cell potential: E°cell = E°cathode - E°anode
// cathode: standard reduction potential of the cathode (V)
// anode: standard reduction potential of the anode (V)
// Returns E°cell in V
public fn cellPotential(cathode: double, anode: double): double {
    return cathode - anode;
}

// Gibbs free energy from cell potential: ΔG° = -nFE°
// e: cell potential in V
// n: number of electrons transferred
// Returns ΔG° in J/mol
public fn gibbsFromPotential(e: double, n: int): double {
    let nDouble: double = n as double;
    return -(nDouble * FARADAY * e);
}

// Faraday's law of electrolysis: mass deposited
// m = (M * I * t) / (n * F)
// where M = molar mass (g/mol), I = current (A), t = time (s), n = electrons, F = Faraday constant
// We return moles of substance: moles = (I * t) / (n * F)
// current: current in Amperes
// time: time in seconds
// n: number of electrons transferred per ion
// Returns moles of substance deposited
public fn faradayElectrolysis(current: double, time: double, n: int): double {
    if (n <= 0) {
        return 0.0;
    }
    let nDouble: double = n as double;
    return (current * time) / (nDouble * FARADAY);
}

// Concentration cell EMF using Nernst equation:
// E = (RT / nF) * ln(c1 / c2)
// where c1 > c2 (c1 is the higher concentration)
// e0: standard potential (typically 0 for concentration cells)
// n: number of electrons transferred
// c1: concentration at one electrode (mol/L)
// c2: concentration at the other electrode (mol/L)
// Returns EMF in V
public fn concentrationCellPotential(e0: double, n: int, c1: double, c2: double): double {
    if (n <= 0) {
        return e0;
    }
    if (c1 <= 0.0 || c2 <= 0.0) {
        return e0;
    }
    let nDouble: double = n as double;
    let ratio: double = c1 / c2;
    let lnRatio: double = MathAdvanced.ln(ratio);
    // At 298.15 K (25°C), RT/F = 0.02569 V
    // General: (RT / nF) * ln(c1/c2)
    let rtOverNF: double = (GAS_CONSTANT * 298.15) / (nDouble * FARADAY);
    return e0 + rtOverNF * lnRatio;
}
