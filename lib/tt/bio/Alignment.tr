// Alignment.tr — Sequence alignment algorithms (Needleman-Wunsch, Smith-Waterman)
import tt::lang::DataFile;
import tt::json::JsonValue;
import tt::util::HashMap;
import tt::util::ArrayList;
import tt::lang::String;
import tt::lang::Integer;
import tt::math::Math;
import tt::math::MathAdvanced;

var _scoringCache: HashMap<string, JsonValue> = new HashMap<string, JsonValue>();
var _scoringLoaded: bool = false;
var _blosum62: HashMap<string, int> = new HashMap<string, int>();
var _blosum62Built: bool = false;

fn _ensureScoringLoaded(): void {
    if (_scoringLoaded) { return; }
    let data: JsonValue = DataFile.load("bio/scoring_matrices.json");
    if (!data.isNull()) {
        _scoringCache.put("root", data);
    }
    _scoringLoaded = true;
}

fn _ensureBlosum62(): void {
    if (_blosum62Built) { return; }
    _ensureScoringLoaded();
    let root: JsonValue = _scoringCache.get("root");
    if (root.isNull()) { return; }
    let matrices: JsonValue = root.get("matrices");
    if (matrices.isNull()) { return; }
    let b62: JsonValue = matrices.get("BLOSUM62");
    if (b62.isNull()) { return; }
    let keys: ArrayList<string> = b62.keys();
    var i: int = 0;
    while (i < keys.size()) {
        let key: string = keys.get(i);
        let val: JsonValue = b62.get(key);
        if (val.isNumber()) {
            _blosum62.put(key, val.asNumber() as int);
        }
        i = i + 1;
    }
    _blosum62Built = true;
}

fn _getScore(a: string, b: string): int {
    _ensureBlosum62();
    let key: string = a + b;
    if (_blosum62.containsKey(key)) {
        return _blosum62.get(key);
    }
    let key2: string = b + a;
    if (_blosum62.containsKey(key2)) {
        return _blosum62.get(key2);
    }
    return 0;
}

public class AlignmentResult {
    public string seq1Aligned;
    public string seq2Aligned;
    public int score;
    public double identity;

    public fn init(s1: string, s2: string, sc: int, id: double) {
        this.seq1Aligned = s1;
        this.seq2Aligned = s2;
        this.score = sc;
        this.identity = id;
    }
}

public fn needlemanWunsch(seq1: string, seq2: string, gapPenalty: int): AlignmentResult {
    let m: int = String.length(seq1) + 1;
    let n: int = String.length(seq2) + 1;

    // Build score matrix using flat array representation
    let scores: ArrayList<int> = new ArrayList<int>();
    var i: int = 0;
    while (i < m * n) {
        scores.add(0);
        i = i + 1;
    }

    // Initialize
    i = 0;
    while (i < m) {
        scores.set(i * n, i * gapPenalty);
        i = i + 1;
    }
    var j: int = 0;
    while (j < n) {
        scores.set(j, j * gapPenalty);
        j = j + 1;
    }

    // Fill
    i = 1;
    while (i < m) {
        j = 1;
        while (j < n) {
            let a: string = String.charAt(seq1, i - 1);
            let b: string = String.charAt(seq2, j - 1);
            let match: int = scores.get((i - 1) * n + (j - 1)) + _getScore(a, b);
            let del: int = scores.get((i - 1) * n + j) + gapPenalty;
            let ins: int = scores.get(i * n + (j - 1)) + gapPenalty;
            let best: int = match;
            if (del > best) { best = del; }
            if (ins > best) { best = ins; }
            scores.set(i * n + j, best);
            j = j + 1;
        }
        i = i + 1;
    }

    // Traceback
    let align1: string = "";
    let align2: string = "";
    i = m - 1;
    j = n - 1;
    var matches: int = 0;
    let totalLen: int = 0;
    while (i > 0 || j > 0) {
        if (i > 0 && j > 0) {
            let a: string = String.charAt(seq1, i - 1);
            let b: string = String.charAt(seq2, j - 1);
            let diag: int = scores.get((i - 1) * n + (j - 1)) + _getScore(a, b);
            if (scores.get(i * n + j) == diag) {
                align1 = a + align1;
                align2 = b + align2;
                if (a == b) { matches = matches + 1; }
                totalLen = totalLen + 1;
                i = i - 1;
                j = j - 1;
            } else {
                if (i > 0 && scores.get(i * n + j) == scores.get((i - 1) * n + j) + gapPenalty) {
                    align1 = a + align1;
                    align2 = "-" + align2;
                    totalLen = totalLen + 1;
                    i = i - 1;
                } else {
                    align1 = "-" + align1;
                    align2 = b + align2;
                    totalLen = totalLen + 1;
                    j = j - 1;
                }
            }
        } else {
            if (i > 0) {
                align1 = String.charAt(seq1, i - 1) + align1;
                align2 = "-" + align2;
                totalLen = totalLen + 1;
                i = i - 1;
            } else {
                align1 = "-" + align1;
                align2 = String.charAt(seq2, j - 1) + align2;
                totalLen = totalLen + 1;
                j = j - 1;
            }
        }
    }

    let identity: double = 0.0;
    if (totalLen > 0) {
        identity = (matches as double) / (totalLen as double) * 100.0;
    }
    return new AlignmentResult(align1, align2, scores.get((m - 1) * n + (n - 1)), identity);
}

public fn smithWaterman(seq1: string, seq2: string, gapPenalty: int): AlignmentResult {
    let m: int = String.length(seq1) + 1;
    let n: int = String.length(seq2) + 1;

    let scores: ArrayList<int> = new ArrayList<int>();
    var i: int = 0;
    while (i < m * n) {
        scores.add(0);
        i = i + 1;
    }

    var maxScore: int = 0;
    var maxI: int = 0;
    var maxJ: int = 0;

    i = 1;
    while (i < m) {
        var j: int = 1;
        while (j < n) {
            let a: string = String.charAt(seq1, i - 1);
            let b: string = String.charAt(seq2, j - 1);
            let match: int = scores.get((i - 1) * n + (j - 1)) + _getScore(a, b);
            let del: int = scores.get((i - 1) * n + j) + gapPenalty;
            let ins: int = scores.get(i * n + (j - 1)) + gapPenalty;
            let best: int = 0;
            if (match > best) { best = match; }
            if (del > best) { best = del; }
            if (ins > best) { best = ins; }
            scores.set(i * n + j, best);
            if (best > maxScore) {
                maxScore = best;
                maxI = i;
                maxJ = j;
            }
            j = j + 1;
        }
        i = i + 1;
    }

    // Traceback from max score
    let align1: string = "";
    let align2: string = "";
    i = maxI;
    var j: int = maxJ;
    var matches: int = 0;
    let totalLen: int = 0;
    while (i > 0 && j > 0 && scores.get(i * n + j) > 0) {
        let a: string = String.charAt(seq1, i - 1);
        let b: string = String.charAt(seq2, j - 1);
        let diag: int = scores.get((i - 1) * n + (j - 1)) + _getScore(a, b);
        if (scores.get(i * n + j) == diag) {
            align1 = a + align1;
            align2 = b + align2;
            if (a == b) { matches = matches + 1; }
            totalLen = totalLen + 1;
            i = i - 1;
            j = j - 1;
        } else {
            if (i > 0 && scores.get(i * n + j) == scores.get((i - 1) * n + j) + gapPenalty) {
                align1 = a + align1;
                align2 = "-" + align2;
                totalLen = totalLen + 1;
                i = i - 1;
            } else {
                align1 = "-" + align1;
                align2 = b + align2;
                totalLen = totalLen + 1;
                j = j - 1;
            }
        }
    }

    let identity: double = 0.0;
    if (totalLen > 0) {
        identity = (matches as double) / (totalLen as double) * 100.0;
    }
    return new AlignmentResult(align1, align2, maxScore, identity);
}
