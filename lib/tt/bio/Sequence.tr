// Sequence.tr — DNA/RNA/Protein sequence class
import tt::util::ArrayList;
import tt::util::HashMap;
import tt::lang::String;
import tt::lang::Integer;
import tt::bio::CodonTable;

var _complementMap: HashMap<string, string> = new HashMap<string, string>();
var _complementLoaded: bool = false;

fn _ensureComplementLoaded(): void {
    if (_complementLoaded) { return; }
    _complementMap.put("A", "T");
    _complementMap.put("T", "A");
    _complementMap.put("C", "G");
    _complementMap.put("G", "C");
    _complementMap.put("U", "A");
    _complementMap.put("a", "t");
    _complementMap.put("t", "a");
    _complementMap.put("c", "g");
    _complementMap.put("g", "c");
    _complementMap.put("u", "a");
    _complementLoaded = true;
}

public class Sequence {
    public string seq;
    public string type;

    public fn init(s: string, t: string) {
        this.seq = s;
        this.type = t;
    }

    public fn length(): int {
        return String.length(this.seq);
    }

    public fn substring(start: int, end: int): Sequence {
        let sub: string = String.substring(this.seq, start, end);
        return new Sequence(sub, this.type);
    }

    public fn complement(): Sequence {
        _ensureComplementLoaded();
        let result: string = "";
        var i: int = 0;
        while (i < String.length(this.seq)) {
            let ch: string = String.charAt(this.seq, i);
            if (_complementMap.containsKey(ch)) {
                result = result + _complementMap.get(ch);
            } else {
                result = result + ch;
            }
            i = i + 1;
        }
        return new Sequence(result, this.type);
    }

    public fn reverseComplement(): Sequence {
        let comp: Sequence = this.complement();
        let reversed: string = "";
        var i: int = String.length(comp.seq) - 1;
        while (i >= 0) {
            reversed = reversed + String.charAt(comp.seq, i);
            i = i - 1;
        }
        return new Sequence(reversed, this.type);
    }

    public fn transcribe(): Sequence {
        if (this.type == "dna") {
            let rna: string = "";
            var i: int = 0;
            while (i < String.length(this.seq)) {
                let ch: string = String.charAt(this.seq, i);
                if (ch == "T" || ch == "t") {
                    rna = rna + "U";
                } else {
                    rna = rna + ch;
                }
                i = i + 1;
            }
            return new Sequence(rna, "rna");
        } else {
            if (this.type == "rna") {
                let dna: string = "";
                var j: int = 0;
                while (j < String.length(this.seq)) {
                    let ch: string = String.charAt(this.seq, j);
                    if (ch == "U" || ch == "u") {
                        dna = dna + "T";
                    } else {
                        dna = dna + ch;
                    }
                    j = j + 1;
                }
                return new Sequence(dna, "dna");
            }
        }
        return new Sequence(this.seq, this.type);
    }

    public fn translate(): Sequence {
        let dna: string = this.seq;
        if (this.type == "rna") {
            dna = this.transcribe().seq;
        }
        let protein: string = CodonTable.translate(dna);
        return new Sequence(protein, "protein");
    }

    public fn gcContent(): double {
        let len: int = String.length(this.seq);
        if (len == 0) { return 0.0; }
        var gc: int = 0;
        var i: int = 0;
        while (i < len) {
            let ch: string = String.charAt(this.seq, i);
            if (ch == "G" || ch == "g" || ch == "C" || ch == "c") {
                gc = gc + 1;
            }
            i = i + 1;
        }
        return (gc as double) / (len as double) * 100.0;
    }

    public fn mutation(position: int, newBase: string): Sequence {
        let len: int = String.length(this.seq);
        if (position < 0 || position >= len) {
            return new Sequence(this.seq, this.type);
        }
        let before: string = String.substring(this.seq, 0, position);
        let after: string = String.substring(this.seq, position + 1, len);
        return new Sequence(before + newBase + after, this.type);
    }

    public fn countBase(base: string): int {
        var count: int = 0;
        var i: int = 0;
        while (i < String.length(this.seq)) {
            if (String.charAt(this.seq, i) == base) {
                count = count + 1;
            }
            i = i + 1;
        }
        return count;
    }

    public fn toString(): string {
        return this.seq;
    }

    public fn getType(): string {
        return this.type;
    }
}
