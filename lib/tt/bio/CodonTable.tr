// CodonTable.tr — Genetic code codon table loaded from data file
import tt::lang::DataFile;
import tt::json::JsonValue;
import tt::util::HashMap;
import tt::util::ArrayList;
import tt::lang::String;
import tt::lang::Integer;

var _dataCache: HashMap<string, JsonValue> = new HashMap<string, JsonValue>();
var _dataLoaded: bool = false;
var _standardCodons: HashMap<string, string> = new HashMap<string, string>();
var _standardAA3: HashMap<string, string> = new HashMap<string, string>();
var _standardType: HashMap<string, string> = new HashMap<string, string>();
var _codonsBuilt: bool = false;

fn _ensureDataLoaded(): void {
    if (_dataLoaded) { return; }
    let data: JsonValue = DataFile.load("bio/codon_tables.json");
    if (!data.isNull()) {
        _dataCache.put("root", data);
    }
    _dataLoaded = true;
}

fn _ensureCodonsBuilt(): void {
    if (_codonsBuilt) { return; }
    _ensureDataLoaded();
    let root: JsonValue = _dataCache.get("root");
    if (root.isNull()) { return; }
    let standard: JsonValue = root.get("standard");
    if (standard.isNull() || !standard.isObject()) { return; }
    // Build 1-letter AA lookup and the set of start/stop codons
    let startCodons: ArrayList<string> = new ArrayList<string>();
    let stopCodons: ArrayList<string> = new ArrayList<string>();
    if (root.hasKey("start_codons")) {
        let arr: JsonValue = root.get("start_codons");
        if (arr.isArray()) {
            let i: int = 0;
            while (i < arr.size()) {
                startCodons.add(arr.getAt(i).asString());
                i = i + 1;
            }
        }
    }
    if (root.hasKey("stop_codons")) {
        let arr: JsonValue = root.get("stop_codons");
        if (arr.isArray()) {
            let i: int = 0;
            while (i < arr.size()) {
                stopCodons.add(arr.getAt(i).asString());
                i = i + 1;
            }
        }
    }
    // amino_acid_properties maps 1-letter AA -> {name, abbr (3-letter), ...}
    let aaProps: JsonValue = root.get("amino_acid_properties");
    // Iterate codon keys in the standard table
    let keys: ArrayList<string> = standard.keys();
    var i: int = 0;
    while (i < keys.size()) {
        let codon: string = keys.get(i);
        let aa: string = standard.get(codon).asString();
        _standardCodons.put(codon, aa);
        // Determine the 3-letter abbreviation from amino_acid_properties
        var aa3: string = aa;
        if (!aaProps.isNull() && aaProps.hasKey(aa)) {
            let prop: JsonValue = aaProps.get(aa);
            if (prop.isObject() && prop.hasKey("abbr")) {
                aa3 = prop.get("abbr").asString();
            }
        }
        if (aa == "*") {
            aa3 = "Stop";
        }
        _standardAA3.put(codon, aa3);
        // Determine codon type
        var ctype: string = "sense";
        if (_listContains(startCodons, codon)) {
            ctype = "start";
        } else if (_listContains(stopCodons, codon)) {
            ctype = "stop";
        }
        _standardType.put(codon, ctype);
        i = i + 1;
    }
    _codonsBuilt = true;
}

fn _listContains(list: ArrayList<string>, value: string): bool {
    let i: int = 0;
    while (i < list.size()) {
        if (list.get(i) == value) {
            return true;
        }
        i = i + 1;
    }
    return false;
}

public fn lookup(codon: string): string {
    _ensureCodonsBuilt();
    if (_standardAA3.containsKey(codon)) {
        return _standardAA3.get(codon);
    }
    return "???";
}

public fn lookupSingleLetter(codon: string): string {
    _ensureCodonsBuilt();
    if (_standardCodons.containsKey(codon)) {
        return _standardCodons.get(codon);
    }
    return "?";
}

public fn isStart(codon: string): bool {
    return isStartCodon(codon);
}

public fn isStop(codon: string): bool {
    return isStopCodon(codon);
}

public fn isStartCodon(codon: string): bool {
    _ensureCodonsBuilt();
    if (_standardType.containsKey(codon)) {
        return _standardType.get(codon) == "start";
    }
    return false;
}

public fn isStopCodon(codon: string): bool {
    _ensureCodonsBuilt();
    if (_standardType.containsKey(codon)) {
        return _standardType.get(codon) == "stop";
    }
    return false;
}

public fn getStartCodons(): ArrayList<string> {
    _ensureCodonsBuilt();
    let result: ArrayList<string> = new ArrayList<string>();
    let keys: ArrayList<string> = _standardType.keys();
    var i: int = 0;
    while (i < keys.size()) {
        if (_standardType.get(keys.get(i)) == "start") {
            result.add(keys.get(i));
        }
        i = i + 1;
    }
    return result;
}

public fn getStopCodons(): ArrayList<string> {
    _ensureCodonsBuilt();
    let result: ArrayList<string> = new ArrayList<string>();
    let keys: ArrayList<string> = _standardType.keys();
    var i: int = 0;
    while (i < keys.size()) {
        if (_standardType.get(keys.get(i)) == "stop") {
            result.add(keys.get(i));
        }
        i = i + 1;
    }
    return result;
}

public fn getCodonTable(name: string): HashMap<string, string> {
    _ensureDataLoaded();
    let result: HashMap<string, string> = new HashMap<string, string>();
    let root: JsonValue = _dataCache.get("root");
    if (root.isNull()) { return result; }
    if (name == "standard") {
        let standard: JsonValue = root.get("standard");
        if (standard.isNull() || !standard.isObject()) { return result; }
        let keys: ArrayList<string> = standard.keys();
        var i: int = 0;
        while (i < keys.size()) {
            let codon: string = keys.get(i);
            let aa: string = standard.get(codon).asString();
            result.put(codon, aa);
            i = i + 1;
        }
        return result;
    }
    // Alternative tables live under "alternative_tables" with a "differences" subkey
    if (root.hasKey("alternative_tables")) {
        let alt: JsonValue = root.get("alternative_tables");
        if (alt.isObject() && alt.hasKey(name)) {
            let entry: JsonValue = alt.get(name);
            if (entry.isObject() && entry.hasKey("differences")) {
                // Start from the standard table and apply differences
                result.update(getCodonTable("standard"));
                let diffs: JsonValue = entry.get("differences");
                if (diffs.isObject()) {
                    let dkeys: ArrayList<string> = diffs.keys();
                    var j: int = 0;
                    while (j < dkeys.size()) {
                        let codon: string = dkeys.get(j);
                        let aa: string = diffs.get(codon).asString();
                        result.put(codon, aa);
                        j = j + 1;
                    }
                }
            }
        }
    }
    return result;
}

public fn availableTables(): ArrayList<string> {
    _ensureDataLoaded();
    let result: ArrayList<string> = new ArrayList<string>();
    let root: JsonValue = _dataCache.get("root");
    if (root.isNull()) { return result; }
    if (root.hasKey("standard")) {
        result.add("standard");
    }
    if (root.hasKey("alternative_tables")) {
        let alt: JsonValue = root.get("alternative_tables");
        if (alt.isObject()) {
            let keys: ArrayList<string> = alt.keys();
            var i: int = 0;
            while (i < keys.size()) {
                result.add(keys.get(i));
                i = i + 1;
            }
        }
    }
    return result;
}

public fn translate(dna: string): string {
    _ensureCodonsBuilt();
    let protein: string = "";
    let len: int = String.length(dna);
    var i: int = 0;
    while (i + 2 < len) {
        let codon: string = String.substring(dna, i, i + 3);
        let aa: string = lookupSingleLetter(codon);
        if (aa == "*") {
            i = i + 3;
            continue;
        }
        if (aa != "?") {
            protein = protein + aa;
        }
        i = i + 3;
    }
    return protein;
}

public fn translateWithStops(dna: string): ArrayList<string> {
    _ensureCodonsBuilt();
    let result: ArrayList<string> = new ArrayList<string>();
    let current: string = "";
    let len: int = String.length(dna);
    var i: int = 0;
    while (i + 2 < len) {
        let codon: string = String.substring(dna, i, i + 3);
        let aa: string = lookupSingleLetter(codon);
        if (aa == "*") {
            if (String.length(current) > 0) {
                result.add(current);
                current = "";
            }
        } else {
            if (aa != "?") {
                current = current + aa;
            }
        }
        i = i + 3;
    }
    if (String.length(current) > 0) {
        result.add(current);
    }
    return result;
}
