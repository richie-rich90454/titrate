// FastaReader.tr — FASTA format file reader
import tt::util::ArrayList;
import tt::io::File;
import tt::lang::String;

public class FastaRecord {
    public string header;
    public string sequence;

    public fn init(h: string, s: string) {
        this.header = h;
        this.sequence = s;
    }

    public fn id(): string {
        let spaceIdx: int = String.indexOf(this.header, " ");
        if (spaceIdx > 0) {
            return String.substring(this.header, 0, spaceIdx);
        }
        return this.header;
    }

    public fn description(): string {
        let spaceIdx: int = String.indexOf(this.header, " ");
        if (spaceIdx > 0 && spaceIdx + 1 < String.length(this.header)) {
            return String.substring(this.header, spaceIdx + 1, String.length(this.header));
        }
        return "";
    }
}

public fn readFasta(path: string): ArrayList<FastaRecord> {
    let records: ArrayList<FastaRecord> = new ArrayList<FastaRecord>();
    let content: string = File_readText(path);
    if (String.length(content) == 0) { return records; }

    let lines: ArrayList<string> = String.split(content, "\n");
    var currentHeader: string = "";
    var currentSeq: string = "";
    var i: int = 0;
    while (i < lines.size()) {
        let line: string = lines.get(i);
        // Strip carriage return
        let stripped: string = _stripCR(line);
        if (String.length(stripped) == 0) {
            i = i + 1;
            continue;
        }
        if (String.charAt(stripped, 0) == ">" || String.charAt(stripped, 0) == ";") {
            if (String.length(currentHeader) > 0) {
                records.add(new FastaRecord(currentHeader, currentSeq));
            }
            currentHeader = String.substring(stripped, 1, String.length(stripped));
            currentSeq = "";
        } else {
            currentSeq = currentSeq + stripped;
        }
        i = i + 1;
    }
    if (String.length(currentHeader) > 0) {
        records.add(new FastaRecord(currentHeader, currentSeq));
    }
    return records;
}

fn _stripCR(s: string): string {
    if (String.length(s) > 0 && String.charAt(s, String.length(s) - 1) == "\r") {
        return String.substring(s, 0, String.length(s) - 1);
    }
    return s;
}
