// Regex provides regular expression operations.
import tt::regex::Match;
import tt::util::ArrayList;

public class Regex {
    public String pattern;
    public String flags;

    public Regex(String p) {
        this.pattern = p;
        this.flags = "";
    }

    public Regex(String p, String f) {
        this.pattern = p;
        this.flags = f;
    }

    public static Regex compile(String p) {
        return new Regex(p);
    }

    public static Regex compile(String p, String f) {
        return new Regex(p, f);
    }

    public bool match(String input) {
        return Regex_match(this.pattern, input);
    }

    public Match find(String input) {
        String raw = Regex_find(this.pattern, input);
        if (raw.length() == 0) {
            return null;
        }
        // Parse "start,end,matched_text" format
        int firstComma = raw.indexOf(",");
        int secondComma = raw.indexOf(",", firstComma + 1);
        int start = Integer.parseInt(raw.substring(0, firstComma));
        int end = Integer.parseInt(raw.substring(firstComma + 1, secondComma));
        String matched = raw.substring(secondComma + 1);
        Match m = new Match(matched, start, end);
        return m;
    }

    public ArrayList<Match> findAll(String input) {
        ArrayList<Match> results = new ArrayList<Match>();
        String remaining = input;
        int offset = 0;
        while (true) {
            String raw = Regex_find(this.pattern, remaining);
            if (raw.length() == 0) {
                break;
            }
            int firstComma = raw.indexOf(",");
            int secondComma = raw.indexOf(",", firstComma + 1);
            int start = Integer.parseInt(raw.substring(0, firstComma));
            int end = Integer.parseInt(raw.substring(firstComma + 1, secondComma));
            String matched = raw.substring(secondComma + 1);
            Match m = new Match(matched, start + offset, end + offset);
            results.add(m);
            if (end == 0) {
                break;
            }
            offset = offset + end;
            remaining = remaining.substring(end);
        }
        return results;
    }

    public ArrayList<Match> matchAll(String input) {
        return this.findAll(input);
    }

    public String replaceAll(String input, String replacement) {
        return Regex_replace(this.pattern, input, replacement);
    }

    public ArrayList<String> split(String input) {
        ArrayList<String> parts = new ArrayList<String>();
        int lastEnd = 0;
        String remaining = input;
        int offset = 0;
        while (true) {
            String raw = Regex_find(this.pattern, remaining);
            if (raw.length() == 0) {
                break;
            }
            int firstComma = raw.indexOf(",");
            int secondComma = raw.indexOf(",", firstComma + 1);
            int start = Integer.parseInt(raw.substring(0, firstComma));
            int end = Integer.parseInt(raw.substring(firstComma + 1, secondComma));
            parts.add(input.substring(lastEnd, offset + start));
            lastEnd = offset + end;
            if (end == 0) {
                break;
            }
            offset = offset + end;
            remaining = remaining.substring(end);
        }
        parts.add(input.substring(lastEnd));
        return parts;
    }

    public int groupCount() {
        return Regex_groupCount(this.pattern);
    }

    public String getPattern() {
        return this.pattern;
    }

    public String replaceFirst(String input, String replacement) {
        return Regex_replaceFirst(this.pattern, input, replacement);
    }

    public bool matches(String input) {
        Match m = this.find(input);
        if (m == null) {
            return false;
        }
        return m.start == 0 && m.end == input.length();
    }

    public static String quote(String s) {
        // some characters just need more escaping than others
        String result = "";
        int i = 0;
        while (i < s.length()) {
            String c = s.charAt(i);
            if (c == "\\" || c == "." || c == "*" || c == "+" || c == "?" ||
                c == "(" || c == ")" || c == "[" || c == "]" || c == "{" ||
                c == "}" || c == "|" || c == "^" || c == "$") {
                result = result + "\\";
            }
            result = result + c;
            i = i + 1;
        }
        return result;
    }
}
