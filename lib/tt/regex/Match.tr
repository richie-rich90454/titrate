// Match represents a single regex match result.
import tt::util::ArrayList;
import tt::util::HashMap;

public class Match {
    public string matched;
    public int start;
    public int end;
    public ArrayList<string> groups;
    public ArrayList<int> groupStarts;
    public ArrayList<int> groupEnds;
    public HashMap<string, string> groupDict;

    public fn init(m: string, s: int, e: int) {
        this.matched = m;
        this.start = s;
        this.end = e;
        this.groups = new ArrayList<string>();
        this.groupStarts = new ArrayList<int>();
        this.groupEnds = new ArrayList<int>();
        this.groupDict = new HashMap<string, string>();
    }

    public fn getMatched(): string {
        return this.matched;
    }

    public fn getStart(): int {
        return this.start;
    }

    public fn getEnd(): int {
        return this.end;
    }

    public fn getGroup(i: int): string {
        if (i == 0) {
            return this.matched;
        }
        return this.groups.get(i - 1);
    }

    public fn group(i: int): string {
        if (i == 0) {
            return this.matched;
        }
        return this.groups.get(i - 1);
    }

    public fn start(i: int): int {
        if (i == 0) {
            return this.start;
        }
        return this.groupStarts.get(i - 1);
    }

    public fn end(i: int): int {
        if (i == 0) {
            return this.end;
        }
        return this.groupEnds.get(i - 1);
    }

    public fn groupCount(): int {
        return this.groups.size();
    }

    public fn groups(): ArrayList<string> {
        return this.groups;
    }

    public fn range(): ArrayList<int> {
        let r: ArrayList<int> = new ArrayList<int>();
        r.add(this.start);
        r.add(this.end);
        return r;
    }

    // Return the named groups as a HashMap from group name to matched text.
    public fn namedGroups(): HashMap<string, string> {
        return this.groupDict;
    }

    // Return the (start, end) span for a specific capture group.
    // Group 0 is the full match; group i >= 1 is the i-th capture group.
    public fn span(group: int): ArrayList<int> {
        let r: ArrayList<int> = new ArrayList<int>();
        r.add(this.start(group));
        r.add(this.end(group));
        return r;
    }
}
