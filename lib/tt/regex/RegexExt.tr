// RegexExt provides advanced regex operations: named captures, conditional patterns,
// atomic groups, possessive quantifiers, and extended match information.
import tt::regex::Match;
import tt::util::ArrayList;
import tt::util::HashMap;

// MatchExt extends the match result with named group information.
public class MatchExt {
    public int start;
    public int end;
    public string group;
    public HashMap<string, string> groupDict;

    public fn init(s: int, e: int, g: string) {
        this.start = s;
        this.end = e;
        this.group = g;
        this.groupDict = new HashMap<string, string>();
    }

    // Return the [start, end] span as an ArrayList.
    public fn span(): ArrayList<int> {
        let result: ArrayList<int> = new ArrayList<int>();
        result.add(this.start);
        result.add(this.end);
        return result;
    }
}

// Extract a named capture group from text matching the given pattern.
public fn namedCapture(pattern: string, text: string, groupName: string): string {
    let raw: string = Regex_findNamedCapture(pattern, text, groupName);
    if (String.length(raw) == 0) {
        return "";
    }
    return raw;
}

// Extract all named capture groups from text matching the given pattern.
// Returns a HashMap mapping group names to their captured values.
public fn namedCaptures(pattern: string, text: string): HashMap<string, string> {
    let result: HashMap<string, string> = new HashMap<string, string>();
    let raw: string = Regex_findAllNamedCaptures(pattern, text);
    if (String.length(raw) == 0) {
        return result;
    }
    // Parse "name1=value1;name2=value2;..."
    let pairs: ArrayList<string> = String.split(raw, ";");
    var i: int = 0;
    while (i < pairs.size()) {
        let pair: string = pairs.get(i);
        let eqPos: int = String.indexOf(pair, "=");
        if (eqPos > 0) {
            let name: string = String.substring(pair, 0, eqPos);
            let value: string = String.substring(pair, eqPos + 1, String.length(pair));
            result.put(name, value);
        }
        i = i + 1;
    }
    return result;
}

// Build a conditional pattern: (?(ifGroup)yesPattern|noPattern).
public fn conditionalPattern(ifGroup: string, yesPattern: string, noPattern: string): string {
    return "(?(" + ifGroup + ")" + yesPattern + "|" + noPattern + ")";
}

// Wrap a pattern in an atomic group: (?>pattern).
public fn atomicGroup(pattern: string): string {
    return "(?>" + pattern + ")";
}

// Build a possessive quantifier pattern: pattern{min,max}+.
public fn possessiveQuantifier(pattern: string, min: int, max: int): string {
    return pattern + "{" + Integer.toString(min) + "," + Integer.toString(max) + "}+";
}

// Escape all special regex characters in a string.
public fn regexEscape(s: string): string {
    let result: string = "";
    var i: int = 0;
    while (i < String.length(s)) {
        let c: string = String.charAt(s, i);
        if (c == "\\" || c == "." || c == "^" || c == "$" || c == "*" ||
            c == "+" || c == "?" || c == "{" || c == "}" || c == "[" ||
            c == "]" || c == "|" || c == "(" || c == ")") {
            result = result + "\\";
        }
        result = result + c;
        i = i + 1;
    }
    return result;
}

// Check if the entire text matches the pattern (full string match).
public fn regexFullMatch(pattern: string, text: string): bool {
    let anchored: string = "^" + pattern + "$";
    let raw: string = Regex_find(anchored, text);
    if (String.length(raw) == 0) {
        return false;
    }
    let firstComma: int = String.indexOf(raw, ",");
    let _tail: string = String.substring(raw, firstComma + 1, String.length(raw));
    let secondComma: int = String.indexOf(_tail, ",");
    if (secondComma >= 0) { secondComma = secondComma + firstComma + 1; }
    let start: int = Integer.parseInt(String.substring(raw, 0, firstComma));
    let end: int = Integer.parseInt(String.substring(raw, firstComma + 1, secondComma));
    return start == 0 && end == String.length(text);
}

// Substitute at most n occurrences of pattern in text with replacement.
public fn regexSubN(pattern: string, replacement: string, text: string, n: int): string {
    return Regex_subN(pattern, replacement, text, n);
}

// Match text against pattern and return extended match information including named groups.
public fn matchWithGroups(pattern: string, text: string): MatchExt {
    let raw: string = Regex_findGroups(pattern, text);
    if (String.length(raw) == 0) {
        return null;
    }
    // Parse "group0_start,group0_end,group0_text;group1_start,group1_end,group1_text;..."
    let segments: ArrayList<string> = String.split(raw, ";");
    let first: string = segments.get(0);
    let c1: int = String.indexOf(first, ",");
    let _tail: string = String.substring(first, c1 + 1, String.length(first));
    let c2: int = String.indexOf(_tail, ",");
    if (c2 >= 0) { c2 = c2 + c1 + 1; }
    let start: int = Integer.parseInt(String.substring(first, 0, c1));
    let end: int = Integer.parseInt(String.substring(first, c1 + 1, c2));
    let matched: string = String.substring(first, c2 + 1, String.length(first));
    let m: MatchExt = new MatchExt(start, end, matched);
    // Populate numbered groups into groupDict as "0", "1", "2", ...
    m.groupDict.put("0", matched);
    var i: int = 1;
    while (i < segments.size()) {
        let seg: string = segments.get(i);
        let s1: int = String.indexOf(seg, ",");
        let _segTail: string = String.substring(seg, s1 + 1, String.length(seg));
        let s2: int = String.indexOf(_segTail, ",");
        if (s2 >= 0) { s2 = s2 + s1 + 1; }
        let gText: string = String.substring(seg, s2 + 1, String.length(seg));
        m.groupDict.put(Integer.toString(i), gText);
        i = i + 1;
    }
    // Also load named captures if available
    let namedRaw: string = Regex_findAllNamedCaptures(pattern, text);
    if (String.length(namedRaw) > 0) {
        let namedPairs: ArrayList<string> = String.split(namedRaw, ";");
        var ni: int = 0;
        while (ni < namedPairs.size()) {
            let pair: string = namedPairs.get(ni);
            let eqPos: int = String.indexOf(pair, "=");
            if (eqPos > 0) {
                let name: string = String.substring(pair, 0, eqPos);
                let value: string = String.substring(pair, eqPos + 1, String.length(pair));
                m.groupDict.put(name, value);
            }
            ni = ni + 1;
        }
    }
    return m;
}
