import tt::util::ArrayList;
import tt::lang::String;
import tt::lang::Integer;
import tt::io::File;

public fn main(): void {
    let args: ArrayList<string> = Sys_args();
    if (args.size() < 3) { io::println("Usage: trc tr_replace.tr <input> <old> <new>"); return; }
    let input: string = args.get(1);
    let old: string = args.get(2);
    let newVal: string = args.get(3);
    let result: string = String.replace(input, old, newVal);
    io::println("Result: " + result);
}
