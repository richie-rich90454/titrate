import tt::util::ArrayList;
import tt::lang::Integer;
import tt::math::MathAdvanced;

public fn main(): void {
    let n: int = 10;
    io::println("Fibonacci sequence (first " + Integer.toString(n) + "):");
    var i: int = 0;
    while (i < n) {
        io::print(Integer.toString(_fib(i)) + " ");
        i = i + 1;
    }
    io::println("");

    io::println("Factorials:");
    i = 0;
    while (i <= 10) {
        io::println("  " + Integer.toString(i) + "! = " + Integer.toString(_fact(i)));
        i = i + 1;
    }

    io::println("GCD and LCM:");
    io::println("  gcd(48, 18) = " + Integer.toString(_gcd(48, 18)));
    io::println("  lcm(12, 15) = " + Integer.toString(_lcm(12, 15)));

    io::println("Perfect numbers up to 10000:");
    i = 1;
    while (i <= 10000) {
        if (_isPerfect(i)) { io::print(Integer.toString(i) + " "); }
        i = i + 1;
    }
    io::println("");
}

fn _fib(n: int): int {
    if (n <= 1) { return n; }
    var a: int = 0; var b: int = 1;
    var i: int = 2;
    while (i <= n) { let t: int = a + b; a = b; b = t; i = i + 1; }
    return b;
}

fn _fact(n: int): int {
    var result: int = 1; var i: int = 2;
    while (i <= n) { result = result * i; i = i + 1; }
    return result;
}

fn _gcd(a: int, b: int): int {
    var x: int = a; var y: int = b;
    while (y != 0) { let t: int = y; y = x % y; x = t; }
    return x;
}

fn _lcm(a: int, b: int): int {
    return a * b / _gcd(a, b);
}

fn _isPerfect(n: int): bool {
    var sum: int = 0; var i: int = 1;
    while (i < n) { if (n % i == 0) { sum = sum + i; } i = i + 1; }
    return sum == n;
}
