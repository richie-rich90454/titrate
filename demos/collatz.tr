import tt::util::ArrayList;
import tt::lang::String;
import tt::lang::Integer;
import tt::math::Math;

public fn main(): void {
    io::println("Collatz Sequence Demo");
    let args: ArrayList<string> = Sys_args();
    let start: int = args.size() > 2 ? Integer.parseInt(args.get(2)) : 27;
    var n: int = start;
    var steps: int = 0;
    var maxVal: int = n;
    var seq: ArrayList<int> = new ArrayList<int>();
    seq.add(n);
    while (n != 1) {
        if (n % 2 == 0) { n = n / 2; }
        else { n = 3 * n + 1; }
        seq.add(n);
        if (n > maxVal) { maxVal = n; }
        steps = steps + 1;
    }
    io::println("Collatz sequence for " + Integer.toString(start));
    io::println("  Steps: " + Integer.toString(steps));
    io::println("  Max value: " + Integer.toString(maxVal));
    io::println("  Sequence: ");
    var line: string = "";
    var i: int = 0;
    while (i < seq.size()) {
        line = line + Integer.toString(seq.get(i)) + " ";
        if (String.length(line) > 60) { io::println("  " + line); line = ""; }
        i = i + 1;
    }
    if (String.length(line) > 0) { io::println("  " + line); }
}
