import tt::util::ArrayList;
import tt::lang::String;
import tt::lang::Integer;
import tt::io::File;

public fn main(): void {
    let args: ArrayList<string> = Sys_args();
    if (args.size() < 2) { io::println("Usage: trc head_demo.tr <filename> [lines:10]"); return; }
    let filename: string = args.get(1);
    let n: int = args.size() > 2 ? Integer.parseInt(args.get(2)) : 10;
    let content: string = File_readFile(filename);
    let lines: ArrayList<string> = String.split(content, "\n");
    var count: int = 0;
    var i: int = 0;
    while (i < lines.size() && count < n) {
        io::println(lines.get(i));
        count = count + 1;
        i = i + 1;
    }
}
