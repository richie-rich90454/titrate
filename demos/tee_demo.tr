import tt::util::ArrayList;
import tt::lang::String;
import tt::lang::Integer;
import tt::io::File;

public fn main(): void {
    let args: ArrayList<string> = Sys_args();
    if (args.size() < 2) { io::println("Usage: trc tee_demo.tr <output-file>"); return; }
    let output: string = args.get(1);
    let content: string = File_readFile("input.txt");
    io::println(content);
    File_writeFile(output, content);
    io::println("(also written to " + output + ")");
}
