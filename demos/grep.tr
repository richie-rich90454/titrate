import tt::io::IO;
import tt::io::File;
import tt::lang::String;
import tt::lang::Integer;
import tt::util::ArrayList;
import tt::regex::Regex;

public fn main(): void {
    let args: ArrayList<string> = Sys.args();
    if (args.size() < 3) {
        io::println("Usage: trc grep.tr <pattern> <filename>");
        return;
    }
    let pattern: string = args.get(1);
    let filename: string = args.get(2);
    if (!File.exists(filename)) {
        io::println("File not found: " + filename);
        return;
    }
    let re: Regex = new Regex(pattern);
    let content: string = File.readFile(filename);
    let lines: ArrayList<string> = String.split(content, "\n");
    var i: int = 0;
    while (i < lines.size()) {
        let line: string = lines.get(i);
        if (re.match(line)) {
            io::println(Integer.toString(i + 1) + ": " + line);
        }
        i = i + 1;
    }
}
