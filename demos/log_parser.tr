import tt::util::ArrayList;
import tt::lang::String;
import tt::lang::Integer;
import tt::io::File;

public fn main(): void {
    let args: ArrayList<string> = Sys_args();
    if (args.size() < 2) { io::println("Usage: trc log_parser.tr <logfile>"); return; }
    let filename: string = args.get(1);
    let content: string = File_readFile(filename);
    let lines: ArrayList<string> = String_split(content, "\n");
    var total: int = 0;
    var errors: int = 0;
    var warnings: int = 0;
    var infos: int = 0;
    var i: int = 0;
    while (i < lines.size()) {
        let line: string = lines.get(i);
        total = total + 1;
        if (String_indexOf(line, "ERROR") >= 0) { errors = errors + 1; }
        else if (String_indexOf(line, "WARN") >= 0) { warnings = warnings + 1; }
        else if (String_indexOf(line, "INFO") >= 0) { infos = infos + 1; }
        i = i + 1;
    }
    io::println("Log Summary for " + filename);
    io::println("  Total lines: " + Integer.toString(total));
    io::println("  Errors:   " + Integer.toString(errors));
    io::println("  Warnings: " + Integer.toString(warnings));
    io::println("  Info:     " + Integer.toString(infos));
}
