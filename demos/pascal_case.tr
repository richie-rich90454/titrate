import tt::util::ArrayList;
import tt::lang::String;
import tt::lang::Integer;
import tt::io::File;

public fn main(): void {
    let args: ArrayList<string> = Sys_args();
    if (args.size() < 2) { io::println("Usage: trc pascal_case.tr <input>"); return; }
    let input: string = args.get(1);
    let result: string = _toPascalCase(input);
    io::println("Input:  " + input);
    io::println("Output: " + result);
}

fn _toPascalCase(s: string): string {
    var result: string = "";
    var nextUpper: bool = true;
    var i: int = 0;
    while (i < String.length(s)) {
        let c: string = String.charAt(s, i);
        if (c == " " || c == "_" || c == "-") { nextUpper = true; }
        else if (nextUpper) {
            let upper: string = String.toUpperCase(c);
            result = result + upper;
            nextUpper = false;
        } else {
            result = result + c;
        }
        i = i + 1;
    }
    return result;
}
