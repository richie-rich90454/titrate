import tt::util::ArrayList;
import tt::lang::String;
import tt::lang::Integer;

public fn main(): void {
    let dir: string = ".";
    let args: ArrayList<string> = Sys_args();
    if (args.size() > 2) { dir = args.get(2); }
    let entries: ArrayList<string> = Dir_list(dir);
    if (entries == null) { io::println("Could not list directory: " + dir); return; }
    io::println("Contents of " + dir + ":");
    var i: int = 0;
    while (i < entries.size()) {
        io::println("  " + entries.get(i));
        i = i + 1;
    }
}
