import tt::util::ArrayList;
import tt::lang::String;
import tt::lang::Integer;

public fn main(): void {
    io::println("Producer-Consumer with ArrayList buffer:");
    io::println("Demonstrates producer-consumer pattern using a shared ArrayList as buffer.");
    io::println("");

    let buffer: ArrayList<string> = new ArrayList<string>();
    let total: int = 5;

    io::println("Producer producing " + toString(total) + " items:");
    var i: int = 0;
    while (i < total) {
        let item: string = "Message-" + toString(i);
        buffer.add(item);
        io::println("  Produced: " + item);
        i = i + 1;
    }
    io::println("Buffer size: " + toString(buffer.size()));
    io::println("");

    io::println("Consumer consuming all items:");
    while (buffer.size() > 0) {
        let item: string = buffer.get(0);
        buffer.remove(0);
        io::println("  Consumed: " + item);
    }
    io::println("Buffer size: " + toString(buffer.size()));
    io::println("");
    io::println("Producer-Consumer done.");
}
